function renderDados(data) {
    // Implementar renderização dos dados reais
    document.getElementById('totalMovimentacoes').textContent = data.totalMovimentacoes || 0;
    document.getElementById('totalEntradas').textContent = data.entradas || 0;
    document.getElementById('totalSaidas').textContent = data.saidas || 0;
    document.getElementById('pendentesEnvio').textContent = data.pendentes || 0;
}

function filtrar() {
    loadDados();
}

function exportarXML() {
    const dataInicio = document.getElementById('dataInicio').value;
    const dataFim = document.getElementById('dataFim').value;
    
    // Tentar baixar XML do backend
    window.open(`/api/Sngpc/export-xml?startDate=${dataInicio}&endDate=${dataFim}`, '_blank');
    
    alert('Exportação XML iniciada. Se o download não iniciar automaticamente, verifique se a API SNGPC está configurada.');
}

function gerarRelatorio() {
    const dataInicio = document.getElementById('dataInicio').value;
    const dataFim = document.getElementById('dataFim').value;
    
    window.open(`/api/Sngpc/report-pdf?startDate=${dataInicio}&endDate=${dataFim}`, '_blank');
    
    alert('Relatório PDF sendo gerado. Se o download não iniciar automaticamente, verifique se a API está configurada.');
}
</script>
}
