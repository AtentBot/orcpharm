@{
    ViewData["Title"] = "Relatório SNGPC / ANVISA";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1"><i class="bi bi-shield-check me-2"></i>SNGPC / ANVISA</h4>
            <p class="text-muted mb-0">Sistema Nacional de Gerenciamento de Produtos Controlados</p>
        </div>
        <div>
            <button class="btn btn-outline-primary me-2" onclick="exportarXML()">
                <i class="bi bi-file-earmark-code me-1"></i> Exportar XML
            </button>
            <button class="btn btn-primary" onclick="gerarRelatorio()">
                <i class="bi bi-file-earmark-pdf me-1"></i> Gerar Relatório
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Período</label>
                    <select id="periodoSelect" class="form-select">
                        <option value="mes_atual">Mês Atual</option>
                        <option value="mes_anterior">Mês Anterior</option>
                        <option value="trimestre">Último Trimestre</option>
                        <option value="semestre">Último Semestre</option>
                        <option value="ano">Ano Atual</option>
                        <option value="personalizado">Personalizado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Data Início</label>
                    <input type="date" id="dataInicio" class="form-control" disabled>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Data Fim</label>
                    <input type="date" id="dataFim" class="form-control" disabled>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo de Controle</label>
                    <select id="tipoControle" class="form-select">
                        <option value="">Todos</option>
                        <option value="A1">A1 - Entorpecentes</option>
                        <option value="A2">A2 - Entorpecentes (uso permitido)</option>
                        <option value="A3">A3 - Psicotrópicos</option>
                        <option value="B1">B1 - Psicotrópicos</option>
                        <option value="B2">B2 - Psicotrópicos Anorexígenos</option>
                        <option value="C1">C1 - Outras substâncias</option>
                        <option value="C2">C2 - Retinóides</option>
                        <option value="C4">C4 - Anti-retrovirais</option>
                        <option value="C5">C5 - Anabolizantes</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" onclick="filtrar()">
                        <i class="bi bi-search me-1"></i> Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="mb-1 opacity-75">Total Movimentações</p>
                            <h2 class="mb-0" id="totalMovimentacoes">0</h2>
                        </div>
                        <i class="bi bi-arrow-left-right fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="mb-1 opacity-75">Entradas</p>
                            <h2 class="mb-0" id="totalEntradas">0</h2>
                        </div>
                        <i class="bi bi-box-arrow-in-down fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="mb-1 opacity-75">Saídas</p>
                            <h2 class="mb-0" id="totalSaidas">0</h2>
                        </div>
                        <i class="bi bi-box-arrow-up fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="mb-1 opacity-75">Pendentes Envio</p>
                            <h2 class="mb-0" id="pendentesEnvio">0</h2>
                        </div>
                        <i class="bi bi-clock-history fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Balanço por Substância -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-clipboard-data me-2"></i>Balanço por Substância</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Substância</th>
                                    <th>Lista</th>
                                    <th class="text-end">Estoque Inicial</th>
                                    <th class="text-end">Entradas</th>
                                    <th class="text-end">Saídas</th>
                                    <th class="text-end">Estoque Final</th>
                                </tr>
                            </thead>
                            <tbody id="balancoTable">
                                <tr>
                                    <td colspan="6" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Últimas Movimentações -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Últimas Movimentações</h6>
                    <a href="/Controlled/Movements" class="btn btn-sm btn-outline-primary">Ver Todas</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Data</th>
                                    <th>Substância</th>
                                    <th>Tipo</th>
                                    <th class="text-end">Qtd</th>
                                    <th>SNGPC</th>
                                </tr>
                            </thead>
                            <tbody id="movimentacoesTable">
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Receitas Processadas -->
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-file-medical me-2"></i>Receituário - Receitas Processadas</h6>
                    <span class="badge bg-primary" id="totalReceitas">0 receitas</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Data</th>
                                    <th>Nº Receita</th>
                                    <th>Paciente</th>
                                    <th>Prescritor</th>
                                    <th>CRM</th>
                                    <th>Substância</th>
                                    <th>Lista</th>
                                    <th class="text-end">Qtd</th>
                                    <th>Status SNGPC</th>
                                </tr>
                            </thead>
                            <tbody id="receitasTable">
                                <tr>
                                    <td colspan="9" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                        <span class="ms-2">Carregando receitas...</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <nav>
                        <ul class="pagination pagination-sm justify-content-center mb-0" id="paginacao">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Alertas e Pendências -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Alertas e Pendências SNGPC</h6>
                </div>
                <div class="card-body" id="alertasContainer">
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-check-circle fs-1 text-success"></i>
                        <p class="mb-0 mt-2">Nenhuma pendência encontrada</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Configurar datas
    const hoje = new Date();
    const primeiroDiaMes = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
    
    document.getElementById('dataInicio').value = primeiroDiaMes.toISOString().split('T')[0];
    document.getElementById('dataFim').value = hoje.toISOString().split('T')[0];
    
    document.getElementById('periodoSelect').addEventListener('change', function() {
        const customDates = document.querySelectorAll('#dataInicio, #dataFim');
        if (this.value === 'personalizado') {
            customDates.forEach(el => el.disabled = false);
        } else {
            customDates.forEach(el => el.disabled = true);
            atualizarDatas(this.value);
        }
    });
    
    loadDados();
});

function atualizarDatas(periodo) {
    const hoje = new Date();
    let inicio, fim;
    
    switch (periodo) {
        case 'mes_atual':
            inicio = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
            fim = hoje;
            break;
        case 'mes_anterior':
            inicio = new Date(hoje.getFullYear(), hoje.getMonth() - 1, 1);
            fim = new Date(hoje.getFullYear(), hoje.getMonth(), 0);
            break;
        case 'trimestre':
            inicio = new Date(hoje.getFullYear(), hoje.getMonth() - 3, 1);
            fim = hoje;
            break;
        case 'semestre':
            inicio = new Date(hoje.getFullYear(), hoje.getMonth() - 6, 1);
            fim = hoje;
            break;
        case 'ano':
            inicio = new Date(hoje.getFullYear(), 0, 1);
            fim = hoje;
            break;
    }
    
    document.getElementById('dataInicio').value = inicio.toISOString().split('T')[0];
    document.getElementById('dataFim').value = fim.toISOString().split('T')[0];
}

async function loadDados() {
    const dataInicio = document.getElementById('dataInicio').value;
    const dataFim = document.getElementById('dataFim').value;
    const tipoControle = document.getElementById('tipoControle').value;
    
    try {
        // Tentar carregar dados do SNGPC
        const response = await fetch(`/api/Sngpc/summary?startDate=${dataInicio}&endDate=${dataFim}&controlType=${tipoControle}`, {
            credentials: 'include'
        });
        
        if (response.ok) {
            const data = await response.json();
            renderDados(data.data || data);
        } else {
            renderDadosSimulados();
        }
    } catch (error) {
        console.log('API SNGPC não disponível, usando dados simulados');
        renderDadosSimulados();
    }
}

