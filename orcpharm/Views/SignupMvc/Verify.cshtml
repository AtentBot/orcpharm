@{
    ViewData["Title"] = "Verificar Código";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Verificação - OrcPharm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/signup.css"/>
    <style>
        .code-inputs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 30px;
        }
        .code-input {
            width: 50px;
            height: 60px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            border: 2px solid #6c63ff;
            border-radius: 10px;
            background: white;
            color: #333;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .code-input:focus {
            border-color: #5a52d5;
            outline: none;
            background: #f8f9fa;
            box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.25);
        }
        .code-input::placeholder {
            color: #ccc;
        }
        .step-indicator {
            display: flex;
            justify-content: center;
            margin-bottom: 30px;
        }
        .step {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 10px;
            font-weight: bold;
            font-size: 14px;
        }
        .step.completed {
            background: #28a745;
            color: white;
        }
        .step.active {
            background: white;
            color: #6c63ff;
        }
        .step-line {
            width: 50px;
            height: 2px;
            background: rgba(255,255,255,0.3);
            align-self: center;
        }
        .step-line.completed {
            background: #28a745;
        }
        .resend-section {
            text-align: center;
            margin-top: 20px;
        }
        .resend-section .btn-link {
            color: rgba(255,255,255,0.7);
        }
        .resend-section .btn-link:hover {
            color: white;
        }
        #resendTimer {
            color: rgba(255,255,255,0.5);
        }
    </style>
</head>
<body>
<div class="signup-wrapper">
    <div class="signup-container">
        <!-- Indicador de passos -->
        <div class="step-indicator">
            <div class="step completed"><i class="bi bi-check"></i></div>
            <div class="step-line completed"></div>
            <div class="step active">2</div>
            <div class="step-line"></div>
            <div class="step">3</div>
        </div>

        <div class="signup-header">
            <h1><i class="bi bi-shield-check me-2"></i>Verificar Código</h1>
            <p>Digite o código de 6 dígitos enviado para seu WhatsApp</p>
        </div>

        <div class="signup-body">
            <form id="verifyForm">
                <input type="hidden" id="whatsapp" value="@ViewBag.WhatsApp" />
                
                <div class="code-inputs">
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                    <input type="text" class="code-input" maxlength="1" inputmode="numeric" pattern="[0-9]"/>
                </div>

                <!-- Alert de erro -->
                <div id="errorAlert" class="alert alert-danger d-none" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <span id="errorMessage"></span>
                </div>

                <!-- Alert de sucesso -->
                <div id="successAlert" class="alert alert-success d-none" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    <span id="successMessage"></span>
                </div>

                <button type="submit" class="btn btn-signup w-100" id="submitBtn">
                    <span id="btnText">Verificar</span>
                    <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>

                <div class="resend-section">
                    <span id="resendTimer">Reenviar código em <strong id="countdown">60</strong>s</span>
                    <button type="button" class="btn btn-link d-none" id="resendCode">
                        <i class="bi bi-arrow-clockwise me-1"></i>Reenviar código
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('verifyForm');
    const inputs = document.querySelectorAll('.code-input');
    const submitBtn = document.getElementById('submitBtn');
    const btnText = document.getElementById('btnText');
    const btnSpinner = document.getElementById('btnSpinner');
    const errorAlert = document.getElementById('errorAlert');
    const errorMessage = document.getElementById('errorMessage');
    const successAlert = document.getElementById('successAlert');
    const successMessage = document.getElementById('successMessage');
    const resendTimer = document.getElementById('resendTimer');
    const resendBtn = document.getElementById('resendCode');
    const countdownEl = document.getElementById('countdown');
    const whatsappInput = document.getElementById('whatsapp');

    let countdown = 60;

    // Timer para reenviar código
    const timer = setInterval(() => {
        countdown--;
        countdownEl.textContent = countdown;
        if (countdown <= 0) {
            clearInterval(timer);
            resendTimer.classList.add('d-none');
            resendBtn.classList.remove('d-none');
        }
    }, 1000);

    // Auto-focus e navegação entre inputs
    inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            const value = e.target.value;
            
            // Apenas números
            e.target.value = value.replace(/\D/g, '');
            
            if (value && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
            
            // Auto-submit quando todos preenchidos
            const code = Array.from(inputs).map(i => i.value).join('');
            if (code.length === 6) {
                form.dispatchEvent(new Event('submit'));
            }
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && index > 0) {
                inputs[index - 1].focus();
            }
        });

        // Permitir colar código completo
        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pastedData = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
            pastedData.split('').forEach((char, i) => {
                if (inputs[i]) {
                    inputs[i].value = char;
                }
            });
            if (pastedData.length === 6) {
                inputs[5].focus();
                setTimeout(() => form.dispatchEvent(new Event('submit')), 100);
            }
        });
    });

    // Focar no primeiro input
    inputs[0].focus();

    // Mostrar erro
    function showError(message) {
        successAlert.classList.add('d-none');
        errorMessage.textContent = message;
        errorAlert.classList.remove('d-none');
    }

    // Mostrar sucesso
    function showSuccess(message) {
        errorAlert.classList.add('d-none');
        successMessage.textContent = message;
        successAlert.classList.remove('d-none');
    }

    // Loading state
    function setLoading(loading) {
        submitBtn.disabled = loading;
        btnText.textContent = loading ? 'Verificando...' : 'Verificar';
        btnSpinner.classList.toggle('d-none', !loading);
        inputs.forEach(i => i.disabled = loading);
    }

    // Submit do formulário
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const code = Array.from(inputs).map(i => i.value).join('');
        const whatsapp = whatsappInput.value;

        if (code.length !== 6) {
            showError('Digite o código completo de 6 dígitos');
            return;
        }

        if (!whatsapp) {
            showError('WhatsApp não informado');
            return;
        }

        setLoading(true);
        errorAlert.classList.add('d-none');

        try {
            const response = await fetch('/api/signup/verify', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    code: code,
                    whatsApp: whatsapp
                })
            });

            const data = await response.json();

            if (!response.ok) {
                showError(data.message || 'Código inválido');
                setLoading(false);
                // Limpar inputs
                inputs.forEach(i => i.value = '');
                inputs[0].focus();
                return;
            }

            // Sucesso! Redirecionar para completar perfil
            showSuccess('Código verificado! Redirecionando...');
            
            setTimeout(() => {
                window.location.href = data.redirectTo || `/signup/complete-profile?establishmentId=${data.establishmentId}`;
            }, 1000);

        } catch (error) {
            console.error('Erro:', error);
            showError('Erro de conexão. Tente novamente.');
            setLoading(false);
        }
    });

    // Reenviar código
    resendBtn.addEventListener('click', async function() {
        const whatsapp = whatsappInput.value;
        
        if (!whatsapp) {
            showError('WhatsApp não informado');
            return;
        }

        resendBtn.disabled = true;
        resendBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Reenviando...';

        try {
            const response = await fetch('/api/signup/resend-code', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    whatsApp: whatsapp
                })
            });

            const data = await response.json();

            if (!response.ok) {
                showError(data.message || 'Erro ao reenviar código');
            } else {
                showSuccess('Código reenviado! Verifique seu WhatsApp.');
                
                // Reiniciar timer
                countdown = 60;
                resendBtn.classList.add('d-none');
                resendTimer.classList.remove('d-none');
                
                const newTimer = setInterval(() => {
                    countdown--;
                    countdownEl.textContent = countdown;
                    if (countdown <= 0) {
                        clearInterval(newTimer);
                        resendTimer.classList.add('d-none');
                        resendBtn.classList.remove('d-none');
                    }
                }, 1000);
            }

        } catch (error) {
            console.error('Erro:', error);
            showError('Erro de conexão. Tente novamente.');
        }

        resendBtn.disabled = false;
        resendBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Reenviar código';
    });
});
</script>
</body>
</html>
