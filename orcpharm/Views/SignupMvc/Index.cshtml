@{
    ViewData["Title"] = "Criar conta";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrcPharm — Criar conta</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>@@import url('https://api.fontshare.com/v2/css?f[]=general-sans@@400,500,600&display=swap');</style>

    <link rel="stylesheet" href="~/css/design-system/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system/components.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.2/font/bootstrap-icons.min.css">

    <style>
        body { background: var(--bg); }
        .auth-wrap { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; }
        .auth-form-side { padding: 48px 64px; display: flex; flex-direction: column; }
        .auth-form-side .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 48px; }
        .auth-form-side .top a { font-size: 13px; color: var(--ink-3); text-decoration: none; }
        .auth-form-side .top a:hover { color: var(--petrol-500); }
        .auth-form-side .top a strong { color: var(--petrol-500); }
        .auth-content { max-width: 440px; width: 100%; margin: auto 0; }
        .auth-content h1 { font-size: 30px; font-weight: 600; letter-spacing: -0.025em; margin: 0 0 8px; }
        .auth-content .sub { color: var(--ink-3); font-size: 15px; margin: 0 0 28px; }
        .step-label { font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 18px; }
        .form-grid { display: grid; gap: 14px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .auth-actions { display: flex; justify-content: space-between; align-items: center; margin-top: 28px; }

        .auth-aside { background: var(--ink); color: #fff; padding: 56px; display: flex; flex-direction: column; position: relative; overflow: hidden; }
        .auth-aside::before { content: ''; position: absolute; inset: 0; background: radial-gradient(900px 500px at 80% 100%, color-mix(in srgb, var(--petrol-500) 45%, transparent), transparent 70%); }
        .auth-aside-content { position: relative; z-index: 1; margin-top: auto; }
        .auth-quote { font-size: 22px; line-height: 1.4; letter-spacing: -0.015em; font-weight: 500; margin: 16px 0 18px; max-width: 36ch; }
        .auth-quote-author { display: flex; align-items: center; gap: 12px; }
        .auth-quote-author .av { width: 40px; height: 40px; border-radius: 50%; background: var(--petrol-500); display: grid; place-items: center; font-weight: 600; font-size: 14px; }
        .auth-quote-author .info { font-size: 13px; line-height: 1.4; }
        .auth-quote-author .info .name { font-weight: 500; }
        .auth-quote-author .info .role { color: rgba(255,255,255,.55); }
        .auth-aside .badge-row { display: flex; gap: 12px; margin-top: 28px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.1); }
        .auth-aside .badge-item { font-family: var(--font-mono); font-size: 11px; color: rgba(255,255,255,.55); letter-spacing: 0.06em; text-transform: uppercase; }
        .perks { list-style: none; padding: 0; margin: 24px 0 0; display: flex; flex-direction: column; gap: 12px; }
        .perks li { display: flex; gap: 10px; align-items: flex-start; font-size: 14px; color: rgba(255,255,255,.85); }
        .perks li i { color: var(--ok); flex-shrink: 0; margin-top: 3px; }
        .perks li b { font-weight: 600; color: #fff; }

        @@media (max-width: 980px) {
            .auth-wrap { grid-template-columns: 1fr; }
            .auth-aside { display: none; }
            .auth-form-side { padding: 32px 24px; }
        }
    </style>
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-form-side">
            <div class="top">
                <a href="/" class="brand">
                    <span class="brand-glyph">o</span>
                    <span class="brand-name">orcpharm</span>
                </a>
                <a href="/Account/Login">Já tem conta? <strong>Entrar</strong></a>
            </div>
            <div class="auth-content">
                <div class="step-label">Passo 1 de 3 · Sua farmácia</div>
                <h1>Vamos começar.</h1>
                <p class="sub">14 dias grátis. Sem cartão. Configuração inicial em 8 minutos.</p>

                <div id="alertContainer" style="margin-bottom:14px;"></div>

                <form id="signupForm" class="form-grid">
                    <input type="hidden" id="planId" value="@(ViewBag.SelectedPlanId ?? "")" />
                    <div>
                        <label class="input-label" for="nomeFantasia">Nome fantasia</label>
                        <input class="input" type="text" id="nomeFantasia" required />
                    </div>
                    <div>
                        <label class="input-label" for="razaoSocial">Razão social</label>
                        <input class="input" type="text" id="razaoSocial" required />
                    </div>
                    <div class="form-row">
                        <div>
                            <label class="input-label" for="cnpj">CNPJ</label>
                            <input class="input mono" type="text" id="cnpj" placeholder="00.000.000/0001-00" required />
                        </div>
                        <div>
                            <label class="input-label" for="whatsapp">WhatsApp</label>
                            <input class="input mono" type="text" id="whatsapp" placeholder="(00) 00000-0000" required />
                        </div>
                    </div>
                    <div>
                        <label class="input-label" for="email">E-mail profissional</label>
                        <input class="input" type="email" id="email" placeholder="voce@@farmacia.com.br" required />
                    </div>
                    <div class="form-row">
                        <div>
                            <label class="input-label" for="password">Senha</label>
                            <input class="input" type="password" id="password" placeholder="••••••••••" required />
                        </div>
                        <div>
                            <label class="input-label" for="passwordConfirm">Confirmar senha</label>
                            <input class="input" type="password" id="passwordConfirm" placeholder="••••••••••" required />
                        </div>
                    </div>
                    <label style="display:flex;gap:10px;align-items:flex-start;font-size:13px;color:var(--ink-2);margin-top:8px;cursor:pointer;">
                        <input type="checkbox" id="acceptTerms" required style="margin-top:3px;" />
                        <span>Aceito os <a href="/terms" style="color:var(--petrol-500);">termos de uso</a> e a <a href="/privacy" style="color:var(--petrol-500);">política de privacidade</a>. Concordo com o tratamento dos dados conforme LGPD.</span>
                    </label>

                    <div class="auth-actions">
                        <a href="/" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
                        <button type="submit" class="btn btn-primary">Criar conta<i class="bi bi-arrow-right"></i></button>
                    </div>
                </form>
            </div>
        </div>

        <aside class="auth-aside">
            <div class="auth-aside-content">
                <div class="eyebrow" style="color:var(--amber-500);">NA PRÁTICA</div>
                <p class="auth-quote">"Saímos de planilhas e três sistemas para um só. Reduzimos em 40% o tempo de manipulação por fórmula."</p>
                <div class="auth-quote-author">
                    <div class="av">RT</div>
                    <div class="info">
                        <div class="name">Renata Tavares</div>
                        <div class="role">Farmacêutica RT · Manipulare Curitiba</div>
                    </div>
                </div>
                <ul class="perks">
                    <li><i class="bi bi-check-lg"></i><span><b>14 dias grátis</b>, sem cartão de crédito</span></li>
                    <li><i class="bi bi-check-lg"></i><span><b>Migração</b> dos seus dados em até 5 dias</span></li>
                    <li><i class="bi bi-check-lg"></i><span><b>Suporte</b> com farmacêuticos no chat</span></li>
                    <li><i class="bi bi-check-lg"></i><span><b>SNGPC e NFC-e</b> ativos desde o dia 1</span></li>
                </ul>
                <div class="badge-row">
                    <span class="badge-item">LGPD</span>
                    <span class="badge-item">Anvisa RDC 67</span>
                    <span class="badge-item">SNGPC</span>
                </div>
            </div>
        </aside>
    </div>

    <script src="~/js/signup.js" asp-append-version="true"></script>
    <script>
        // Máscaras
        const cnpj = document.getElementById('cnpj');
        if (cnpj) cnpj.addEventListener('input', e => {
            let v = e.target.value.replace(/\D/g, '').slice(0, 14);
            v = v.replace(/^(\d{2})(\d)/, '$1.$2').replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3').replace(/\.(\d{3})(\d)/, '.$1/$2').replace(/(\d{4})(\d)/, '$1-$2');
            e.target.value = v;
        });
        const wa = document.getElementById('whatsapp');
        if (wa) wa.addEventListener('input', e => {
            let v = e.target.value.replace(/\D/g, '').slice(0, 11);
            if (v.length > 7) v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
            else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
            else if (v.length > 0) v = `(${v}`;
            e.target.value = v;
        });
    </script>
</body>
</html>
