@{ViewData["Title"] = "Pagamento"; Layout = null;}
<!DOCTYPE html>
<html><head><meta charset="utf-8"/><title>Pagamento - Formula Clear</title>
<meta name="stripe-publishable-key" content="@ViewBag.StripePublishableKey">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/signup.css"/></head><body>
<div class="signup-wrapper"><div class="signup-container">
<div class="signup-header"><h1>Iniciar Teste Grátis</h1></div>
<div class="signup-body">
<div class="trial-badge"><i class="bi bi-gift me-2"></i>14 DIAS GRÁTIS</div>
<div class="plan-summary"><h3>@ViewBag.PlanName</h3><p>R$ @ViewBag.PlanPrice/mês após o período de teste</p></div>
<button id="startTrialBtn" class="btn btn-signup w-100" 
        data-establishment-id="@ViewBag.EstablishmentId" 
        data-plan-id="@ViewBag.PlanId">Iniciar Teste Grátis</button>
<div class="payment-security mt-3"><i class="bi bi-shield-check"></i><small>Pagamento 100% seguro via Stripe</small></div>
</div></div></div>
<script src="https://js.stripe.com/v3/"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/stripe-checkout.js"></script></body></html>