@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0">
                    <i class="bi bi-pencil-square text-warning me-2"></i>
                    Editar Cliente
                </h2>
                <p class="text-muted mb-0" id="customerCode">Carregando...</p>
            </div>
            <div>
                <a href="#" id="backBtn" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    Voltar
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Loading -->
<div id="loadingDiv" class="text-center py-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Carregando...</span>
    </div>
    <p class="text-muted mt-3">Carregando dados do cliente...</p>
</div>

<!-- Formulário -->
<form id="customerForm" style="display: none;">
    <!-- Dados Pessoais -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0">
                <i class="bi bi-person me-2"></i>
                Dados Pessoais
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Nome Completo <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="fullName" required 
                           minlength="3" maxlength="200">
                    <div class="invalid-feedback">Nome completo é obrigatório (mín. 3 caracteres)</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">CPF</label>
                    <input type="text" class="form-control" id="cpf" 
                           placeholder="000.000.000-00" maxlength="14" disabled>
                    <small class="text-muted">CPF não pode ser alterado</small>
                </div>

                <div class="col-md-4">
                    <label class="form-label">RG</label>
                    <input type="text" class="form-control" id="rg" maxlength="20">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Data de Nascimento</label>
                    <input type="date" class="form-control" id="birthDate">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Gênero</label>
                    <select class="form-select" id="gender">
                        <option value="">Selecione</option>
                        <option value="M">Masculino</option>
                        <option value="F">Feminino</option>
                        <option value="O">Outro</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Contato -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0">
                <i class="bi bi-telephone me-2"></i>
                Contato
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Telefone</label>
                    <input type="text" class="form-control" id="phone" 
                           placeholder="(00) 0000-0000" maxlength="15">
                    <div class="invalid-feedback">Telefone deve ter 10 ou 11 dígitos</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">WhatsApp</label>
                    <input type="text" class="form-control" id="whatsApp" 
                           placeholder="(00) 00000-0000" maxlength="15">
                    <div class="invalid-feedback">WhatsApp deve ter 10 ou 11 dígitos</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" maxlength="200">
                    <div class="invalid-feedback">Email inválido</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Endereço -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0">
                <i class="bi bi-geo-alt me-2"></i>
                Endereço
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">CEP</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="zipCode" 
                               placeholder="00000-000" maxlength="9">
                        <button class="btn btn-outline-secondary" type="button" onclick="searchZipCode()">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    <div class="invalid-feedback">CEP deve ter 8 dígitos</div>
                </div>

                <div class="col-md-7">
                    <label class="form-label">Logradouro</label>
                    <input type="text" class="form-control" id="street" maxlength="200">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Número</label>
                    <input type="text" class="form-control" id="number" maxlength="20">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Complemento</label>
                    <input type="text" class="form-control" id="complement" maxlength="100">
                </div>

                <div class="col-md-4">
                    <label class="form-label">Bairro</label>
                    <input type="text" class="form-control" id="neighborhood" maxlength="100">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cidade</label>
                    <input type="text" class="form-control" id="city" maxlength="100">
                </div>

                <div class="col-md-1">
                    <label class="form-label">UF</label>
                    <input type="text" class="form-control" id="state" 
                           maxlength="2" placeholder="SP">
                </div>
            </div>
        </div>
    </div>

    <!-- Informações Médicas -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0">
                <i class="bi bi-heart-pulse me-2"></i>
                Informações Médicas
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Alergias</label>
                    <textarea class="form-control" id="allergies" rows="3" 
                              placeholder="Descreva alergias conhecidas"></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Condições Médicas</label>
                    <textarea class="form-control" id="medicalConditions" rows="3" 
                              placeholder="Descreva condições médicas relevantes"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">Observações</label>
                    <textarea class="form-control" id="observations" rows="2" 
                              placeholder="Observações adicionais"></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Status -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0">
                <i class="bi bi-toggle-on me-2"></i>
                Status do Cliente
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Status <span class="text-danger">*</span></label>
                    <select class="form-select" id="status" required>
                        <option value="ATIVO">Ativo</option>
                        <option value="INATIVO">Inativo</option>
                        <option value="BLOQUEADO">Bloqueado</option>
                    </select>
                </div>

                <div class="col-md-6" id="blockReasonDiv" style="display: none;">
                    <label class="form-label">Motivo do Bloqueio</label>
                    <input type="text" class="form-control" id="blockReason" disabled>
                    <small class="text-muted">Use o botão "Bloquear" para alterar o motivo</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Botões -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-end gap-2">
                <a href="#" id="cancelBtn" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>
                    Cancelar
                </a>
                <button type="submit" class="btn btn-warning" id="submitBtn">
                    <i class="bi bi-check-circle me-1"></i>
                    Salvar Alterações
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    let customerId = null;
    let originalData = null;

    document.addEventListener('DOMContentLoaded', function() {
        customerId = window.location.pathname.split('/').pop();
        loadCustomer();
        setupMasks();
        setupForm();
    });

    async function loadCustomer() {
        try {
            const response = await fetch(`/api/Customers/${customerId}`, {
                credentials: 'include'
            });

            if (!response.ok) {
                throw new Error('Cliente não encontrado');
            }

            originalData = await response.json();
            populateForm();

            document.getElementById('loadingDiv').style.display = 'none';
            document.getElementById('customerForm').style.display = 'block';

        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao carregar cliente');
            window.location.href = '/Customers';
        }
    }

    function populateForm() {
        document.getElementById('customerCode').textContent = `Código: ${originalData.code} - ${originalData.fullName}`;
        document.getElementById('backBtn').href = `/Customers/Details/${customerId}`;
        document.getElementById('cancelBtn').href = `/Customers/Details/${customerId}`;

        // Dados Pessoais
        document.getElementById('fullName').value = originalData.fullName || '';
        document.getElementById('cpf').value = formatCpf(originalData.cpf) || '';
        document.getElementById('rg').value = originalData.rg || '';
        
        if (originalData.birthDate) {
            document.getElementById('birthDate').value = originalData.birthDate.split('T')[0];
        }
        
        document.getElementById('gender').value = originalData.gender || '';

        // Contato
        document.getElementById('phone').value = formatPhone(originalData.phone) || '';
        document.getElementById('whatsApp').value = formatPhone(originalData.whatsApp) || '';
        document.getElementById('email').value = originalData.email || '';

        // Endereço
        document.getElementById('zipCode').value = formatZipCode(originalData.zipCode) || '';
        document.getElementById('street').value = originalData.street || '';
        document.getElementById('number').value = originalData.number || '';
        document.getElementById('complement').value = originalData.complement || '';
        document.getElementById('neighborhood').value = originalData.neighborhood || '';
        document.getElementById('city').value = originalData.city || '';
        document.getElementById('state').value = originalData.state || '';

        // Informações Médicas
        document.getElementById('allergies').value = originalData.allergies || '';
        document.getElementById('medicalConditions').value = originalData.medicalConditions || '';
        document.getElementById('observations').value = originalData.observations || '';

        // Status
        document.getElementById('status').value = originalData.status;
        if (originalData.status === 'BLOQUEADO' && originalData.blockReason) {
            document.getElementById('blockReasonDiv').style.display = 'block';
            document.getElementById('blockReason').value = originalData.blockReason;
        }

        // Listener para mostrar motivo de bloqueio
        document.getElementById('status').addEventListener('change', function() {
            if (this.value === 'BLOQUEADO' && originalData.blockReason) {
                document.getElementById('blockReasonDiv').style.display = 'block';
            } else {
                document.getElementById('blockReasonDiv').style.display = 'none';
            }
        });
    }

    function setupMasks() {
        // Máscara Telefone/WhatsApp
        const phoneMask = (e) => {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 11) {
                if (value.length > 10) {
                    value = value.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
                } else {
                    value = value.replace(/(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
                }
                e.target.value = value;
            }
        };

        document.getElementById('phone').addEventListener('input', phoneMask);
        document.getElementById('whatsApp').addEventListener('input', phoneMask);

        // Máscara CEP
        document.getElementById('zipCode').addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 8) {
                value = value.replace(/(\d{5})(\d)/, '$1-$2');
                e.target.value = value;
            }
        });

        // UF maiúsculo
        document.getElementById('state').addEventListener('input', function(e) {
            e.target.value = e.target.value.toUpperCase();
        });
    }

    function setupForm() {
        const form = document.getElementById('customerForm');
        
        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            if (!form.checkValidity()) {
                e.stopPropagation();
                form.classList.add('was-validated');
                return;
            }

            await saveCustomer();
        });
    }

    async function saveCustomer() {
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Salvando...';

        try {
            const data = {
                fullName: document.getElementById('fullName').value,
                rg: document.getElementById('rg').value || null,
                birthDate: document.getElementById('birthDate').value || null,
                gender: document.getElementById('gender').value || null,
                phone: document.getElementById('phone').value.replace(/\D/g, '') || null,
                whatsApp: document.getElementById('whatsApp').value.replace(/\D/g, '') || null,
                email: document.getElementById('email').value || null,
                zipCode: document.getElementById('zipCode').value.replace(/\D/g, '') || null,
                street: document.getElementById('street').value || null,
                number: document.getElementById('number').value || null,
                complement: document.getElementById('complement').value || null,
                neighborhood: document.getElementById('neighborhood').value || null,
                city: document.getElementById('city').value || null,
                state: document.getElementById('state').value || null,
                allergies: document.getElementById('allergies').value || null,
                medicalConditions: document.getElementById('medicalConditions').value || null,
                observations: document.getElementById('observations').value || null,
                status: document.getElementById('status').value
            };

            const response = await fetch(`/api/Customers/${customerId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok) {
                alert(result.message);
                window.location.href = `/Customers/Details/${customerId}`;
            } else {
                alert(result.message || result.errors?.join('\n') || 'Erro ao atualizar cliente');
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Salvar Alterações';
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao atualizar cliente');
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Salvar Alterações';
        }
    }

    async function searchZipCode() {
        const zipCode = document.getElementById('zipCode').value.replace(/\D/g, '');

        if (zipCode.length !== 8) {
            alert('CEP deve ter 8 dígitos');
            return;
        }

        try {
            const response = await fetch(`https://viacep.com.br/ws/${zipCode}/json/`);
            const data = await response.json();

            if (data.erro) {
                alert('CEP não encontrado');
                return;
            }

            document.getElementById('street').value = data.logradouro || '';
            document.getElementById('neighborhood').value = data.bairro || '';
            document.getElementById('city').value = data.localidade || '';
            document.getElementById('state').value = data.uf || '';
            document.getElementById('number').focus();

        } catch (error) {
            console.error('Erro ao buscar CEP:', error);
            alert('Erro ao buscar CEP');
        }
    }

    function formatCpf(cpf) {
        if (!cpf) return '';
        return cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
    }

    function formatPhone(phone) {
        if (!phone) return '';
        if (phone.length === 11) {
            return phone.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
        }
        return phone.replace(/(\d{2})(\d{4})(\d{4})/, '($1) $2-$3');
    }

    function formatZipCode(zipCode) {
        if (!zipCode) return '';
        return zipCode.replace(/(\d{5})(\d{3})/, '$1-$2');
    }
</script>
}
