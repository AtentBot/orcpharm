@{
    var customer = ViewContext.HttpContext.Items["Customer"] as Models.Customer;
    var session = ViewContext.HttpContext.Items["CustomerSession"] as Models.CustomerSession;
    var isLoggedIn = customer != null;
    var hideNav = ViewData["HideNav"]?.Equals(true) == true;
    var activeNav = ViewData["ActiveNav"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] · OrcPharm</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>@@import url('https://api.fontshare.com/v2/css?f[]=general-sans@@400,500,600&display=swap');</style>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/design-system/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system/components.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/orcpharm-theme.css" asp-append-version="true">

    <style>
        /* Customer portal — mobile first */
        body { background: var(--bg); }

        .ds-cli-navbar {
            background: var(--surface);
            border-bottom: 1px solid var(--rule);
            padding: 12px 16px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
        }
        .ds-cli-navbar .brand { font-size: 14px; }
        .ds-cli-navbar .brand-glyph { width: 28px; height: 28px; font-size: 14px; }
        .ds-cli-establishment {
            display: flex; align-items: center; gap: 6px;
            color: var(--ink-3); font-size: 12px; font-weight: 500;
        }
        .ds-cli-establishment .bi { color: var(--petrol-500); }

        /* Auth wrap */
        .auth-container {
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--petrol-700) 0%, var(--petrol-500) 60%, var(--petrol-400) 100%);
            padding: 20px;
            position: relative; overflow: hidden;
        }
        .auth-container::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(900px 500px at 80% 100%, rgba(255,255,255,.08), transparent 60%);
            pointer-events: none;
        }
        .auth-card {
            background: var(--surface);
            border-radius: var(--r-lg);
            box-shadow: var(--shadow-3);
            padding: 36px 32px;
            width: 100%; max-width: 420px;
            position: relative; z-index: 1;
        }
        .auth-header { text-align: center; margin-bottom: 24px; }
        .auth-header h1 {
            font-size: 22px; font-weight: 600;
            color: var(--ink); letter-spacing: -0.02em; margin: 0;
        }
        .auth-header p { color: var(--ink-3); font-size: 14px; margin-top: 6px; }
        .auth-header .logo {
            width: 64px; height: 64px;
            background: var(--petrol-500); color: #fff;
            border-radius: var(--r-md);
            display: grid; place-items: center;
            margin: 0 auto 18px;
            font-size: 28px; font-weight: 600; letter-spacing: -0.04em;
            position: relative;
        }
        .auth-header .logo::after {
            content: '.'; position: absolute; right: 12px; bottom: 6px;
            color: var(--amber-500); font-weight: 700; font-size: 24px;
        }

        .form-floating > .form-control { border-radius: var(--r-sm); border: 1px solid var(--rule); padding: 16px 14px; font-size: 14px; }
        .form-floating > .form-control:focus { border-color: var(--petrol-500); box-shadow: var(--ring-focus); }

        .verification-input { display: flex; gap: 10px; justify-content: center; }
        .verification-input input {
            width: 50px; height: 60px; text-align: center;
            font-size: 24px; font-weight: 600;
            border: 1px solid var(--rule); border-radius: var(--r-sm);
            transition: all var(--t-fast); font-family: var(--font-mono);
        }
        .verification-input input:focus { border-color: var(--petrol-500); box-shadow: var(--ring-focus); outline: none; }

        /* Bottom nav (mobile) */
        .bottom-nav {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(12px);
            border-top: 1px solid var(--rule);
            padding: 6px 0 max(6px, env(safe-area-inset-bottom));
            z-index: 50;
        }
        .bottom-nav .nav-link {
            display: flex; flex-direction: column; align-items: center;
            font-size: 11px; font-weight: 500;
            color: var(--ink-3);
            padding: 6px 8px;
            border-radius: var(--r-sm);
            transition: all var(--t-fast);
            text-decoration: none; gap: 2px;
        }
        .bottom-nav .nav-link i { font-size: 20px; }
        .bottom-nav .nav-link.active { color: var(--petrol-500); }
        .bottom-nav .nav-link.active i { transform: scale(1.05); }

        .content-area { padding-bottom: 80px; }

        .establishment-card {
            background: var(--surface);
            border: 1px solid var(--rule);
            border-radius: var(--r-md);
            padding: 16px;
            margin-bottom: 12px;
            box-shadow: var(--shadow-1);
            cursor: pointer;
            transition: all var(--t-fast);
        }
        .establishment-card:hover { box-shadow: var(--shadow-2); }
        .establishment-card.selected { border-color: var(--petrol-500); background: var(--petrol-50); }

        .scan-area {
            width: 100%; max-width: 400px; aspect-ratio: 1;
            border: 2px dashed var(--rule);
            border-radius: var(--r-lg);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto;
            background: var(--bg-subtle);
            transition: all var(--t-fast);
        }
        .scan-area.scanning { border-color: var(--petrol-500); border-style: solid; background: var(--surface); }

        @@media (max-width: 576px) {
            .auth-card { padding: 28px 20px; }
            .verification-input input { width: 45px; height: 55px; font-size: 20px; }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
@if (isLoggedIn && !hideNav)
{
    <nav class="ds-cli-navbar">
        <a class="brand" href="/Cliente/Inicio">
            <span class="brand-glyph">o</span>
            <span class="brand-name">orcpharm</span>
        </a>
        @if (session?.CurrentEstablishment != null)
        {
            <span class="ds-cli-establishment">
                <i class="bi bi-shop"></i>
                @session.CurrentEstablishment.NomeFantasia
            </span>
        }
    </nav>
}

<main class="@(isLoggedIn && !hideNav ? "content-area" : "")">
    @RenderBody()
</main>

@if (isLoggedIn && !hideNav)
{
    <nav class="bottom-nav">
        <div class="container">
            <div class="row text-center">
                <div class="col">
                    <a href="/Cliente/Inicio" class="nav-link @(activeNav == "inicio" ? "active" : "")">
                        <i class="bi bi-house"></i>Início
                    </a>
                </div>
                <div class="col">
                    <a href="/Cliente/LerQRCode" class="nav-link @(activeNav == "qrcode" ? "active" : "")">
                        <i class="bi bi-qr-code-scan"></i>QR Code
                    </a>
                </div>
                <div class="col">
                    <a href="/Cliente/MeusPedidos" class="nav-link @(activeNav == "pedidos" ? "active" : "")">
                        <i class="bi bi-bag"></i>Pedidos
                    </a>
                </div>
                <div class="col">
                    <a href="/Cliente/MeusDados" class="nav-link @(activeNav == "perfil" ? "active" : "")">
                        <i class="bi bi-person"></i>Perfil
                    </a>
                </div>
            </div>
        </div>
    </nav>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showToast(message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = `alert alert-${type} position-fixed top-0 start-50 translate-middle-x mt-3`;
        toast.style.zIndex = '9999';
        toast.style.fontSize = '14px';
        toast.style.fontWeight = '500';
        toast.style.boxShadow = '0 8px 32px rgba(11,18,32,.18)';
        toast.innerHTML = message;
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.transition = 'opacity .3s ease'; toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3500);
    }
    function formatPhone(input) {
        let v = input.value.replace(/\D/g, '');
        if (v.length > 11) v = v.slice(0, 11);
        if (v.length > 7) input.value = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
        else if (v.length > 2) input.value = `(${v.slice(0,2)}) ${v.slice(2)}`;
        else if (v.length > 0) input.value = `(${v}`;
    }
    function formatCpf(input) {
        let v = input.value.replace(/\D/g, '');
        if (v.length > 11) v = v.slice(0, 11);
        if (v.length > 9) input.value = `${v.slice(0,3)}.${v.slice(3,6)}.${v.slice(6,9)}-${v.slice(9)}`;
        else if (v.length > 6) input.value = `${v.slice(0,3)}.${v.slice(3,6)}.${v.slice(6)}`;
        else if (v.length > 3) input.value = `${v.slice(0,3)}.${v.slice(3)}`;
        else input.value = v;
    }
    function formatCep(input) {
        let v = input.value.replace(/\D/g, '');
        if (v.length > 8) v = v.slice(0, 8);
        input.value = v.length > 5 ? `${v.slice(0,5)}-${v.slice(5)}` : v;
    }
    async function buscarCep(cep) {
        cep = cep.replace(/\D/g, '');
        if (cep.length !== 8) return;
        try {
            const r = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
            const d = await r.json();
            if (!d.erro) {
                document.getElementById('street').value = d.logradouro || '';
                document.getElementById('neighborhood').value = d.bairro || '';
                document.getElementById('city').value = d.localidade || '';
                document.getElementById('state').value = d.uf || '';
            }
        } catch (e) { console.error('CEP:', e); }
    }
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
