@{
    ViewData["Title"] = "Dashboard de Produção";
    Layout = "_Layout";
}

<div class="container-fluid py-3">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-graph-up text-primary me-2"></i>
                Dashboard de Produção
            </h2>
            <p class="text-muted mb-0">Métricas e indicadores de desempenho</p>
        </div>
        <div class="d-flex gap-2">
            <select id="periodFilter" class="form-select form-select-sm" style="width: auto;">
                <option value="today">Hoje</option>
                <option value="week" selected>Esta Semana</option>
                <option value="month">Este Mês</option>
                <option value="year">Este Ano</option>
            </select>
            <button class="btn btn-sm btn-outline-primary" onclick="refreshDashboard()">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <!-- KPIs Principais -->
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total em Produção</p>
                            <h2 class="mb-0" id="kpiEmProducao">0</h2>
                            <small class="text-info">
                                <i class="bi bi-gear-fill me-1"></i>
                                <span id="kpiProducaoTrend">Em andamento</span>
                            </small>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-gear-fill text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Finalizados Hoje</p>
                            <h2 class="mb-0" id="kpiFinalizadosHoje">0</h2>
                            <small class="text-success">
                                <i class="bi bi-check-circle me-1"></i>
                                <span id="kpiFinalizadosTrend">+0% vs ontem</span>
                            </small>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle-fill text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Taxa de Aprovação</p>
                            <h2 class="mb-0"><span id="kpiTaxaAprovacao">0</span>%</h2>
                            <small class="text-primary">
                                <i class="bi bi-award me-1"></i>
                                <span id="kpiAprovacaoMeta">Meta: 95%</span>
                            </small>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-award-fill text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Tempo Médio</p>
                            <h2 class="mb-0"><span id="kpiTempoMedio">0</span>h</h2>
                            <small class="text-warning">
                                <i class="bi bi-clock me-1"></i>
                                <span id="kpiTempoTrend">Por manipulação</span>
                            </small>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-clock-fill text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Gráfico de Produção por Status -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0">
                        <i class="bi bi-bar-chart me-2"></i>
                        Ordens por Etapa
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="chartEtapas" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Resumo de Status -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0">
                        <i class="bi bi-pie-chart me-2"></i>
                        Distribuição por Status
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="chartStatus" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Ordens Pendentes de Ação -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                        Aguardando Ação
                    </h6>
                    <span class="badge bg-warning text-dark" id="badgeAguardando">0</span>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="listAguardando">
                        <!-- Carregado via JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Ordens Atrasadas -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="bi bi-alarm text-danger me-2"></i>
                        Ordens Atrasadas
                    </h6>
                    <span class="badge bg-danger" id="badgeAtrasadas">0</span>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="listAtrasadas">
                        <!-- Carregado via JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Produção por Período -->
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0">
                        <i class="bi bi-calendar3 me-2"></i>
                        Produção nos Últimos 7 Dias
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="chartSemanal" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let chartEtapas, chartStatus, chartSemanal;

    document.addEventListener('DOMContentLoaded', function() {
        initCharts();
        loadDashboardData();
        
        // Auto-refresh a cada 60 segundos
        setInterval(loadDashboardData, 60000);
    });

    function initCharts() {
        // Gráfico de Etapas (Barras)
        const ctxEtapas = document.getElementById('chartEtapas').getContext('2d');
        chartEtapas = new Chart(ctxEtapas, {
            type: 'bar',
            data: {
                labels: ['Separação', 'Pesagem', 'Mistura', 'Envase', 'Rotulagem', 'Conferência', 'Aprovação'],
                datasets: [{
                    label: 'Ordens',
                    data: [0, 0, 0, 0, 0, 0, 0],
                    backgroundColor: [
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(13, 202, 240, 0.7)',
                        'rgba(13, 110, 253, 0.7)',
                        'rgba(25, 135, 84, 0.7)'
                    ],
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Gráfico de Status (Pizza)
        const ctxStatus = document.getElementById('chartStatus').getContext('2d');
        chartStatus = new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: ['Pendentes', 'Em Produção', 'Finalizados', 'Rejeitados'],
                datasets: [{
                    data: [0, 0, 0, 0],
                    backgroundColor: [
                        'rgba(255, 193, 7, 0.8)',
                        'rgba(13, 202, 240, 0.8)',
                        'rgba(25, 135, 84, 0.8)',
                        'rgba(220, 53, 69, 0.8)'
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // Gráfico Semanal (Linhas)
        const ctxSemanal = document.getElementById('chartSemanal').getContext('2d');
        chartSemanal = new Chart(ctxSemanal, {
            type: 'line',
            data: {
                labels: getLast7Days(),
                datasets: [
                    {
                        label: 'Finalizadas',
                        data: [0, 0, 0, 0, 0, 0, 0],
                        borderColor: 'rgba(25, 135, 84, 1)',
                        backgroundColor: 'rgba(25, 135, 84, 0.1)',
                        fill: true,
                        tension: 0.4
                    },
                    {
                        label: 'Iniciadas',
                        data: [0, 0, 0, 0, 0, 0, 0],
                        borderColor: 'rgba(13, 110, 253, 1)',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: true,
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top'
                    }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    }

    function getLast7Days() {
        const days = [];
        for (let i = 6; i >= 0; i--) {
            const date = new Date();
            date.setDate(date.getDate() - i);
            days.push(date.toLocaleDateString('pt-BR', { weekday: 'short', day: 'numeric' }));
        }
        return days;
    }

    async function loadDashboardData() {
        try {
            const response = await fetch('/api/ManipulationWorkflow/dashboard');
            const result = await response.json();
            
            if (result.success) {
                const data = result.data;
                
                // Atualizar KPIs
                document.getElementById('kpiEmProducao').textContent = data.totalEmProducao;
                document.getElementById('kpiFinalizadosHoje').textContent = data.totalFinalizados;
                document.getElementById('kpiTaxaAprovacao').textContent = data.taxaAprovacao.toFixed(1);
                document.getElementById('kpiTempoMedio').textContent = data.tempoMedioProducao?.toFixed(1) || '0';
                
                // Atualizar gráfico de status
                chartStatus.data.datasets[0].data = [
                    data.totalPendentes,
                    data.totalEmProducao,
                    data.totalFinalizados,
                    data.totalRejeitados
                ];
                chartStatus.update();
                
                // Atualizar gráfico de etapas (se disponível)
                if (data.ordensPorEtapa && data.ordensPorEtapa.length > 0) {
                    const etapasData = ['SEPARACAO', 'PESAGEM', 'MISTURA', 'ENVASE', 'ROTULAGEM', 'CONFERENCIA', 'APROVACAO']
                        .map(etapa => {
                            const found = data.ordensPorEtapa.find(e => e.etapa === etapa);
                            return found ? found.quantidade : 0;
                        });
                    chartEtapas.data.datasets[0].data = etapasData;
                    chartEtapas.update();
                }
            }
            
            // Carregar listas
            await loadPendingOrders();
            await loadDelayedOrders();
            
        } catch (error) {
            console.error('Erro ao carregar dashboard:', error);
        }
    }

    async function loadPendingOrders() {
        try {
            const response = await fetch('/api/ManipulationOrders?status=CONFERENCIA');
            const result = await response.json();
            
            const list = document.getElementById('listAguardando');
            const badge = document.getElementById('badgeAguardando');
            
            if (result.success && result.data.length > 0) {
                badge.textContent = result.data.length;
                list.innerHTML = result.data.slice(0, 5).map(order => `
                    <a href="/Manipulacoes/ProducaoOrdem/${order.id}" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>${order.orderNumber}</strong>
                                <br><small class="text-muted">${order.customerName || 'Cliente não informado'}</small>
                            </div>
                            <span class="badge bg-primary">${order.status}</span>
                        </div>
                    </a>
                `).join('');
            } else {
                badge.textContent = '0';
                list.innerHTML = '<div class="list-group-item text-muted text-center py-4">Nenhuma ordem aguardando</div>';
            }
        } catch (error) {
            console.error('Erro ao carregar ordens pendentes:', error);
        }
    }

    async function loadDelayedOrders() {
        try {
            const response = await fetch('/api/ManipulationOrders?delayed=true');
            const result = await response.json();
            
            const list = document.getElementById('listAtrasadas');
            const badge = document.getElementById('badgeAtrasadas');
            
            // Filtrar ordens atrasadas (estimatedCompletionDate < hoje)
            const delayed = result.success ? result.data.filter(o => {
                if (!o.estimatedCompletionDate) return false;
                return new Date(o.estimatedCompletionDate) < new Date() && o.status !== 'FINALIZADO';
            }) : [];
            
            if (delayed.length > 0) {
                badge.textContent = delayed.length;
                list.innerHTML = delayed.slice(0, 5).map(order => `
                    <a href="/Manipulacoes/ProducaoOrdem/${order.id}" class="list-group-item list-group-item-action list-group-item-danger">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>${order.orderNumber}</strong>
                                <br><small>Previsto: ${formatDate(order.estimatedCompletionDate)}</small>
                            </div>
                            <span class="badge bg-danger">${order.status}</span>
                        </div>
                    </a>
                `).join('');
            } else {
                badge.textContent = '0';
                list.innerHTML = '<div class="list-group-item text-muted text-center py-4">Nenhuma ordem atrasada 🎉</div>';
            }
        } catch (error) {
            console.error('Erro ao carregar ordens atrasadas:', error);
        }
    }

    function formatDate(dateString) {
        if (!dateString) return '-';
        return new Date(dateString).toLocaleDateString('pt-BR');
    }

    function refreshDashboard() {
        loadDashboardData();
    }

    document.getElementById('periodFilter').addEventListener('change', function() {
        // TODO: Implementar filtro por período
        loadDashboardData();
    });
</script>
}
