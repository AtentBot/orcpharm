@* Partial View para Etapa de Aprovação Final *@
@model dynamic

<div class="card border-success mb-4" id="stepAprovacao">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-award me-2"></i>
            Etapa 7: Aprovação Final
            <small class="ms-2 badge bg-light text-success">Farmacêutico RT</small>
        </h5>
        <span class="badge bg-white text-success" id="statusAprovacao">PENDENTE</span>
    </div>
    <div class="card-body">
        <!-- Alerta Farmacêutico RT -->
        <div class="alert alert-success mb-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-shield-fill-check fs-3 me-3"></i>
                <div>
                    <strong>Aprovação Final pelo Farmacêutico Responsável Técnico</strong>
                    <p class="mb-0 small">Esta é a última etapa do processo de manipulação. 
                    A aprovação libera o produto para expedição ao cliente.</p>
                </div>
            </div>
        </div>

        <form id="formAprovacao">
            <!-- Resumo da Ordem -->
            <div class="card mb-4 bg-light">
                <div class="card-header">
                    <i class="bi bi-info-circle me-2"></i>
                    Resumo da Manipulação
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Ordem:</strong><br>
                            <span id="resumoOrdem" class="fs-5 text-primary">-</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Fórmula:</strong><br>
                            <span id="resumoFormula">-</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Quantidade:</strong><br>
                            <span id="resumoQuantidade">-</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Lote:</strong><br>
                            <span id="resumoLote" class="fw-bold">-</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Identificação do Farmacêutico RT -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <i class="bi bi-person-badge-fill me-2"></i>
                    Farmacêutico Responsável Técnico
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Farmacêutico RT <span class="text-danger">*</span></label>
                            <select id="farmaceuticoAprovacao" name="FarmaceuticoId" class="form-select" required
                                onchange="preencherDadosFarmaceuticoRT(this)">
                                <option value="">Selecione o farmacêutico RT...</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nome Completo</label>
                            <input type="text" id="nomeAprovacao" name="FarmaceuticoNome" class="form-control" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">CRF <span class="text-danger">*</span></label>
                            <input type="text" id="crfAprovacao" name="CRF" class="form-control" required readonly>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Verificação Final -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <i class="bi bi-check2-all me-2"></i>
                    Verificação Final
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="checkInspecao" required>
                                <label class="form-check-label" for="checkInspecao">
                                    <i class="bi bi-eye me-1 text-primary"></i>
                                    Inspeção visual realizada e aprovada
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="checkDocumentacao" required>
                                <label class="form-check-label" for="checkDocumentacao">
                                    <i class="bi bi-file-earmark-check me-1 text-primary"></i>
                                    Documentação completa e conforme
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="checkRotulagem" required>
                                <label class="form-check-label" for="checkRotulagem">
                                    <i class="bi bi-tag me-1 text-primary"></i>
                                    Rotulagem correta (RDC 67/2007)
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="checkEmbalagem" required>
                                <label class="form-check-label" for="checkEmbalagem">
                                    <i class="bi bi-box me-1 text-primary"></i>
                                    Embalagem íntegra e adequada
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Decisão Final -->
            <div class="card border-3 mb-4" id="cardDecisao">
                <div class="card-body">
                    <h5 class="mb-4 text-center">
                        <i class="bi bi-question-circle me-2"></i>
                        Decisão Final
                    </h5>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card h-100 border-success cursor-pointer" onclick="selecionarDecisao('aprovar')" id="cardAprovar">
                                <div class="card-body text-center py-4">
                                    <i class="bi bi-check-circle-fill text-success fs-1 mb-3"></i>
                                    <h4 class="text-success">APROVAR</h4>
                                    <p class="text-muted small mb-0">
                                        Produto liberado para expedição
                                    </p>
                                    <input type="radio" name="Aprovado" value="true" class="d-none" id="radioAprovar">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100 border-danger cursor-pointer" onclick="selecionarDecisao('rejeitar')" id="cardRejeitar">
                                <div class="card-body text-center py-4">
                                    <i class="bi bi-x-circle-fill text-danger fs-1 mb-3"></i>
                                    <h4 class="text-danger">REJEITAR</h4>
                                    <p class="text-muted small mb-0">
                                        Produto não conforme - requer ação
                                    </p>
                                    <input type="radio" name="Aprovado" value="false" class="d-none" id="radioRejeitar">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Campos de Rejeição (oculto por padrão) -->
            <div class="card mb-4 border-danger d-none" id="camposRejeicao">
                <div class="card-header bg-danger text-white">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Motivo da Rejeição
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Motivo da Reprovação <span class="text-danger">*</span></label>
                        <textarea id="motivoReprovacao" name="MotivoReprovacao" class="form-control" rows="3"
                            placeholder="Descreva detalhadamente o motivo da reprovação..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ações Corretivas Necessárias</label>
                        <textarea id="acoesCorretivas" name="AcoesCorretivas" class="form-control" rows="2"
                            placeholder="Descreva as ações corretivas necessárias..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Observações -->
            <div class="mb-4">
                <label class="form-label">Observações Finais</label>
                <textarea id="observacoesAprovacao" name="Observacoes" class="form-control" rows="2"
                    placeholder="Observações adicionais (opcional)..."></textarea>
            </div>

            <!-- Assinatura Digital -->
            <div class="card mb-4 bg-light">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-fingerprint me-1"></i>
                                Assinatura Digital (Senha)
                            </label>
                            <input type="password" id="assinaturaDigital" name="AssinaturaDigital" 
                                class="form-control" placeholder="Digite sua senha para assinar"
                                autocomplete="new-password">
                            <small class="text-muted">Opcional - Para registro de assinatura eletrônica</small>
                        </div>
                        <div class="col-md-6 text-end">
                            <p class="mb-0 text-muted">
                                <i class="bi bi-calendar me-1"></i>
                                Data/Hora: <strong id="dataHoraAprovacao"></strong>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botões de Ação -->
            <div class="d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" onclick="voltarEtapa('CONFERENCIA')">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </button>
                <button type="submit" class="btn btn-success btn-lg" id="btnFinalizar" disabled>
                    <i class="bi bi-check-lg me-1"></i> Finalizar Manipulação
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; transition: all 0.2s; }
    .cursor-pointer:hover { transform: scale(1.02); }
    .card.selected { border-width: 3px !important; box-shadow: 0 0 15px rgba(0,0,0,0.2); }
</style>

<script>
    let decisaoSelecionada = null;

    document.addEventListener('DOMContentLoaded', function() {
        carregarFarmaceuticosRT();
        carregarResumoOrdem();
        document.getElementById('dataHoraAprovacao').textContent = new Date().toLocaleString('pt-BR');
    });

    async function carregarFarmaceuticosRT() {
        try {
            // Carregar apenas farmacêuticos RT
            const response = await fetch('/api/Employees?jobPosition=PHARMACIST_RT');
            const result = await response.json();
            
            if (result.success) {
                const select = document.getElementById('farmaceuticoAprovacao');
                result.data.forEach(farm => {
                    const option = document.createElement('option');
                    option.value = farm.id;
                    option.textContent = `${farm.fullName} (RT)`;
                    option.dataset.crf = farm.crf || '';
                    option.dataset.name = farm.fullName;
                    select.appendChild(option);
                });
            }
            
            // Se não houver RT, carregar farmacêuticos normais
            if (document.getElementById('farmaceuticoAprovacao').options.length <= 1) {
                const response2 = await fetch('/api/Employees?jobPosition=PHARMACIST');
                const result2 = await response2.json();
                
                if (result2.success) {
                    const select = document.getElementById('farmaceuticoAprovacao');
                    result2.data.forEach(farm => {
                        const option = document.createElement('option');
                        option.value = farm.id;
                        option.textContent = farm.fullName;
                        option.dataset.crf = farm.crf || '';
                        option.dataset.name = farm.fullName;
                        select.appendChild(option);
                    });
                }
            }
        } catch (error) {
            console.error('Erro ao carregar farmacêuticos:', error);
        }
    }

    function preencherDadosFarmaceuticoRT(select) {
        const option = select.options[select.selectedIndex];
        document.getElementById('nomeAprovacao').value = option.dataset.name || '';
        document.getElementById('crfAprovacao').value = option.dataset.crf || '';
    }

    function carregarResumoOrdem() {
        // Preencher resumo com dados da ordem
        document.getElementById('resumoOrdem').textContent = 
            document.getElementById('orderNumber')?.textContent || '-';
        document.getElementById('resumoFormula').textContent = 
            document.getElementById('formulaName')?.textContent || '-';
        document.getElementById('resumoQuantidade').textContent = 
            document.getElementById('quantidadeProduzir')?.value + ' ' + 
            document.getElementById('unidadeOrdem')?.value || '-';
        document.getElementById('resumoLote').textContent = 
            document.getElementById('numeroLote')?.value || '-';
    }

    function selecionarDecisao(decisao) {
        decisaoSelecionada = decisao;
        
        // Remover seleção anterior
        document.querySelectorAll('#cardDecisao .card').forEach(c => c.classList.remove('selected'));
        
        if (decisao === 'aprovar') {
            document.getElementById('cardAprovar').classList.add('selected');
            document.getElementById('radioAprovar').checked = true;
            document.getElementById('camposRejeicao').classList.add('d-none');
            document.getElementById('btnFinalizar').textContent = '✓ Aprovar e Finalizar';
            document.getElementById('btnFinalizar').className = 'btn btn-success btn-lg';
        } else {
            document.getElementById('cardRejeitar').classList.add('selected');
            document.getElementById('radioRejeitar').checked = true;
            document.getElementById('camposRejeicao').classList.remove('d-none');
            document.getElementById('btnFinalizar').textContent = '✗ Registrar Rejeição';
            document.getElementById('btnFinalizar').className = 'btn btn-danger btn-lg';
        }
        
        document.getElementById('btnFinalizar').disabled = false;
    }

    document.getElementById('formAprovacao').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        if (!decisaoSelecionada) {
            showToast('Selecione APROVAR ou REJEITAR', 'warning');
            return;
        }
        
        const aprovado = decisaoSelecionada === 'aprovar';
        
        // Validar motivo se rejeitado
        if (!aprovado && !document.getElementById('motivoReprovacao').value.trim()) {
            showToast('Motivo da reprovação é obrigatório', 'warning');
            document.getElementById('motivoReprovacao').focus();
            return;
        }
        
        const farmSelect = document.getElementById('farmaceuticoAprovacao');
        const orderId = document.getElementById('orderId').value;
        
        const data = {
            farmaceuticoId: farmSelect.value,
            farmaceuticoNome: document.getElementById('nomeAprovacao').value,
            crf: document.getElementById('crfAprovacao').value,
            aprovado: aprovado,
            motivoReprovacao: document.getElementById('motivoReprovacao').value || null,
            acoesCorretivas: document.getElementById('acoesCorretivas').value || null,
            observacoes: document.getElementById('observacoesAprovacao').value || null,
            assinaturaDigital: document.getElementById('assinaturaDigital').value || null
        };

        // Confirmar ação
        const confirmMsg = aprovado 
            ? 'Confirma a APROVAÇÃO e FINALIZAÇÃO desta manipulação?'
            : 'Confirma a REJEIÇÃO desta manipulação?';
            
        if (!confirm(confirmMsg)) return;

        try {
            const response = await fetch(`/api/ManipulationWorkflow/${orderId}/approve-final`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                if (aprovado) {
                    showToast('✅ Manipulação APROVADA e FINALIZADA com sucesso!', 'success');
                    document.getElementById('statusAprovacao').textContent = 'FINALIZADA';
                    document.getElementById('statusAprovacao').className = 'badge bg-success';
                    
                    // Exibir modal de sucesso
                    exibirSucesso();
                } else {
                    showToast('❌ Manipulação REJEITADA. Ações corretivas necessárias.', 'warning');
                    document.getElementById('statusAprovacao').textContent = 'REJEITADA';
                    document.getElementById('statusAprovacao').className = 'badge bg-danger';
                }
                
                // Desabilitar formulário
                document.getElementById('formAprovacao').querySelectorAll('input, select, textarea, button')
                    .forEach(el => el.disabled = true);
                    
            } else {
                showToast(result.message || 'Erro ao processar aprovação', 'danger');
            }
        } catch (error) {
            console.error('Erro:', error);
            showToast('Erro ao processar requisição', 'danger');
        }
    });

    function exibirSucesso() {
        const html = `
            <div class="text-center py-5">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                <h2 class="mt-3 text-success">Manipulação Finalizada!</h2>
                <p class="text-muted">O produto está liberado para expedição.</p>
                <div class="mt-4">
                    <a href="/Workflow" class="btn btn-outline-primary me-2">
                        <i class="bi bi-list me-1"></i> Ver Todas Ordens
                    </a>
                    <a href="/Manipulacoes/Imprimir/${document.getElementById('orderId').value}" 
                        class="btn btn-primary" target="_blank">
                        <i class="bi bi-printer me-1"></i> Imprimir Ficha
                    </a>
                </div>
            </div>
        `;
        
        document.getElementById('stepAprovacao').innerHTML = html;
    }
</script>
