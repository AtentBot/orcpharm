@{
    ViewData["Title"] = "Indicadores de Qualidade";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1"><i class="bi bi-graph-up me-2"></i>Indicadores de Qualidade</h4>
            <p class="text-muted mb-0">Métricas e KPIs de controle de qualidade</p>
        </div>
        <div>
            <select id="periodoSelect" class="form-select" style="width: 200px;">
                <option value="7">Últimos 7 dias</option>
                <option value="30" selected>Últimos 30 dias</option>
                <option value="90">Últimos 90 dias</option>
                <option value="365">Último ano</option>
            </select>
        </div>
    </div>

    <!-- KPIs Principais -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small">Taxa de Aprovação</p>
                            <h2 class="mb-0 text-success" id="taxaAprovacao">-</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-check-circle text-success fs-3"></i>
                        </div>
                    </div>
                    <small class="text-muted">Lotes aprovados no CQ</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small">Taxa de Rejeição</p>
                            <h2 class="mb-0 text-danger" id="taxaRejeicao">-</h2>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded">
                            <i class="bi bi-x-circle text-danger fs-3"></i>
                        </div>
                    </div>
                    <small class="text-muted">Lotes rejeitados no CQ</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small">CAPAs Abertas</p>
                            <h2 class="mb-0 text-warning" id="capasAbertas">-</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-exclamation-triangle text-warning fs-3"></i>
                        </div>
                    </div>
                    <small class="text-muted">Ações pendentes</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted mb-1 small">POPs Vigentes</p>
                            <h2 class="mb-0 text-primary" id="popsVigentes">-</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-file-text text-primary fs-3"></i>
                        </div>
                    </div>
                    <small class="text-muted">Procedimentos ativos</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Gráfico de Aprovações -->
        <div class="col-md-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Evolução da Taxa de Aprovação</h6>
                </div>
                <div class="card-body">
                    <canvas id="chartAprovacao" height="300"></canvas>
                </div>
            </div>
        </div>

        <!-- Resumo por Tipo -->
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Não Conformidades por Tipo</h6>
                </div>
                <div class="card-body">
                    <canvas id="chartNaoConformidades" height="300"></canvas>
                </div>
            </div>
        </div>

        <!-- Indicadores Detalhados -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Indicadores de Processo</h6>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <td>Tempo Médio de Produção</td>
                                <td class="text-end"><strong id="tempoMedioProducao">-</strong></td>
                            </tr>
                            <tr>
                                <td>Tempo Médio de Aprovação CQ</td>
                                <td class="text-end"><strong id="tempoMedioCQ">-</strong></td>
                            </tr>
                            <tr>
                                <td>Índice de Retrabalho</td>
                                <td class="text-end"><strong id="indiceRetrabalho">-</strong></td>
                            </tr>
                            <tr>
                                <td>Desvios Registrados</td>
                                <td class="text-end"><strong id="desviosRegistrados">-</strong></td>
                            </tr>
                            <tr>
                                <td>Reclamações de Clientes</td>
                                <td class="text-end"><strong id="reclamacoesClientes">-</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Status CAPAs -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Status das CAPAs</h6>
                    <a href="/Qualidade/CAPAs" class="btn btn-sm btn-outline-primary">Ver Todas</a>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-3">
                            <div class="border rounded p-3">
                                <h3 class="mb-0 text-warning" id="capasAbertasCount">0</h3>
                                <small class="text-muted">Abertas</small>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border rounded p-3">
                                <h3 class="mb-0 text-info" id="capasAndamentoCount">0</h3>
                                <small class="text-muted">Em Andamento</small>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border rounded p-3">
                                <h3 class="mb-0 text-primary" id="capasVerificacaoCount">0</h3>
                                <small class="text-muted">Verificação</small>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="border rounded p-3">
                                <h3 class="mb-0 text-success" id="capasConcluidasCount">0</h3>
                                <small class="text-muted">Concluídas</small>
                            </div>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div id="capasRecentes">
                        <p class="text-center text-muted py-3">Carregando...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- POPs por Revisão -->
        <div class="col-12 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-calendar-check me-2"></i>POPs com Revisão Pendente</h6>
                    <a href="/Qualidade/POPs" class="btn btn-sm btn-outline-primary">Ver Todos</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Código</th>
                                    <th>Título</th>
                                    <th>Versão</th>
                                    <th>Última Revisão</th>
                                    <th>Próxima Revisão</th>
                                    <th>Status</th>
                                    <th class="text-center">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="popsRevisaoTable">
                                <tr>
                                    <td colspan="7" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                        <span class="ms-2">Carregando...</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
let chartAprovacao, chartNaoConformidades;

document.addEventListener('DOMContentLoaded', function() {
    loadIndicadores();
    initCharts();
    
    document.getElementById('periodoSelect').addEventListener('change', function() {
        loadIndicadores();
    });
});

async function loadIndicadores() {
    const dias = document.getElementById('periodoSelect').value;
    
    try {
        // Carregar estatísticas de qualidade
        const [statsResponse, capasResponse, popsResponse] = await Promise.all([
            fetch(`/api/Qualidade/statistics?days=${dias}`, { credentials: 'include' }).catch(() => null),
            fetch(`/api/Qualidade/capas?status=ABERTA`, { credentials: 'include' }).catch(() => null),
            fetch(`/api/Qualidade/pops?needsReview=true`, { credentials: 'include' }).catch(() => null)
        ]);
        
        // Valores padrão
        let stats = {
            taxaAprovacao: 100,
            taxaRejeicao: 0,
            capasAbertas: 0,
            popsVigentes: 0,
            tempoMedioProducao: '2h 30min',
            tempoMedioCQ: '45min',
            indiceRetrabalho: '0%',
            desviosRegistrados: 0,
            reclamacoesClientes: 0
        };
        
        if (statsResponse?.ok) {
            const data = await statsResponse.json();
            if (data.success && data.data) {
                stats = { ...stats, ...data.data };
            }
        }
        
        // Atualizar KPIs
        document.getElementById('taxaAprovacao').textContent = `${stats.taxaAprovacao}%`;
        document.getElementById('taxaRejeicao').textContent = `${stats.taxaRejeicao}%`;
        document.getElementById('capasAbertas').textContent = stats.capasAbertas;
        document.getElementById('popsVigentes').textContent = stats.popsVigentes;
        
        // Indicadores detalhados
        document.getElementById('tempoMedioProducao').textContent = stats.tempoMedioProducao;
        document.getElementById('tempoMedioCQ').textContent = stats.tempoMedioCQ;
        document.getElementById('indiceRetrabalho').textContent = stats.indiceRetrabalho;
        document.getElementById('desviosRegistrados').textContent = stats.desviosRegistrados;
        document.getElementById('reclamacoesClientes').textContent = stats.reclamacoesClientes;
        
        // CAPAs
        loadCAPAsStatus();
        
        // POPs para revisão
        loadPOPsRevisao();
        
        // Atualizar gráficos
        updateCharts(stats);
        
    } catch (error) {
        console.error('Erro ao carregar indicadores:', error);
    }
}

async function loadCAPAsStatus() {
    try {
        const response = await fetch('/api/Qualidade/capas/summary', { credentials: 'include' });
        
        if (response.ok) {
            const data = await response.json();
            const summary = data.data || data || {};
            
            document.getElementById('capasAbertasCount').textContent = summary.abertas || 0;
            document.getElementById('capasAndamentoCount').textContent = summary.emAndamento || 0;
            document.getElementById('capasVerificacaoCount').textContent = summary.verificacao || 0;
            document.getElementById('capasConcluidasCount').textContent = summary.concluidas || 0;
        }
    } catch (error) {
        console.log('API de CAPAs não disponível');
    }
    
    document.getElementById('capasRecentes').innerHTML = `
        <div class="text-center text-muted py-3">
            <i class="bi bi-check-circle fs-3 text-success"></i>
            <p class="mb-0 mt-2">Nenhuma CAPA pendente</p>
        </div>
    `;
}

async function loadPOPsRevisao() {
    const tbody = document.getElementById('popsRevisaoTable');
    
    try {
        const response = await fetch('/api/Qualidade/pops?needsReview=true&limit=5', { credentials: 'include' });
        
        if (response.ok) {
            const data = await response.json();
            const pops = data.data || data || [];
            
            if (pops.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="bi bi-check-circle text-success fs-3"></i>
                            <p class="mb-0 mt-2">Todos os POPs estão em dia</p>
                        </td>
                    </tr>
                `;
                return;
            }
            
            tbody.innerHTML = pops.map(p => `
                <tr>
                    <td><strong>${p.code || '-'}</strong></td>
                    <td>${p.title || '-'}</td>
                    <td>${p.version || '1.0'}</td>
                    <td>${formatDate(p.lastReviewDate)}</td>
                    <td class="${isOverdue(p.nextReviewDate) ? 'text-danger' : ''}">${formatDate(p.nextReviewDate)}</td>
                    <td>
                        ${isOverdue(p.nextReviewDate) 
                            ? '<span class="badge bg-danger">Vencido</span>' 
                            : '<span class="badge bg-warning">Revisar</span>'}
                    </td>
                    <td class="text-center">
                        <a href="/Qualidade/POPs/Editar/${p.id}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
            `).join('');
            return;
        }
    } catch (error) {
        console.log('API de POPs não disponível');
    }
    
    tbody.innerHTML = `
        <tr>
            <td colspan="7" class="text-center py-4 text-muted">
                <i class="bi bi-check-circle text-success fs-3"></i>
                <p class="mb-0 mt-2">Todos os POPs estão em dia</p>
            </td>
        </tr>
    `;
}

function initCharts() {
    // Gráfico de Aprovação
    const ctxAprovacao = document.getElementById('chartAprovacao').getContext('2d');
    chartAprovacao = new Chart(ctxAprovacao, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: 'Taxa de Aprovação (%)',
                data: [],
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { min: 0, max: 100 }
            }
        }
    });
    
    // Gráfico de Não Conformidades
    const ctxNC = document.getElementById('chartNaoConformidades').getContext('2d');
    chartNaoConformidades = new Chart(ctxNC, {
        type: 'doughnut',
        data: {
            labels: ['Processo', 'Matéria-prima', 'Equipamento', 'Documentação', 'Outros'],
            datasets: [{
                data: [0, 0, 0, 0, 0],
                backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6', '#8b5cf6', '#6b7280']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });
}

function updateCharts(stats) {
    // Dados simulados para o gráfico de evolução
    const dias = parseInt(document.getElementById('periodoSelect').value);
    const labels = [];
    const data = [];
    
    for (let i = dias; i >= 0; i -= Math.max(1, Math.floor(dias / 10))) {
        const date = new Date();
        date.setDate(date.getDate() - i);
        labels.push(date.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' }));
        data.push(95 + Math.random() * 5); // Simula taxa entre 95-100%
    }
    
    chartAprovacao.data.labels = labels;
    chartAprovacao.data.datasets[0].data = data;
    chartAprovacao.update();
    
    // Dados simulados para não conformidades
    chartNaoConformidades.data.datasets[0].data = [
        Math.floor(Math.random() * 5),
        Math.floor(Math.random() * 3),
        Math.floor(Math.random() * 2),
        Math.floor(Math.random() * 2),
        Math.floor(Math.random() * 1)
    ];
    chartNaoConformidades.update();
}

function formatDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('pt-BR');
}

function isOverdue(dateStr) {
    if (!dateStr) return false;
    return new Date(dateStr) < new Date();
}
</script>
}
