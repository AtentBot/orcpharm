@{
    ViewData["Title"] = "Solicitação de Acesso - Auditoria";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - OrcPharm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-check text-primary" style="font-size: 4rem;"></i>
                    <h2 class="mt-3">Portal de Auditoria</h2>
                    <p class="text-muted">Solicitação de Acesso para Auditores Externos</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    </div>
                }

                <div class="card border-0 shadow">
                    <div class="card-body p-4">
                        <form asp-action="AccessRequestSubmit" method="post">
                            @Html.AntiForgeryToken()

                            <h6 class="text-uppercase text-muted mb-3">Dados do Estabelecimento</h6>
                            
                            <div class="mb-3">
                                <label class="form-label">CNPJ do Estabelecimento <span class="text-danger">*</span></label>
                                <input type="text" name="EstablishmentCnpj" class="form-control" required 
                                       placeholder="00.000.000/0000-00" maxlength="18">
                                <div class="form-text">Informe o CNPJ da farmácia que deseja auditar</div>
                            </div>

                            <hr class="my-4">
                            <h6 class="text-uppercase text-muted mb-3">Dados do Auditor</h6>

                            <div class="mb-3">
                                <label class="form-label">Nome Completo <span class="text-danger">*</span></label>
                                <input type="text" name="AuditorName" class="form-control" required>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">CPF <span class="text-danger">*</span></label>
                                    <input type="text" name="AuditorDocument" class="form-control" required 
                                           placeholder="000.000.000-00" maxlength="14">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Credencial/Matrícula</label>
                                    <input type="text" name="AuditorCredential" class="form-control">
                                </div>
                            </div>

                            <div class="mb-3 mt-3">
                                <label class="form-label">Instituição <span class="text-danger">*</span></label>
                                <select name="AuditorInstitution" class="form-select" required>
                                    <option value="">Selecione...</option>
                                    <option value="ANVISA">ANVISA</option>
                                    <option value="VISA_ESTADUAL">Vigilância Sanitária Estadual</option>
                                    <option value="VISA_MUNICIPAL">Vigilância Sanitária Municipal</option>
                                    <option value="CRF">Conselho Regional de Farmácia</option>
                                    <option value="POLICIA_CIVIL">Polícia Civil</option>
                                    <option value="POLICIA_FEDERAL">Polícia Federal</option>
                                    <option value="MINISTERIO_PUBLICO">Ministério Público</option>
                                    <option value="OUTRO">Outro</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Motivo do Acesso <span class="text-danger">*</span></label>
                                <textarea name="AccessReason" class="form-control" rows="3" required
                                          placeholder="Descreva o motivo da auditoria..."></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Relatórios Solicitados</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="reports" value="BMPO" id="r1">
                                    <label class="form-check-label" for="r1">BMPO - Balanço Mensal de Psicotrópicos</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="reports" value="BSPO" id="r2">
                                    <label class="form-check-label" for="r2">BSPO - Balanço de Substâncias Psicoativas</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="reports" value="MOVIMENTACOES" id="r3">
                                    <label class="form-check-label" for="r3">Movimentações de Controlados</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="reports" value="RECEITUARIOS" id="r4">
                                    <label class="form-check-label" for="r4">Livro de Receituários</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="reports" value="INVENTARIO" id="r5">
                                    <label class="form-check-label" for="r5">Inventário de Controlados</label>
                                </div>
                                <input type="hidden" name="RequestedReports" id="requestedReports">
                            </div>

                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                Sua solicitação será analisada pelo Farmacêutico Responsável Técnico do estabelecimento.
                                Você receberá um token de acesso temporário após a aprovação.
                            </div>

                            <button type="submit" class="btn btn-primary w-100" onclick="prepareSubmit()">
                                <i class="bi bi-send me-1"></i>Enviar Solicitação
                            </button>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <small class="text-muted">
                        <i class="bi bi-shield-lock me-1"></i>
                        Acesso protegido em conformidade com LGPD e normas ANVISA
                    </small>
                </div>
            </div>
        </div>
    </div>

    <script>
    function prepareSubmit() {
        var checks = document.querySelectorAll('input[name="reports"]:checked');
        var values = [];
        checks.forEach(function(c) { values.push(c.value); });
        document.getElementById('requestedReports').value = values.join(',');
    }
    </script>
</body>
</html>
