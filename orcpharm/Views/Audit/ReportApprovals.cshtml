@model List<Models.Controlled.PharmacistApproval>
@{
    ViewData["Title"] = "Relatório de Aprovações";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <a href="/Audit" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div class="flex-grow-1">
            <h4 class="mb-1">
                <i class="bi bi-check2-square text-primary me-2"></i>Relatório de Aprovações RT
            </h4>
            <p class="text-muted mb-0">Histórico de aprovações farmacêuticas</p>
        </div>
        <button onclick="window.print()" class="btn btn-outline-primary">
            <i class="bi bi-printer me-1"></i>Imprimir
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Data Inicial</label>
                    <input type="date" name="startDate" class="form-control" value="@(((DateTime?)ViewBag.StartDate)?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Data Final</label>
                    <input type="date" name="endDate" class="form-control" value="@(((DateTime?)ViewBag.EndDate)?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Data/Hora</th>
                            <th>Farmacêutico</th>
                            <th>Tipo</th>
                            <th>Status</th>
                            <th>Receita Válida</th>
                            <th>Dose OK</th>
                            <th>Observações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var a in Model)
                            {
                                <tr>
                                    <td>@a.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@a.PharmacistName</td>
                                    <td>@a.ApprovalType</td>
                                    <td>
                                        @if (a.ApprovalStatus == "APPROVED")
                                        {
                                            <span class="badge bg-success">Aprovado</span>
                                        }
                                        else if (a.ApprovalStatus == "REJECTED")
                                        {
                                            <span class="badge bg-danger">Rejeitado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@a.ApprovalStatus</span>
                                        }
                                    </td>
                                    <td>@(a.PrescriptionValid ? "✓" : "✗")</td>
                                    <td>@(a.DoseWithinLimits ? "✓" : "✗")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(a.RejectionReason))
                                        {
                                            <small class="text-danger">@a.RejectionReason</small>
                                        }
                                        else if (!string.IsNullOrEmpty(a.Observations))
                                        {
                                            <small>@a.Observations</small>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    Nenhuma aprovação encontrada no período
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white">
                <div class="row text-center">
                    <div class="col">
                        <strong>Total:</strong> @Model.Count
                    </div>
                    <div class="col">
                        <strong class="text-success">Aprovados:</strong> @Model.Count(a => a.ApprovalStatus == "APPROVED")
                    </div>
                    <div class="col">
                        <strong class="text-danger">Rejeitados:</strong> @Model.Count(a => a.ApprovalStatus == "REJECTED")
                    </div>
                </div>
            </div>
        }
    </div>
</div>
