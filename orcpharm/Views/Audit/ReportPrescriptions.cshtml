@model List<Models.SpecialPrescriptionControl>
@{
    ViewData["Title"] = "Relatório de Receituários";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <a href="/Audit" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div class="flex-grow-1">
            <h4 class="mb-1">
                <i class="bi bi-file-medical text-primary me-2"></i>Relatório de Receituários
            </h4>
            <p class="text-muted mb-0">Controle de receitas especiais</p>
        </div>
        <button onclick="window.print()" class="btn btn-outline-primary">
            <i class="bi bi-printer me-1"></i>Imprimir
        </button>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Data Inicial</label>
                    <input type="date" name="startDate" class="form-control" value="@(((DateTime?)ViewBag.StartDate)?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Data Final</label>
                    <input type="date" name="endDate" class="form-control" value="@(((DateTime?)ViewBag.EndDate)?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo</label>
                    <select name="type" class="form-select">
                        <option value="">Todos</option>
                        <option value="AZUL">Azul (B)</option>
                        <option value="AMARELA">Amarela (A)</option>
                        <option value="BRANCA">Branca (C)</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th>Nº Receita</th>
                            <th>Paciente</th>
                            <th>Prescritor</th>
                            <th>CRM</th>
                            <th>Medicação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var p in Model)
                            {
                                <tr>
                                    <td>@p.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @(p.PrescriptionType == "AZUL" ? "bg-primary" : p.PrescriptionType == "AMARELA" ? "bg-warning text-dark" : "bg-light text-dark")">
                                            @p.PrescriptionType
                                        </span>
                                    </td>
                                    <td><code>@p.PrescriptionNumber</code></td>
                                    <td>@p.PatientName</td>
                                    <td>@p.DoctorName</td>
                                    <td>@p.DoctorCrm</td>
                                    <td>@p.Medication</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    Nenhuma receita encontrada no período
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-white">
                <strong>Total:</strong> @Model.Count receitas
            </div>
        }
    </div>
</div>
