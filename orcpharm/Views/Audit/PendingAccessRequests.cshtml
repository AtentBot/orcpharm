@model List<Models.Controlled.AuditorAccessRequest>
@{
    ViewData["Title"] = "Solicitações de Acesso Pendentes";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <a href="/Audit" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h4 class="mb-1">
                <i class="bi bi-person-badge text-primary me-2"></i>Solicitações de Acesso Pendentes
            </h4>
            <p class="text-muted mb-0">Auditores aguardando aprovação de acesso</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-x-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var request in Model)
            {
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-warning text-dark">Pendente</span>
                                <small class="text-muted ms-2">@request.RequestedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@request.AuditorName</h5>
                            <p class="card-text">
                                <strong>Instituição:</strong> @request.AuditorInstitution<br>
                                <strong>CPF:</strong> @request.AuditorDocument<br>
                                @if (!string.IsNullOrEmpty(request.AuditorCredential))
                                {
                                    <strong>Credencial:</strong> @request.AuditorCredential<br>
                                }
                            </p>
                            
                            <div class="bg-light p-3 rounded mb-3">
                                <strong>Motivo:</strong><br>
                                <small>@request.AccessReason</small>
                            </div>

                            @if (request.RequestedReports != null && request.RequestedReports.Any())
                            {
                                <div class="mb-3">
                                    <strong>Relatórios solicitados:</strong><br>
                                    @foreach (var report in request.RequestedReports)
                                    {
                                        <span class="badge bg-secondary me-1">@report</span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-white">
                            <form asp-action="ApproveAccess" asp-route-id="@request.Id" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <select name="validityHours" class="form-select form-select-sm" style="width: auto;">
                                    <option value="4">4 horas</option>
                                    <option value="8">8 horas</option>
                                    <option value="24" selected>24 horas</option>
                                    <option value="48">48 horas</option>
                                    <option value="72">72 horas</option>
                                </select>
                                <button type="submit" class="btn btn-success btn-sm flex-grow-1">
                                    <i class="bi bi-check-lg me-1"></i>Aprovar Acesso
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <h5 class="mt-3">Nenhuma solicitação pendente</h5>
                <p class="text-muted">Não há auditores aguardando aprovação de acesso.</p>
                <a href="/Audit" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-1"></i>Voltar ao Portal
                </a>
            </div>
        </div>
    }
</div>
