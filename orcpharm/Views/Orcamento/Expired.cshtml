@model DTOs.Prescriptions.PrescriptionQuoteDto
@{
    Layout = null;
    ViewData["Title"] = "Orçamento expirado";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .expired-container {
            text-align: center;
            padding: 40px;
            max-width: 600px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }
        
        .expired-icon {
            font-size: 80px;
            color: #ffc107;
            margin-bottom: 20px;
        }
        
        .expired-title {
            font-size: 24px;
            font-weight: 600;
            color: #333;
            margin-bottom: 15px;
        }
        
        .expired-message {
            color: #666;
            margin-bottom: 30px;
        }
        
        .quote-info {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            text-align: left;
        }
        
        .pharmacy-contact {
            padding: 20px;
            background: #e8f5e9;
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="expired-container">
        <div class="expired-icon">
            <i class="bi bi-clock-history"></i>
        </div>
        <h1 class="expired-title">Orçamento Expirado</h1>
        <p class="expired-message">
            Este orçamento expirou em @Model.ValidUntil.ToLocalTime().ToString("dd/MM/yyyy 'às' HH:mm").
            <br>
            Para solicitar um novo orçamento, entre em contato com a farmácia.
        </p>
        
        <div class="quote-info">
            <p class="mb-2"><strong>Código:</strong> @Model.Code</p>
            <p class="mb-2"><strong>Valor:</strong> R$ @Model.FinalPrice.ToString("N2")</p>
            <p class="mb-0"><strong>Emitido em:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</p>
        </div>
        
        <div class="pharmacy-contact">
            <h5 class="mb-3">@Model.PharmacyName</h5>
            <p class="mb-2"><i class="bi bi-geo-alt"></i> @Model.PharmacyAddress</p>
            <p class="mb-3"><i class="bi bi-telephone"></i> @Model.PharmacyPhone</p>
            
            <a href="https://wa.me/55@(Model.PharmacyPhone?.Replace("(", "").Replace(")", "").Replace("-", "").Replace(" ", ""))?text=Olá! Gostaria de solicitar um novo orçamento. O anterior (@Model.Code) expirou."
               class="btn btn-success" target="_blank">
                <i class="bi bi-whatsapp"></i> Solicitar Novo Orçamento
            </a>
        </div>
    </div>
</body>
</html>
