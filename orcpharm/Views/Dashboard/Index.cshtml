@* 
    DASHBOARD - Acesso Rápido
    TODOS OS LINKS CORRIGIDOS
*@

<!-- Acesso Rápido -->
<div class="mb-4">
    <h5 class="mb-3">
        <i class="bi bi-lightning-charge me-2"></i>Acesso Rápido
    </h5>
    <div class="row g-3">

        @* ========== LINHA 1: VENDAS E OPERAÇÃO ========== *@

        @* PDV *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/PDV" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-shop fs-2"></i>
                    </div>
                    <h6 class="mb-1">PDV</h6>
                    <small class="opacity-75">Ponto de Venda</small>
                    @if (ViewBag.PedidosProntos > 0)
                    {
                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">
                            @ViewBag.PedidosProntos
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Notas Fiscais *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Fiscal" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-receipt fs-2"></i>
                    </div>
                    <h6 class="mb-1">Notas Fiscais</h6>
                    <small class="opacity-75">NF-e / NFC-e</small>
                    @if (ViewBag.NotasPendentes > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                            @ViewBag.NotasPendentes
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Pedidos Online *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/OnlineOrders/Dashboard" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-bag-check fs-2"></i>
                    </div>
                    <h6 class="mb-1">Pedidos Online</h6>
                    <small class="opacity-75">Gerenciar pedidos</small>
                    @if (ViewBag.PedidosPendentes > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                            @ViewBag.PedidosPendentes
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Caixa *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Caixa" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #f39c12 0%, #d68910 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-cash-stack fs-2"></i>
                    </div>
                    <h6 class="mb-1">Caixa</h6>
                    <small class="opacity-75">Gestão de caixa</small>
                </div>
            </a>
        </div>

        @* ========== LINHA 2: PRODUÇÃO E PRESCRIÇÕES ========== *@

        @* Produção *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Manipulacoes/Workflow" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-gear-wide-connected fs-2"></i>
                    </div>
                    <h6 class="mb-1">Produção</h6>
                    <small class="opacity-75">Workflow de Manipulação</small>
                    @if (Model.TotalAtrasados > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                            @Model.TotalAtrasados
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Prescrições *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/PrescriptionsView" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #1abc9c 0%, #16a085 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-file-earmark-medical fs-2"></i>
                    </div>
                    <h6 class="mb-1">Prescrições</h6>
                    <small class="opacity-75">Gestão de Receitas e OCR</small>
                    @if (Model.PrescriptionsPendentes > 0)
                    {
                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">
                            @Model.PrescriptionsPendentes
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Processar Receita *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/PrescriptionsView/Processar" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #27ae60 0%, #229954 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-upload fs-2"></i>
                    </div>
                    <h6 class="mb-1">Processar Receita</h6>
                    <small class="opacity-75">Upload e OCR de Receitas</small>
                </div>
            </a>
        </div>

        @* Orçamentos *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/PrescriptionQuotes" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-currency-dollar text-success fs-2"></i>
                    </div>
                    <h6 class="mb-1">Orçamentos</h6>
                    <small class="text-muted">Gerenciar orçamentos</small>
                    @if (Model.OrcamentosPendentes > 0)
                    {
                        <span class="badge bg-primary position-absolute top-0 end-0 m-2">
                            @Model.OrcamentosPendentes
                        </span>
                    }
                </div>
            </a>
        </div>

        @* ========== LINHA 3: ESTOQUE E OPERAÇÕES ========== *@

        @* Estoque *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Stock" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-boxes text-info fs-2"></i>
                    </div>
                    <h6 class="mb-1">Estoque</h6>
                    <small class="text-muted">Gerenciar matérias-primas</small>
                    @if (Model.LowStockItems > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                            @Model.LowStockItems
                        </span>
                    }
                </div>
            </a>
        </div>

        @* Nova Compra *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/compras/criar" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-cart-plus text-primary fs-2"></i>
                    </div>
                    <h6 class="mb-1">Nova Compra</h6>
                    <small class="text-muted">Criar pedido de compra</small>
                </div>
            </a>
        </div>

        @* Manipulações *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Manipulacoes" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-list-check text-info fs-2"></i>
                    </div>
                    <h6 class="mb-1">Manipulações</h6>
                    <small class="text-muted">Ordens de manipulação</small>
                </div>
            </a>
        </div>

        @* Rótulos *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Labels" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-tag text-secondary fs-2"></i>
                    </div>
                    <h6 class="mb-1">Rótulos</h6>
                    <small class="text-muted">Etiquetas de produtos</small>
                </div>
            </a>
        </div>

        @* ========== LINHA 4: CADASTROS ========== *@

        @* Clientes *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Customers" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-people text-primary fs-2"></i>
                    </div>
                    <h6 class="mb-1">Clientes</h6>
                    <small class="text-muted">Gestão de clientes</small>
                </div>
            </a>
        </div>

        @if (Model.CanManageEmployees)
        {
            @* Funcionários *@
            <div class="col-6 col-md-4 col-lg-3">
                <a href="/Employees/List" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                    <div class="card-body text-center py-4">
                        <div class="mb-2">
                            <i class="bi bi-person-badge text-danger fs-2"></i>
                        </div>
                        <h6 class="mb-1">Funcionários</h6>
                        <small class="text-muted">Gerenciar equipe</small>
                    </div>
                </a>
            </div>
        }

        @* Fórmulas *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Formulas" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-journal-medical text-success fs-2"></i>
                    </div>
                    <h6 class="mb-1">Fórmulas</h6>
                    <small class="text-muted">Gerenciar fórmulas</small>
                </div>
            </a>
        </div>

        @* Fornecedores *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Suppliers" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-building text-secondary fs-2"></i>
                    </div>
                    <h6 class="mb-1">Fornecedores</h6>
                    <small class="text-muted">Gerenciar fornecedores</small>
                </div>
            </a>
        </div>

        @* ========== LINHA 5: EXTRAS ========== *@

        @* QR Code *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/QRCodes" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card"
               style="background: linear-gradient(135deg, #8e44ad 0%, #9b59b6 100%);">
                <div class="card-body text-center text-white py-4">
                    <div class="mb-2">
                        <i class="bi bi-qr-code fs-2"></i>
                    </div>
                    <h6 class="mb-1">QR Code</h6>
                    <small class="opacity-75">Portal do Cliente</small>
                </div>
            </a>
        </div>

        @* Relatórios *@
        <div class="col-6 col-md-4 col-lg-3">
            <a href="/Reports" class="card h-100 text-decoration-none border-0 shadow-sm quick-access-card">
                <div class="card-body text-center py-4">
                    <div class="mb-2">
                        <i class="bi bi-graph-up text-info fs-2"></i>
                    </div>
                    <h6 class="mb-1">Relatórios</h6>
                    <small class="text-muted">Análises e estatísticas</small>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    .quick-access-card {
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

        .quick-access-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }
</style>
