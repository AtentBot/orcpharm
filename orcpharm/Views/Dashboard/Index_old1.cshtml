@model ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0">Bem-vindo, @Model.Employee.FullName! 👋</h2>
                <p class="text-muted mb-0">@Model.Employee.JobPosition?.Name - @Model.Employee.Establishment?.NomeFantasia</p>
            </div>
            <div>
                <span class="badge bg-success fs-6">
                    <i class="bi bi-clock me-1"></i>
                    @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>
        </div>
    </div>
</div>

@if (Model.CanViewReports)
{
    <!-- Cards de Estatísticas -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Fornecedores</p>
                            <h3 class="mb-0">@Model.TotalSuppliers</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-truck text-primary fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Matérias-Primas</p>
                            <h3 class="mb-0">@Model.TotalRawMaterials</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-boxes text-success fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Estoque Baixo</p>
                            <h3 class="mb-0 @(Model.LowStockItems > 0 ? "text-danger" : "")">@Model.LowStockItems</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-exclamation-triangle @(Model.LowStockItems > 0 ? "text-danger" : "text-warning") fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Card Prescrições -->
        <div class="col-md-3 mb-3">
            <a href="/PrescriptionsView" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Prescrições</p>
                                <h3 class="mb-0 text-primary" id="prescricoesPendentes">-</h3>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded">
                                <i class="bi bi-file-medical text-primary fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Compras Pendentes</p>
                            <h3 class="mb-0">@Model.PendingPurchases</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cart3 text-info fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Cards de Manipulações -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <a href="/Manipulacoes" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Manipulações Pendentes</p>
                                <h3 class="mb-0 text-warning" id="manipPendentes">-</h3>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded">
                                <i class="bi bi-hourglass-split text-warning fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <!-- Card Gestão de Estoque -->
        <div class="col-md-3 mb-3">
            <a href="/Stock" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Gestão de Estoque</p>
                                <h3 class="mb-0 text-info">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </h3>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-box-seam text-info fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/Manipulacoes/Producao" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Em Produção</p>
                                <h3 class="mb-0 text-primary" id="manipProducao">-</h3>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded">
                                <i class="bi bi-gear-wide-connected text-primary fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/Manipulacoes?status=FINALIZADO" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Finalizadas Hoje</p>
                                <h3 class="mb-0 text-success" id="manipFinalizadas">-</h3>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded">
                                <i class="bi bi-check-circle text-success fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/Manipulacoes?status=PESAGEM" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Aguardando Pesagem</p>
                                <h3 class="mb-0 text-info" id="manipPesagem">-</h3>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-calculator text-info fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/Workflow/Kanban" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Workflow Produção</p>
                                <h3 class="mb-0 text-secondary">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </h3>
                            </div>
                            <div class="bg-secondary bg-opacity-10 p-3 rounded">
                                <i class="bi bi-kanban text-secondary fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/Manipulacoes?status=ATRASADO" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Atrasadas</p>
                                <h3 class="mb-0 text-danger" id="manipAtrasadas">-</h3>
                            </div>
                            <div class="bg-danger bg-opacity-10 p-3 rounded">
                                <i class="bi bi-exclamation-octagon text-danger fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Cards de Pedidos Online -->
    <div class="row mb-4">
        <div class="col-12 mb-2">
            <h5 class="text-muted">
                <i class="bi bi-bag-check me-2"></i>Pedidos Online
            </h5>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/OnlineOrders?status=PENDING" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Pedidos Pendentes</p>
                                <h3 class="mb-0 text-warning" id="onlinePendentes">-</h3>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded">
                                <i class="bi bi-clock text-warning fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/OnlineOrders?status=READY" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Prontos p/ Retirada</p>
                                <h3 class="mb-0 text-success" id="onlineProntos">-</h3>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded">
                                <i class="bi bi-check-circle text-success fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/OnlineOrders" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Pedidos Hoje</p>
                                <h3 class="mb-0 text-primary" id="onlineHoje">-</h3>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded">
                                <i class="bi bi-calendar-day text-primary fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-3">
            <a href="/OnlineOrders/Dashboard" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Dashboard Online</p>
                                <h3 class="mb-0 text-info">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </h3>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-graph-up text-info fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Cards de Pagamentos/Financeiro -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <a href="/PDV" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">PDV - Vendas</p>
                                <h3 class="mb-0 text-primary">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </h3>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded">
                                <i class="bi bi-shop text-primary fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/PaymentManagement" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Recebido Hoje</p>
                                <h3 class="mb-0 text-success" id="totalRecebidoHoje">R$ 0,00</h3>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded">
                                <i class="bi bi-cash-stack text-success fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/PaymentManagement/PendingPayments" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Pagamentos Pendentes</p>
                                <h3 class="mb-0 text-warning" id="pagamentosPendentes">0</h3>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded">
                                <i class="bi bi-hourglass-split text-warning fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/PaymentManagement/DailyReport" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Relatório do Dia</p>
                                <h3 class="mb-0 text-info">
                                    <i class="bi bi-arrow-right-circle"></i>
                                </h3>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-file-earmark-bar-graph text-info fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Cards de Rótulos -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <a href="/Labels/History" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Rótulos Hoje</p>
                                <h3 class="mb-0 text-success" id="rotulosHoje">-</h3>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded">
                                <i class="bi bi-file-earmark-text text-success fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/Labels/History?status=PENDENTE" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Pendentes Impressão</p>
                                <h3 class="mb-0 text-warning" id="rotulosPendentes">-</h3>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded">
                                <i class="bi bi-printer text-warning fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/Labels/History?isControlled=true" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Controlados</p>
                                <h3 class="mb-0 text-danger" id="rotulosControlados">-</h3>
                            </div>
                            <div class="bg-danger bg-opacity-10 p-3 rounded">
                                <i class="bi bi-shield-exclamation text-danger fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-3 mb-3">
            <a href="/Labels" class="text-decoration-none">
                <div class="card border-0 shadow-sm hover-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 small">Templates</p>
                                <h3 class="mb-0 text-info" id="totalTemplates">-</h3>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded">
                                <i class="bi bi-layout-text-window text-info fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- ========== NOVA SEÇÃO: Cards de Equipe & Administração ========== -->
    @if (Model.CanManageEmployees)
    {
        <div class="row mb-4">
            <div class="col-12 mb-2">
                <h5 class="text-muted">
                    <i class="bi bi-people me-2"></i>Equipe & Administração
                </h5>
            </div>
            
            <div class="col-md-3 mb-3">
                <a href="/Employees/List" class="text-decoration-none">
                    <div class="card border-0 shadow-sm hover-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Funcionários Ativos</p>
                                    <h3 class="mb-0 text-primary">@Model.TotalEmployeesActive</h3>
                                </div>
                                <div class="bg-primary bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-people-fill text-primary fs-3"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3 mb-3">
                <a href="/Employees/List?status=inactive" class="text-decoration-none">
                    <div class="card border-0 shadow-sm hover-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Funcionários Inativos</p>
                                    <h3 class="mb-0 @(Model.TotalEmployeesInactive > 0 ? "text-warning" : "text-muted")">@Model.TotalEmployeesInactive</h3>
                                </div>
                                <div class="bg-warning bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-person-dash text-warning fs-3"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3 mb-3">
                <a href="/Employees/Create" class="text-decoration-none">
                    <div class="card border-0 shadow-sm hover-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Novo Funcionário</p>
                                    <h3 class="mb-0 text-success">
                                        <i class="bi bi-plus-circle"></i>
                                    </h3>
                                </div>
                                <div class="bg-success bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-person-plus text-success fs-3"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-3 mb-3">
                <a href="/Employees/List" class="text-decoration-none">
                    <div class="card border-0 shadow-sm hover-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted mb-1 small">Gerenciar Equipe</p>
                                    <h3 class="mb-0 text-info">
                                        <i class="bi bi-arrow-right-circle"></i>
                                    </h3>
                                </div>
                                <div class="bg-info bg-opacity-10 p-3 rounded">
                                    <i class="bi bi-gear text-info fs-3"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }
}

<!-- Acesso Rápido -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-lightning-charge me-2"></i>
                    Acesso Rápido
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @* ========== PRODUÇÃO - DESTAQUE ========== *@
                    @if (Model.CanManageFormulas)
                    {
                        <div class="col-md-3 mb-3">
                            <a href="/Manipulacoes/Producao" class="text-decoration-none">
                                <div class="card h-100 border-0 bg-gradient-primary hover-card production-card">
                                    <div class="card-body text-center text-white">
                                        <i class="bi bi-gear-wide-connected fs-1 mb-3"></i>
                                        <h6 class="card-title">Produção</h6>
                                        <p class="card-text small opacity-75">Workflow de Manipulação</p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        @* ========== PRESCRIÇÕES - DESTAQUE ========== *@
                        <div class="col-md-3 mb-3">
                            <a href="/PrescriptionsView" class="text-decoration-none">
                                <div class="card h-100 border-0 bg-gradient-info hover-card">
                                    <div class="card-body text-center text-white">
                                        <i class="bi bi-file-medical fs-1 mb-3"></i>
                                        <h6 class="card-title">Prescrições</h6>
                                        <p class="card-text small opacity-75">Gestão de Receitas e OCR</p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        @* ========== PROCESSAR RECEITA OCR - DESTAQUE ========== *@
                        <div class="col-md-3 mb-3">
                            <a href="/PrescriptionsView/OcrUpload" class="text-decoration-none">
                                <div class="card h-100 border-0 bg-gradient-success hover-card">
                                    <div class="card-body text-center text-white">
                                        <i class="bi bi-camera fs-1 mb-3"></i>
                                        <h6 class="card-title">Processar Receita</h6>
                                        <p class="card-text small opacity-75">Upload e OCR de Receitas</p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        @* ========== ORÇAMENTOS ========== *@
                        <div class="col-md-3 mb-3">
                            <a href="/Orcamentos" class="text-decoration-none">
                                <div class="card h-100 border-0 bg-light hover-card">
                                    <div class="card-body text-center">
                                        <i class="bi bi-cash-coin text-success fs-1 mb-3"></i>
                                        <h6 class="card-title">Orçamentos</h6>
