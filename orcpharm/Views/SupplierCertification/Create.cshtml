@model SupplierCertificateForm
@{
    ViewData["Title"] = "Nova Certificação AFE";
    var suppliers = ViewBag.Suppliers as List<Models.Pharmacy.Supplier>;
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="d-flex align-items-center mb-4">
                <a href="/SupplierCertification" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-plus-circle text-primary me-2"></i>Nova Certificação AFE
                    </h4>
                    <p class="text-muted mb-0">Cadastrar certificado de fornecedor</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="CreateSubmit" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Fornecedor -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Fornecedor <span class="text-danger">*</span></label>
                            <select name="SupplierId" class="form-select" required>
                                <option value="">Selecione o fornecedor...</option>
                                @if (suppliers != null)
                                {
                                    foreach (var supplier in suppliers)
                                    {
                                        <option value="@supplier.Id">
                                            @supplier.CompanyName
                                            @if (!string.IsNullOrEmpty(supplier.TradeName))
                                            {
                                                @:(@supplier.TradeName)
                                            }
                                            - CNPJ: @supplier.Cnpj
                                        </option>
                                    }
                                }
                            </select>
                            <div class="form-text">Apenas fornecedores ativos são listados</div>
                        </div>

                        <hr class="my-4">

                        <!-- Dados do Certificado -->
                        <h6 class="text-uppercase text-muted mb-3">Dados do Certificado</h6>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Tipo de Certificado <span class="text-danger">*</span></label>
                                <select name="CertificateType" class="form-select" required>
                                    <option value="AFE">AFE - Autorização de Funcionamento</option>
                                    <option value="AE">AE - Autorização Especial</option>
                                    <option value="CBPF">CBPF - Certificado de Boas Práticas</option>
                                    <option value="ISO">ISO - Certificação ISO</option>
                                    <option value="GMP">GMP - Boas Práticas de Fabricação</option>
                                    <option value="OUTRO">Outro</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nome do Certificado</label>
                                <input type="text" name="Name" class="form-control" placeholder="Ex: Autorização de Funcionamento">
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label">Número <span class="text-danger">*</span></label>
                                <input type="text" name="Number" class="form-control" placeholder="Ex: 1.02.789-0" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Órgão Emissor</label>
                                <input type="text" name="IssuingAuthority" class="form-control" value="ANVISA" placeholder="Ex: ANVISA">
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label">Data de Emissão</label>
                                <input type="date" name="IssueDate" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Data de Validade <span class="text-danger">*</span></label>
                                <input type="date" name="ExpiryDate" class="form-control" required>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label">Observações</label>
                            <textarea name="Notes" class="form-control" rows="3" placeholder="Informações adicionais sobre o certificado..."></textarea>
                        </div>

                        <!-- Alerta ANVISA -->
                        <div class="alert alert-info mt-4">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Verificação:</strong> Confirme os dados do certificado no portal da ANVISA:
                            <a href="https://consultas.anvisa.gov.br/" target="_blank" class="alert-link">consultas.anvisa.gov.br</a>
                        </div>

                        <!-- Botões -->
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="/SupplierCertification" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Cadastrar Certificação
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
