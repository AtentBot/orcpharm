@model List<Models.Pharmacy.SupplierCertificate>
@{
    ViewData["Title"] = "Certificados Vencendo";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <a href="/SupplierCertification" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h4 class="mb-1">
                <i class="bi bi-exclamation-triangle text-warning me-2"></i>Certificados Vencendo
            </h4>
            <p class="text-muted mb-0">Certificados que vencem nos próximos 60 dias</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fornecedor</th>
                                <th>Certificado</th>
                                <th>Número</th>
                                <th>Validade</th>
                                <th>Status</th>
                                <th class="text-end">Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cert in Model)
                            {
                                var isExpired = cert.ExpiryDate.HasValue && cert.ExpiryDate.Value < DateTime.UtcNow;
                                <tr class="@(isExpired ? "table-danger" : "table-warning")">
                                    <td>
                                        <strong>@cert.Supplier?.CompanyName</strong>
                                    </td>
                                    <td>@cert.CertificateType</td>
                                    <td><code>@cert.Number</code></td>
                                    <td>
                                        <strong class="@(isExpired ? "text-danger" : "text-warning")">
                                            @cert.ExpiryDate?.ToString("dd/MM/yyyy")
                                        </strong>
                                        <br>
                                        <small>
                                            @if (isExpired)
                                            {
                                                <span class="text-danger">Vencido há @Math.Abs(cert.DaysUntilExpiry ?? 0) dias</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning">@cert.DaysUntilExpiry dias restantes</span>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        @if (isExpired)
                                        {
                                            <span class="badge bg-danger">VENCIDO</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">VENCENDO</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a href="/SupplierCertification/Renew/@cert.Id" class="btn btn-success btn-sm">
                                            <i class="bi bi-arrow-repeat me-1"></i>Renovar
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-check-circle text-success fs-1 d-block mb-3"></i>
                <h5>Nenhum certificado vencendo</h5>
                <p class="text-muted">Todos os certificados estão com validade superior a 60 dias.</p>
            </div>
        </div>
    }
</div>
