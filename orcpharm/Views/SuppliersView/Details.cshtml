@{
    ViewData["Title"] = "Detalhes do Fornecedor";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1" id="supplierName">Carregando...</h2>
            <p class="text-muted mb-0" id="supplierCnpj">-</p>
        </div>
        <div>
            <button type="button" class="btn btn-outline-secondary me-2" onclick="window.history.back()">
                <i class="bi bi-arrow-left"></i> Voltar
            </button>
            <button type="button" class="btn btn-primary" onclick="editSupplier()">
                <i class="bi bi-pencil"></i> Editar
            </button>
        </div>
    </div>

    <div id="loadingState" class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>

    <div id="supplierContent" style="display: none;">
        <!-- Status Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Status</h6>
                        <h4 class="mb-0"><span class="badge" id="badgeStatus">-</span></h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Classificação</h6>
                        <h4 class="mb-0"><span class="badge" id="badgeClassification">-</span></h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Avaliação</h6>
                        <h4 class="mb-0" id="supplierRating">-</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Total de Pedidos</h6>
                        <h4 class="mb-0" id="supplierOrders">-</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- Badges -->
        <div class="mb-4" id="supplierBadges"></div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-3" id="supplierTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button">
                    <i class="bi bi-info-circle"></i> Informações
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="contacts-tab" data-bs-toggle="tab" data-bs-target="#contacts" type="button">
                    <i class="bi bi-people"></i> Contatos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="certificates-tab" data-bs-toggle="tab" data-bs-target="#certificates" type="button">
                    <i class="bi bi-file-earmark-check"></i> Certificados
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="evaluations-tab" data-bs-toggle="tab" data-bs-target="#evaluations" type="button">
                    <i class="bi bi-star"></i> Avaliações
                </button>
            </li>
        </ul>

        <div class="tab-content" id="supplierTabContent">
            <!-- Tab Informações -->
            <div class="tab-pane fade show active" id="info" role="tabpanel">
                <div class="row g-3">
                    <!-- Dados Básicos -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="bi bi-building"></i> Dados Básicos</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-12">
                                        <small class="text-muted">Razão Social</small>
                                        <div id="infoCompanyName">-</div>
                                    </div>
                                    <div class="col-12">
                                        <small class="text-muted">Nome Fantasia</small>
                                        <div id="infoTradeName">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">CNPJ</small>
                                        <div id="infoCnpj">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">I.E.</small>
                                        <div id="infoStateRegistration">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Endereço -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-secondary text-white">
                                <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Endereço</h5>
                            </div>
                            <div class="card-body">
                                <div id="infoAddress">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Contato -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="bi bi-telephone"></i> Contato</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <small class="text-muted">Telefone</small>
                                        <div id="infoPhone">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">WhatsApp</small>
                                        <div id="infoWhatsApp">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">E-mail</small>
                                        <div id="infoEmail">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Website</small>
                                        <div id="infoWebsite">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dados Comerciais -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="bi bi-cash-stack"></i> Dados Comerciais</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <small class="text-muted">Prazo de Entrega</small>
                                        <div id="infoDeliveryTime">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Prazo de Pagamento</small>
                                        <div id="infoPaymentTerm">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Pedido Mínimo</small>
                                        <div id="infoMinOrder">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Produtos</small>
                                        <div id="infoProductTypes">-</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- AFE -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-danger text-white">
                                <h5 class="mb-0"><i class="bi bi-shield-check"></i> AFE</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <small class="text-muted">Número</small>
                                        <div id="infoAfeNumber">-</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Validade</small>
                                        <div id="infoAfeExpiry">-</div>
                                    </div>
                                    <div class="col-12">
                                        <div id="infoAfeStatus"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Observações -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="bi bi-journal-text"></i> Observações</h5>
                            </div>
                            <div class="card-body">
                                <div id="infoNotes">-</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Contatos -->
            <div class="tab-pane fade" id="contacts" role="tabpanel">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Contatos do Fornecedor</h5>
                            <button type="button" class="btn btn-primary btn-sm" onclick="addContact()">
                                <i class="bi bi-plus-lg"></i> Novo Contato
                            </button>
                        </div>
                        <div id="contactsList">
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1"></i>
                                <p class="mt-2">Nenhum contato cadastrado</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Certificados -->
            <div class="tab-pane fade" id="certificates" role="tabpanel">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Certificados e Documentos</h5>
                            <button type="button" class="btn btn-primary btn-sm" onclick="addCertificate()">
                                <i class="bi bi-plus-lg"></i> Novo Certificado
                            </button>
                        </div>
                        <div id="certificatesList">
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1"></i>
                                <p class="mt-2">Nenhum certificado cadastrado</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Avaliações -->
            <div class="tab-pane fade" id="evaluations" role="tabpanel">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Avaliações de Desempenho</h5>
                            <button type="button" class="btn btn-primary btn-sm" onclick="addEvaluation()">
                                <i class="bi bi-plus-lg"></i> Nova Avaliação
                            </button>
                        </div>
                        <div id="evaluationsList">
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1"></i>
                                <p class="mt-2">Nenhuma avaliação registrada</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let supplierId;
    let supplierData;

    document.addEventListener('DOMContentLoaded', function() {
        const pathParts = window.location.pathname.split('/');
        supplierId = pathParts[pathParts.length - 1];
        
        loadSupplier();
    });

    async function loadSupplier() {
        try {
            const response = await fetch(`/api/suppliers/${supplierId}`, {
                credentials: 'include'
            });

            if (!response.ok) throw new Error('Erro ao carregar fornecedor');

            supplierData = await response.json();
            
            renderSupplierInfo();
            renderContacts();
            renderCertificates();
            renderEvaluations();
            
            document.getElementById('loadingState').style.display = 'none';
            document.getElementById('supplierContent').style.display = 'block';
            
        } catch (error) {
            console.error('Erro:', error);
            showAlert('Erro ao carregar dados do fornecedor', 'danger');
        }
    }

    function renderSupplierInfo() {
        const s = supplierData;
        
        // Header
        document.getElementById('supplierName').textContent = s.companyName;
        document.getElementById('supplierCnpj').textContent = formatCnpj(s.cnpj);
        
        // Status cards
        document.getElementById('badgeStatus').className = `badge ${getStatusBadge(s.status)}`;
        document.getElementById('badgeStatus').textContent = s.status;
        
        document.getElementById('badgeClassification').className = s.classification 
            ? `badge ${getClassificationBadge(s.classification)}` 
            : 'badge bg-secondary';
        document.getElementById('badgeClassification').textContent = s.classification || 'N/A';
        
        document.getElementById('supplierRating').innerHTML = s.rating 
            ? `<i class="bi bi-star-fill text-warning"></i> ${s.rating.toFixed(1)}` 
            : '-';
        
        document.getElementById('supplierOrders').textContent = s.statistics.totalOrders || 0;
        
        // Badges
        const badges = [];
        if (s.isQualified) badges.push('<span class="badge bg-success me-2"><i class="bi bi-patch-check"></i> Qualificado</span>');
        if (s.isPreferred) badges.push('<span class="badge bg-warning me-2"><i class="bi bi-star-fill"></i> Preferencial</span>');
        if (s.certifications.hasGmpCertificate) badges.push('<span class="badge bg-info me-2">BPF/GMP</span>');
        if (s.certifications.hasIsoCertificate) badges.push('<span class="badge bg-info me-2">ISO</span>');
        if (s.certifications.hasAnvisaAuthorization) badges.push('<span class="badge bg-info me-2">ANVISA</span>');
        if (s.products.suppliesControlled) badges.push('<span class="badge bg-danger me-2">Controlados</span>');
        if (s.products.suppliesAntibiotics) badges.push('<span class="badge bg-warning me-2">Antibióticos</span>');
        
        document.getElementById('supplierBadges').innerHTML = badges.join('');
        
        // Dados básicos
        document.getElementById('infoCompanyName').textContent = s.companyName;
        document.getElementById('infoTradeName').textContent = s.tradeName || '-';
        document.getElementById('infoCnpj').textContent = formatCnpj(s.cnpj);
        document.getElementById('infoStateRegistration').textContent = s.stateRegistration || '-';
        
        // Endereço
        const address = [];
        if (s.address.street) address.push(s.address.street);
        if (s.address.number) address.push(`nº ${s.address.number}`);
        if (s.address.complement) address.push(s.address.complement);
        if (s.address.neighborhood) address.push(`<br>${s.address.neighborhood}`);
        if (s.address.city) address.push(`<br>${s.address.city}/${s.address.state}`);
        if (s.address.postalCode) address.push(`<br>CEP: ${formatPostalCode(s.address.postalCode)}`);
        
        document.getElementById('infoAddress').innerHTML = address.length > 0 ? address.join(' ') : '-';
        
        // Contato
        document.getElementById('infoPhone').textContent = s.contact.phone ? formatPhone(s.contact.phone) : '-';
        document.getElementById('infoWhatsApp').textContent = s.contact.whatsApp ? formatPhone(s.contact.whatsApp) : '-';
        document.getElementById('infoEmail').innerHTML = s.contact.email ? `<a href="mailto:${s.contact.email}">${s.contact.email}</a>` : '-';
        document.getElementById('infoWebsite').innerHTML = s.contact.website ? `<a href="${s.contact.website}" target="_blank">${s.contact.website}</a>` : '-';
        
        // Dados comerciais
        document.getElementById('infoDeliveryTime').textContent = s.averageDeliveryTime ? `${s.averageDeliveryTime} dias` : '-';
        document.getElementById('infoPaymentTerm').textContent = s.paymentTermDays ? `${s.paymentTermDays} dias` : '-';
        document.getElementById('infoMinOrder').textContent = s.minimumOrderValue ? `R$ ${s.minimumOrderValue.toFixed(2)}` : '-';
        document.getElementById('infoProductTypes').textContent = s.productTypes || '-';
        
        // AFE
        document.getElementById('infoAfeNumber').textContent = s.afe.afeNumber || '-';
        if (s.afe.afeExpiryDate) {
            const expiryDate = new Date(s.afe.afeExpiryDate);
            document.getElementById('infoAfeExpiry').textContent = expiryDate.toLocaleDateString('pt-BR');
            
            const statusClass = s.afe.status === 'Válida' ? 'success' : (s.afe.status === 'Vencendo' ? 'warning' : 'danger');
            document.getElementById('infoAfeStatus').innerHTML = `<span class="badge bg-${statusClass}">${s.afe.status}</span>`;
            
            if (s.afe.daysUntilExpiry !== null) {
                document.getElementById('infoAfeStatus').innerHTML += ` <small class="text-muted">(${s.afe.daysUntilExpiry} dias)</small>`;
            }
        } else {
            document.getElementById('infoAfeExpiry').textContent = '-';
            document.getElementById('infoAfeStatus').innerHTML = '';
        }
        
        // Observações
        document.getElementById('infoNotes').textContent = s.notes || '-';
    }

    function renderContacts() {
        const contacts = supplierData.contacts || [];
        const container = document.getElementById('contactsList');
        
        if (contacts.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">Nenhum contato cadastrado</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = `
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Cargo</th>
                            <th>Departamento</th>
                            <th>E-mail</th>
                            <th>Telefone</th>
                            <th>Tipo</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${contacts.map(c => `
                            <tr>
                                <td>${escapeHtml(c.fullName)}</td>
                                <td>${c.jobTitle || '-'}</td>
                                <td>${c.department || '-'}</td>
                                <td>${c.email ? `<a href="mailto:${c.email}">${c.email}</a>` : '-'}</td>
                                <td>${c.phone ? formatPhone(c.phone) : (c.mobile ? formatPhone(c.mobile) : '-')}</td>
                                <td>
                                    ${c.isPrimary ? '<span class="badge bg-primary">Principal</span>' : ''}
                                    ${c.isEmergencyContact ? '<span class="badge bg-danger">Emergência</span>' : ''}
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            </div>
        `;
    }

    function renderCertificates() {
        const certificates = supplierData.certificates || [];
        const container = document.getElementById('certificatesList');
        
        if (certificates.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">Nenhum certificado cadastrado</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = `
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Nome</th>
                            <th>Número</th>
                            <th>Órgão Emissor</th>
                            <th>Emissão</th>
                            <th>Validade</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${certificates.map(c => {
                            const issueDate = c.issueDate ? new Date(c.issueDate).toLocaleDateString('pt-BR') : '-';
                            const expiryDate = c.expiryDate ? new Date(c.expiryDate).toLocaleDateString('pt-BR') : '-';
                            const isValid = c.isValid;
                            const isExpiringSoon = c.isExpiringSoon;
                            
                            return `
                                <tr>
                                    <td>${escapeHtml(c.certificateType)}</td>
                                    <td>${escapeHtml(c.name)}</td>
                                    <td>${c.number || '-'}</td>
                                    <td>${c.issuingAuthority || '-'}</td>
                                    <td>${issueDate}</td>
                                    <td>${expiryDate}</td>
                                    <td>
                                        <span class="badge ${isValid ? (isExpiringSoon ? 'bg-warning' : 'bg-success') : 'bg-danger'}">
                                            ${isValid ? (isExpiringSoon ? 'Vencendo' : 'Válido') : 'Vencido'}
                                        </span>
                                    </td>
                                </tr>
                            `;
                        }).join('')}
                    </tbody>
                </table>
            </div>
        `;
    }

    function renderEvaluations() {
        const evaluations = supplierData.evaluations || [];
        const container = document.getElementById('evaluationsList');
        
        if (evaluations.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">Nenhuma avaliação registrada</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = evaluations.map(e => {
            const evalDate = new Date(e.evaluationDate).toLocaleDateString('pt-BR');
            const classificationBadge = e.classification ? `<span class="badge ${getClassificationBadge(e.classification)}">${e.classification}</span>` : '';
            
            return `
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h5 class="mb-1">${e.period || 'Avaliação'}</h5>
                                <small class="text-muted">${evalDate}</small>
                            </div>
                            <div>
                                ${classificationBadge}
                                <span class="badge bg-primary ms-2">
                                    <i class="bi bi-star-fill"></i> ${e.overallScore.toFixed(1)}
                                </span>
                            </div>
                        </div>
                        
                        <div class="row g-3 mb-3">
                            ${e.qualityScore ? `<div class="col-md-2"><small class="text-muted">Qualidade</small><br><strong>${e.qualityScore.toFixed(1)}</strong></div>` : ''}
                            ${e.deliveryScore ? `<div class="col-md-2"><small class="text-muted">Entrega</small><br><strong>${e.deliveryScore.toFixed(1)}</strong></div>` : ''}
                            ${e.priceScore ? `<div class="col-md-2"><small class="text-muted">Preço</small><br><strong>${e.priceScore.toFixed(1)}</strong></div>` : ''}
                            ${e.serviceScore ? `<div class="col-md-2"><small class="text-muted">Atendimento</small><br><strong>${e.serviceScore.toFixed(1)}</strong></div>` : ''}
                            ${e.documentationScore ? `<div class="col-md-2"><small class="text-muted">Documentação</small><br><strong>${e.documentationScore.toFixed(1)}</strong></div>` : ''}
                            ${e.complianceScore ? `<div class="col-md-2"><small class="text-muted">Conformidade</small><br><strong>${e.complianceScore.toFixed(1)}</strong></div>` : ''}
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-md-3">
                                <small class="text-muted">Pedidos no Período</small><br>
                                <strong>${e.totalOrders}</strong>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted">Entregas no Prazo</small><br>
                                <strong>${e.onTimeDeliveries}</strong>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted">Não Conformidades</small><br>
                                <strong class="text-danger">${e.nonConformities}</strong>
                            </div>
                            <div class="col-md-3">
                                <small class="text-muted">Devoluções</small><br>
                                <strong class="text-warning">${e.returns}</strong>
                            </div>
                        </div>
                        
                        ${e.comments ? `<div class="mt-3"><small class="text-muted">Comentários:</small><br>${escapeHtml(e.comments)}</div>` : ''}
                    </div>
                </div>
            `;
        }).join('');
    }

    function editSupplier() {
        window.location.href = `/suppliers/edit/${supplierId}`;
    }

    function addContact() {
        showAlert('Funcionalidade em desenvolvimento', 'info');
    }

    function addCertificate() {
        showAlert('Funcionalidade em desenvolvimento', 'info');
    }

    function addEvaluation() {
        showAlert('Funcionalidade em desenvolvimento', 'info');
    }

    function getStatusBadge(status) {
        const badges = {
            'Ativo': 'bg-success',
            'Inativo': 'bg-secondary',
            'Bloqueado': 'bg-danger',
            'Em Avaliação': 'bg-warning'
        };
        return badges[status] || 'bg-secondary';
    }

    function getClassificationBadge(classification) {
        const badges = {
            'A': 'bg-success',
            'B': 'bg-info',
            'C': 'bg-warning',
            'D': 'bg-danger'
        };
        return badges[classification] || 'bg-secondary';
    }

    function formatCnpj(cnpj) {
        if (!cnpj) return '-';
        return cnpj.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
    }

    function formatPostalCode(code) {
        if (!code) return '';
        return code.replace(/^(\d{5})(\d{3})$/, '$1-$2');
    }

    function formatPhone(phone) {
        if (!phone) return '-';
        if (phone.length === 11) {
            return phone.replace(/^(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3');
        } else if (phone.length === 10) {
            return phone.replace(/^(\d{2})(\d{4})(\d{4})$/, '($1) $2-$3');
        }
        return phone;
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function showAlert(message, type = 'info') {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
        alertDiv.style.zIndex = '9999';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        
        setTimeout(() => {
            alertDiv.remove();
        }, 5000);
    }
</script>
}
