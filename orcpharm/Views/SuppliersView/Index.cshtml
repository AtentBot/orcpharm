@{
    ViewData["Title"] = "Fornecedores";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Fornecedores</h2>
            <p class="text-muted mb-0">Gerenciamento de fornecedores e matérias-primas</p>
        </div>
        <button type="button" class="btn btn-primary" onclick="createSupplier()">
            <i class="bi bi-plus-lg"></i> Novo Fornecedor
        </button>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Buscar</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Nome, CNPJ...">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">Todos</option>
                        <option value="Ativo">Ativo</option>
                        <option value="Inativo">Inativo</option>
                        <option value="Bloqueado">Bloqueado</option>
                        <option value="Em Avaliação">Em Avaliação</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Classificação</label>
                    <select class="form-select" id="classificationFilter">
                        <option value="">Todas</option>
                        <option value="A">A - Excelente</option>
                        <option value="B">B - Bom</option>
                        <option value="C">C - Regular</option>
                        <option value="D">D - Crítico</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Qualificado</label>
                    <select class="form-select" id="qualifiedFilter">
                        <option value="">Todos</option>
                        <option value="true">Sim</option>
                        <option value="false">Não</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">AFE Vencendo</label>
                    <select class="form-select" id="afeFilter">
                        <option value="">Todos</option>
                        <option value="true">Sim</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="button" class="btn btn-secondary w-100" onclick="clearFilters()">
                        <i class="bi bi-x-circle"></i> Limpar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Estatísticas -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Fornecedores</h6>
                            <h3 class="mb-0" id="statTotal">-</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded p-3">
                            <i class="bi bi-building fs-4 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Qualificados</h6>
                            <h3 class="mb-0" id="statQualified">-</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <i class="bi bi-patch-check fs-4 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Preferenciais</h6>
                            <h3 class="mb-0" id="statPreferred">-</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded p-3">
                            <i class="bi bi-star-fill fs-4 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">AFE Vencendo</h6>
                            <h3 class="mb-0" id="statAfeExpiring">-</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded p-3">
                            <i class="bi bi-exclamation-triangle fs-4 text-danger"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="suppliersTable">
                    <thead>
                        <tr>
                            <th>Razão Social</th>
                            <th>CNPJ</th>
                            <th>Cidade/UF</th>
                            <th>Status</th>
                            <th>Classif.</th>
                            <th>Avaliação</th>
                            <th>Contatos</th>
                            <th>Certificados</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody id="suppliersTableBody">
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Carregando...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Paginação -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted" id="paginationInfo">-</div>
                <nav>
                    <ul class="pagination mb-0" id="pagination"></ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentPage = 1;
    let currentFilters = {};

    document.addEventListener('DOMContentLoaded', function() {
        loadSuppliers();
        loadStatistics();
        
        // Filtros
        document.getElementById('searchInput').addEventListener('input', debounce(() => {
            currentPage = 1;
            loadSuppliers();
        }, 500));
        
        document.getElementById('statusFilter').addEventListener('change', () => {
            currentPage = 1;
            loadSuppliers();
        });
        
        document.getElementById('classificationFilter').addEventListener('change', () => {
            currentPage = 1;
            loadSuppliers();
        });
        
        document.getElementById('qualifiedFilter').addEventListener('change', () => {
            currentPage = 1;
            loadSuppliers();
        });
        
        document.getElementById('afeFilter').addEventListener('change', () => {
            currentPage = 1;
            loadSuppliers();
        });
    });

    async function loadSuppliers() {
        const search = document.getElementById('searchInput').value;
        const status = document.getElementById('statusFilter').value;
        const classification = document.getElementById('classificationFilter').value;
        const qualified = document.getElementById('qualifiedFilter').value;
        const afeExpiring = document.getElementById('afeFilter').value;

        const params = new URLSearchParams({
            page: currentPage,
            pageSize: 50
        });

        if (search) params.append('search', search);
        if (status) params.append('status', status);
        if (classification) params.append('classification', classification);
        if (qualified) params.append('isQualified', qualified);
        if (afeExpiring) params.append('afeExpiring', afeExpiring);

        try {
            const response = await fetch(`/api/suppliers?${params}`, {
                credentials: 'include'
            });

            if (!response.ok) throw new Error('Erro ao carregar fornecedores');

            const result = await response.json();
            renderSuppliers(result.data);
            renderPagination(result.pagination);
        } catch (error) {
            console.error('Erro:', error);
            showAlert('Erro ao carregar fornecedores', 'danger');
        }
    }

    async function loadStatistics() {
        try {
            const response = await fetch('/api/suppliers?pageSize=1000', {
                credentials: 'include'
            });

            if (!response.ok) return;

            const result = await response.json();
            const suppliers = result.data;

            document.getElementById('statTotal').textContent = suppliers.length;
            document.getElementById('statQualified').textContent = suppliers.filter(s => s.isQualified).length;
            document.getElementById('statPreferred').textContent = suppliers.filter(s => s.isPreferred).length;
            
            // AFE Expiring
            const afeExpiring = suppliers.filter(s => {
                if (!s.afeExpiryDate) return false;
                const expiryDate = new Date(s.afeExpiryDate);
                const now = new Date();
                const daysUntil = Math.floor((expiryDate - now) / (1000 * 60 * 60 * 24));
                return daysUntil > 0 && daysUntil <= 30;
            }).length;
            
            document.getElementById('statAfeExpiring').textContent = afeExpiring;
        } catch (error) {
            console.error('Erro ao carregar estatísticas:', error);
        }
    }

    function renderSuppliers(suppliers) {
        const tbody = document.getElementById('suppliersTableBody');
        
        if (suppliers.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="9" class="text-center py-5">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="text-muted mt-2 mb-0">Nenhum fornecedor encontrado</p>
                    </td>
                </tr>
            `;
            return;
        }

        tbody.innerHTML = suppliers.map(s => `
            <tr>
                <td>
                    <div class="d-flex align-items-center">
                        ${s.isPreferred ? '<i class="bi bi-star-fill text-warning me-2" title="Preferencial"></i>' : ''}
                        <div>
                            <div class="fw-semibold">${escapeHtml(s.companyName)}</div>
                            ${s.tradeName ? `<small class="text-muted">${escapeHtml(s.tradeName)}</small>` : ''}
                        </div>
                    </div>
                </td>
                <td>${formatCnpj(s.cnpj)}</td>
                <td>
                    ${s.city ? `${escapeHtml(s.city)}` : ''}
                    ${s.state ? `/${s.state}` : '-'}
                </td>
                <td><span class="badge ${getStatusBadge(s.status)}">${s.status}</span></td>
                <td>
                    ${s.classification ? `<span class="badge ${getClassificationBadge(s.classification)}">${s.classification}</span>` : '-'}
                </td>
                <td>
                    ${s.rating ? `
                        <div class="d-flex align-items-center">
                            <i class="bi bi-star-fill text-warning me-1"></i>
                            <span>${s.rating.toFixed(1)}</span>
                        </div>
                    ` : '-'}
                </td>
                <td class="text-center">
                    <span class="badge bg-info">${s.contactsCount || 0}</span>
                </td>
                <td class="text-center">
                    <span class="badge bg-success">${s.certificatesCount || 0}</span>
                </td>
                <td>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn btn-outline-primary" onclick="viewSupplier('${s.id}')" title="Visualizar">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="editSupplier('${s.id}')" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button type="button" class="btn btn-outline-danger" onclick="deleteSupplier('${s.id}', '${escapeHtml(s.companyName)}')" title="Inativar">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function renderPagination(pagination) {
        const info = document.getElementById('paginationInfo');
        const paginationEl = document.getElementById('pagination');

        const start = (pagination.currentPage - 1) * pagination.pageSize + 1;
        const end = Math.min(pagination.currentPage * pagination.pageSize, pagination.totalRecords);
        
        info.textContent = `Mostrando ${start} a ${end} de ${pagination.totalRecords} registros`;

        if (pagination.totalPages <= 1) {
            paginationEl.innerHTML = '';
            return;
        }

        let pages = [];
        
        pages.push(`
            <li class="page-item ${pagination.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${pagination.currentPage - 1}); return false;">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        `);

        for (let i = 1; i <= pagination.totalPages; i++) {
            if (i === 1 || i === pagination.totalPages || (i >= pagination.currentPage - 2 && i <= pagination.currentPage + 2)) {
                pages.push(`
                    <li class="page-item ${i === pagination.currentPage ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                    </li>
                `);
            } else if (i === pagination.currentPage - 3 || i === pagination.currentPage + 3) {
                pages.push(`<li class="page-item disabled"><span class="page-link">...</span></li>`);
            }
        }

        pages.push(`
            <li class="page-item ${pagination.currentPage === pagination.totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${pagination.currentPage + 1}); return false;">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        `);

        paginationEl.innerHTML = pages.join('');
    }

    function changePage(page) {
        currentPage = page;
        loadSuppliers();
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = '';
        document.getElementById('classificationFilter').value = '';
        document.getElementById('qualifiedFilter').value = '';
        document.getElementById('afeFilter').value = '';
        currentPage = 1;
        loadSuppliers();
    }

    function createSupplier() {
        window.location.href = '/suppliers/create';
    }

    function viewSupplier(id) {
        window.location.href = `/suppliers/details/${id}`;
    }

    function editSupplier(id) {
        window.location.href = `/suppliers/edit/${id}`;
    }

    async function deleteSupplier(id, name) {
        const reason = prompt(`Digite o motivo da inativação do fornecedor "${name}":`);
        
        if (!reason || reason.trim() === '') {
            return;
        }

        if (!confirm(`Confirma a inativação do fornecedor "${name}"?`)) {
            return;
        }

        try {
            const response = await fetch(`/api/suppliers/${id}`, {
                method: 'DELETE',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ reason: reason.trim() })
            });

            const result = await response.json();

            if (!response.ok) {
                throw new Error(result.error || 'Erro ao inativar fornecedor');
            }

            showAlert('Fornecedor inativado com sucesso', 'success');
            loadSuppliers();
            loadStatistics();
        } catch (error) {
            console.error('Erro:', error);
            showAlert(error.message, 'danger');
        }
    }

    function getStatusBadge(status) {
        const badges = {
            'Ativo': 'bg-success',
            'Inativo': 'bg-secondary',
            'Bloqueado': 'bg-danger',
            'Em Avaliação': 'bg-warning'
        };
        return badges[status] || 'bg-secondary';
    }

    function getClassificationBadge(classification) {
        const badges = {
            'A': 'bg-success',
            'B': 'bg-info',
            'C': 'bg-warning',
            'D': 'bg-danger'
        };
        return badges[classification] || 'bg-secondary';
    }

    function formatCnpj(cnpj) {
        if (!cnpj) return '-';
        return cnpj.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, '$1.$2.$3/$4-$5');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
            const later = () => {
                clearTimeout(timeout);
                func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
        };
    }

    function showAlert(message, type = 'info') {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
        alertDiv.style.zIndex = '9999';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        
        setTimeout(() => {
            alertDiv.remove();
        }, 5000);
    }
</script>
}
