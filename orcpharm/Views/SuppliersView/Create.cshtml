@{
    ViewData["Title"] = "Novo Fornecedor";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-1">Novo Fornecedor</h2>
                    <p class="text-muted mb-0">Cadastro de novo fornecedor de matérias-primas</p>
                </div>
                <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
            </div>

            <form id="supplierForm">
                <!-- Dados Básicos -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-building"></i> Dados Básicos</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="companyName" class="form-label">Razão Social <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="companyName" required maxlength="200">
                            </div>
                            <div class="col-md-6">
                                <label for="tradeName" class="form-label">Nome Fantasia</label>
                                <input type="text" class="form-control" id="tradeName" maxlength="200">
                            </div>
                            <div class="col-md-4">
                                <label for="cnpj" class="form-label">CNPJ <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="cnpj" required maxlength="18" placeholder="00.000.000/0000-00">
                            </div>
                            <div class="col-md-4">
                                <label for="stateRegistration" class="form-label">Inscrição Estadual</label>
                                <input type="text" class="form-control" id="stateRegistration" maxlength="20">
                            </div>
                            <div class="col-md-4">
                                <label for="classification" class="form-label">Classificação</label>
                                <select class="form-select" id="classification">
                                    <option value="">Selecione...</option>
                                    <option value="A">A - Excelente</option>
                                    <option value="B">B - Bom</option>
                                    <option value="C">C - Regular</option>
                                    <option value="D">D - Crítico</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Endereço -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Endereço</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="postalCode" class="form-label">CEP</label>
                                <div class="input-group">
                                    <input type="text" class="form-control" id="postalCode" maxlength="9" placeholder="00000-000">
                                    <button class="btn btn-outline-secondary" type="button" onclick="searchPostalCode()">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <label for="street" class="form-label">Logradouro</label>
                                <input type="text" class="form-control" id="street" maxlength="100">
                            </div>
                            <div class="col-md-2">
                                <label for="number" class="form-label">Número</label>
                                <input type="text" class="form-control" id="number" maxlength="10">
                            </div>
                            <div class="col-md-4">
                                <label for="complement" class="form-label">Complemento</label>
                                <input type="text" class="form-control" id="complement" maxlength="100">
                            </div>
                            <div class="col-md-4">
                                <label for="neighborhood" class="form-label">Bairro</label>
                                <input type="text" class="form-control" id="neighborhood" maxlength="100">
                            </div>
                            <div class="col-md-4">
                                <label for="city" class="form-label">Cidade</label>
                                <input type="text" class="form-control" id="city" maxlength="100">
                            </div>
                            <div class="col-md-2">
                                <label for="state" class="form-label">UF</label>
                                <select class="form-select" id="state">
                                    <option value="">--</option>
                                    <option value="AC">AC</option>
                                    <option value="AL">AL</option>
                                    <option value="AP">AP</option>
                                    <option value="AM">AM</option>
                                    <option value="BA">BA</option>
                                    <option value="CE">CE</option>
                                    <option value="DF">DF</option>
                                    <option value="ES">ES</option>
                                    <option value="GO">GO</option>
                                    <option value="MA">MA</option>
                                    <option value="MT">MT</option>
                                    <option value="MS">MS</option>
                                    <option value="MG">MG</option>
                                    <option value="PA">PA</option>
                                    <option value="PB">PB</option>
                                    <option value="PR">PR</option>
                                    <option value="PE">PE</option>
                                    <option value="PI">PI</option>
                                    <option value="RJ">RJ</option>
                                    <option value="RN">RN</option>
                                    <option value="RS">RS</option>
                                    <option value="RO">RO</option>
                                    <option value="RR">RR</option>
                                    <option value="SC">SC</option>
                                    <option value="SP">SP</option>
                                    <option value="SE">SE</option>
                                    <option value="TO">TO</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="country" class="form-label">País</label>
                                <input type="text" class="form-control" id="country" maxlength="50" value="Brasil">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contato -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-telephone"></i> Contato</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="phone" class="form-label">Telefone</label>
                                <input type="text" class="form-control" id="phone" maxlength="20" placeholder="(00) 0000-0000">
                            </div>
                            <div class="col-md-3">
                                <label for="whatsapp" class="form-label">WhatsApp</label>
                                <input type="text" class="form-control" id="whatsapp" maxlength="20" placeholder="(00) 00000-0000">
                            </div>
                            <div class="col-md-3">
                                <label for="email" class="form-label">E-mail</label>
                                <input type="email" class="form-control" id="email" maxlength="200">
                            </div>
                            <div class="col-md-3">
                                <label for="website" class="form-label">Website</label>
                                <input type="url" class="form-control" id="website" maxlength="200" placeholder="https://">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dados Comerciais -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-cash-stack"></i> Dados Comerciais</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="rating" class="form-label">Avaliação (0-10)</label>
                                <input type="number" class="form-control" id="rating" min="0" max="10" step="0.1">
                            </div>
                            <div class="col-md-3">
                                <label for="averageDeliveryTime" class="form-label">Prazo Entrega (dias)</label>
                                <input type="number" class="form-control" id="averageDeliveryTime" min="0">
                            </div>
                            <div class="col-md-3">
                                <label for="paymentTermDays" class="form-label">Prazo Pagamento (dias)</label>
                                <input type="number" class="form-control" id="paymentTermDays" min="0">
                            </div>
                            <div class="col-md-3">
                                <label for="minimumOrderValue" class="form-label">Pedido Mínimo (R$)</label>
                                <input type="number" class="form-control" id="minimumOrderValue" min="0" step="0.01">
                            </div>
                            <div class="col-md-12">
                                <label for="productTypes" class="form-label">Tipos de Produtos</label>
                                <textarea class="form-control" id="productTypes" rows="2" placeholder="Ex: Matérias-primas farmacêuticas, excipientes, embalagens..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Certificações -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-patch-check"></i> Certificações</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="isQualified">
                                    <label class="form-check-label" for="isQualified">
                                        <strong>Fornecedor Qualificado</strong>
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="hasGmpCertificate">
                                    <label class="form-check-label" for="hasGmpCertificate">
                                        Certificação BPF/GMP
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="hasIsoCertificate">
                                    <label class="form-check-label" for="hasIsoCertificate">
                                        Certificação ISO
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="hasAnvisaAuthorization">
                                    <label class="form-check-label" for="hasAnvisaAuthorization">
                                        Autorização ANVISA
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="suppliesControlled">
                                    <label class="form-check-label" for="suppliesControlled">
                                        Fornece Controlados
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="suppliesAntibiotics">
                                    <label class="form-check-label" for="suppliesAntibiotics">
                                        Fornece Antibióticos
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- AFE -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="bi bi-shield-check"></i> Autorização de Funcionamento (AFE)</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="afeNumber" class="form-label">Número da AFE</label>
                                <input type="text" class="form-control" id="afeNumber" maxlength="50">
                            </div>
                            <div class="col-md-6">
                                <label for="afeExpiryDate" class="form-label">Data de Validade</label>
                                <input type="date" class="form-control" id="afeExpiryDate">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Observações -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-journal-text"></i> Observações</h5>
                    </div>
                    <div class="card-body">
                        <textarea class="form-control" id="notes" rows="4" placeholder="Observações adicionais sobre o fornecedor..."></textarea>
                    </div>
                </div>

                <!-- Botões -->
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </button>
                            <button type="submit" class="btn btn-primary" id="btnSave">
                                <i class="bi bi-check-circle"></i> Salvar Fornecedor
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Máscaras
        applyMasks();
        
        // Submit
        document.getElementById('supplierForm').addEventListener('submit', handleSubmit);
    });

    function applyMasks() {
        const cnpjInput = document.getElementById('cnpj');
        cnpjInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 14) {
                value = value.replace(/^(\d{2})(\d)/, '$1.$2');
                value = value.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
                value = value.replace(/\.(\d{3})(\d)/, '.$1/$2');
                value = value.replace(/(\d{4})(\d)/, '$1-$2');
            }
            e.target.value = value;
        });

        const postalCodeInput = document.getElementById('postalCode');
        postalCodeInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 8) {
                value = value.replace(/^(\d{5})(\d)/, '$1-$2');
            }
            e.target.value = value;
        });

        const phoneInput = document.getElementById('phone');
        phoneInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 11) {
                if (value.length <= 10) {
                    value = value.replace(/^(\d{2})(\d)/, '($1) $2');
                    value = value.replace(/(\d{4})(\d)/, '$1-$2');
                } else {
                    value = value.replace(/^(\d{2})(\d)/, '($1) $2');
                    value = value.replace(/(\d{5})(\d)/, '$1-$2');
                }
            }
            e.target.value = value;
        });

        const whatsappInput = document.getElementById('whatsapp');
        whatsappInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 11) {
                value = value.replace(/^(\d{2})(\d)/, '($1) $2');
                value = value.replace(/(\d{5})(\d)/, '$1-$2');
            }
            e.target.value = value;
        });
    }

    async function searchPostalCode() {
        const postalCode = document.getElementById('postalCode').value.replace(/\D/g, '');
        
        if (postalCode.length !== 8) {
            showAlert('CEP inválido', 'warning');
            return;
        }

        try {
            const response = await fetch(`https://viacep.com.br/ws/${postalCode}/json/`);
            const data = await response.json();

            if (data.erro) {
                showAlert('CEP não encontrado', 'warning');
                return;
            }

            document.getElementById('street').value = data.logradouro || '';
            document.getElementById('neighborhood').value = data.bairro || '';
            document.getElementById('city').value = data.localidade || '';
            document.getElementById('state').value = data.uf || '';
            
            document.getElementById('number').focus();
            
            showAlert('Endereço preenchido automaticamente', 'success');
        } catch (error) {
            console.error('Erro ao buscar CEP:', error);
            showAlert('Erro ao buscar CEP', 'danger');
        }
    }

    async function handleSubmit(e) {
        e.preventDefault();

        const btnSave = document.getElementById('btnSave');
        const originalText = btnSave.innerHTML;
        btnSave.disabled = true;
        btnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Salvando...';

        const formData = {
            companyName: document.getElementById('companyName').value.trim(),
            tradeName: document.getElementById('tradeName').value.trim() || null,
            cnpj: document.getElementById('cnpj').value.replace(/\D/g, ''),
            stateRegistration: document.getElementById('stateRegistration').value.trim() || null,
            classification: document.getElementById('classification').value || null,
            
            postalCode: document.getElementById('postalCode').value.replace(/\D/g, '') || null,
            street: document.getElementById('street').value.trim() || null,
            number: document.getElementById('number').value.trim() || null,
            complement: document.getElementById('complement').value.trim() || null,
            neighborhood: document.getElementById('neighborhood').value.trim() || null,
            city: document.getElementById('city').value.trim() || null,
            state: document.getElementById('state').value || null,
            country: document.getElementById('country').value.trim() || null,
            
            phone: document.getElementById('phone').value.replace(/\D/g, '') || null,
            whatsapp: document.getElementById('whatsapp').value.replace(/\D/g, '') || null,
            email: document.getElementById('email').value.trim() || null,
            website: document.getElementById('website').value.trim() || null,
            
            rating: parseFloat(document.getElementById('rating').value) || null,
            averageDeliveryTime: parseInt(document.getElementById('averageDeliveryTime').value) || null,
            paymentTermDays: parseInt(document.getElementById('paymentTermDays').value) || null,
            minimumOrderValue: parseFloat(document.getElementById('minimumOrderValue').value) || null,
            productTypes: document.getElementById('productTypes').value.trim() || null,
            
            isQualified: document.getElementById('isQualified').checked,
            hasGmpCertificate: document.getElementById('hasGmpCertificate').checked,
            hasIsoCertificate: document.getElementById('hasIsoCertificate').checked,
            hasAnvisaAuthorization: document.getElementById('hasAnvisaAuthorization').checked,
            suppliesControlled: document.getElementById('suppliesControlled').checked,
            suppliesAntibiotics: document.getElementById('suppliesAntibiotics').checked,
            
            afeNumber: document.getElementById('afeNumber').value.trim() || null,
            afeExpiryDate: document.getElementById('afeExpiryDate').value || null,
            
            notes: document.getElementById('notes').value.trim() || null
        };

        try {
            const response = await fetch('/api/suppliers', {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            });

            const result = await response.json();

            if (!response.ok) {
                throw new Error(result.error || 'Erro ao cadastrar fornecedor');
            }

            showAlert('Fornecedor cadastrado com sucesso', 'success');
            
            setTimeout(() => {
                window.location.href = `/suppliers/details/${result.id}`;
            }, 1500);

        } catch (error) {
            console.error('Erro:', error);
            showAlert(error.message, 'danger');
            btnSave.disabled = false;
            btnSave.innerHTML = originalText;
        }
    }

    function showAlert(message, type = 'info') {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
        alertDiv.style.zIndex = '9999';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        
        setTimeout(() => {
            alertDiv.remove();
        }, 5000);
    }
</script>
}
