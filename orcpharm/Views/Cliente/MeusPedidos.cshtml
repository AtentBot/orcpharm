@using Models
@{
    ViewData["Title"] = "Meus Pedidos";
    Layout = null;
    var orders = ViewBag.Orders as List<OnlineOrder> ?? new List<OnlineOrder>();
    var pharmacyName = ViewBag.PharmacyName ?? "Farmácia";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="var(--petrol-500)">
    <title>@ViewData["Title"] - Formula Clear</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary: var(--petrol-500);
            --primary-light: var(--petrol-200);
            --secondary: var(--ok);
            --accent: var(--amber-500);
            --danger: var(--danger);
            --gray-900: var(--ink);
            --gray-700: var(--ink-2);
            --gray-500: var(--ink-3);
            --gray-400: var(--ink-4);
            --gray-200: var(--rule);
            --gray-100: var(--bg-subtle);
            --gray-50: var(--bg);
            --white: #ffffff;
            --gradient-primary: var(--petrol-500);
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 12px;
            --radius-lg: 16px;
            --radius-full: 9999px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50);
            color: var(--gray-900);
            min-height: 100vh;
            padding-bottom: 80px;
        }

        .app-header {
            background: var(--white);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 1px solid var(--gray-100);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .back-btn {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-full);
            background: var(--gray-100);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--gray-700);
            cursor: pointer;
        }

        .header-title {
            flex: 1;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 18px;
            font-weight: 700;
        }

        /* Tabs */
        .tabs {
            background: var(--white);
            padding: 12px 20px;
            display: flex;
            gap: 8px;
            border-bottom: 1px solid var(--gray-100);
        }

        .tab {
            flex: 1;
            padding: 10px 16px;
            border-radius: var(--radius-full);
            background: var(--gray-100);
            border: none;
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .tab.active {
            background: var(--gradient-primary);
            color: var(--white);
        }

        .main-content {
            padding: 20px;
        }

        .orders-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .order-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .order-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

        .order-header {
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 1px solid var(--gray-100);
        }

        .order-code {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 4px;
        }

        .order-pharmacy {
            font-size: 13px;
            color: var(--gray-500);
        }

        .order-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: var(--radius-full);
            font-size: 12px;
            font-weight: 600;
        }

        .order-status.pendente {
            background: var(--warn-soft);
            color: var(--amber-700);
        }

        .order-status.em-producao {
            background: var(--info-soft);
            color: var(--info);
        }

        .order-status.pronto {
            background: var(--ok-soft);
            color: var(--ok);
        }

        .order-status.entregue {
            background: var(--gray-100);
            color: var(--gray-700);
        }

        .order-status.cancelado {
            background: var(--danger-soft);
            color: var(--danger);
        }

        .order-body {
            padding: 16px;
        }

        .order-items {
            font-size: 14px;
            color: var(--gray-700);
            margin-bottom: 12px;
        }

        .order-items strong {
            color: var(--gray-900);
        }

        .order-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .order-date {
            font-size: 13px;
            color: var(--gray-500);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .order-total {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 18px;
            color: var(--primary);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 24px;
        }

        .empty-icon {
            width: 100px;
            height: 100px;
            border-radius: var(--radius-full);
            background: var(--gray-100);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: var(--gray-400);
            margin: 0 auto 20px;
        }

        .empty-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-text {
            font-size: 15px;
            color: var(--gray-500);
            margin-bottom: 24px;
        }

        .empty-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: var(--gradient-primary);
            color: var(--white);
            border: none;
            border-radius: var(--radius-full);
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }

        /* Bottom Nav */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--gray-100);
            padding: 8px 16px;
            padding-bottom: calc(8px + env(safe-area-inset-bottom));
            display: flex;
            justify-content: space-around;
            z-index: 1000;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 16px;
            text-decoration: none;
            color: var(--gray-500);
        }

        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 22px; }
        .nav-item span { font-size: 11px; font-weight: 600; }

        @@media (min-width: 768px) {
            body { max-width: 480px; margin: 0 auto; }
            .bottom-nav { max-width: 480px; left: 50%; transform: translateX(-50%); }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <button class="back-btn" onclick="location.href='/Cliente/Inicio'">
            <i class="bi bi-arrow-left"></i>
        </button>
        <h1 class="header-title">Meus Pedidos</h1>
    </header>

    <div class="tabs">
        <button class="tab active" onclick="filterOrders('all')">Todos</button>
        <button class="tab" onclick="filterOrders('active')">Em andamento</button>
        <button class="tab" onclick="filterOrders('completed')">Concluídos</button>
    </div>

    <main class="main-content">
        @if(orders.Any())
        {
            <div class="orders-list">
                @foreach(var order in orders)
                {
                    var statusClass = order.Status?.ToLower() switch {
                        "pending" or "pendente" => "pendente",
                        "processing" or "em_producao" => "em-producao",
                        "ready" or "pronto" => "pronto",
                        "delivered" or "entregue" => "entregue",
                        "cancelled" or "cancelado" => "cancelado",
                        _ => "pendente"
                    };
                    
                    var statusText = order.Status?.ToLower() switch {
                        "pending" or "pendente" => "Pendente",
                        "processing" or "em_producao" => "Em produção",
                        "ready" or "pronto" => "Pronto",
                        "delivered" or "entregue" => "Entregue",
                        "cancelled" or "cancelado" => "Cancelado",
                        _ => order.Status
                    };
                    
                    <div class="order-card" onclick="location.href='/Cliente/Pedido/@order.Id'">
                        <div class="order-header">
                            <div>
                                <h3 class="order-code">Pedido #@order.OrderNumber</h3>
                                <p class="order-pharmacy">@(order.Establishment?.NomeFantasia ?? "Farmácia")</p>
                            </div>
                            <span class="order-status @statusClass">
                                <i class="bi bi-circle-fill" style="font-size: 8px;"></i>
                                @statusText
                            </span>
                        </div>
                        <div class="order-body">
                            <p class="order-items">
                                <strong>@(order.Items?.Count ?? 0) item(s)</strong>
                            </p>
                            <div class="order-footer">
                                <span class="order-date">
                                    <i class="bi bi-calendar3"></i>
                                    @order.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                <span class="order-total">R$ @order.Total.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-bag-x"></i>
                </div>
                <h3 class="empty-title">Nenhum pedido ainda</h3>
                <p class="empty-text">Envie uma receita ou explore nosso catálogo para fazer seu primeiro pedido!</p>
                <a href="/Cliente/EnviarReceita" class="empty-btn">
                    <i class="bi bi-camera"></i>
                    Enviar Receita
                </a>
            </div>
        }
    </main>

    <nav class="bottom-nav">
        <a href="/Cliente/Inicio" class="nav-item">
            <i class="bi bi-house"></i>
            <span>Início</span>
        </a>
        <a href="/Cliente/Buscar" class="nav-item">
            <i class="bi bi-search"></i>
            <span>Buscar</span>
        </a>
        <a href="/Cliente/MeusPedidos" class="nav-item active">
            <i class="bi bi-bag-fill"></i>
            <span>Pedidos</span>
        </a>
        <a href="/Cliente/Carrinho" class="nav-item">
            <i class="bi bi-cart3"></i>
            <span>Carrinho</span>
        </a>
        <a href="/Cliente/Perfil" class="nav-item">
            <i class="bi bi-person"></i>
            <span>Perfil</span>
        </a>
    </nav>

    <script>
        function filterOrders(filter) {
            const tabs = document.querySelectorAll('.tab');
            tabs.forEach(tab => tab.classList.remove('active'));
            event.target.classList.add('active');
            
            // TODO: Implementar filtro real
        }
    </script>
</body>
</html>
