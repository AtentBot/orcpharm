@using Models
@{
    ViewData["Title"] = "Meu Perfil";
    Layout = null;
    var customer = ViewBag.Customer as Customer;
    var pharmacyName = ViewBag.PharmacyName ?? "Farmácia";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="var(--petrol-500)">
    <title>@ViewData["Title"] - Formula Clear</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary: var(--petrol-500);
            --primary-light: var(--petrol-200);
            --secondary: var(--ok);
            --accent: var(--amber-500);
            --danger: var(--danger);
            --gray-900: var(--ink);
            --gray-700: var(--ink-2);
            --gray-500: var(--ink-3);
            --gray-400: var(--ink-4);
            --gray-200: var(--rule);
            --gray-100: var(--bg-subtle);
            --gray-50: var(--bg);
            --white: #ffffff;
            --gradient-primary: var(--petrol-500);
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.1);
            --radius: 12px;
            --radius-lg: 16px;
            --radius-full: 9999px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50);
            color: var(--gray-900);
            min-height: 100vh;
            padding-bottom: 80px;
        }

        /* Profile Header */
        .profile-header {
            background: var(--gradient-primary);
            padding: 60px 20px 80px;
            text-align: center;
            position: relative;
        }

        .profile-avatar {
            width: 100px;
            height: 100px;
            border-radius: var(--radius-full);
            background: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: var(--primary);
            margin: 0 auto 16px;
            border: 4px solid rgba(255,255,255,0.3);
        }

        .profile-name {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: var(--white);
            margin-bottom: 4px;
        }

        .profile-phone {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
        }

        .edit-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 40px;
            height: 40px;
            border-radius: var(--radius-full);
            background: rgba(255,255,255,0.2);
            border: none;
            color: var(--white);
            font-size: 18px;
            cursor: pointer;
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            width: 40px;
            height: 40px;
            border-radius: var(--radius-full);
            background: rgba(255,255,255,0.2);
            border: none;
            color: var(--white);
            font-size: 18px;
            cursor: pointer;
        }

        /* Stats Cards */
        .stats-row {
            display: flex;
            gap: 12px;
            padding: 0 20px;
            margin-top: -40px;
            margin-bottom: 20px;
        }

        .stat-card {
            flex: 1;
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 16px;
            text-align: center;
            box-shadow: var(--shadow-md);
        }

        .stat-value {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
        }

        .stat-label {
            font-size: 12px;
            color: var(--gray-500);
            margin-top: 4px;
        }

        /* Menu Sections */
        .menu-section {
            background: var(--white);
            border-radius: var(--radius-lg);
            margin: 0 20px 16px;
            overflow: hidden;
            box-shadow: var(--shadow);
        }

        .menu-section-title {
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 700;
            color: var(--gray-500);
            text-transform: uppercase;
            background: var(--gray-50);
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            border-bottom: 1px solid var(--gray-100);
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            color: inherit;
        }

        .menu-item:last-child {
            border-bottom: none;
        }

        .menu-item:hover {
            background: var(--gray-50);
        }

        .menu-icon {
            width: 40px;
            height: 40px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .menu-icon.primary {
            background: rgba(99,102,241,0.1);
            color: var(--primary);
        }

        .menu-icon.secondary {
            background: rgba(16,185,129,0.1);
            color: var(--secondary);
        }

        .menu-icon.accent {
            background: rgba(245,158,11,0.1);
            color: var(--accent);
        }

        .menu-icon.danger {
            background: rgba(239,68,68,0.1);
            color: var(--danger);
        }

        .menu-content {
            flex: 1;
        }

        .menu-title {
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 2px;
        }

        .menu-subtitle {
            font-size: 13px;
            color: var(--gray-500);
        }

        .menu-arrow {
            color: var(--gray-400);
            font-size: 18px;
        }

        .menu-badge {
            padding: 4px 10px;
            background: var(--danger);
            color: var(--white);
            border-radius: var(--radius-full);
            font-size: 11px;
            font-weight: 700;
        }

        /* Bottom Nav */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            border-top: 1px solid var(--gray-100);
            padding: 8px 16px;
            padding-bottom: calc(8px + env(safe-area-inset-bottom));
            display: flex;
            justify-content: space-around;
            z-index: 1000;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 16px;
            text-decoration: none;
            color: var(--gray-500);
        }

        .nav-item.active { color: var(--primary); }
        .nav-item i { font-size: 22px; }
        .nav-item span { font-size: 11px; font-weight: 600; }

        /* Version */
        .version {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: var(--gray-400);
        }

        @@media (min-width: 768px) {
            body { max-width: 480px; margin: 0 auto; }
            .bottom-nav { max-width: 480px; left: 50%; transform: translateX(-50%); }
        }
    </style>
</head>
<body>
    <header class="profile-header">
        <button class="back-btn" onclick="location.href='/Cliente/Inicio'">
            <i class="bi bi-arrow-left"></i>
        </button>
        <button class="edit-btn" onclick="editProfile()">
            <i class="bi bi-pencil"></i>
        </button>
        
        <div class="profile-avatar">
            <i class="bi bi-person"></i>
        </div>
        <h1 class="profile-name">@(customer?.FullName ?? "Cliente")</h1>
        <p class="profile-phone">@(customer?.Phone ?? "")</p>
    </header>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-value" id="ordersCount">0</div>
            <div class="stat-label">Pedidos</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="formulasCount">0</div>
            <div class="stat-label">Fórmulas</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="couponsCount">0</div>
            <div class="stat-label">Cupons</div>
        </div>
    </div>

    <main>
        <div class="menu-section">
            <div class="menu-section-title">Minha Conta</div>
            <a href="/Cliente/MeusPedidos" class="menu-item">
                <div class="menu-icon primary">
                    <i class="bi bi-bag"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Meus Pedidos</div>
                    <div class="menu-subtitle">Acompanhe seus pedidos</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
            <a href="/Cliente/Historico" class="menu-item">
                <div class="menu-icon primary">
                    <i class="bi bi-capsule"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Minhas Fórmulas</div>
                    <div class="menu-subtitle">Histórico de fórmulas</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
            <a href="/Cliente/MeusCupons" class="menu-item">
                <div class="menu-icon accent">
                    <i class="bi bi-ticket-perforated"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Meus Cupons</div>
                    <div class="menu-subtitle">Cupons disponíveis</div>
                </div>
                <span class="menu-badge" id="couponsAvailable">0</span>
            </a>
        </div>

        <div class="menu-section">
            <div class="menu-section-title">Preferências</div>
            <a href="/Cliente/Notificacoes" class="menu-item">
                <div class="menu-icon secondary">
                    <i class="bi bi-bell"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Notificações</div>
                    <div class="menu-subtitle">Gerenciar alertas</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
            <a href="/Cliente/Estabelecimentos" class="menu-item">
                <div class="menu-icon secondary">
                    <i class="bi bi-building"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Trocar Farmácia</div>
                    <div class="menu-subtitle">@(ViewBag.PharmacyName ?? "Selecionar farmácia")</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
        </div>

        <div class="menu-section">
            <div class="menu-section-title">Ajuda</div>
            <a href="#" class="menu-item" onclick="openWhatsApp()">
                <div class="menu-icon secondary">
                    <i class="bi bi-whatsapp"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Fale Conosco</div>
                    <div class="menu-subtitle">Atendimento via WhatsApp</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
            <a href="#" class="menu-item">
                <div class="menu-icon primary">
                    <i class="bi bi-question-circle"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title">Ajuda</div>
                    <div class="menu-subtitle">Perguntas frequentes</div>
                </div>
                <i class="bi bi-chevron-right menu-arrow"></i>
            </a>
        </div>

        <div class="menu-section">
            <a href="#" class="menu-item" onclick="logout()">
                <div class="menu-icon danger">
                    <i class="bi bi-box-arrow-right"></i>
                </div>
                <div class="menu-content">
                    <div class="menu-title" style="color: var(--danger);">Sair</div>
                    <div class="menu-subtitle">Encerrar sessão</div>
                </div>
            </a>
        </div>

        <p class="version">Formula Clear v1.0.0</p>
    </main>

    <nav class="bottom-nav">
        <a href="/Cliente/Inicio" class="nav-item">
            <i class="bi bi-house"></i>
            <span>Início</span>
        </a>
        <a href="/Cliente/Buscar" class="nav-item">
            <i class="bi bi-search"></i>
            <span>Buscar</span>
        </a>
        <a href="/Cliente/MeusPedidos" class="nav-item">
            <i class="bi bi-bag"></i>
            <span>Pedidos</span>
        </a>
        <a href="/Cliente/Carrinho" class="nav-item">
            <i class="bi bi-cart3"></i>
            <span>Carrinho</span>
        </a>
        <a href="/Cliente/Perfil" class="nav-item active">
            <i class="bi bi-person-fill"></i>
            <span>Perfil</span>
        </a>
    </nav>

    <script>
        // Load stats
        async function loadStats() {
            try {
                const response = await fetch('/api/cliente/profile/stats');
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('ordersCount').textContent = data.ordersCount || 0;
                    document.getElementById('formulasCount').textContent = data.formulasCount || 0;
                    document.getElementById('couponsCount').textContent = data.couponsCount || 0;
                    document.getElementById('couponsAvailable').textContent = data.couponsCount || 0;
                }
            } catch (e) {
                console.log('Stats not available');
            }
        }

        function editProfile() {
            alert('Editar perfil - Em desenvolvimento');
        }

        function openWhatsApp() {
            window.open('https://wa.me/5511999999999?text=Olá! Preciso de ajuda com meu pedido.', '_blank');
        }

        async function logout() {
            if (!confirm('Deseja realmente sair?')) return;
            
            try {
                await fetch('/api/cliente/auth/logout', { method: 'POST' });
            } catch (e) {}
            
            window.location.href = '/Cliente/Login';
        }

        document.addEventListener('DOMContentLoaded', loadStats);
    </script>
</body>
</html>
