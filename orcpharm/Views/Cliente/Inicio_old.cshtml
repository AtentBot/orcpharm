@using Models
@{
    ViewData["Title"] = "Início";
    ViewData["ActiveNav"] = "inicio";
    Layout = "_LayoutCliente";
    
    var customer = ViewBag.Customer as Customer;
    var establishment = ViewBag.Establishment as Establishment;
    var recentOrders = ViewBag.RecentOrders as List<OnlineOrder> ?? new List<OnlineOrder>();
    var pendingCount = (int)(ViewBag.PendingOrdersCount ?? 0);
    var readyCount = (int)(ViewBag.ReadyOrdersCount ?? 0);
}

<div class="container py-4">
    <!-- Boas-vindas com botão de logout -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h5 class="mb-1">Olá, @(customer?.FullName?.Split(' ')[0] ?? "Cliente")! 👋</h5>
            <p class="text-muted mb-0">O que você precisa hoje?</p>
        </div>
        <div class="dropdown">
            <button class="btn btn-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/Cliente/MeusDados"><i class="bi bi-person me-2"></i>Meus Dados</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/Cliente/Logout"><i class="bi bi-box-arrow-right me-2"></i>Sair</a></li>
            </ul>
        </div>
    </div>

    <!-- Alertas de Pedidos -->
    @if (readyCount > 0)
    {
        <div class="alert alert-success d-flex align-items-center mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div class="flex-grow-1">
                <strong>@readyCount pedido(s) pronto(s)!</strong>
                <div class="small">Disponível para retirada</div>
            </div>
            <a href="/Cliente/MeusPedidos?status=prontos" class="btn btn-success btn-sm">Ver</a>
        </div>
    }

    @if (pendingCount > 0 && readyCount == 0)
    {
        <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
            <i class="bi bi-clock-fill me-2 fs-5"></i>
            <div class="flex-grow-1">
                <strong>@pendingCount pedido(s) em andamento</strong>
            </div>
            <a href="/Cliente/MeusPedidos?status=pendentes" class="btn btn-info btn-sm text-white">Ver</a>
        </div>
    }

    <!-- NOVO: Card de Destaque - Fórmula Personalizada -->
    @if (establishment != null)
    {
        <a href="/Cliente/CriarFormula" class="text-decoration-none">
            <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="card-body text-white py-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 56px; height: 56px;">
                            <i class="bi bi-stars fs-3"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1">
                                <h6 class="mb-0 fw-bold">Criar Fórmula Personalizada</h6>
                                <span class="badge bg-warning text-dark ms-2 small">NOVO</span>
                            </div>
                            <p class="mb-0 small opacity-90">Monte sua fórmula exclusiva em minutos</p>
                        </div>
                        <i class="bi bi-chevron-right fs-4"></i>
                    </div>
                </div>
            </div>
        </a>
    }

    <!-- Farmácia selecionada (opcional) -->
    @if (establishment != null)
    {
        <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="card-body text-white py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="small mb-0 opacity-75">Comprando em</p>
                        <h6 class="mb-0">@establishment.NomeFantasia</h6>
                    </div>
                    <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/Inicio" class="btn btn-light btn-sm">
                        <i class="bi bi-arrow-repeat"></i>
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-4 bg-light">
            <div class="card-body py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="small mb-0 text-muted">Nenhuma farmácia selecionada</p>
                        <span class="small text-muted">Selecione para comprar</span>
                    </div>
                    <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/Inicio" class="btn btn-primary btn-sm">
                        <i class="bi bi-shop me-1"></i>Escolher
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Ações principais -->
    <div class="row g-3 mb-4">
        <!-- NOVO: Card Fórmula Personalizada -->
        <div class="col-6">
            @if (establishment != null)
            {
                <a href="/Cliente/CriarFormula" class="card border-0 shadow-sm text-decoration-none h-100 position-relative">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                            <i class="bi bi-stars text-white fs-4"></i>
                        </div>
                        <h6 class="mb-1">Fórmula Personalizada</h6>
                        <p class="text-muted small mb-0">Crie sua fórmula</p>
                    </div>
                    <span class="position-absolute top-0 end-0 m-2 badge bg-warning text-dark">NOVO</span>
                </a>
            }
            else
            {
                <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/CriarFormula" class="card border-0 shadow-sm text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                             style="width: 60px; height: 60px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                            <i class="bi bi-stars text-white fs-4"></i>
                        </div>
                        <h6 class="mb-1">Fórmula Personalizada</h6>
                        <p class="text-muted small mb-0">Escolha a farmácia</p>
                    </div>
                </a>
            }
        </div>
        <div class="col-6">
            @if (establishment != null)
            {
                <a href="/Cliente/EnviarReceita" class="card border-0 shadow-sm text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-camera text-primary fs-4"></i>
                        </div>
                        <h6 class="mb-1">Enviar Receita</h6>
                        <p class="text-muted small mb-0">Fotografe sua receita</p>
                    </div>
                </a>
            }
            else
            {
                <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/EnviarReceita" class="card border-0 shadow-sm text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-camera text-primary fs-4"></i>
                        </div>
                        <h6 class="mb-1">Enviar Receita</h6>
                        <p class="text-muted small mb-0">Escolha a farmácia</p>
                    </div>
                </a>
            }
        </div>
        <div class="col-6">
            @if (establishment != null)
            {
                <a href="/Cliente/Catalogo" class="card border-0 shadow-sm text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-grid text-success fs-4"></i>
                        </div>
                        <h6 class="mb-1">Catálogo</h6>
                        <p class="text-muted small mb-0">Ver produtos</p>
                    </div>
                </a>
            }
            else
            {
                <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/Catalogo" class="card border-0 shadow-sm text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-grid text-success fs-4"></i>
                        </div>
                        <h6 class="mb-1">Catálogo</h6>
                        <p class="text-muted small mb-0">Escolha a farmácia</p>
                    </div>
                </a>
            }
        </div>
        <div class="col-6">
            <a href="/Cliente/MeusPedidos" class="card border-0 shadow-sm text-decoration-none h-100 position-relative">
                <div class="card-body text-center py-4">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-bag text-warning fs-4"></i>
                    </div>
                    <h6 class="mb-1">Meus Pedidos</h6>
                    <p class="text-muted small mb-0">Acompanhar status</p>
                </div>
                @if (pendingCount + readyCount > 0)
                {
                    <span class="position-absolute top-0 end-0 m-2 badge bg-danger">@(pendingCount + readyCount)</span>
                }
            </a>
        </div>
        <div class="col-6">
            <a href="/Cliente/Estabelecimentos" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body text-center py-4">
                    <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-shop text-info fs-4"></i>
                    </div>
                    <h6 class="mb-1">Farmácias</h6>
                    <p class="text-muted small mb-0">Trocar farmácia</p>
                </div>
            </a>
        </div>
        <div class="col-6">
            <a href="/Cliente/MeusDados" class="card border-0 shadow-sm text-decoration-none h-100">
                <div class="card-body text-center py-4">
                    <div class="bg-secondary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-person text-secondary fs-4"></i>
                    </div>
                    <h6 class="mb-1">Meus Dados</h6>
                    <p class="text-muted small mb-0">Editar perfil</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Pedidos recentes (de todas as farmácias) -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0">Pedidos Recentes</h6>
            <a href="/Cliente/MeusPedidos" class="text-decoration-none small">Ver todos</a>
        </div>
        
        @if (recentOrders.Any())
        {
            foreach (var order in recentOrders)
            {
                var statusClass = order.Status switch
                {
                    "PENDING" => "warning",
                    "CONFIRMED" => "info",
                    "PREPARING" => "primary",
                    "READY" => "success",
                    "DELIVERED" => "secondary",
                    "CANCELLED" => "danger",
                    _ => "secondary"
                };
                
                var statusText = order.Status switch
                {
                    "PENDING" => "Aguardando",
                    "CONFIRMED" => "Confirmado",
                    "PREPARING" => "Em Produção",
                    "READY" => "Pronto",
                    "DELIVERED" => "Entregue",
                    "CANCELLED" => "Cancelado",
                    _ => order.Status
                };
                
                <div class="card border-0 shadow-sm mb-2">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <strong>#@order.OrderNumber</strong>
                                    <span class="badge bg-@statusClass">@statusText</span>
                                </div>
                                <small class="text-muted">
                                    @order.Establishment?.NomeFantasia • @order.CreatedAt.ToString("dd/MM HH:mm")
                                </small>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold text-success">R$ @order.Total.ToString("N2")</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2 mb-0">Nenhum pedido ainda</p>
                <a href="/Cliente/Estabelecimentos?returnUrl=/Cliente/Catalogo" class="btn btn-primary btn-sm mt-3">
                    Fazer primeiro pedido
                </a>
            </div>
        }
    </div>

    <!-- WhatsApp da farmácia selecionada -->
    @if (establishment != null && !string.IsNullOrEmpty(establishment.WhatsApp))
    {
        var whatsappNumber = establishment.WhatsApp.Replace("-", "").Replace(" ", "").Replace("(", "").Replace(")", "");
        <div class="d-grid mb-3">
            <a href="https://wa.me/55@whatsappNumber" class="btn btn-success" target="_blank">
                <i class="bi bi-whatsapp me-2"></i>Falar com @establishment.NomeFantasia
            </a>
        </div>
    }

    <!-- Botão de Logout -->
    <div class="d-grid">
        <a href="/Cliente/Logout" class="btn btn-outline-danger">
            <i class="bi bi-box-arrow-right me-2"></i>Sair da Conta
        </a>
    </div>
</div>
