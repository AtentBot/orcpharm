@using Models
@{
    ViewData["Title"] = "Catálogo";
    ViewData["ActiveNav"] = "catalogo";
    Layout = "_LayoutCliente";
    
    var establishment = ViewBag.Establishment as Establishment;
    var categories = ViewBag.Categories as List<CatalogCategory> ?? new List<CatalogCategory>();
    var products = ViewBag.Products as List<CatalogProduct> ?? new List<CatalogProduct>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var cartItemCount = (int)(ViewBag.CartItemCount ?? 0);
}

<style>
    .category-pill {
        white-space: nowrap;
        border-radius: 20px;
        padding: 8px 16px;
        font-size: 14px;
        border: 1px solid #dee2e6;
        background: white;
        color: #495057;
        text-decoration: none;
        transition: all 0.2s;
    }
    .category-pill:hover, .category-pill.active {
        background: #4361ee;
        border-color: #4361ee;
        color: white;
    }
    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
    }
    .product-image {
        height: 120px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    .product-image i {
        font-size: 40px;
        color: #adb5bd;
    }
    .product-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        font-size: 11px;
        padding: 3px 8px;
        border-radius: 12px;
    }
    .product-body {
        padding: 12px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    .product-name {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 4px;
        color: #212529;
        line-height: 1.3;
    }
    .product-desc {
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 8px;
        flex-grow: 1;
    }
    .product-price {
        font-weight: 700;
        font-size: 18px;
        color: #198754;
    }
    .product-price-old {
        font-size: 12px;
        color: #adb5bd;
        text-decoration: line-through;
    }
    .cart-fab {
        position: fixed;
        bottom: 80px;
        right: 20px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #4361ee;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(67, 97, 238, 0.4);
        text-decoration: none;
        z-index: 1000;
    }
    .cart-fab:hover {
        background: #3651d4;
        color: white;
        transform: scale(1.05);
    }
    .cart-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background: #dc3545;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
    }
</style>

<div class="container py-3">
    <!-- Header -->
    <div class="d-flex align-items-center mb-3">
        <a href="/Cliente/Inicio" class="btn btn-link text-dark p-0 me-3">
            <i class="bi bi-arrow-left fs-4"></i>
        </a>
        <div class="flex-grow-1">
            <h5 class="mb-0">Catálogo</h5>
            <small class="text-muted">@establishment?.NomeFantasia</small>
        </div>
    </div>

    <!-- Busca -->
    <div class="mb-3">
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="searchInput" placeholder="Buscar produto..." oninput="filterProducts()">
        </div>
    </div>

    <!-- Categorias -->
    <div class="mb-4" style="overflow-x: auto; white-space: nowrap; -webkit-overflow-scrolling: touch;">
        <div class="d-inline-flex gap-2 pb-2">
            <a href="/Cliente/Catalogo" class="category-pill @(string.IsNullOrEmpty(selectedCategory) ? "active" : "")">
                Todos
            </a>
            @foreach (var cat in categories)
            {
                <a href="/Cliente/Catalogo?categoria=@cat.Slug" 
                   class="category-pill @(selectedCategory == cat.Slug ? "active" : "")">
                    <i class="@cat.IconClass me-1"></i>@cat.Name
                </a>
            }
        </div>
    </div>

    <!-- Produtos -->
    @if (products.Any())
    {
        <div class="row g-3" id="productsGrid">
            @foreach (var product in products)
            {
                <div class="col-6 col-md-4 col-lg-3 product-item" 
                     data-name="@product.Name.ToLower()" 
                     data-desc="@(product.ShortDescription?.ToLower() ?? "")">
                    <div class="product-card" onclick="viewProduct('@product.Id')">
                        <div class="product-image">
                            <i class="bi bi-capsule"></i>
                            @if (product.IsOnPromotion)
                            {
                                <span class="product-badge bg-danger text-white">-@product.DiscountPercent%</span>
                            }
                            else if (product.IsHighlight)
                            {
                                <span class="product-badge bg-warning text-dark">Destaque</span>
                            }
                            else if (product.IsBestSeller)
                            {
                                <span class="product-badge bg-success text-white">Mais Vendido</span>
                            }
                        </div>
                        <div class="product-body">
                            <div class="product-name">@product.Name</div>
                            <div class="product-desc">@product.ShortDescription</div>
                            <div class="mt-auto">
                                @if (product.IsOnPromotion)
                                {
                                    <div class="product-price-old">R$ @product.Price.ToString("N2")</div>
                                    <div class="product-price">R$ @product.PromotionalPrice?.ToString("N2")</div>
                                }
                                else
                                {
                                    <div class="product-price">R$ @product.Price.ToString("N2")</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted"></i>
            <p class="text-muted mt-2">Nenhum produto encontrado</p>
            @if (!string.IsNullOrEmpty(selectedCategory))
            {
                <a href="/Cliente/Catalogo" class="btn btn-outline-primary btn-sm">Ver todos os produtos</a>
            }
        </div>
    }
</div>

<!-- FAB Carrinho -->
@if (cartItemCount > 0)
{
    <a href="/Cliente/Carrinho" class="cart-fab">
        <i class="bi bi-cart3 fs-4"></i>
        <span class="cart-badge">@cartItemCount</span>
    </a>
}

@section Scripts {
<script>
    function filterProducts() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const items = document.querySelectorAll('.product-item');
        
        items.forEach(item => {
            const name = item.dataset.name || '';
            const desc = item.dataset.desc || '';
            const matches = name.includes(search) || desc.includes(search);
            item.style.display = matches ? 'block' : 'none';
        });
    }
    
    function viewProduct(id) {
        window.location.href = '/Cliente/Produto/' + id;
    }
</script>
}
