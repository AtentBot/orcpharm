@{
    ViewData["Title"] = "Escolher Farmácia";
    Layout = null;
    var establishments = ViewBag.Establishments as List<Establishment> ?? new List<Establishment>();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#6366f1">
    <title>@ViewData["Title"] - OrcPharm</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #a5b4fc;
            --secondary: #10b981;
            --accent: #f59e0b;
            --danger: #ef4444;
            --dark: #1e1b4b;
            --gray-900: #111827;
            --gray-700: #374151;
            --gray-500: #6b7280;
            --gray-400: #9ca3af;
            --gray-300: #d1d5db;
            --gray-200: #e5e7eb;
            --gray-100: #f3f4f6;
            --gray-50: #f9fafb;
            --white: #ffffff;
            --gradient-primary: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.1);
            --shadow-lg: 0 20px 25px -5px rgba(0,0,0,0.1);
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            --radius-full: 9999px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-50);
            color: var(--gray-900);
            min-height: 100vh;
        }

        .app-header {
            background: var(--white);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 1px solid var(--gray-100);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .back-btn {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-full);
            background: var(--gray-100);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--gray-700);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .back-btn:hover { background: var(--gray-200); }

        .header-content {
            flex: 1;
        }

        .header-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 18px;
            font-weight: 700;
        }

        .header-subtitle {
            font-size: 13px;
            color: var(--gray-500);
        }

        .main-content {
            padding: 20px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* QR Scanner Button */
        .qr-scanner-btn {
            width: 100%;
            padding: 16px 24px;
            background: var(--gradient-primary);
            color: var(--white);
            border: none;
            border-radius: var(--radius-lg);
            font-size: 16px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 24px;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-md);
        }

        .qr-scanner-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg), 0 0 40px rgba(99,102,241,0.3);
        }

        .qr-scanner-btn i { font-size: 24px; }

        .divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .divider-line {
            flex: 1;
            height: 1px;
            background: var(--gray-200);
        }

        .divider-text {
            font-size: 13px;
            color: var(--gray-500);
        }

        /* Search */
        .search-box {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            border: 1px solid var(--gray-200);
            transition: all 0.3s ease;
        }

        .search-box:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
        }

        .search-box i { color: var(--gray-400); font-size: 20px; }

        .search-box input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 15px;
            font-family: inherit;
            background: transparent;
        }

        /* Pharmacy List */
        .pharmacy-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .pharmacy-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .pharmacy-card:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow-md);
            transform: translateX(4px);
        }

        .pharmacy-card.selected {
            border-color: var(--primary);
            background: rgba(99,102,241,0.05);
        }

        .pharmacy-icon {
            width: 56px;
            height: 56px;
            border-radius: var(--radius);
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--white);
            flex-shrink: 0;
        }

        .pharmacy-info {
            flex: 1;
            min-width: 0;
        }

        .pharmacy-name {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 4px;
            color: var(--gray-900);
        }

        .pharmacy-address {
            font-size: 13px;
            color: var(--gray-500);
            display: flex;
            align-items: center;
            gap: 4px;
            margin-bottom: 2px;
        }

        .pharmacy-phone {
            font-size: 13px;
            color: var(--gray-500);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .pharmacy-arrow {
            color: var(--gray-400);
            font-size: 20px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 48px 24px;
        }

        .empty-icon {
            width: 80px;
            height: 80px;
            border-radius: var(--radius-full);
            background: var(--gray-100);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            color: var(--gray-400);
            margin: 0 auto 16px;
        }

        .empty-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-text {
            font-size: 14px;
            color: var(--gray-500);
        }

        /* QR Modal */
        .qr-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .qr-modal.active { display: flex; }

        .qr-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 44px;
            height: 44px;
            border-radius: var(--radius-full);
            background: rgba(255,255,255,0.1);
            border: none;
            color: var(--white);
            font-size: 24px;
            cursor: pointer;
        }

        .qr-viewport {
            width: 280px;
            height: 280px;
            border: 3px solid var(--primary);
            border-radius: var(--radius-xl);
            position: relative;
            overflow: hidden;
        }

        .qr-viewport video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .qr-corners {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
        }

        .qr-corner {
            position: absolute;
            width: 30px;
            height: 30px;
            border-color: var(--white);
            border-style: solid;
        }

        .qr-corner.tl { top: 10px; left: 10px; border-width: 3px 0 0 3px; }
        .qr-corner.tr { top: 10px; right: 10px; border-width: 3px 3px 0 0; }
        .qr-corner.bl { bottom: 10px; left: 10px; border-width: 0 0 3px 3px; }
        .qr-corner.br { bottom: 10px; right: 10px; border-width: 0 3px 3px 0; }

        .qr-text {
            color: var(--white);
            text-align: center;
            margin-top: 24px;
            font-size: 15px;
        }

        @@media (min-width: 768px) {
            body {
                max-width: 480px;
                margin: 0 auto;
                box-shadow: 0 0 40px rgba(0,0,0,0.1);
            }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <button class="back-btn" onclick="history.back()">
            <i class="bi bi-arrow-left"></i>
        </button>
        <div class="header-content">
            <h1 class="header-title">Escolher Farmácia</h1>
            <p class="header-subtitle">Para onde deseja comprar?</p>
        </div>
    </header>

    <main class="main-content">
        <button class="qr-scanner-btn" onclick="openQrScanner()">
            <i class="bi bi-qr-code-scan"></i>
            Escanear QR Code da Farmácia
        </button>

        <div class="divider">
            <div class="divider-line"></div>
            <span class="divider-text">ou escolha na lista abaixo</span>
            <div class="divider-line"></div>
        </div>

        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Buscar farmácia..." oninput="filterPharmacies()">
        </div>

        <div class="pharmacy-list" id="pharmacyList">
            @if(establishments.Any())
            {
                @foreach(var est in establishments)
                {
                    <div class="pharmacy-card" onclick="selectPharmacy('@est.Id')">
                        <div class="pharmacy-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div class="pharmacy-info">
                            <h3 class="pharmacy-name">@est.NomeFantasia</h3>
                            @if(!string.IsNullOrEmpty(est.Street))
                            {
                                <p class="pharmacy-address">
                                    <i class="bi bi-geo-alt"></i>
                                    @est.Street, @est.Number - @est.Neighborhood@(string.IsNullOrEmpty(est.City) ? "" : $", {est.City}") - @est.State
                                </p>
                            }
                            @if(!string.IsNullOrEmpty(est.Phone))
                            {
                                <p class="pharmacy-phone">
                                    <i class="bi bi-telephone"></i>
                                    @est.Phone
                                </p>
                            }
                        </div>
                        <i class="bi bi-chevron-right pharmacy-arrow"></i>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-building-x"></i>
                    </div>
                    <h3 class="empty-title">Nenhuma farmácia disponível</h3>
                    <p class="empty-text">Escaneie o QR Code de uma farmácia para começar</p>
                </div>
            }
        </div>
    </main>

    <!-- QR Scanner Modal -->
    <div class="qr-modal" id="qrModal">
        <button class="qr-close" onclick="closeQrScanner()">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="qr-viewport">
            <video id="qrVideo" autoplay playsinline></video>
            <div class="qr-corners">
                <div class="qr-corner tl"></div>
                <div class="qr-corner tr"></div>
                <div class="qr-corner bl"></div>
                <div class="qr-corner br"></div>
            </div>
        </div>
        <p class="qr-text">Aponte para o QR Code da farmácia</p>
    </div>

    <script src="https://unpkg.com/html5-qrcode@2.3.4/html5-qrcode.min.js"></script>
    <script>
        let html5QrCode = null;

        function filterPharmacies() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.querySelectorAll('.pharmacy-card');
            
            cards.forEach(card => {
                const name = card.querySelector('.pharmacy-name').textContent.toLowerCase();
                const address = card.querySelector('.pharmacy-address')?.textContent.toLowerCase() || '';
                
                if (name.includes(query) || address.includes(query)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        async function selectPharmacy(id) {
            try {
                const response = await fetch('/api/cliente/session/select-establishment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ establishmentId: id })
                });
                
                const data = await response.json();
                if (data.success) {
                    window.location.href = '/Cliente/Inicio';
                } else {
                    alert(data.message || 'Erro ao selecionar farmácia');
                }
            } catch (e) {
                console.error(e);
                // Fallback - redirect anyway
                window.location.href = '/Cliente/Inicio';
            }
        }

        function openQrScanner() {
            const modal = document.getElementById('qrModal');
            const video = document.getElementById('qrVideo');
            modal.classList.add('active');
            
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment' } 
                })
                .then(stream => {
                    video.srcObject = stream;
                    startQrScanning();
                })
                .catch(err => {
                    alert('Não foi possível acessar a câmera');
                    closeQrScanner();
                });
            } else {
                alert('Seu navegador não suporta acesso à câmera');
                closeQrScanner();
            }
        }

        function startQrScanning() {
            // Using html5-qrcode library
            html5QrCode = new Html5Qrcode("qrVideo");
            
            Html5Qrcode.getCameras().then(devices => {
                if (devices && devices.length) {
                    const cameraId = devices[devices.length - 1].id; // Back camera
                    html5QrCode.start(
                        cameraId, 
                        { fps: 10, qrbox: { width: 250, height: 250 } },
                        onQrCodeSuccess,
                        onQrCodeError
                    );
                }
            });
        }

        function onQrCodeSuccess(decodedText, decodedResult) {
            // Expected format: ORCPHARM:establishment_id
            if (decodedText.startsWith('ORCPHARM:')) {
                const id = decodedText.replace('ORCPHARM:', '');
                closeQrScanner();
                selectPharmacy(id);
            } else if (decodedText.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i)) {
                closeQrScanner();
                selectPharmacy(decodedText);
            }
        }

        function onQrCodeError(error) {
            // Ignore scan errors
        }

        function closeQrScanner() {
            const modal = document.getElementById('qrModal');
            const video = document.getElementById('qrVideo');
            
            modal.classList.remove('active');
            
            if (video.srcObject) {
                video.srcObject.getTracks().forEach(track => track.stop());
                video.srcObject = null;
            }
            
            if (html5QrCode) {
                html5QrCode.stop().catch(err => {});
                html5QrCode = null;
            }
        }
    </script>
</body>
</html>
