@{
    ViewData["Title"] = "Dashboard SNGPC - Substâncias Controladas";
    var pendingTransmissions = (int)(ViewBag.PendingTransmissions ?? 0);
    var pendingApprovals = (int)(ViewBag.PendingApprovals ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-shield-exclamation text-danger me-2"></i>Dashboard SNGPC</h4>
        <p class="text-muted mb-0">Gestão de Substâncias Controladas - Portaria 344/98</p>
    </div>
</div>

@if (pendingApprovals > 0)
{
    <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
        <div class="flex-grow-1">
            <strong>@pendingApprovals ordens</strong> com substâncias controladas aguardam aprovação farmacêutica.
        </div>
        <a href="/Controlled/PendingApprovals" class="btn btn-danger btn-sm">
            <i class="bi bi-clipboard-check me-1"></i>Aprovar
        </a>
    </div>
}

@if (pendingTransmissions > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-cloud-upload fs-4 me-3"></i>
        <div class="flex-grow-1">
            <strong>@pendingTransmissions movimentações</strong> pendentes de transmissão ao SNGPC/ANVISA.
        </div>
        <a href="/Sngpc/Transmissions" class="btn btn-warning btn-sm">
            <i class="bi bi-send me-1"></i>Transmitir
        </a>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #dc2626 !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Aprovações Pendentes</p>
                        <h3 class="mb-0 text-danger">@pendingApprovals</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded p-2">
                        <i class="bi bi-clipboard-check text-danger fs-4"></i>
                    </div>
                </div>
                <a href="/Controlled/PendingApprovals" class="btn btn-outline-danger btn-sm mt-3 w-100">Ver Pendentes</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #f59e0b !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Transmissões SNGPC</p>
                        <h3 class="mb-0 text-warning">@pendingTransmissions</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded p-2">
                        <i class="bi bi-cloud-upload text-warning fs-4"></i>
                    </div>
                </div>
                <a href="/Sngpc/Transmissions" class="btn btn-outline-warning btn-sm mt-3 w-100">Transmitir</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #10b981 !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Inventário Mensal</p>
                        <h3 class="mb-0 text-success">@DateTime.Now.ToString("MMM/yy")</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded p-2">
                        <i class="bi bi-clipboard-data text-success fs-4"></i>
                    </div>
                </div>
                <a href="/Controlled/Inventory" class="btn btn-outline-success btn-sm mt-3 w-100">Realizar</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #6366f1 !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">Certificações</p>
                        <h3 class="mb-0 text-primary">Fornecedores</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded p-2">
                        <i class="bi bi-award text-primary fs-4"></i>
                    </div>
                </div>
                <a href="/SupplierCertification" class="btn btn-outline-primary btn-sm mt-3 w-100">Ver</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-list-check me-2 text-danger"></i>Listas de Substâncias Controladas</h5>
                    <a href="/Controlled/Movements" class="btn btn-outline-secondary btn-sm">Ver Todas</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Lista</th>
                                <th>Descrição</th>
                                <th>Receituário</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="badge bg-danger">A1</span></td>
                                <td>Entorpecentes</td>
                                <td><span class="badge bg-warning text-dark">Amarela</span></td>
                                <td><a href="/Controlled/Movements?list=A1" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-danger">A2</span></td>
                                <td>Entorpecentes (uso permitido em concentrações especiais)</td>
                                <td><span class="badge bg-warning text-dark">Amarela</span></td>
                                <td><a href="/Controlled/Movements?list=A2" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-danger">A3</span></td>
                                <td>Psicotrópicos (sujeitos a Notificação de Receita "A")</td>
                                <td><span class="badge bg-warning text-dark">Amarela</span></td>
                                <td><a href="/Controlled/Movements?list=A3" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-primary">B1</span></td>
                                <td>Psicotrópicos</td>
                                <td><span class="badge bg-info text-dark">Azul</span></td>
                                <td><a href="/Controlled/Movements?list=B1" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-primary">B2</span></td>
                                <td>Psicotrópicos anorexígenos</td>
                                <td><span class="badge bg-info text-dark">Azul</span></td>
                                <td><a href="/Controlled/Movements?list=B2" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-secondary">C1</span></td>
                                <td>Outras substâncias sujeitas a controle especial</td>
                                <td><span class="badge bg-light text-dark">Branca 2 vias</span></td>
                                <td><a href="/Controlled/Movements?list=C1" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-secondary">C2</span></td>
                                <td>Retinóides de uso sistêmico</td>
                                <td><span class="badge bg-light text-dark">Branca 2 vias</span></td>
                                <td><a href="/Controlled/Movements?list=C2" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-secondary">C4</span></td>
                                <td>Anti-retrovirais</td>
                                <td><span class="badge bg-light text-dark">Receituário Programa</span></td>
                                <td><a href="/Controlled/Movements?list=C4" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-secondary">C5</span></td>
                                <td>Anabolizantes</td>
                                <td><span class="badge bg-light text-dark">Branca 2 vias</span></td>
                                <td><a href="/Controlled/Movements?list=C5" class="btn btn-sm btn-outline-secondary">Ver</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-lightning me-2 text-warning"></i>Ações Rápidas</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Controlled/PendingApprovals" class="btn btn-outline-danger">
                        <i class="bi bi-clipboard-check me-2"></i>Aprovar Controlados
                    </a>
                    <a href="/Controlled/Inventory" class="btn btn-outline-success">
                        <i class="bi bi-clipboard-data me-2"></i>Inventário Mensal
                    </a>
                    <a href="/Controlled/Movements" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left-right me-2"></i>Movimentações
                    </a>
                    <a href="/Controlled/Prescriptions" class="btn btn-outline-secondary">
                        <i class="bi bi-file-medical me-2"></i>Receituários
                    </a>
                    <a href="/SupplierCertification" class="btn btn-outline-info">
                        <i class="bi bi-award me-2"></i>Certificações AFE/AE
                    </a>
                    <a href="/Audit" class="btn btn-outline-dark">
                        <i class="bi bi-shield-check me-2"></i>Portal de Auditoria
                    </a>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-book me-2 text-info"></i>Legislação</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2"><i class="bi bi-file-text text-muted me-2"></i>Portaria 344/98 - SVS/MS</li>
                    <li class="mb-2"><i class="bi bi-file-text text-muted me-2"></i>RDC 67/2007 - Boas Práticas</li>
                    <li class="mb-2"><i class="bi bi-file-text text-muted me-2"></i>RDC 22/2014 - SNGPC</li>
                    <li class="mb-2"><i class="bi bi-file-text text-muted me-2"></i>RDC 471/2021 - Receituário</li>
                    <li><i class="bi bi-file-text text-muted me-2"></i>RDC 20/2011 - Antimicrobianos</li>
                </ul>
            </div>
        </div>
    </div>
</div>
