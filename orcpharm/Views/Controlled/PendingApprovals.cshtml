@using Models.Pharmacy
@model List<ManipulationOrder>
@{
    ViewData["Title"] = "Aprovações Pendentes - Controlados";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-clipboard-check text-danger me-2"></i>Aprovações Farmacêuticas</h4>
        <p class="text-muted mb-0">Manipulações com substâncias controladas aguardando aprovação</p>
    </div>
    <a href="/Controlled" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
</div>

<div class="alert alert-warning mb-4">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <strong>Atenção:</strong> Somente o Farmacêutico RT pode aprovar manipulações contendo substâncias controladas (Portaria 344/98).
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-danger text-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Ordens Pendentes de Aprovação</h5>
            <span class="badge bg-light text-danger">@(Model?.Count ?? 0) pendentes</span>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ordem</th>
                        <th>Fórmula</th>
                        <th>Data Solicitação</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.OrderNumber</strong></td>
                                <td>@(order.Formula?.Name ?? "N/A")</td>
                                <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-warning text-dark">Aguardando Aprovação</span></td>
                                <td>
                                    <a href="/Controlled/Approve/@order.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-clipboard-check me-1"></i>Analisar
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
                                <p class="mb-0">Nenhuma aprovação pendente.</p>
                                <small>Todas as ordens com controlados foram aprovadas.</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
