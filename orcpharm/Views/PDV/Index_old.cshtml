@{
    ViewData["Title"] = "Ponto de Venda";
    Layout = "_Layout";
}

<style>
    .pdv-container {
        height: calc(100vh - 120px);
        overflow: hidden;
    }
    .items-lista {
        max-height: calc(100vh - 320px);
        overflow-y: auto;
    }
    .carrinho-lista {
        max-height: calc(100vh - 450px);
        overflow-y: auto;
    }
    .item-card {
        cursor: pointer;
        transition: all 0.2s;
        border-left: 4px solid transparent;
    }
    .item-card:hover {
        background-color: #f8f9fa;
        border-left-color: #0d6efd;
    }
    .item-card.loaded {
        background-color: #d1e7dd;
        border-left-color: #198754;
    }
    .btn-pagamento {
        height: 60px;
        font-size: 1rem;
    }
    .btn-pagamento.selected {
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.5);
    }
    .total-display {
        font-size: 1.8rem;
        font-weight: bold;
    }
    .caixa-fechado-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.95);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 100;
    }
    .item-carrinho {
        border-bottom: 1px solid #eee;
        padding: 0.5rem 0;
    }
    .nav-tabs .nav-link {
        font-weight: 500;
    }
    .nav-tabs .nav-link.active {
        border-bottom: 3px solid #0d6efd;
    }
    .produto-card {
        cursor: pointer;
        transition: all 0.2s;
    }
    .produto-card:hover {
        background-color: #e7f1ff;
    }
    .badge-count {
        min-width: 22px;
    }
</style>

<div class="container-fluid py-3 pdv-container position-relative">
    <!-- Overlay Caixa Fechado -->
    <div id="caixaFechadoOverlay" class="caixa-fechado-overlay d-none">
        <div class="text-center">
            <i class="bi bi-lock-fill text-warning" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Caixa Fechado</h3>
            <p class="text-muted">Abra o caixa para começar a registrar vendas</p>
            <a href="/Caixa/Abrir" class="btn btn-success btn-lg">
                <i class="bi bi-unlock me-2"></i>Abrir Caixa
            </a>
        </div>
    </div>

    <!-- Header -->
    <div class="row mb-3">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="mb-0">
                        <i class="bi bi-shop me-2"></i>Ponto de Venda
                    </h4>
                    <span id="caixaInfo" class="badge bg-success">
                        <i class="bi bi-unlock me-1"></i>Carregando...
                    </span>
                    <span id="horaAtual" class="badge bg-dark"></span>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary" onclick="refreshData()" title="Atualizar">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                    <a href="/Caixa" class="btn btn-outline-primary">
                        <i class="bi bi-cash-stack me-1"></i>Gestão de Caixa
                    </a>
                    <a href="/Dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-house me-1"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Coluna 1: Itens para Venda (3 Abas) -->
        <div class="col-lg-5">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-primary text-white p-0">
                    <ul class="nav nav-tabs nav-fill" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active text-white" data-bs-toggle="tab" data-bs-target="#tabOnline">
                                <i class="bi bi-globe me-1"></i>Online
                                <span id="badgeOnline" class="badge bg-warning text-dark badge-count ms-1">0</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link text-white" data-bs-toggle="tab" data-bs-target="#tabManipulacoes">
                                <i class="bi bi-prescription2 me-1"></i>Manipulações
                                <span id="badgeManipulacoes" class="badge bg-info badge-count ms-1">0</span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link text-white" data-bs-toggle="tab" data-bs-target="#tabBalcao">
                                <i class="bi bi-shop-window me-1"></i>Balcão
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-0 tab-content">
                    
                    <!-- Tab: Pedidos Online -->
                    <div class="tab-pane fade show active" id="tabOnline">
                        <div class="p-2 border-bottom">
                            <input type="text" class="form-control form-control-sm" 
                                   placeholder="Buscar pedido..." id="buscaOnline" onkeyup="filtrarLista('online')">
                        </div>
                        <div id="listaOnline" class="items-lista">
                            <div class="text-center py-4 text-muted">
                                <div class="spinner-border text-primary mb-2"></div>
                                <p class="mb-0">Carregando pedidos...</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tab: Manipulações Finalizadas -->
                    <div class="tab-pane fade" id="tabManipulacoes">
                        <div class="p-2 border-bottom">
                            <input type="text" class="form-control form-control-sm" 
                                   placeholder="Buscar manipulação..." id="buscaManipulacao" onkeyup="filtrarLista('manipulacao')">
                        </div>
                        <div id="listaManipulacoes" class="items-lista">
                            <div class="text-center py-4 text-muted">
                                <div class="spinner-border text-primary mb-2"></div>
                                <p class="mb-0">Carregando manipulações...</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tab: Venda Balcão -->
                    <div class="tab-pane fade" id="tabBalcao">
                        <div class="p-2 border-bottom">
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" 
                                       placeholder="Buscar produto ou código de barras..." 
                                       id="buscaProduto" onkeypress="if(event.key==='Enter') buscarProdutos()">
                                <button class="btn btn-primary" onclick="buscarProdutos()">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>
                        <div id="listaProdutos" class="items-lista">
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-upc-scan fs-1"></i>
                                <p class="mt-2 mb-0">Digite o nome ou código do produto</p>
                                <small>Os resultados aparecerão aqui</small>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>

        <!-- Coluna 2: Carrinho -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span>
                        <i class="bi bi-cart3 me-2"></i>Carrinho
                        <span id="carrinhoCount" class="badge bg-light text-success ms-1">0</span>
                    </span>
                    <button class="btn btn-sm btn-outline-light" onclick="limparCarrinho()" id="btnLimparCarrinho" disabled>
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <div class="card-body d-flex flex-column p-2">
                    <!-- Cliente -->
                    <div class="mb-2">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" class="form-control" id="clienteNome" placeholder="Cliente (opcional)" readonly>
                            <button class="btn btn-outline-secondary" onclick="buscarCliente()" title="Buscar cliente">
                                <i class="bi bi-search"></i>
                            </button>
                            <button class="btn btn-outline-danger" onclick="limparCliente()" title="Limpar">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                        <input type="hidden" id="clienteId" value="">
                    </div>
                    
                    <!-- Lista de Itens -->
                    <div id="carrinhoItens" class="carrinho-lista flex-grow-1">
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-cart-x fs-1"></i>
                            <p class="mt-2 mb-0">Carrinho vazio</p>
                            <small>Selecione itens à esquerda</small>
                        </div>
                    </div>
                    
                    <!-- Totais -->
                    <div class="border-top pt-2 mt-auto">
                        <div class="d-flex justify-content-between small">
                            <span>Subtotal:</span>
                            <span id="subtotalDisplay">R$ 0,00</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span>Desconto:</span>
                            <div>
                                <input type="number" class="form-control form-control-sm d-inline" 
                                       style="width: 70px;" id="descontoInput" value="0" min="0" step="0.01"
                                       onchange="calcularTotais()">
                            </div>
                        </div>
                        <hr class="my-1">
                        <div class="d-flex justify-content-between align-items-center">
                            <strong>TOTAL:</strong>
                            <span class="total-display text-success" id="totalDisplay">R$ 0,00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Coluna 3: Pagamento -->
        <div class="col-lg-3">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-credit-card me-2"></i>Pagamento</span>
                    <span id="statusPagamento" class="badge bg-dark">Aguardando</span>
                </div>
                <div class="card-body d-flex flex-column p-2">
                    <!-- Formas de Pagamento -->
                    <div class="row g-1 mb-2">
                        <div class="col-6">
                            <button class="btn btn-outline-success btn-pagamento w-100" 
                                    onclick="selecionarPagamento('DINHEIRO')" id="btnDinheiro" disabled>
                                <i class="bi bi-cash-stack d-block"></i>
                                <small>Dinheiro</small>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-primary btn-pagamento w-100" 
                                    onclick="selecionarPagamento('CARTAO_DEBITO')" id="btnDebito" disabled>
                                <i class="bi bi-credit-card d-block"></i>
                                <small>Débito</small>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-info btn-pagamento w-100" 
                                    onclick="selecionarPagamento('CARTAO_CREDITO')" id="btnCredito" disabled>
                                <i class="bi bi-credit-card-2-front d-block"></i>
                                <small>Crédito</small>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-warning btn-pagamento w-100" 
                                    onclick="selecionarPagamento('PIX')" id="btnPix" disabled>
                                <i class="bi bi-qr-code d-block"></i>
                                <small>PIX</small>
                            </button>
                        </div>
                    </div>

                    <!-- Campos de Pagamento -->
                    <div id="camposPagamento" class="d-none flex-grow-1">
                        <!-- Dinheiro -->
                        <div id="camposDinheiro" class="d-none">
                            <label class="form-label small mb-1">Valor Recebido</label>
                            <div class="input-group mb-1">
                                <span class="input-group-text">R$</span>
                                <input type="number" class="form-control" id="valorRecebido" 
                                       step="0.01" min="0" onkeyup="calcularTroco()" onchange="calcularTroco()">
                            </div>
                            <div class="d-flex gap-1 mb-1">
                                <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="setValorRecebido(10)">10</button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="setValorRecebido(20)">20</button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="setValorRecebido(50)">50</button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill" onclick="setValorRecebido(100)">100</button>
                                <button class="btn btn-outline-success btn-sm flex-fill" onclick="setValorExato()">Exato</button>
                            </div>
                            <div id="trocoContainer" class="alert alert-info py-1 mb-0 small">
                                <div class="d-flex justify-content-between">
                                    <span>Troco:</span>
                                    <strong id="trocoDisplay">R$ 0,00</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Cartão -->
                        <div id="camposCartao" class="d-none">
                            <div class="row g-1">
                                <div class="col-6">
                                    <label class="form-label small mb-1">Bandeira</label>
                                    <select class="form-select form-select-sm" id="bandeira">
                                        <option value="VISA">Visa</option>
                                        <option value="MASTERCARD">Master</option>
                                        <option value="ELO">Elo</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-1">4 últimos</label>
                                    <input type="text" class="form-control form-control-sm" id="ultimosDigitos" maxlength="4">
                                </div>
                                <div class="col-6" id="parcelasGroup">
                                    <label class="form-label small mb-1">Parcelas</label>
                                    <select class="form-select form-select-sm" id="parcelas">
                                        <option value="1">1x</option>
                                        <option value="2">2x</option>
                                        <option value="3">3x</option>
                                        <option value="6">6x</option>
                                        <option value="12">12x</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small mb-1">NSU</label>
                                    <input type="text" class="form-control form-control-sm" id="nsu">
                                </div>
                            </div>
                        </div>

                        <!-- PIX -->
                        <div id="camposPix" class="d-none">
                            <label class="form-label small mb-1">ID Transação PIX</label>
                            <input type="text" class="form-control form-control-sm" id="pixTransactionId" 
                                   placeholder="Opcional">
                        </div>
                    </div>

                    <!-- Botão Finalizar -->
                    <div class="mt-auto pt-2">
                        <button class="btn btn-lg btn-success w-100" id="btnFinalizar" 
                                onclick="finalizarVenda()" disabled>
                            <i class="bi bi-check-circle me-2"></i>FINALIZAR
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden Fields -->
<input type="hidden" id="selectedPaymentMethod" value="">
<input type="hidden" id="currentTotal" value="0">

<!-- Modal Buscar Cliente -->
<div class="modal fade" id="modalBuscarCliente" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Buscar Cliente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="buscaClienteInput" 
                           placeholder="Nome, CPF ou telefone...">
                    <button class="btn btn-primary" onclick="executarBuscaCliente()">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <div id="resultadosCliente">
                    <p class="text-muted text-center">Digite para buscar</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Estado global
    let pedidosOnline = [];
    let manipulacoes = [];
    let produtosBusca = [];
    let carrinhoItens = [];
    let caixaAberto = false;
    let totalCarrinho = 0;

    // Inicialização
    document.addEventListener('DOMContentLoaded', function() {
        verificarCaixa();
        carregarDados();
        atualizarHora();
        setInterval(atualizarHora, 1000);
        setInterval(carregarDados, 60000); // Refresh a cada 60s
        
        // Verificar se veio com orderId na URL
        const urlParams = new URLSearchParams(window.location.search);
        const orderId = urlParams.get('orderId');
        const manipulationId = urlParams.get('manipulationId');
        
        if (orderId) {
            setTimeout(() => selecionarPedidoOnline(orderId), 500);
        }
        if (manipulationId) {
            setTimeout(() => selecionarManipulacao(manipulationId), 500);
        }
    });

    function atualizarHora() {
        document.getElementById('horaAtual').textContent = new Date().toLocaleTimeString('pt-BR');
    }

    async function verificarCaixa() {
        try {
            const response = await fetch('/api/PDV/cash-register/status');
            const data = await response.json();
            
            if (data.success && data.data && data.data.isOpen) {
                caixaAberto = true;
                document.getElementById('caixaFechadoOverlay').classList.add('d-none');
                document.getElementById('caixaInfo').innerHTML = 
                    `<i class="bi bi-unlock me-1"></i>${data.data.code}`;
                document.getElementById('caixaInfo').className = 'badge bg-success';
            } else {
                caixaAberto = false;
                document.getElementById('caixaFechadoOverlay').classList.remove('d-none');
                document.getElementById('caixaInfo').innerHTML = '<i class="bi bi-lock me-1"></i>Fechado';
                document.getElementById('caixaInfo').className = 'badge bg-danger';
            }
        } catch (error) {
            console.error('Erro ao verificar caixa:', error);
        }
    }

    async function carregarDados() {
        await Promise.all([
            carregarPedidosOnline(),
            carregarManipulacoes()
        ]);
    }

    // ========== PEDIDOS ONLINE ==========
    async function carregarPedidosOnline() {
        try {
            const response = await fetch('/api/PDV/online-orders-ready');
            const data = await response.json();
            
            if (data.success) {
                pedidosOnline = data.data || [];
                document.getElementById('badgeOnline').textContent = pedidosOnline.length;
                renderizarPedidosOnline();
            }
        } catch (error) {
            console.error('Erro:', error);
        }
    }

    function renderizarPedidosOnline() {
        const container = document.getElementById('listaOnline');
        
        if (pedidosOnline.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-check-circle text-success fs-1"></i>
                    <p class="mt-2 mb-0">Nenhum pedido aguardando</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = pedidosOnline.map(p => `
            <div class="item-card p-2 border-bottom" onclick="selecionarPedidoOnline('${p.id}')" data-search="${p.orderNumber} ${p.customerName}".toLowerCase()>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong class="text-primary">#${p.orderNumber}</strong>
                        <span class="badge bg-success ms-1">Pronto</span>
                        <br><small class="text-muted"><i class="bi bi-person me-1"></i>${p.customerName}</small>
                        <br><small class="text-muted">${p.itemsCount} item(s)</small>
                    </div>
                    <div class="text-end">
                        <strong class="text-success">R$ ${p.total.toFixed(2).replace('.', ',')}</strong>
                        <br><button class="btn btn-sm btn-warning mt-1"><i class="bi bi-cart-plus"></i></button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    async function selecionarPedidoOnline(id) {
        try {
            const response = await fetch(`/api/PDV/online-order/${id}`);
            const data = await response.json();
            
            if (data.success && data.data) {
                const pedido = data.data;
                
                // Adicionar ao carrinho
                carrinhoItens = pedido.items.map(item => ({
                    tipo: 'ONLINE_ORDER',
                    referenciaId: id,
                    descricao: item.productName,
                    quantidade: item.quantity,
                    precoUnitario: item.unitPrice,
                    total: item.totalPrice
                }));
                
                // Setar cliente
                document.getElementById('clienteId').value = pedido.customerId || '';
                document.getElementById('clienteNome').value = pedido.customerName || '';
                
                atualizarCarrinho();
                habilitarPagamento(true);
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro ao carregar pedido');
        }
    }

    // ========== MANIPULAÇÕES ==========
    async function carregarManipulacoes() {
        try {
            const response = await fetch('/api/PDV/manipulations-ready');
            const data = await response.json();
            
            if (data.success) {
                manipulacoes = data.data || [];
                document.getElementById('badgeManipulacoes').textContent = manipulacoes.length;
                renderizarManipulacoes();
            }
        } catch (error) {
            console.error('Erro:', error);
            document.getElementById('listaManipulacoes').innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-exclamation-triangle text-warning fs-1"></i>
                    <p class="mt-2 mb-0">Erro ao carregar</p>
                </div>
            `;
        }
    }

    function renderizarManipulacoes() {
        const container = document.getElementById('listaManipulacoes');
        
        if (manipulacoes.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-check-circle text-success fs-1"></i>
                    <p class="mt-2 mb-0">Nenhuma manipulação aguardando</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = manipulacoes.map(m => `
            <div class="item-card p-2 border-bottom" onclick="selecionarManipulacao('${m.id}')" 
                 data-search="${m.code} ${m.customerName} ${m.formulaName}".toLowerCase()>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong class="text-info">#${m.code}</strong>
                        <span class="badge bg-success ms-1">Finalizado</span>
                        <br><small>${m.formulaName}</small>
                        <br><small class="text-muted"><i class="bi bi-person me-1"></i>${m.customerName}</small>
                    </div>
                    <div class="text-end">
                        <strong class="text-success">R$ ${m.totalPrice.toFixed(2).replace('.', ',')}</strong>
                        <br><button class="btn btn-sm btn-warning mt-1"><i class="bi bi-cart-plus"></i></button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    async function selecionarManipulacao(id) {
        const manip = manipulacoes.find(m => m.id === id);
        if (!manip) return;
        
        // Adicionar ao carrinho
        carrinhoItens.push({
            tipo: 'MANIPULATION',
            referenciaId: id,
            descricao: manip.formulaName + ' (' + manip.code + ')',
            quantidade: 1,
            precoUnitario: manip.totalPrice,
            total: manip.totalPrice
        });
        
        // Setar cliente se não tiver
        if (!document.getElementById('clienteId').value && manip.customerId) {
            document.getElementById('clienteId').value = manip.customerId;
            document.getElementById('clienteNome').value = manip.customerName;
        }
        
        atualizarCarrinho();
        habilitarPagamento(true);
    }

    // ========== PRODUTOS (BALCÃO) ==========
    async function buscarProdutos() {
        const termo = document.getElementById('buscaProduto').value.trim();
        if (!termo || termo.length < 2) {
            alert('Digite pelo menos 2 caracteres');
            return;
        }
        
        const container = document.getElementById('listaProdutos');
        container.innerHTML = `
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2 mb-0">Buscando...</p>
            </div>
        `;
        
        try {
            const response = await fetch(`/api/PDV/products/search?q=${encodeURIComponent(termo)}`);
            const data = await response.json();
            
            if (data.success && data.data && data.data.length > 0) {
                produtosBusca = data.data;
                renderizarProdutos();
            } else {
                container.innerHTML = `
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-search fs-1"></i>
                        <p class="mt-2 mb-0">Nenhum produto encontrado</p>
                    </div>
                `;
            }
        } catch (error) {
            console.error('Erro:', error);
            container.innerHTML = `
                <div class="text-center py-4 text-danger">
                    <i class="bi bi-exclamation-triangle fs-1"></i>
                    <p class="mt-2 mb-0">Erro ao buscar produtos</p>
                </div>
            `;
        }
    }

    function renderizarProdutos() {
        const container = document.getElementById('listaProdutos');
        
        container.innerHTML = produtosBusca.map(p => `
            <div class="produto-card p-2 border-bottom d-flex justify-content-between align-items-center" 
                 onclick="adicionarProduto('${p.id}')">
                <div>
                    <strong>${p.name}</strong>
                    ${p.barcode ? `<br><small class="text-muted"><i class="bi bi-upc me-1"></i>${p.barcode}</small>` : ''}
                    <br><small class="text-muted">Estoque: ${p.stock}</small>
                </div>
                <div class="text-end">
                    <strong class="text-success">R$ ${p.price.toFixed(2).replace('.', ',')}</strong>
                    <br><button class="btn btn-sm btn-success"><i class="bi bi-plus"></i></button>
                </div>
            </div>
        `).join('');
    }

    function adicionarProduto(id) {
        const produto = produtosBusca.find(p => p.id === id);
        if (!produto) return;
        
        // Verificar se já existe no carrinho
        const existente = carrinhoItens.find(i => i.tipo === 'PRODUCT' && i.referenciaId === id);
        if (existente) {
            existente.quantidade++;
            existente.total = existente.quantidade * existente.precoUnitario;
        } else {
            carrinhoItens.push({
                tipo: 'PRODUCT',
                referenciaId: id,
                descricao: produto.name,
                quantidade: 1,
                precoUnitario: produto.price,
                total: produto.price
            });
        }
        
        atualizarCarrinho();
        habilitarPagamento(true);
    }

    // ========== CARRINHO ==========
    function atualizarCarrinho() {
        const container = document.getElementById('carrinhoItens');
        const btnLimpar = document.getElementById('btnLimparCarrinho');
        const countBadge = document.getElementById('carrinhoCount');
        
        countBadge.textContent = carrinhoItens.length;
        
        if (carrinhoItens.length === 0) {
            container.innerHTML = `
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-cart-x fs-1"></i>
                    <p class="mt-2 mb-0">Carrinho vazio</p>
                </div>
            `;
            btnLimpar.disabled = true;
            totalCarrinho = 0;
        } else {
            container.innerHTML = carrinhoItens.map((item, idx) => `
                <div class="item-carrinho">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <small class="fw-bold">${item.descricao}</small>
                            <br>
                            <small class="text-muted">
                                ${item.quantidade}x R$ ${item.precoUnitario.toFixed(2).replace('.', ',')}
                            </small>
                        </div>
                        <div class="text-end">
                            <strong class="text-success">R$ ${item.total.toFixed(2).replace('.', ',')}</strong>
                            <button class="btn btn-sm btn-link text-danger p-0 ms-1" onclick="removerItem(${idx})">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
            
            btnLimpar.disabled = false;
            totalCarrinho = carrinhoItens.reduce((sum, item) => sum + item.total, 0);
        }
        
        calcularTotais();
    }

    function calcularTotais() {
        const desconto = parseFloat(document.getElementById('descontoInput').value) || 0;
        const total = Math.max(0, totalCarrinho - desconto);
        
        document.getElementById('subtotalDisplay').textContent = formatarMoeda(totalCarrinho);
        document.getElementById('totalDisplay').textContent = formatarMoeda(total);
        document.getElementById('currentTotal').value = total;
    }

    function removerItem(idx) {
        carrinhoItens.splice(idx, 1);
        atualizarCarrinho();
        if (carrinhoItens.length === 0) {
            habilitarPagamento(false);
            limparFormPagamento();
        }
    }

    function limparCarrinho() {
        if (!confirm('Limpar todo o carrinho?')) return;
        carrinhoItens = [];
        document.getElementById('clienteId').value = '';
        document.getElementById('clienteNome').value = '';
        document.getElementById('descontoInput').value = '0';
        atualizarCarrinho();
        habilitarPagamento(false);
        limparFormPagamento();
    }

    // ========== PAGAMENTO ==========
    function habilitarPagamento(enabled) {
        ['btnDinheiro', 'btnDebito', 'btnCredito', 'btnPix'].forEach(id => {
            document.getElementById(id).disabled = !enabled;
        });
        document.getElementById('statusPagamento').textContent = enabled ? 'Selecione' : 'Aguardando';
    }

    function selecionarPagamento(metodo) {
        document.getElementById('selectedPaymentMethod').value = metodo;
        
        ['btnDinheiro', 'btnDebito', 'btnCredito', 'btnPix'].forEach(id => {
            document.getElementById(id).classList.remove('selected');
        });
        
        const btnMap = {
            'DINHEIRO': 'btnDinheiro', 'CARTAO_DEBITO': 'btnDebito',
            'CARTAO_CREDITO': 'btnCredito', 'PIX': 'btnPix'
        };
        document.getElementById(btnMap[metodo]).classList.add('selected');
        
        document.getElementById('camposPagamento').classList.remove('d-none');
        document.getElementById('camposDinheiro').classList.add('d-none');
        document.getElementById('camposCartao').classList.add('d-none');
        document.getElementById('camposPix').classList.add('d-none');
        
        if (metodo === 'DINHEIRO') {
            document.getElementById('camposDinheiro').classList.remove('d-none');
        } else if (metodo.includes('CARTAO')) {
            document.getElementById('camposCartao').classList.remove('d-none');
            document.getElementById('parcelasGroup').style.display = metodo === 'CARTAO_CREDITO' ? 'block' : 'none';
        } else if (metodo === 'PIX') {
            document.getElementById('camposPix').classList.remove('d-none');
        }
        
        document.getElementById('btnFinalizar').disabled = false;
        document.getElementById('statusPagamento').textContent = metodo.replace('CARTAO_', '').replace('_', ' ');
    }

    function setValorRecebido(v) {
        document.getElementById('valorRecebido').value = v.toFixed(2);
        calcularTroco();
    }

    function setValorExato() {
        const total = parseFloat(document.getElementById('currentTotal').value) || 0;
        document.getElementById('valorRecebido').value = total.toFixed(2);
        calcularTroco();
    }

    function calcularTroco() {
        const total = parseFloat(document.getElementById('currentTotal').value) || 0;
        const recebido = parseFloat(document.getElementById('valorRecebido').value) || 0;
        const troco = recebido - total;
        document.getElementById('trocoDisplay').textContent = formatarMoeda(Math.max(0, troco));
        
        const container = document.getElementById('trocoContainer');
        container.className = troco < 0 ? 'alert alert-danger py-1 mb-0 small' : 'alert alert-info py-1 mb-0 small';
    }

    function limparFormPagamento() {
        document.getElementById('selectedPaymentMethod').value = '';
        document.getElementById('camposPagamento').classList.add('d-none');
        document.getElementById('valorRecebido').value = '';
        document.getElementById('btnFinalizar').disabled = true;
        ['btnDinheiro', 'btnDebito', 'btnCredito', 'btnPix'].forEach(id => {
            document.getElementById(id).classList.remove('selected');
        });
    }

    async function finalizarVenda() {
        if (!caixaAberto) {
            alert('Abra o caixa primeiro!');
            return;
        }
        
        if (carrinhoItens.length === 0) {
            alert('Carrinho vazio!');
            return;
        }
        
        const metodo = document.getElementById('selectedPaymentMethod').value;
        if (!metodo) {
            alert('Selecione uma forma de pagamento!');
            return;
        }
        
        const total = parseFloat(document.getElementById('currentTotal').value) || 0;
        let valorRecebido = total;
        let troco = 0;
        
        if (metodo === 'DINHEIRO') {
            valorRecebido = parseFloat(document.getElementById('valorRecebido').value) || 0;
            if (valorRecebido < total) {
                alert('Valor recebido insuficiente!');
                return;
            }
            troco = valorRecebido - total;
        }
        
        if (!confirm(`Finalizar venda de ${formatarMoeda(total)}?`)) return;
        
        const btn = document.getElementById('btnFinalizar');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Processando...';
        
        const payload = {
            customerId: document.getElementById('clienteId').value || null,
            items: carrinhoItens,
            discount: parseFloat(document.getElementById('descontoInput').value) || 0,
            payment: {
                method: metodo,
                amount: total,
                cashReceived: metodo === 'DINHEIRO' ? valorRecebido : null,
                changeAmount: troco,
                cardBrand: metodo.includes('CARTAO') ? document.getElementById('bandeira').value : null,
                cardLastDigits: metodo.includes('CARTAO') ? document.getElementById('ultimosDigitos').value : null,
                installments: metodo === 'CARTAO_CREDITO' ? parseInt(document.getElementById('parcelas').value) : 1,
                nsu: metodo.includes('CARTAO') ? document.getElementById('nsu').value : null,
                pixTransactionId: metodo === 'PIX' ? document.getElementById('pixTransactionId').value : null
            }
        };
        
        try {
            const response = await fetch('/api/PDV/sale', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            const data = await response.json();
            
            if (data.success) {
                alert(`✅ Venda finalizada!\n\nCódigo: ${data.data.saleCode}\nTotal: ${formatarMoeda(data.data.total)}`);
                limparCarrinho();
                carregarDados();
            } else {
                alert('❌ Erro: ' + data.message);
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('❌ Erro ao processar venda');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>FINALIZAR';
        }
    }

    // ========== CLIENTE ==========
    function buscarCliente() {
        new bootstrap.Modal(document.getElementById('modalBuscarCliente')).show();
    }

    async function executarBuscaCliente() {
        const termo = document.getElementById('buscaClienteInput').value.trim();
        if (!termo) return;
        
        const container = document.getElementById('resultadosCliente');
        container.innerHTML = '<div class="text-center"><div class="spinner-border spinner-border-sm"></div></div>';
        
        try {
            const response = await fetch(`/api/Customers/search?q=${encodeURIComponent(termo)}`);
            const data = await response.json();
            
            if (data.success && data.data && data.data.length > 0) {
                container.innerHTML = data.data.map(c => `
                    <div class="p-2 border-bottom" style="cursor:pointer" onclick="selecionarCliente('${c.id}', '${c.fullName}')">
                        <strong>${c.fullName}</strong>
                        <br><small class="text-muted">${c.phone || ''} ${c.cpf || ''}</small>
                    </div>
                `).join('');
            } else {
                container.innerHTML = '<p class="text-muted text-center">Nenhum cliente encontrado</p>';
            }
        } catch (error) {
            container.innerHTML = '<p class="text-danger text-center">Erro na busca</p>';
        }
    }

    function selecionarCliente(id, nome) {
        document.getElementById('clienteId').value = id;
        document.getElementById('clienteNome').value = nome;
        bootstrap.Modal.getInstance(document.getElementById('modalBuscarCliente')).hide();
    }

    function limparCliente() {
        document.getElementById('clienteId').value = '';
        document.getElementById('clienteNome').value = '';
    }

    // ========== UTILITÁRIOS ==========
    function formatarMoeda(v) {
        return 'R$ ' + (v || 0).toFixed(2).replace('.', ',');
    }

    function filtrarLista(tipo) {
        const input = tipo === 'online' ? 'buscaOnline' : 'buscaManipulacao';
        const termo = document.getElementById(input).value.toLowerCase();
        const container = tipo === 'online' ? 'listaOnline' : 'listaManipulacoes';
        
        document.querySelectorAll(`#${container} .item-card`).forEach(card => {
            const texto = card.getAttribute('data-search') || '';
            card.style.display = texto.includes(termo) ? '' : 'none';
        });
    }

    function refreshData() {
        carregarDados();
        verificarCaixa();
    }
</script>
}
