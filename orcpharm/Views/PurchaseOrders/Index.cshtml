@{
    ViewData["Title"] = "Matérias-Primas";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-boxes me-2"></i>Matérias-Primas</h2>
            <p class="text-muted mb-0">Gerencie o cadastro de insumos e matérias-primas</p>
        </div>
        <a href="/MateriasPrimas/Criar" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nova Matéria-Prima
        </a>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="searchInput" placeholder="Buscar por nome, CAS, DCB...">
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterControlType">
                        <option value="">Todos os Tipos</option>
                        <option value="COMUM">Comum</option>
                        <option value="A1">Lista A1</option>
                        <option value="A2">Lista A2</option>
                        <option value="A3">Lista A3</option>
                        <option value="B1">Lista B1</option>
                        <option value="B2">Lista B2</option>
                        <option value="C1">Lista C1</option>
                        <option value="C2">Lista C2</option>
                        <option value="C4">Lista C4</option>
                        <option value="C5">Lista C5</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterStatus">
                        <option value="">Todos Status</option>
                        <option value="NORMAL">Estoque Normal</option>
                        <option value="BAIXO">Estoque Baixo</option>
                        <option value="EXCESSO">Excesso</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" id="filterLowStock">
                        <label class="form-check-label" for="filterLowStock">Só Estoque Baixo</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" onclick="clearFilters()">
                        <i class="bi bi-x-lg me-1"></i>Limpar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Estatísticas Rápidas -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10">
                <div class="card-body text-center">
                    <h3 class="text-primary mb-0" id="statTotal">-</h3>
                    <small class="text-muted">Total Cadastradas</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success bg-opacity-10">
                <div class="card-body text-center">
                    <h3 class="text-success mb-0" id="statNormal">-</h3>
                    <small class="text-muted">Estoque Normal</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10">
                <div class="card-body text-center">
                    <h3 class="text-warning mb-0" id="statLow">-</h3>
                    <small class="text-muted">Estoque Baixo</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-danger bg-opacity-10">
                <div class="card-body text-center">
                    <h3 class="text-danger mb-0" id="statControlled">-</h3>
                    <small class="text-muted">Controladas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>CAS</th>
                            <th>DCB/DCI</th>
                            <th class="text-center">Estoque Atual</th>
                            <th class="text-center">Mín/Máx</th>
                            <th class="text-center">Tipo Controle</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Especial</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Carregando...</span>
                                </div>
                                <p class="mt-2 text-muted">Carregando matérias-primas...</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Info de Paginação -->
    <div class="d-flex justify-content-between align-items-center mt-3" id="paginationInfo" style="display: none !important;">
        <small class="text-muted" id="paginationText">Mostrando 0 de 0 registros</small>
        <nav>
            <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
        </nav>
    </div>
</div>

@section Scripts {
<script>
    var allMaterials = [];
    var filteredMaterials = [];
    var pagination = { currentPage: 1, totalPages: 1, totalRecords: 0 };

    document.addEventListener('DOMContentLoaded', function() {
        loadMaterials();
        loadStatistics();
        
        document.getElementById('searchInput').addEventListener('input', debounce(applyFilters, 300));
        document.getElementById('filterControlType').addEventListener('change', applyFilters);
        document.getElementById('filterStatus').addEventListener('change', applyFilters);
        document.getElementById('filterLowStock').addEventListener('change', applyFilters);
    });

    async function loadMaterials() {
        try {
            var search = document.getElementById('searchInput').value;
            var controlType = document.getElementById('filterControlType').value;
            var lowStock = document.getElementById('filterLowStock').checked;
            
            var url = '/api/RawMaterials?pageSize=100';
            if (search) url += '&search=' + encodeURIComponent(search);
            if (controlType) url += '&controlType=' + encodeURIComponent(controlType);
            if (lowStock) url += '&lowStock=true';
            
            var response = await fetch(url, {
                credentials: 'include'
            });
            
            if (!response.ok) {
                if (response.status === 401) {
                    showError('Sessão expirada. Faça login novamente.');
                } else {
                    showError('Erro HTTP ' + response.status);
                }
                return;
            }
            
            var result = await response.json();
            
            if (result.data) {
                allMaterials = result.data;
                filteredMaterials = allMaterials;
                
                if (result.pagination) {
                    pagination = result.pagination;
                }
                
                applyLocalFilters();
            } else if (result.error) {
                showError(result.error);
            }
        } catch (error) {
            console.error('Erro:', error);
            showError('Erro ao conectar: ' + error.message);
        }
    }

    async function loadStatistics() {
        try {
            var response = await fetch('/api/RawMaterials/statistics', {
                credentials: 'include'
            });
            
            if (response.ok) {
                var stats = await response.json();
                document.getElementById('statTotal').textContent = stats.totalMaterials || 0;
                document.getElementById('statNormal').textContent = stats.normalStock || 0;
                document.getElementById('statLow').textContent = stats.lowStock || 0;
                document.getElementById('statControlled').textContent = stats.controlledSubstances || 0;
            }
        } catch (error) {
            console.error('Erro ao carregar estatísticas:', error);
        }
    }

    function applyFilters() {
        loadMaterials();
    }

    function applyLocalFilters() {
        var statusFilter = document.getElementById('filterStatus').value;
        
        if (statusFilter) {
            filteredMaterials = allMaterials.filter(function(m) {
                return m.stockStatus === statusFilter;
            });
        } else {
            filteredMaterials = allMaterials;
        }
        
        renderTable();
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('filterControlType').value = '';
        document.getElementById('filterStatus').value = '';
        document.getElementById('filterLowStock').checked = false;
        loadMaterials();
    }

    function renderTable() {
        var tbody = document.getElementById('tableBody');

        if (filteredMaterials.length === 0) {
            tbody.innerHTML = '<tr><td colspan="9" class="text-center py-5 text-muted">' +
                '<i class="bi bi-inbox fs-1 d-block mb-2"></i>Nenhuma matéria-prima encontrada</td></tr>';
            document.getElementById('paginationInfo').style.display = 'none';
            return;
        }

        var html = '';
        filteredMaterials.forEach(function(m) {
            // Status badge
            var statusBadge = '';
            if (m.stockStatus === 'NORMAL') {
                statusBadge = '<span class="badge bg-success">Normal</span>';
            } else if (m.stockStatus === 'BAIXO') {
                statusBadge = '<span class="badge bg-warning">Baixo</span>';
            } else if (m.stockStatus === 'EXCESSO') {
                statusBadge = '<span class="badge bg-info">Excesso</span>';
            } else {
                statusBadge = '<span class="badge bg-secondary">-</span>';
            }

            // Tipo de controle badge
            var controlBadge = m.controlType === 'COMUM' ? 
                '<span class="badge bg-secondary">Comum</span>' : 
                '<span class="badge bg-danger">' + m.controlType + '</span>';

            // Ícones especiais
            var specialIcons = '';
            if (m.requiresRefrigeration) specialIcons += '<i class="bi bi-snow text-info me-1" title="Refrigeração"></i>';
            if (m.lightSensitive) specialIcons += '<i class="bi bi-sun text-warning me-1" title="Sensível à luz"></i>';
            if (m.humiditySensitive) specialIcons += '<i class="bi bi-droplet text-primary me-1" title="Sensível à umidade"></i>';
            if (m.requiresSpecialAuthorization) specialIcons += '<i class="bi bi-shield-exclamation text-danger me-1" title="Autorização especial"></i>';
            if (!specialIcons) specialIcons = '<span class="text-muted">-</span>';

            // DCB/DCI
            var dcbDci = m.dcbCode || m.dciCode || '-';

            // Barra de progresso do estoque
            var stockPercent = m.stockPercentage || 0;
            var barColor = stockPercent < 25 ? 'bg-danger' : stockPercent < 50 ? 'bg-warning' : 'bg-success';

            html += '<tr>' +
                '<td>' +
                    '<strong>' + (m.name || '-') + '</strong>' +
                    '<div class="progress mt-1" style="height: 4px;">' +
                        '<div class="progress-bar ' + barColor + '" style="width: ' + Math.min(stockPercent, 100) + '%"></div>' +
                    '</div>' +
                '</td>' +
                '<td><code class="small">' + (m.casNumber || '-') + '</code></td>' +
                '<td><small class="text-muted">' + dcbDci + '</small></td>' +
                '<td class="text-center"><strong>' + formatNumber(m.currentStock) + '</strong> <small class="text-muted">' + (m.unit || '') + '</small></td>' +
                '<td class="text-center"><small>' + formatNumber(m.minimumStock) + ' / ' + formatNumber(m.maximumStock) + '</small></td>' +
                '<td class="text-center">' + controlBadge + '</td>' +
                '<td class="text-center">' + statusBadge + '</td>' +
                '<td class="text-center">' + specialIcons + '</td>' +
                '<td class="text-end">' +
                    '<div class="btn-group btn-group-sm">' +
                        '<a href="/MateriasPrimas/Detalhes/' + m.id + '" class="btn btn-outline-primary" title="Detalhes">' +
                            '<i class="bi bi-eye"></i>' +
                        '</a>' +
                        '<a href="/MateriasPrimas/Editar/' + m.id + '" class="btn btn-outline-secondary" title="Editar">' +
                            '<i class="bi bi-pencil"></i>' +
                        '</a>' +
                    '</div>' +
                '</td>' +
            '</tr>';
        });

        tbody.innerHTML = html;
        
        // Atualizar info de paginação
        document.getElementById('paginationInfo').style.display = 'flex';
        document.getElementById('paginationText').textContent = 
            'Mostrando ' + filteredMaterials.length + ' de ' + pagination.totalRecords + ' registros';
    }

    function formatNumber(num) {
        if (num === null || num === undefined) return '0';
        return parseFloat(num).toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    }

    function showError(message) {
        var tbody = document.getElementById('tableBody');
        tbody.innerHTML = '<tr><td colspan="9" class="text-center py-5 text-danger">' +
            '<i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i>' + message + '</td></tr>';
    }

    function debounce(func, wait) {
        var timeout;
        return function() {
            var context = this, args = arguments;
            clearTimeout(timeout);
            timeout = setTimeout(function() {
                func.apply(context, args);
            }, wait);
        };
    }
</script>
}
