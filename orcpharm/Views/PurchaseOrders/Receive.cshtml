@{
    ViewData["Title"] = "Receber Mercadoria";
    var orderId = ViewBag.OrderId;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2><i class="bi bi-box-seam"></i> Receber Mercadoria</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="/compras/@orderId" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <div id="loadingOrder" class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>

    <form id="formReceiveOrder" style="display:none;">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Informações do Pedido</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <strong>Nº Pedido:</strong>
                        <p id="orderNumber"></p>
                    </div>
                    <div class="col-md-3">
                        <strong>Fornecedor:</strong>
                        <p id="supplierName"></p>
                    </div>
                    <div class="col-md-3">
                        <strong>Data do Pedido:</strong>
                        <p id="orderDate"></p>
                    </div>
                    <div class="col-md-3">
                        <strong>Valor Total:</strong>
                        <p id="totalValue" class="text-success fw-bold"></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Dados do Recebimento</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="actualDeliveryDate" class="form-label">Data de Recebimento *</label>
                        <input type="datetime-local" id="actualDeliveryDate" name="actualDeliveryDate" 
                               class="form-control" required>
                    </div>
                    <div class="col-md-4">
                        <label for="supplierInvoiceNumber" class="form-label">Número da Nota Fiscal</label>
                        <input type="text" id="supplierInvoiceNumber" name="supplierInvoiceNumber" 
                               class="form-control" maxlength="100">
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Itens para Receber</h5>
            </div>
            <div class="card-body">
                <div id="itemsContainer"></div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body text-center">
                <button type="submit" class="btn btn-success btn-lg px-5">
                    <i class="bi bi-check-circle"></i> Confirmar Recebimento
                </button>
                <a href="/compras/@orderId" class="btn btn-secondary btn-lg px-5 ms-3">
                    <i class="bi bi-x-circle"></i> Cancelar
                </a>
            </div>
        </div>
    </form>
</div>

<style>
.item-card {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    background-color: #f8f9fa;
}

.item-card.completed {
    background-color: #d1e7dd;
    border-color: #badbcc;
}

.item-header {
    font-weight: bold;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: #0d6efd;
}

.batch-info {
    background-color: white;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 1rem;
    margin-top: 1rem;
}
</style>

@section Scripts {
    <script src="~/js/purchase-orders-receive.js"></script>
    <script>
        $(document).ready(function() {
            PurchaseOrdersReceive.init(@orderId);
        });
    </script>
}
