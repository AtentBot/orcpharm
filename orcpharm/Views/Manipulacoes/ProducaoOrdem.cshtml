@model Models.Pharmacy.ManipulationOrder
@{
    ViewData["Title"] = $"Produção - {Model.OrderNumber}";
    Layout = "_Layout";
}

<style>
    .production-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }
    .step-timeline {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        position: relative;
        padding: 0 20px;
    }
    .step-timeline::before {
        content: '';
        position: absolute;
        top: 20px;
        left: 40px;
        right: 40px;
        height: 4px;
        background: #e9ecef;
        z-index: 0;
    }
    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 1;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .step-item:hover {
        transform: scale(1.05);
    }
    .step-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        background: #e9ecef;
        color: #6c757d;
        border: 3px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .step-circle.completed {
        background: #28a745;
        color: white;
    }
    .step-circle.current {
        background: #007bff;
        color: white;
        animation: pulse 2s infinite;
    }
    .step-circle.pending {
        background: #e9ecef;
        color: #adb5bd;
    }
    @@keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(0,123,255,0.4); }
        50% { box-shadow: 0 0 0 10px rgba(0,123,255,0); }
    }
    .step-label {
        font-size: 0.75rem;
        margin-top: 8px;
        text-align: center;
        max-width: 80px;
    }
    .action-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        transition: all 0.3s;
    }
    .action-card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }
    .action-card .card-header {
        border-radius: 12px 12px 0 0;
        font-weight: 600;
    }
    .btn-step {
        padding: 1rem 2rem;
        font-size: 1.1rem;
        border-radius: 8px;
        min-width: 200px;
    }
    .info-badge {
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
    }
    .component-list {
        max-height: 300px;
        overflow-y: auto;
    }
    .component-item {
        padding: 0.75rem;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .component-item:last-child {
        border-bottom: none;
    }
    .touch-friendly {
        min-height: 60px;
        font-size: 1.1rem;
    }
</style>

<div class="container-fluid py-3">
    <!-- Header da Produção -->
    <div class="production-header">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h4 class="mb-1">
                    <i class="bi bi-gear-wide-connected me-2"></i>
                    @Model.OrderNumber
                </h4>
                <p class="mb-0 opacity-75">
                    @(Model.Formula?.Name ?? "Fórmula Livre") • @Model.QuantityToProduce @Model.Unit
                </p>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="info-badge bg-white text-dark me-2">
                    <i class="bi bi-person me-1"></i>@Model.CustomerName
                </span>
                <span class="info-badge @(Model.ExpectedDate < DateTime.UtcNow ? "bg-danger" : "bg-success")">
                    <i class="bi bi-calendar me-1"></i>@Model.ExpectedDate.ToString("dd/MM HH:mm")
                </span>
            </div>
        </div>
    </div>

    <!-- Timeline de Etapas -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="step-timeline" id="stepTimeline">
                @{
                    var steps = new[] { 
                        ("SEPARACAO", "Separação", "bi-box-seam"),
                        ("PESAGEM", "Pesagem", "bi-speedometer"),
                        ("MISTURA", "Mistura", "bi-arrow-repeat"),
                        ("ENVASE", "Envase", "bi-droplet"),
                        ("ROTULAGEM", "Rotulagem", "bi-tag"),
                        ("CONFERENCIA", "Conferência", "bi-check2-square"),
                        ("APROVACAO", "Aprovação", "bi-patch-check")
                    };
                    
                    // Mapear status para índice da etapa
                    int currentIdx = Model.Status switch {
                        "PENDENTE" or "AGUARDANDO_PRODUCAO" or "EM_PRODUCAO" => -1,
                        "SEPARACAO" => 0,
                        "PESAGEM" => 1,
                        "MISTURA" => 2,
                        "ENVASE" => 3,
                        "ROTULAGEM" => 4,
                        "CONFERENCIA" => 5,
                        "APROVADO" or "FINALIZADO" => 7, // Todas completas
                        _ => -1
                    };
                    
                    for (int i = 0; i < steps.Length; i++)
                    {
                        var stepClass = i < currentIdx ? "completed" : (i == currentIdx ? "current" : "pending");
                        <div class="step-item" onclick="showStepInfo('@steps[i].Item1')">
                            <div class="step-circle @stepClass">
                                @if (i < currentIdx)
                                {
                                    <i class="bi bi-check"></i>
                                }
                                else
                                {
                                    <i class="bi @steps[i].Item3"></i>
                                }
                            </div>
                            <span class="step-label @(i == currentIdx ? "fw-bold text-primary" : "")">
                                @steps[i].Item2
                            </span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Área Principal de Ação -->
        <div class="col-lg-8">
            <div class="card action-card mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-lightning-charge me-2"></i>
                    <span id="currentStepName">@GetNextStepName(Model.Status)</span>
                </div>
                <div class="card-body" id="actionArea">
                    @await Html.PartialAsync("_StepAction", Model)
                </div>
            </div>

            <!-- Componentes da Fórmula -->
            @if (Model.Formula?.Components != null && Model.Formula.Components.Any())
            {
                <div class="card action-card">
                    <div class="card-header bg-light">
                        <i class="bi bi-list-check me-2"></i>
                        Componentes da Fórmula (@Model.Formula.Components.Count)
                    </div>
                    <div class="card-body p-0">
                        <div class="component-list">
                            @foreach (var comp in Model.Formula.Components.OrderBy(c => c.OrderIndex))
                            {
                                var totalQty = comp.Quantity * Model.QuantityToProduce;
                                <div class="component-item">
                                    <div>
                                        <strong>@comp.RawMaterial?.Name</strong>
                                        <br>
                                        <small class="text-muted">
                                            @comp.RawMaterial?.DcbCode
                                            @if (comp.RawMaterial?.ControlType != "COMUM")
                                            {
                                                <span class="badge bg-danger ms-1">Controlado</span>
                                            }
                                        </small>
                                    </div>
                                    <div class="text-end">
                                        <strong class="text-primary">@totalQty.ToString("N2") @comp.Unit</strong>
                                        <br>
                                        <small class="text-muted">(@comp.Quantity @comp.Unit × @Model.QuantityToProduce)</small>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Status e Informações -->
            <div class="card action-card mb-3">
                <div class="card-header bg-light">
                    <i class="bi bi-info-circle me-2"></i>Informações
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> 
                        <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span>
                    </p>
                    <p><strong>Prescritor:</strong> @(Model.PrescriberName ?? "N/A")</p>
                    <p><strong>Receita:</strong> @(Model.PrescriptionNumber ?? "N/A")</p>
                    <p><strong>Início:</strong> @(Model.StartDate?.ToString("dd/MM/yyyy HH:mm") ?? "Não iniciado")</p>
                    @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                    {
                        <hr>
                        <p class="mb-0"><strong>Instruções:</strong></p>
                        <p class="text-muted small">@Model.SpecialInstructions</p>
                    }
                </div>
            </div>

            <!-- Ações Rápidas -->
            <div class="card action-card mb-3">
                <div class="card-header bg-light">
                    <i class="bi bi-lightning me-2"></i>Ações Rápidas
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="/Manipulacoes/FichaPesagem/@Model.Id" target="_blank" 
                       class="btn btn-outline-primary touch-friendly">
                        <i class="bi bi-printer me-2"></i>Imprimir Ficha
                    </a>
                    <a href="/Manipulacoes/Historico/@Model.Id" 
                       class="btn btn-outline-secondary touch-friendly">
                        <i class="bi bi-clock-history me-2"></i>Ver Histórico
                    </a>
                    @if (Model.Status != "FINALIZADO" && Model.Status != "CANCELADO" && Model.Status != "APROVADO")
                    {
                        <button class="btn btn-outline-warning touch-friendly" onclick="pauseProduction()">
                            <i class="bi bi-pause-circle me-2"></i>Pausar Produção
                        </button>
                        <button class="btn btn-outline-danger touch-friendly" onclick="cancelOrder()">
                            <i class="bi bi-x-circle me-2"></i>Cancelar Ordem
                        </button>
                    }
                </div>
            </div>

            <!-- Histórico Recente -->
            <div class="card action-card">
                <div class="card-header bg-light">
                    <i class="bi bi-clock-history me-2"></i>Etapas Concluídas
                </div>
                <div class="card-body p-0" id="recentHistory">
                    <div class="text-center py-3 text-muted">
                        <div class="spinner-border spinner-border-sm"></div>
                        Carregando...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmação -->
<div class="modal fade" id="modalConfirm" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalConfirmTitle">Confirmar Ação</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalConfirmBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnModalConfirm">Confirmar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ===== VARIÁVEIS GLOBAIS (usadas pela partial _StepAction) =====
const orderId = '@Model.Id';
const currentStatus = '@Model.Status';

document.addEventListener('DOMContentLoaded', () => {
    loadRecentHistory();
});

// ===== CARREGAR HISTÓRICO DE ETAPAS =====
async function loadRecentHistory() {
    try {
        const response = await fetch(`/api/ManipulationOrders/${orderId}/steps`);
        const result = await response.json();
        
        if (result.success && result.data && result.data.length > 0) {
            const html = result.data.map(step => `
                <div class="p-2 border-bottom">
                    <div class="d-flex justify-content-between">
                        <strong class="small">${step.stepType}</strong>
                        <span class="badge bg-${step.status === 'CONCLUIDA' ? 'success' : 'warning'} small">${step.status}</span>
                    </div>
                    <small class="text-muted">${step.performedByEmployeeName || 'N/A'} - ${formatDate(step.completedAt)}</small>
                </div>
            `).join('');
            document.getElementById('recentHistory').innerHTML = html || '<div class="text-center py-3 text-muted small">Nenhuma etapa concluída</div>';
        } else {
            document.getElementById('recentHistory').innerHTML = `
                <div class="text-center py-3 text-muted small">
                    <i class="bi bi-info-circle me-1"></i>Nenhuma etapa concluída ainda
                </div>
            `;
        }
    } catch (e) {
        console.error('Erro ao carregar histórico:', e);
        document.getElementById('recentHistory').innerHTML = `
            <div class="text-center py-3 text-danger small">Erro ao carregar histórico</div>
        `;
    }
}

// ===== EXECUTAR ETAPA (FUNÇÃO PRINCIPAL) =====
async function executeStep(stepType, additionalData = {}) {
    const observations = document.getElementById('stepObservations')?.value || '';
    
    const baseData = {
        observations: observations,
        startTime: new Date().toISOString(),
        ...additionalData
    };
    
    try {
        showLoading();
        
        const response = await fetch(`/api/ManipulationOrders/${orderId}/steps/${stepType}/start`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(baseData)
        });
        
        const result = await response.json();
        
        if (result.success || response.ok) {
            showSuccess(result.message || 'Etapa concluída com sucesso!');
            setTimeout(() => location.reload(), 1500);
        } else {
            showError(result.message || 'Erro ao executar etapa. Verifique os dados e tente novamente.');
        }
    } catch (error) {
        console.error('Erro:', error);
        showError('Erro de conexão: ' + error.message);
    }
}

// ===== FUNÇÕES AUXILIARES =====
function showStepInfo(stepType) {
    console.log('Info da etapa:', stepType);
    // Futuro: mostrar modal com informações detalhadas da etapa
}

function pauseProduction() {
    if (confirm('Deseja pausar a produção desta ordem?\n\nA ordem ficará com status atual e poderá ser retomada depois.')) {
        alert('Produção pausada. A ordem permanece no status atual.');
    }
}

async function cancelOrder() {
    const reason = prompt('Informe o motivo do cancelamento (mínimo 10 caracteres):');
    if (!reason || reason.length < 10) {
        alert('Motivo inválido. Informe pelo menos 10 caracteres.');
        return;
    }
    
    if (!confirm('ATENÇÃO: Esta ação é IRREVERSÍVEL!\n\nDeseja realmente CANCELAR esta ordem de manipulação?')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/ManipulationOrders/${orderId}/cancel`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason: reason })
        });
        
        const result = await response.json();
        
        if (result.success || response.ok) {
            alert('Ordem cancelada com sucesso.');
            location.href = '/Manipulacoes';
        } else {
            alert('Erro ao cancelar: ' + (result.message || 'Falha na operação'));
        }
    } catch (e) {
        alert('Erro: ' + e.message);
    }
}

function showLoading() {
    document.getElementById('actionArea').innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3 text-muted">Processando etapa...</p>
        </div>
    `;
}

function showSuccess(msg) {
    document.getElementById('actionArea').innerHTML = `
        <div class="text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
            <h5 class="mt-3 text-success">${msg}</h5>
            <p class="text-muted">Aguarde, a página será atualizada...</p>
        </div>
    `;
}

function showError(msg) {
    document.getElementById('actionArea').innerHTML = `
        <div class="text-center py-5">
            <i class="bi bi-x-circle text-danger" style="font-size: 4rem;"></i>
            <h5 class="mt-3 text-danger">Erro</h5>
            <p class="text-muted">${msg}</p>
            <button class="btn btn-outline-primary mt-2" onclick="location.reload()">
                <i class="bi bi-arrow-clockwise me-2"></i>Tentar Novamente
            </button>
        </div>
    `;
}

function formatDate(d) {
    if (!d) return 'N/A';
    return new Date(d).toLocaleString('pt-BR');
}
</script>
}

@functions {
    string GetNextStepName(string status) => status switch {
        "PENDENTE" or "AGUARDANDO_PRODUCAO" or "EM_PRODUCAO" => "Próxima Ação: Separação de Materiais",
        "SEPARACAO" => "Próxima Ação: Pesagem dos Componentes",
        "PESAGEM" => "Próxima Ação: Mistura / Manipulação",
        "MISTURA" => "Próxima Ação: Envase do Produto",
        "ENVASE" => "Próxima Ação: Rotulagem",
        "ROTULAGEM" => "Próxima Ação: Conferência Final",
        "CONFERENCIA" => "Próxima Ação: Aprovação do Farmacêutico",
        "APROVADO" or "FINALIZADO" => "✓ Manipulação Concluída",
        "CANCELADO" => "✗ Ordem Cancelada",
        "REJEITADO" => "⚠ Manipulação Rejeitada",
        _ => $"Status Atual: {status}"
    };
    
    string GetStatusColor(string status) => status switch {
        "PENDENTE" or "AGUARDANDO_PRODUCAO" => "secondary",
        "EM_PRODUCAO" or "SEPARACAO" or "PESAGEM" or "MISTURA" or "ENVASE" or "ROTULAGEM" => "primary",
        "CONFERENCIA" => "info",
        "APROVADO" or "FINALIZADO" => "success",
        "CANCELADO" or "REJEITADO" => "danger",
        _ => "light"
    };
}
