    async function confirmStep() {
        const stepType = document.getElementById('stepExecutionBody').dataset.stepType;
        const observations = document.getElementById('stepObservations')?.value || '';
        
        let endpoint = `/api/ManipulationOrders/${currentOrder.orderId}/steps/${stepType.toLowerCase()}/start`;
        let payload = { observations };
        
        // Construir payload específico por etapa
        switch(stepType) {
            case 'SEPARACAO':
                payload.areaSeparacao = document.getElementById('areaSeparacao')?.value;
                payload.items = []; // TODO: Carregar itens da ordem
                break;
            case 'PESAGEM':
                payload.scaleName = document.getElementById('balanca')?.value;
                payload.environmentTemperature = parseFloat(document.getElementById('temperatura')?.value) || null;
                payload.environmentHumidity = parseFloat(document.getElementById('umidade')?.value) || null;
                payload.components = []; // TODO: Carregar componentes
                break;
            case 'MISTURA':
                payload.mixingMethod = document.getElementById('metodoMistura')?.value;
                payload.equipment = document.getElementById('equipamento')?.value;
                payload.mixingDuration = parseInt(document.getElementById('tempoMistura')?.value) || null;
                payload.mixingSpeed = parseInt(document.getElementById('velocidade')?.value) || null;
                break;
            case 'ENVASE':
                payload.packagingType = document.getElementById('tipoEmbalagem')?.value;
                payload.packagedQuantity = parseFloat(document.getElementById('quantidadeEnvasada')?.value) || 0;
                break;
            case 'ROTULAGEM':
                payload.batchNumber = document.getElementById('numeroLote')?.value;
                payload.manufacturingDate = document.getElementById('dataFabricacao')?.value;
                payload.expiryDate = document.getElementById('dataValidade')?.value;
                break;
            case 'CONFERENCIA':
                payload.visualAspects = document.getElementById('checkVisual')?.checked;
                payload.packagingIntact = document.getElementById('checkEmbalagem')?.checked;
                payload.labelCorrect = document.getElementById('checkRotulo')?.checked;
                payload.quantityCorrect = document.getElementById('checkQuantidade')?.checked;
                payload.documentationComplete = document.getElementById('checkDocumentacao')?.checked;
                break;
            case 'APROVACAO':
                payload.pharmacistName = document.getElementById('farmaceuticoNome')?.value;
                payload.pharmacistCRF = document.getElementById('farmaceuticoCRF')?.value;
                payload.approved = document.getElementById('checkAprovado')?.checked;
                break;
            case 'EXPEDICAO':
                payload.deliveryMethod = document.getElementById('metodoEntrega')?.value;
                payload.receiverName = document.getElementById('nomeRecebedor')?.value;
                payload.customerNotified = document.getElementById('checkNotificado')?.checked;
                break;
        }

        try {
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify(payload)
            });

            const data = await response.json();
            
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('stepExecutionModal')).hide();
                await openWorkflow(currentOrder.orderId);
                loadOrders();
                showToast('success', data.message || 'Etapa concluída com sucesso!');
            } else {
                showToast('danger', data.message || 'Erro ao concluir etapa');
            }
        } catch (error) {
            console.error('Erro:', error);
            showToast('danger', 'Erro ao processar etapa');
        }
    }

    function formatDate(dateStr) {
        if (!dateStr) return '-';
        return new Date(dateStr).toLocaleDateString('pt-BR');
    }

    function formatTime(dateStr) {
        if (!dateStr) return '-';
        return new Date(dateStr).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    }

    function formatDateTime(dateStr) {
        if (!dateStr) return '-';
        return new Date(dateStr).toLocaleString('pt-BR');
    }

    function formatDuration(duration) {
        if (!duration) return '';
        // Assumindo formato TimeSpan como string
        return duration;
    }

    function showToast(type, message) {
        // Implementar toast notification
        alert(message);
    }
</script>
