function toggleEditMode() {
    isEditMode = !isEditMode;
    
    if (isEditMode) {
        document.getElementById('btnEditar').innerHTML = '<i class="bi bi-x-lg me-1"></i>Cancelar';
        document.getElementById('btnEditar').classList.remove('btn-warning');
        document.getElementById('btnEditar').classList.add('btn-secondary');
        document.getElementById('btnSalvarEdicao').classList.remove('d-none');
        document.getElementById('btnValidar').style.display = 'none';
        document.getElementById('btnOrcamento').style.display = 'none';
    } else {
        document.getElementById('btnEditar').innerHTML = '<i class="bi bi-pencil me-1"></i>Editar';
        document.getElementById('btnEditar').classList.add('btn-warning');
        document.getElementById('btnEditar').classList.remove('btn-secondary');
        document.getElementById('btnSalvarEdicao').classList.add('d-none');
        
        // Restaurar botões
        const data = currentPrescriptionData;
        document.getElementById('btnValidar').style.display = data.status === 'PENDENTE' ? '' : 'none';
        document.getElementById('btnOrcamento').style.display = data.status === 'VALIDADA' && !data.manipulationOrderId ? '' : 'none';
    }
    
    renderDetailsContent(currentPrescriptionData, isEditMode);
}

async function savePrescriptionEdits() {
    if (!currentPrescription) return;
    
    const updateData = {
        prescriptionDate: document.getElementById('editPrescriptionDate').value,
        expirationDate: document.getElementById('editExpirationDate').value,
        prescriptionType: document.getElementById('editPrescriptionType').value,
        controlledType: document.getElementById('editControlledType')?.value || null,
        doctorName: document.getElementById('editDoctorName').value,
        doctorCrm: document.getElementById('editDoctorCrm').value,
        doctorCrmState: document.getElementById('editDoctorCrmState').value,
        customerName: document.getElementById('editCustomerName').value,
        medications: document.getElementById('editMedications').value,
        posology: document.getElementById('editPosology').value,
        observations: document.getElementById('editObservations').value
    };
    
    try {
        const response = await fetch(`/api/Prescriptions/${currentPrescription.id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updateData)
        });
        
        const result = await response.json().catch(() => ({ message: 'Erro de resposta' }));
        
        if (response.ok) {
            showToast('Prescrição atualizada com sucesso!', 'success');
            
            // Atualizar dados locais
            Object.assign(currentPrescriptionData, updateData);
            
            // Voltar ao modo visualização
            toggleEditMode();
            
            // Recarregar lista
            loadPrescriptions();
        } else {
            showToast('Erro: ' + (result.message || 'Falha ao salvar'), 'danger');
        }
    } catch (error) {
        showToast('Erro ao salvar: ' + error.message, 'danger');
    }
}

// Validação
function openValidateModal(id) {
    currentPrescription = prescriptions.find(p => p.id === id);
    document.getElementById('validationNotes').value = '';
    new bootstrap.Modal(document.getElementById('validateModal')).show();
}

async function confirmValidation() {
    if (!currentPrescription) return;
    
    const notes = document.getElementById('validationNotes').value;
    
    try {
        const response = await fetch(`/api/Prescriptions/${currentPrescription.id}/validate`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isValid: true, validationNotes: notes })
        });
        
        const data = await response.json().catch(() => ({ message: 'Erro de resposta do servidor' }));
        
        if (response.ok) {
            bootstrap.Modal.getInstance(document.getElementById('validateModal')).hide();
            bootstrap.Modal.getInstance(document.getElementById('detailsModal'))?.hide();
            showToast(data.message || 'Prescrição validada com sucesso!', 'success');
            loadPrescriptions();
        } else {
            showToast('Erro: ' + (data.message || `Status ${response.status}`), 'danger');
        }
    } catch (error) {
        showToast('Erro ao validar: ' + error.message, 'danger');
    }
}

function validatePrescription() {
    if (currentPrescription) {
        openValidateModal(currentPrescription.id);
    }
}

// Cancelamento
function openCancelModal(id) {
    currentPrescription = prescriptions.find(p => p.id === id);
    document.getElementById('cancelReason').value = '';
    new bootstrap.Modal(document.getElementById('cancelModal')).show();
}

async function confirmCancel() {
    if (!currentPrescription) return;
    
    const reason = document.getElementById('cancelReason').value;
    if (!reason.trim()) {
        showToast('Informe o motivo do cancelamento', 'warning');
        return;
    }
    
    try {
        const response = await fetch(`/api/Prescriptions/${currentPrescription.id}/cancel`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
        });
        
        const data = await response.json().catch(() => ({ message: 'Erro de resposta do servidor' }));
        
        if (response.ok) {
            bootstrap.Modal.getInstance(document.getElementById('cancelModal')).hide();
            showToast(data.message || 'Prescrição cancelada', 'success');
            loadPrescriptions();
        } else {
            showToast('Erro: ' + (data.message || `Status ${response.status}`), 'danger');
        }
    } catch (error) {
        showToast('Erro ao cancelar: ' + error.message, 'danger');
    }
}

// Orçamento
function goToQuote(prescriptionId) {
    window.location.href = `/Prescriptions/Processar?prescriptionId=${prescriptionId}`;
}

function createQuote() {
    if (currentPrescription) {
        goToQuote(currentPrescription.id);
    }
}

// Toast
function showToast(message, type = 'info') {
    const container = document.getElementById('toastContainer') || createToastContainer();
    const toast = document.createElement('div');
    toast.className = `toast align-items-center text-white bg-${type} border-0`;
    toast.setAttribute('role', 'alert');
    toast.innerHTML = `
        <div class="d-flex">
            <div class="toast-body">${message}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    `;
    container.appendChild(toast);
    new bootstrap.Toast(toast).show();
    toast.addEventListener('hidden.bs.toast', () => toast.remove());
}

function createToastContainer() {
    const container = document.createElement('div');
    container.id = 'toastContainer';
    container.className = 'toast-container position-fixed top-0 end-0 p-3';
    container.style.zIndex = '1100';
    document.body.appendChild(container);
    return container;
}

// Busca em tempo real
let searchTimeout;
document.getElementById('filterSearch').addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        currentPage = 1;
        loadPrescriptions();
    }, 500);
});

// Inicialização
document.addEventListener('DOMContentLoaded', () => {
    // Data padrão: último mês
    const now = new Date();
    const lastMonth = new Date(now.getFullYear(), now.getMonth() - 1, now.getDate());
    document.getElementById('filterStartDate').value = lastMonth.toISOString().split('T')[0];
    document.getElementById('filterEndDate').value = now.toISOString().split('T')[0];
    
    loadPrescriptions();
});
</script>
