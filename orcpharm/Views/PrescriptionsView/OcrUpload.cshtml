@{
    ViewData["Title"] = "OCR de Receitas";
    var prescription = Model;
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="bi bi-file-medical"></i> OCR de Receitas
            </h1>
            <p class="text-muted mb-0">Processamento inteligente com IA</p>
        </div>
        <div>
            <a href="@Url.Action("Details", new { id = prescription.Id })" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <!-- Informações da Prescrição -->
    <div class="alert alert-info">
        <strong>Prescrição:</strong> @prescription.Code | 
        <strong>Paciente:</strong> @prescription.CustomerName | 
        <strong>Status:</strong> @prescription.Status
    </div>

    <!-- Step Indicator -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between position-relative">
                <div class="step-line"></div>
                <div class="text-center step-item active" id="step1">
                    <div class="step-number">1</div>
                    <small class="d-block mt-1">Upload</small>
                </div>
                <div class="text-center step-item" id="step2">
                    <div class="step-number">2</div>
                    <small class="d-block mt-1">OCR</small>
                </div>
                <div class="text-center step-item" id="step3">
                    <div class="step-number">3</div>
                    <small class="d-block mt-1">Matching</small>
                </div>
                <div class="text-center step-item" id="step4">
                    <div class="step-number">4</div>
                    <small class="d-block mt-1">Revisão</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Upload Section -->
    <div class="card shadow-sm mb-4" id="uploadSection">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-cloud-upload"></i> Upload da Receita</h5>
        </div>
        <div class="card-body">
            <div class="upload-zone" id="uploadZone">
                <i class="bi bi-cloud-arrow-up" style="font-size: 4rem; color: #6c757d;"></i>
                <h5 class="mt-3">Arraste a receita aqui ou clique para selecionar</h5>
                <p class="text-muted">JPG, PNG ou PDF - Máximo 5MB</p>
                <input type="file" id="fileInput" accept="image/jpeg,image/jpg,image/png,application/pdf" hidden>
            </div>

            <div class="preview-container mt-3" id="previewContainer" style="display: none;">
                <img id="previewImage" class="img-fluid rounded" alt="Preview">
                <div class="mt-3 text-center">
                    <button class="btn btn-outline-danger" onclick="clearUpload()">
                        <i class="bi bi-trash"></i> Remover
                    </button>
                </div>
            </div>

            <div class="mt-4 text-end">
                <button class="btn btn-primary" id="uploadBtn" disabled onclick="uploadFile()">
                    <i class="bi bi-upload"></i> Fazer Upload
                </button>
            </div>
        </div>
    </div>

    <!-- OCR Section -->
    <div class="card shadow-sm mb-4" id="ocrSection" style="display: none;">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-cpu"></i> Processamento OCR</h5>
        </div>
        <div class="card-body">
            <div class="text-center py-5" id="ocrLoading" style="display: none;">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Processando...</span>
                </div>
                <h5 class="mt-3">Processando receita com IA...</h5>
                <p class="text-muted">Isso pode levar alguns segundos</p>
            </div>

            <div id="ocrResults" style="display: none;">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-muted">MÉDICO</h6>
                                <p class="card-text mb-1" id="doctorName">-</p>
                                <small class="text-muted">CRM: <span id="doctorCrm">-</span></small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-muted">PACIENTE</h6>
                                <p class="card-text mb-1" id="patientName">-</p>
                                <small class="text-muted">Idade: <span id="patientAge">-</span></small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-muted">COMPONENTES DETECTADOS</h6>
                        <div id="itemsList"></div>
                    </div>
                </div>

                <div class="card bg-light mb-3">
                    <div class="card-body">
                        <h6 class="card-title text-muted">INSTRUÇÕES</h6>
                        <p class="card-text" id="instructions">-</p>
                    </div>
                </div>

                <div class="text-end">
                    <span class="badge" id="confidenceBadge">-</span>
                </div>
            </div>

            <div class="mt-4 text-end">
                <button class="btn btn-primary" id="processOcrBtn" onclick="processOCR()">
                    <i class="bi bi-magic"></i> Processar OCR
                </button>
                <button class="btn btn-success" id="matchBtn" style="display: none;" onclick="matchIngredients()">
                    <i class="bi bi-search"></i> Buscar Componentes
                </button>
            </div>
        </div>
    </div>

    <!-- Matching Section -->
    <div class="card shadow-sm mb-4" id="matchingSection" style="display: none;">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-box-seam"></i> Matching de Componentes</h5>
        </div>
        <div class="card-body">
            <div class="text-center py-5" id="matchLoading" style="display: none;">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Buscando...</span>
                </div>
                <h5 class="mt-3">Buscando componentes no estoque...</h5>
            </div>

            <div id="matchResults"></div>

            <div class="mt-4 text-end">
                <button class="btn btn-success" id="confirmBtn" style="display: none;" onclick="confirmSelection()">
                    <i class="bi bi-check-circle"></i> Confirmar Seleção
                </button>
            </div>
        </div>
    </div>

    <!-- Review Section -->
    <div class="card shadow-sm mb-4" id="reviewSection" style="display: none;">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Revisão Final</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <strong>Processamento Concluído!</strong>
                <p class="mb-0">Revise os dados e confirme para atualizar a prescrição.</p>
            </div>

            <div id="reviewContent"></div>

            <div class="mt-4 text-end">
                <button class="btn btn-outline-secondary me-2" onclick="startOver()">
                    <i class="bi bi-arrow-clockwise"></i> Processar Nova Receita
                </button>
                <button class="btn btn-success" onclick="updatePrescription()">
                    <i class="bi bi-check-circle"></i> Atualizar Prescrição
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    .upload-zone {
        border: 3px dashed #dee2e6;
        border-radius: 12px;
        padding: 60px 20px;
        text-align: center;
        background: #fff;
        cursor: pointer;
        transition: all 0.3s;
    }

    .upload-zone:hover {
        border-color: #0d6efd;
        background: #f8f9fa;
    }

    .upload-zone.dragover {
        border-color: #198754;
        background: #d1f4e0;
    }

    .step-line {
        position: absolute;
        top: 20px;
        left: 0;
        right: 0;
        height: 2px;
        background: #dee2e6;
        z-index: -1;
    }

    .step-item {
        flex: 1;
        position: relative;
        z-index: 1;
    }

    .step-number {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #dee2e6;
        color: #6c757d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .step-item.active .step-number {
        background: #0d6efd;
        color: white;
    }

    .step-item.completed .step-number {
        background: #198754;
        color: white;
    }

    .suggestion {
        background: #f8f9fa;
        border-left: 3px solid #0d6efd;
        padding: 10px 15px;
        margin: 5px 0;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .suggestion:hover {
        background: #e9ecef;
        transform: translateX(5px);
    }

    .suggestion.selected {
        background: #d1f4e0;
        border-left-color: #198754;
    }

    .confidence-high {
        background: #d1f4e0;
        color: #0a6b2e;
    }

    .confidence-medium {
        background: #fff3cd;
        color: #664d03;
    }

    .confidence-low {
        background: #f8d7da;
        color: #721c24;
    }

    .stock-badge {
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 10px;
    }

    .in-stock {
        background: #d1f4e0;
        color: #0a6b2e;
    }

    .out-stock {
        background: #f8d7da;
        color: #721c24;
    }
</style>
}

@section Scripts {
<script>
    const prescriptionId = '@prescription.Id';
    const appState = {
        uploadedFileId: null,
        ocrResult: null,
        matchResults: null,
        selectedIngredients: {}
    };

    // Setup
    document.addEventListener('DOMContentLoaded', function() {
        setupEventListeners();
    });

    function setupEventListeners() {
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');

        uploadZone.addEventListener('click', () => fileInput.click());

        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('dragover');
        });

        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('dragover');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('dragover');
            if (e.dataTransfer.files.length > 0) {
                handleFileSelect(e.dataTransfer.files[0]);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFileSelect(e.target.files[0]);
            }
        });
    }

    function handleFileSelect(file) {
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf'];
        if (!allowedTypes.includes(file.type)) {
            alert('Tipo de arquivo não permitido. Use JPG, PNG ou PDF.');
            return;
        }

        if (file.size > 5 * 1024 * 1024) {
            alert('Arquivo muito grande. Máximo 5MB.');
            return;
        }

        if (file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = (e) => {
                document.getElementById('previewImage').src = e.target.result;
                document.getElementById('previewContainer').style.display = 'block';
                document.getElementById('uploadZone').style.display = 'none';
            };
            reader.readAsDataURL(file);
        }

        document.getElementById('uploadBtn').disabled = false;
        appState.selectedFile = file;
    }

    function clearUpload() {
        document.getElementById('previewContainer').style.display = 'none';
        document.getElementById('uploadZone').style.display = 'block';
        document.getElementById('uploadBtn').disabled = true;
        document.getElementById('fileInput').value = '';
        appState.selectedFile = null;
    }

    async function uploadFile() {
        if (!appState.selectedFile) {
            alert('Selecione um arquivo primeiro');
            return;
        }

        const uploadBtn = document.getElementById('uploadBtn');
        uploadBtn.disabled = true;
        uploadBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enviando...';

        try {
            const base64 = await fileToBase64(appState.selectedFile);
            
            const payload = {
                fileName: appState.selectedFile.name,
                fileType: appState.selectedFile.type,
                fileBase64: base64
            };

            const response = await fetch(`/api/Prescriptions/${prescriptionId}/upload`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!response.ok) throw new Error('Erro no upload');

            const result = await response.json();
            appState.uploadedFileId = result.fileId;

            alert('Upload realizado com sucesso!');
            moveToStep(2);
            document.getElementById('uploadSection').style.display = 'none';
            document.getElementById('ocrSection').style.display = 'block';

        } catch (error) {
            alert('Erro no upload: ' + error.message);
            uploadBtn.disabled = false;
            uploadBtn.innerHTML = '<i class="bi bi-upload"></i> Fazer Upload';
        }
    }

    async function processOCR() {
        document.getElementById('ocrLoading').style.display = 'block';
        document.getElementById('processOcrBtn').style.display = 'none';

        try {
            const response = await fetch(
                `/api/Prescriptions/${prescriptionId}/files/${appState.uploadedFileId}/parse`,
                { method: 'POST' }
            );

            if (!response.ok) throw new Error('Erro no processamento');

            appState.ocrResult = await response.json();
            displayOCRResults();
            
            document.getElementById('ocrLoading').style.display = 'none';
            document.getElementById('ocrResults').style.display = 'block';
            document.getElementById('matchBtn').style.display = 'inline-block';

        } catch (error) {
            document.getElementById('ocrLoading').style.display = 'none';
            alert('Erro no OCR: ' + error.message);
            document.getElementById('processOcrBtn').style.display = 'inline-block';
        }
    }

    function displayOCRResults() {
        const result = appState.ocrResult;
        
        document.getElementById('doctorName').textContent = result.doctorInfo?.name || '-';
        document.getElementById('doctorCrm').textContent = 
            (result.doctorInfo?.crm || '-') + '/' + (result.doctorInfo?.crmState || '-');
        document.getElementById('patientName').textContent = result.patientInfo?.name || '-';
        document.getElementById('patientAge').textContent = result.patientInfo?.age || '-';

        const itemsList = document.getElementById('itemsList');
        itemsList.innerHTML = '';
        result.items.forEach((item, index) => {
            itemsList.innerHTML += `
                <div class="mb-2 p-2 bg-white rounded">
                    <strong>${index + 1}. ${item.component}</strong><br>
                    <small class="text-muted">Qtd: ${item.quantity} ${item.unit} | "${item.rawText}"</small>
                </div>
            `;
        });

        document.getElementById('instructions').textContent = result.instructions || '-';

        const confidence = result.overallConfidence;
        const badge = document.getElementById('confidenceBadge');
        badge.textContent = `Confiança: ${confidence.toFixed(1)}%`;
        badge.className = 'badge ' + (confidence >= 90 ? 'confidence-high' : confidence >= 70 ? 'confidence-medium' : 'confidence-low');
    }

    async function matchIngredients() {
        moveToStep(3);
        document.getElementById('matchingSection').style.display = 'block';
        document.getElementById('matchLoading').style.display = 'block';

        try {
            const response = await fetch(
                `/api/Prescriptions/${prescriptionId}/match-ingredients`,
                {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: appState.ocrResult.items })
                }
            );

            if (!response.ok) throw new Error('Erro no matching');

            appState.matchResults = await response.json();
            displayMatchResults();

            document.getElementById('matchLoading').style.display = 'none';
            document.getElementById('confirmBtn').style.display = 'inline-block';

        } catch (error) {
            document.getElementById('matchLoading').style.display = 'none';
            alert('Erro no matching: ' + error.message);
        }
    }

    function displayMatchResults() {
        const container = document.getElementById('matchResults');
        container.innerHTML = '';

        appState.matchResults.matches.forEach((match, matchIndex) => {
            let html = `<div class="card mb-3">
                <div class="card-body">
                    <h6>${match.ocrText}</h6>
                    <small class="text-muted">Qtd: ${match.quantity} ${match.unit} | "${match.rawText}"</small>
                    <hr>`;

            if (match.suggestions.length === 0) {
                html += '<div class="alert alert-warning mb-0">Nenhuma sugestão encontrada</div>';
            } else {
                match.suggestions.forEach((suggestion, suggIndex) => {
                    const stockClass = suggestion.inStock ? 'in-stock' : 'out-stock';
                    const stockText = suggestion.inStock 
                        ? `${suggestion.availableQuantity} ${suggestion.unit}` 
                        : 'Sem estoque';
                    
                    html += `
                        <div class="suggestion" data-match="${matchIndex}" data-suggestion="${suggIndex}"
                             onclick="selectSuggestion(${matchIndex}, ${suggIndex})">
                            <div class="d-flex justify-content-between">
                                <div><strong>${suggestion.name}</strong></div>
                                <div>
                                    <span class="badge ${stockClass}">${stockText}</span>
                                    <span class="badge bg-primary">${(suggestion.confidence * 100).toFixed(0)}%</span>
                                </div>
                            </div>
                        </div>`;
                });
            }

            html += '</div></div>';
            container.innerHTML += html;
        });
    }

    function selectSuggestion(matchIndex, suggestionIndex) {
        document.querySelectorAll(`[data-match="${matchIndex}"]`).forEach(el => el.classList.remove('selected'));
        document.querySelector(`[data-match="${matchIndex}"][data-suggestion="${suggestionIndex}"]`).classList.add('selected');

        const match = appState.matchResults.matches[matchIndex];
        const suggestion = match.suggestions[suggestionIndex];
        
        appState.selectedIngredients[matchIndex] = {
            ocrText: match.ocrText,
            quantity: match.quantity,
            unit: match.unit,
            rawMaterialId: suggestion.rawMaterialId,
            name: suggestion.name
        };
    }

    function confirmSelection() {
        const selectedCount = Object.keys(appState.selectedIngredients).length;
        
        if (selectedCount === 0) {
            alert('Selecione pelo menos um componente');
            return;
        }

        moveToStep(4);
        displayReview();
        document.getElementById('reviewSection').style.display = 'block';
    }

    function displayReview() {
        let html = '<h6 class="mb-3">Componentes Selecionados:</h6>';
        
        Object.values(appState.selectedIngredients).forEach((ing, index) => {
            html += `
                <div class="card bg-light mb-2">
                    <div class="card-body py-2">
                        <strong>${index + 1}. ${ing.name}</strong><br>
                        <small class="text-muted">OCR: "${ing.ocrText}" | Qtd: ${ing.quantity} ${ing.unit}</small>
                    </div>
                </div>`;
        });

        document.getElementById('reviewContent').innerHTML = html;
    }

    function updatePrescription() {
        if (confirm('Deseja atualizar a prescrição com os dados processados?')) {
            alert('Funcionalidade em desenvolvimento!');
            console.log('Dados:', appState);
        }
    }

    function moveToStep(stepNumber) {
        for (let i = 1; i <= 4; i++) {
            const step = document.getElementById(`step${i}`);
            step.classList.remove('active', 'completed');
            
            if (i < stepNumber) {
                step.classList.add('completed');
            } else if (i === stepNumber) {
                step.classList.add('active');
            }
        }
    }

    function startOver() {
        if (confirm('Processar nova receita? Os dados atuais serão perdidos.')) {
            location.reload();
        }
    }

    function fileToBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = reject;
            reader.readAsDataURL(file);
        });
    }
</script>
}
</EOF>
