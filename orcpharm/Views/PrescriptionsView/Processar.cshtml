    if (!quoteItems || quoteItems.length === 0) {
        tbody.innerHTML = '';
        noItemsMsg.classList.remove('d-none');
        return;
    }
    
    noItemsMsg.classList.add('d-none');
    
    tbody.innerHTML = quoteItems.map((item, index) => `
        <tr>
            <td>
                <strong>${escapeHtml(item.name)}</strong>
            </td>
            <td class="text-center">${item.quantity} ${item.unit}</td>
            <td class="text-end">${formatMoney(item.totalCost)}</td>
            <td class="text-center">
                <button class="btn btn-sm btn-outline-danger p-0 px-1" onclick="removeQuoteItem(${index})">
                    <i class="bi bi-x"></i>
                </button>
            </td>
        </tr>
    `).join('');
    
    // Atualizar custo total de materiais
    const totalMaterials = quoteItems.reduce((sum, item) => sum + (item.totalCost || 0), 0);
    document.getElementById('quoteMaterialsCost').textContent = formatMoney(totalMaterials);
}

