function selectQuoteRawMaterial(id, name, unitCost) {
    document.getElementById('quoteItemSelectedId').value = id;
    document.getElementById('quoteItemSelectedName').value = name;
    document.getElementById('quoteItemSelectedCost').value = unitCost;
    document.getElementById('quoteItemSearch').value = name;
    document.getElementById('quoteItemSearchResults').classList.add('d-none');
    document.getElementById('quoteItemQuantity').focus();
}

function addQuoteItem() {
    const id = document.getElementById('quoteItemSelectedId').value;
    const name = document.getElementById('quoteItemSelectedName').value;
    const unitCost = parseFloat(document.getElementById('quoteItemSelectedCost').value) || 0;
    const quantity = parseFloat(document.getElementById('quoteItemQuantity').value) || 0;
    const unit = document.getElementById('quoteItemUnit').value;
    
    if (!id || !name) {
        showToast('Selecione uma matéria-prima', 'warning');
        return;
    }
    if (quantity <= 0) {
        showToast('Informe a quantidade', 'warning');
        return;
    }
    
    // Verificar duplicata
    if (quoteItems.some(i => i.rawMaterialId === id)) {
        showToast('Item já adicionado', 'warning');
        return;
    }
    
    // Calcular custo (simplificado - precisa ajustar conforme lógica real)
    const totalCost = unitCost * quantity / 1000; // Assumindo mg para g
    
    quoteItems.push({
        rawMaterialId: id,
        name: name,
        quantity: quantity,
        unit: unit,
        unitCost: unitCost,
        totalCost: totalCost
    });
    
    renderQuoteItems();
    recalculateQuote();
    
    // Limpar form
    document.getElementById('quoteItemSearch').value = '';
    document.getElementById('quoteItemQuantity').value = '';
    document.getElementById('quoteItemSelectedId').value = '';
    document.getElementById('quoteItemSearch').focus();
    
    showToast(`${name} adicionado`, 'success');
}

function removeQuoteItem(index) {
    const removed = quoteItems.splice(index, 1);
    renderQuoteItems();
    recalculateQuote();
    showToast(`${removed[0]?.name || 'Item'} removido`, 'info');
}

// ========== QUOTE RECALCULATION ==========

function recalculateQuote() {
    const materialsCost = quoteItems.reduce((sum, item) => sum + (item.totalCost || 0), 0);
    const markupPercent = parseFloat(document.getElementById('quoteMarkupInput').value) || 0;
    const laborCost = parseFloat(document.getElementById('quoteLaborInput').value) || 0;
    const packagingCost = parseFloat(document.getElementById('quotePackagingInput').value) || 0;
    const discountPercent = parseFloat(document.getElementById('quoteDiscountInput').value) || 0;
    
    const markupValue = materialsCost * (markupPercent / 100);
    const subtotal = materialsCost + markupValue + laborCost + packagingCost;
    const discountValue = subtotal * (discountPercent / 100);
    const finalPrice = subtotal - discountValue;
    
    document.getElementById('quoteMaterialsCost').textContent = formatMoney(materialsCost);
    document.getElementById('quoteMarkupValue').textContent = formatMoney(markupValue);
    document.getElementById('quoteFinalPrice').textContent = formatMoney(finalPrice);
    document.getElementById('quoteTotalValue').textContent = formatMoney(finalPrice);
}

async function updateQuotePricing() {
    if (!createdQuote) {
        showToast('Orçamento não encontrado', 'error');
        return;
    }
    
    const markupPercentage = parseFloat(document.getElementById('quoteMarkupInput').value) || 150;
    const laborCost = parseFloat(document.getElementById('quoteLaborInput').value) || 0;
    const packagingCost = parseFloat(document.getElementById('quotePackagingInput').value) || 0;
    const discountPercentage = parseFloat(document.getElementById('quoteDiscountInput').value) || 0;
    
    showLoading(true, 'Atualizando valores...');
    
    try {
        const response = await fetch(`/api/PrescriptionQuotes/${createdQuote.id}/pricing`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                markupPercentage,
                laborCost,
                packagingCost,
                discountPercentage
            })
        });
        
        if (response.ok) {
            showToast('Valores atualizados!', 'success');
            recalculateQuote();
        } else {
            const result = await response.json();
            showToast('Erro: ' + result.message, 'error');
        }
    } catch (error) {
        showToast('Erro ao atualizar: ' + error.message, 'error');
    } finally {
        showLoading(false);
    }
}

