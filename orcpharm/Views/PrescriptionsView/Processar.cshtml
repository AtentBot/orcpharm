                        <br><small class="text-muted">${m.dcbCode || ''} ${m.unit || ''}</small>
                    </div>
                `).join('');
            } else {
                resultsDiv.innerHTML = '<div class="p-2 text-center text-muted">Nenhum resultado</div>';
            }
