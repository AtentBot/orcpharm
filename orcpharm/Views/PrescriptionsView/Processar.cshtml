</div>

@section Scripts {
<script>
let uploadedFile = null;
let fileBase64 = null;
let ocrResult = null;
let ingredientMatches = [];
let selectedCustomerId = null;
let selectedCustomerData = null;
let createdQuote = null;

// Step 4 - Variáveis do orçamento
let quoteItems = [];
let quoteCustomerData = null;
let quoteDoctorData = null;

// ========== UPLOAD ==========

document.addEventListener('DOMContentLoaded', function() {
    const zone = document.getElementById('uploadZone');
    
    zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('dragover');
    });
    
    zone.addEventListener('dragleave', () => {
        zone.classList.remove('dragover');
    });
    
    zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file) processFile(file);
    });
});

function handleFileSelect(event) {
    const file = event.target.files[0];
    if (file) processFile(file);
}

function processFile(file) {
    if (file.size > 5 * 1024 * 1024) {
        showToast('Arquivo muito grande. Máximo 5MB.', 'error');
        return;
    }
    
    const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf'];
    if (!validTypes.includes(file.type)) {
        showToast('Formato não suportado. Use JPG, PNG ou PDF.', 'error');
        return;
    }
    
    uploadedFile = file;
    
    const reader = new FileReader();
    reader.onload = function(e) {
        fileBase64 = e.target.result.split(',')[1];
        
        document.getElementById('previewImage').src = e.target.result;
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = formatFileSize(file.size);
        document.getElementById('fileType').textContent = file.type;
        
        document.getElementById('uploadZone').classList.add('has-file');
        document.getElementById('previewSection').classList.remove('d-none');
    };
    reader.readAsDataURL(file);
}

function resetUpload() {
    uploadedFile = null;
    fileBase64 = null;
    document.getElementById('fileInput').value = '';
    document.getElementById('uploadZone').classList.remove('has-file');
    document.getElementById('previewSection').classList.add('d-none');
}

// ========== OCR PROCESSING ==========

async function processOcr() {
    if (!fileBase64) {
        showToast('Selecione uma imagem primeiro', 'warning');
        return;
    }
    
    showLoading(true, 'Analisando receita com IA...');
    setStep(2);
    
    try {
        const response = await fetch('/api/PrescriptionQuotes/quick-process', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                imageBase64: fileBase64,
                imageType: uploadedFile.type
            })
        });
        
        const result = await response.json();
        
        if (result.quote) {
            showQuoteResult(result.quote);
            setStep(4);
        } else if (result.ocrResult) {
            ocrResult = result.ocrResult;
            displayOcrResults(result);
            setStep(3);
        } else {
            throw new Error(result.message || 'Erro no processamento');
        }
    } catch (error) {
        console.error('Erro OCR:', error);
        showToast('Erro: ' + error.message, 'error');
        setStep(1);
    } finally {
        showLoading(false);
    }
}

function displayOcrResults(result) {
    document.getElementById('reviewImage').src = document.getElementById('previewImage').src;
    
    if (result.ocrResult) {
        document.getElementById('doctorName').value = result.ocrResult.doctorName || '';
        document.getElementById('doctorCrm').value = result.ocrResult.doctorCrm || '';
        document.getElementById('doctorCrmState').value = result.ocrResult.doctorCrmState || '';
        
        if (result.ocrResult.pharmaceuticalForm) {
            document.getElementById('pharmaceuticalForm').value = result.ocrResult.pharmaceuticalForm;
        }
        if (result.ocrResult.totalQuantity) {
            document.getElementById('totalQuantity').value = result.ocrResult.totalQuantity;
        }
        if (result.ocrResult.instructions) {
            document.getElementById('instructions').value = result.ocrResult.instructions;
        }
    }
    
    if (result.matchedIngredients) {
        ingredientMatches = result.matchedIngredients;
        renderIngredients();
    }
    
    document.getElementById('uploadSection').classList.add('d-none');
    document.getElementById('reviewSection').classList.remove('d-none');
}

function renderIngredients() {
    const container = document.getElementById('ingredientsList');
    const noIngredientsMsg = document.getElementById('noIngredientsMessage');
    
    document.getElementById('ingredientCount').textContent = ingredientMatches.length;
    
    // Mostrar/esconder mensagem de vazio
    if (ingredientMatches.length === 0) {
        container.innerHTML = '';
        if (noIngredientsMsg) {
            noIngredientsMsg.classList.remove('d-none');
            container.appendChild(noIngredientsMsg);
        }
        return;
    }
    
    container.innerHTML = '';
    
    ingredientMatches.forEach((ingredient, index) => {
        const hasMatch = ingredient.matchedRawMaterial != null;
        const confidence = ingredient.confidence || (hasMatch ? 100 : 0);
        const confidenceClass = confidence >= 80 ? 'success' : confidence >= 50 ? 'warning' : 'danger';
        const name = ingredient.matchedRawMaterial?.name || ingredient.originalName || ingredient.name || 'Ingrediente';
        
        container.innerHTML += `
            <div class="card mb-2 ingredient-card ${hasMatch ? 'matched' : 'unmatched'}">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1">
                                <strong class="me-2">${escapeHtml(name)}</strong>
                                ${hasMatch ? '<span class="badge bg-success confidence-badge"><i class="bi bi-check"></i></span>' : `<span class="badge bg-${confidenceClass} confidence-badge">${confidence}%</span>`}
                            </div>
                            <small class="text-muted">${ingredient.quantity || ''} ${ingredient.unit || ''}</small>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="removeIngredient(${index})">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    ${!hasMatch && ingredient.suggestions && ingredient.suggestions.length > 0 ? `
                    <div class="mt-2">
                        <select class="form-select form-select-sm match-select" onchange="updateMatch(${index}, this.value)">
                            <option value="">Selecione a matéria-prima...</option>
                            ${ingredient.suggestions.map(s => 
                                `<option value="${s.id}" ${ingredient.matchedRawMaterial?.id === s.id ? 'selected' : ''}>
                                    ${escapeHtml(s.name)} ${s.dcbCode ? '(' + s.dcbCode + ')' : ''}
                                </option>`
                            ).join('')}
                        </select>
                    </div>
                    ` : ''}
                </div>
            </div>
        `;
    });
}

function updateMatch(index, rawMaterialId) {
    if (rawMaterialId && ingredientMatches[index].suggestions) {
        ingredientMatches[index].matchedRawMaterial = ingredientMatches[index].suggestions.find(s => s.id === rawMaterialId);
    } else {
        ingredientMatches[index].matchedRawMaterial = null;
    }
    renderIngredients();
}

function removeIngredient(index) {
    ingredientMatches.splice(index, 1);
    renderIngredients();
}

// ========== ADICIONAR INGREDIENTE MANUAL ==========

let searchTimeout = null;

function toggleAddIngredient() {
    const form = document.getElementById('addIngredientForm');
    form.classList.toggle('d-none');
    
    if (!form.classList.contains('d-none')) {
        document.getElementById('searchRawMaterial').focus();
    }
    
    // Limpar campos
    document.getElementById('searchRawMaterial').value = '';
    document.getElementById('addQuantity').value = '';
    document.getElementById('addUnit').value = 'mg';
    document.getElementById('selectedRawMaterialId').value = '';
    document.getElementById('selectedRawMaterialName').value = '';
    document.getElementById('selectedRawMaterialInfo').classList.add('d-none');
    document.getElementById('rawMaterialResults').classList.add('d-none');
}

async function searchRawMaterials(query) {
    const resultsDiv = document.getElementById('rawMaterialResults');
    
    if (!query || query.length < 2) {
        resultsDiv.classList.add('d-none');
        return;
    }
    
    // Debounce
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(async () => {
        try {
            const response = await fetch(`/api/RawMaterials?search=${encodeURIComponent(query)}&pageSize=10`);
            
            if (!response.ok) {
                throw new Error('Erro na busca');
            }
            
            const result = await response.json();
            const materials = result.data || result || [];
            
            if (materials && materials.length > 0) {
                resultsDiv.innerHTML = materials.map(m => `
                    <div class="p-2 border-bottom cursor-pointer raw-material-item" 
                         style="cursor: pointer;"
                         onclick="selectRawMaterial('${m.id}', '${escapeHtml(m.name)}', ${m.unitCost || 0}, '${m.dcbCode || ''}')">
                        <div class="fw-bold">${escapeHtml(m.name)}</div>
                        <small class="text-muted">
                            ${m.dcbCode ? `DCB: ${m.dcbCode} | ` : ''}
                            ${m.casNumber || ''} 
                            ${m.stockStatus === 'NORMAL' || m.stockStatus === 'EXCESSO' ? '<span class="text-success">• Em estoque</span>' : '<span class="text-warning">• Estoque baixo</span>'}
                        </small>
                    </div>
                `).join('');
                resultsDiv.classList.remove('d-none');
            } else {
                resultsDiv.innerHTML = '<div class="p-3 text-muted text-center">Nenhuma matéria-prima encontrada</div>';
                resultsDiv.classList.remove('d-none');
            }
        } catch (error) {
            console.error('Erro na busca:', error);
            resultsDiv.innerHTML = '<div class="p-3 text-danger text-center">Erro ao buscar</div>';
            resultsDiv.classList.remove('d-none');
        }
    }, 300);
}

function selectRawMaterial(id, name, unitCost, dcbCode) {
    document.getElementById('selectedRawMaterialId').value = id;
    document.getElementById('selectedRawMaterialName').value = name;
    document.getElementById('selectedRawMaterialUnitCost').value = unitCost;
    document.getElementById('searchRawMaterial').value = name;
    document.getElementById('rawMaterialResults').classList.add('d-none');
    
    // Mostrar info selecionada
    document.getElementById('selectedRawMaterialDisplay').textContent = `${name}${dcbCode ? ' (DCB: ' + dcbCode + ')' : ''}`;
    document.getElementById('selectedRawMaterialInfo').classList.remove('d-none');
    
    // Focar no campo quantidade
    document.getElementById('addQuantity').focus();
}

function addIngredientManual() {
    const rawMaterialId = document.getElementById('selectedRawMaterialId').value;
    const rawMaterialName = document.getElementById('selectedRawMaterialName').value;
    const unitCost = parseFloat(document.getElementById('selectedRawMaterialUnitCost').value) || 0;
    const quantity = document.getElementById('addQuantity').value;
    const unit = document.getElementById('addUnit').value;
    
    if (!rawMaterialId) {
        showToast('Selecione uma matéria-prima', 'warning');
        return;
    }
    
    if (!quantity || parseFloat(quantity) <= 0) {
        showToast('Informe a quantidade', 'warning');
        return;
    }
    
    // Verificar se já existe
    const exists = ingredientMatches.some(i => i.matchedRawMaterial?.id === rawMaterialId);
    if (exists) {
        showToast('Esta matéria-prima já foi adicionada', 'warning');
        return;
    }
    
    // Adicionar ao array
    ingredientMatches.push({
        originalName: rawMaterialName,
        name: rawMaterialName,
        quantity: quantity,
        unit: unit,
        confidence: 100,
        matchedRawMaterial: {
            id: rawMaterialId,
            name: rawMaterialName,
            unitCost: unitCost
        },
        suggestions: []
    });
    
    // Renderizar
    renderIngredients();
    
    // Limpar e fechar formulário
    document.getElementById('searchRawMaterial').value = '';
    document.getElementById('addQuantity').value = '';
    document.getElementById('selectedRawMaterialId').value = '';
    document.getElementById('selectedRawMaterialName').value = '';
    document.getElementById('selectedRawMaterialInfo').classList.add('d-none');
    
    showToast(`${rawMaterialName} adicionado`, 'success');
    
    // Manter form aberto para adicionar mais
    document.getElementById('searchRawMaterial').focus();
}

// Fechar dropdown ao clicar fora
document.addEventListener('click', function(e) {
    const resultsDiv = document.getElementById('rawMaterialResults');
    const searchInput = document.getElementById('searchRawMaterial');
    
    if (resultsDiv && searchInput && !resultsDiv.contains(e.target) && e.target !== searchInput) {
        resultsDiv.classList.add('d-none');
    }
});

// ========== CUSTOMER ==========

async function searchCustomer() {
    const search = document.getElementById('customerSearch').value.trim();
    if (!search) {
        showToast('Digite um termo de busca', 'warning');
        return;
    }
    
    try {
        const response = await fetch(`/api/Customers/search?query=${encodeURIComponent(search)}`);
        const result = await response.json();
        
        if (result && result.length > 0) {
            const customer = result[0];
            selectedCustomerId = customer.id;
            selectedCustomerData = customer;
            document.getElementById('customerName').textContent = customer.fullName;
            document.getElementById('customerPhone').textContent = customer.phone || customer.whatsApp || '-';
            document.getElementById('customerResult').classList.remove('d-none');
            document.getElementById('newCustomerForm').classList.add('d-none');
        } else {
            showToast('Cliente não encontrado', 'warning');
            selectedCustomerId = null;
            selectedCustomerData = null;
        }
    } catch (error) {
        showToast('Erro ao buscar cliente', 'error');
    }
}

function clearCustomer() {
    selectedCustomerId = null;
    selectedCustomerData = null;
    document.getElementById('customerResult').classList.add('d-none');
    document.getElementById('customerSearch').value = '';
}

function toggleNewCustomer() {
    const form = document.getElementById('newCustomerForm');
    form.classList.toggle('d-none');
    document.getElementById('customerResult').classList.add('d-none');
    selectedCustomerId = null;
    selectedCustomerData = null;
}

// ========== GENERATE QUOTE ==========

async function generateQuote() {
    const validIngredients = ingredientMatches.filter(i => i.matchedRawMaterial);
    
    if (validIngredients.length === 0) {
        showToast('Selecione pelo menos um ingrediente', 'warning');
        return;
    }
    
    // Capturar dados do cliente
    const customerName = selectedCustomerData?.fullName || document.getElementById('newCustomerName')?.value || null;
    const customerPhone = selectedCustomerData?.phone || selectedCustomerData?.whatsApp || document.getElementById('newCustomerPhone')?.value || null;
    const customerEmail = selectedCustomerData?.email || document.getElementById('newCustomerEmail')?.value || null;
    
    showLoading(true, 'Gerando orçamento...');
    
    try {
        const payload = {
            imageBase64: fileBase64,
            imageType: uploadedFile.type,
            customerId: selectedCustomerId,
            customerName: customerName,
            customerPhone: customerPhone,
            customerEmail: customerEmail,
            doctorName: document.getElementById('doctorName').value,
            doctorCrm: document.getElementById('doctorCrm').value,
            doctorCrmState: document.getElementById('doctorCrmState').value,
            pharmaceuticalForm: document.getElementById('pharmaceuticalForm').value,
            totalQuantity: parseInt(document.getElementById('totalQuantity').value) || 30,
            quantityUnit: document.getElementById('quantityUnit').value,
            usageType: document.getElementById('usageType').value,
            instructions: document.getElementById('instructions').value,
            confirmedIngredients: validIngredients.map(i => ({
                rawMaterialId: i.matchedRawMaterial.id,
                name: i.matchedRawMaterial.name,
                quantity: parseFloat(i.quantity) || 1,
                unit: i.unit || 'mg'
            }))
        };
        
        const response = await fetch('/api/PrescriptionQuotes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.message || 'Erro ao gerar orçamento');
        }
        
        showQuoteResult(result);
        setStep(4);
        
    } catch (error) {
        console.error('Erro:', error);
        showToast('Erro: ' + error.message, 'error');
    } finally {
        showLoading(false);
    }
}

function showQuoteResult(quote) {
    createdQuote = quote;
    
    document.getElementById('reviewSection').classList.add('d-none');
    document.getElementById('uploadSection').classList.add('d-none');
    document.getElementById('quoteSection').classList.remove('d-none');
    
    // Dados básicos
    document.getElementById('quoteCode').textContent = quote.code;
    document.getElementById('quoteTotalValue').textContent = formatMoney(quote.finalPrice);
    document.getElementById('quoteMaterialsCost').textContent = formatMoney(quote.materialsCost);
    document.getElementById('quoteMarkupInput').value = quote.markupPercentage || 150;
    document.getElementById('quoteMarkupValue').textContent = formatMoney(quote.markupValue);
    document.getElementById('quoteLaborInput').value = quote.laborCost || 10;
    document.getElementById('quotePackagingInput').value = quote.packagingCost || 3;
    document.getElementById('quoteDiscountInput').value = quote.discountPercentage || 0;
    document.getElementById('quoteFinalPrice').textContent = formatMoney(quote.finalPrice);
    
    // Dados do cliente
    quoteCustomerData = {
        id: quote.customerId || selectedCustomerId,
        name: quote.customerName || selectedCustomerData?.fullName || document.getElementById('newCustomerName')?.value || '',
        phone: quote.customerPhone || selectedCustomerData?.phone || document.getElementById('newCustomerPhone')?.value || '',
        email: quote.customerEmail || selectedCustomerData?.email || document.getElementById('newCustomerEmail')?.value || ''
    };
    updateQuoteCustomerDisplay();
    
    // Dados do médico
    quoteDoctorData = {
        name: quote.doctorName || document.getElementById('doctorName')?.value || '',
        crm: quote.doctorCrm || document.getElementById('doctorCrm')?.value || '',
        crmState: quote.doctorCrmState || document.getElementById('doctorCrmState')?.value || 'SE',
        specialty: quote.doctorSpecialty || ''
    };
    updateQuoteDoctorDisplay();
    
    // Dados da fórmula
    document.getElementById('quotePharmForm').value = quote.pharmaceuticalForm || 'Cápsulas';
    document.getElementById('quoteTotalQty').value = quote.totalQuantityNumeric || 30;
    document.getElementById('quoteTotalUnit').value = quote.totalQuantityUnit || 'un';
    document.getElementById('quoteInstructions').value = quote.instructions || '';
    
    // Prazo e validade
    document.getElementById('quoteEstimatedDays').textContent = (quote.estimatedDays || 3) + ' dias';
    if (quote.validUntil) {
        document.getElementById('quoteValidUntil').textContent = new Date(quote.validUntil).toLocaleDateString('pt-BR');
    }
    
    // Popular itens do orçamento
    quoteItems = [];
    if (quote.items && quote.items.length > 0) {
        quote.items.forEach(item => {
            quoteItems.push({
                rawMaterialId: item.rawMaterialId || item.id,
                name: item.rawMaterialName || item.name,
                quantity: item.quantity,
                unit: item.unit || '',
                unitCost: item.unitCost || 0,
                totalCost: item.totalCost || item.cost || 0
            });
        });
    } else if (ingredientMatches && ingredientMatches.length > 0) {
        // Fallback: usar ingredientMatches se não tiver items
        ingredientMatches.filter(i => i.matchedRawMaterial).forEach(ing => {
            quoteItems.push({
                rawMaterialId: ing.matchedRawMaterial.id,
                name: ing.matchedRawMaterial.name,
                quantity: parseFloat(ing.quantity) || 0,
                unit: ing.unit || '',
                unitCost: ing.matchedRawMaterial.unitCost || 0,
                totalCost: 0
            });
        });
    }
    renderQuoteItems();
    
    // Reset estados de edição
    document.getElementById('quoteCustomerEdit').classList.add('d-none');
    document.getElementById('quoteCustomerView').classList.remove('d-none');
    document.getElementById('quoteDoctorEdit').classList.add('d-none');
    document.getElementById('quoteDoctorView').classList.remove('d-none');
    document.getElementById('addQuoteItemForm').classList.add('d-none');
    
    // Reset badges de envio
    document.getElementById('whatsappSentBadge').classList.add('d-none');
    document.getElementById('emailSentBadge').classList.add('d-none');
    
    // Check if already sent
    if (quote.whatsAppSent) {
        document.getElementById('whatsappSentBadge').classList.remove('d-none');
    }
    if (quote.emailSent) {
        document.getElementById('emailSentBadge').classList.remove('d-none');
    }
}

