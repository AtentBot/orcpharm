            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">E-mail do Cliente</label>
                    <input type="email" class="form-control" id="emailTo" placeholder="cliente@email.com">
                </div>
                <div class="mb-3">
                    <label class="form-label">Mensagem (opcional)</label>
                    <textarea class="form-control" id="emailMessage" rows="3" placeholder="Mensagem personalizada..."></textarea>
                </div>
