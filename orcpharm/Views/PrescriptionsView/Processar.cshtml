@{
    ViewData["Title"] = "Novo Orçamento - Processar Receita";
    Layout = "_Layout";
}

<style>
    .upload-zone {
        border: 3px dashed #dee2e6;
        border-radius: 12px;
        padding: 60px 40px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
    .upload-zone:hover, .upload-zone.dragover {
        border-color: #0d6efd;
        background: linear-gradient(135deg, #e7f1ff 0%, #cfe2ff 100%);
    }
    .upload-zone.has-file {
        border-color: #198754;
        background: linear-gradient(135deg, #d1e7dd 0%, #badbcc 100%);
    }
    .upload-zone i {
        font-size: 4rem;
        color: #6c757d;
        margin-bottom: 1rem;
    }
    .upload-zone.has-file i {
        color: #198754;
    }
    .preview-image {
        max-width: 100%;
        max-height: 400px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
    .step-indicator {
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
    }
    .step {
        display: flex;
        align-items: center;
        padding: 0 1.5rem;
    }
    .step-number {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-right: 0.5rem;
        transition: all 0.3s;
    }
    .step.active .step-number {
        background: #0d6efd;
        color: white;
    }
    .step.completed .step-number {
        background: #198754;
        color: white;
    }
    .step-connector {
        width: 60px;
        height: 3px;
        background: #e9ecef;
    }
    .step.completed + .step-connector,
    .step-connector.completed {
        background: #198754;
    }
    .ingredient-card {
        border-left: 4px solid #0d6efd;
        transition: all 0.2s;
    }
    .ingredient-card:hover {
        transform: translateX(5px);
    }
    .ingredient-card.matched {
        border-left-color: #198754;
    }
    .ingredient-card.unmatched {
        border-left-color: #dc3545;
    }
    .confidence-badge {
        font-size: 0.75rem;
    }
    .match-select {
        max-width: 100%;
    }
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.9);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }
    .loading-text {
        margin-top: 1rem;
        font-size: 1.2rem;
        color: #495057;
    }
    .quote-summary {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        color: white;
        border-radius: 12px;
        padding: 2rem;
    }
    .ocr-result-card {
        max-height: 500px;
        overflow-y: auto;
    }
    .customer-card {
        border-left: 4px solid #0d6efd;
    }
    .raw-material-item:hover {
        background-color: #e7f1ff;
    }
    .action-btn {
        padding: 12px 20px;
        font-size: 0.95rem;
    }
    .action-btn i {
        font-size: 1.2rem;
    }
    .sent-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #198754;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/Prescriptions">Orçamentos</a></li>
                    <li class="breadcrumb-item active">Novo Orçamento</li>
                </ol>
            </nav>
            <h4 class="mb-0">
                <i class="bi bi-file-earmark-medical text-success"></i> Processar Receita
            </h4>
        </div>
        <a href="/Prescriptions" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- Step Indicator -->
    <div class="step-indicator mb-4">
        <div class="step active" id="step1">
            <div class="step-number">1</div>
            <span>Upload</span>
        </div>
        <div class="step-connector" id="connector1"></div>
        <div class="step" id="step2">
            <div class="step-number">2</div>
            <span>OCR</span>
        </div>
        <div class="step-connector" id="connector2"></div>
        <div class="step" id="step3">
            <div class="step-number">3</div>
            <span>Revisar</span>
        </div>
        <div class="step-connector" id="connector3"></div>
        <div class="step" id="step4">
            <div class="step-number">4</div>
            <span>Orçamento</span>
        </div>
    </div>

    <!-- Step 1: Upload -->
    <div id="uploadSection">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
                            <i class="bi bi-cloud-arrow-up"></i>
                            <h5>Arraste a imagem da receita aqui</h5>
                            <p class="text-muted mb-2">ou clique para selecionar</p>
                            <small class="text-muted">Formatos: JPG, PNG, PDF (máx. 5MB)</small>
                        </div>
                        <input type="file" id="fileInput" class="d-none" accept="image/*,.pdf" onchange="handleFileSelect(event)">
                        
                        <!-- Preview -->
                        <div id="previewSection" class="mt-4 d-none">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6><i class="bi bi-image"></i> Preview</h6>
                                    <img id="previewImage" class="preview-image" src="" alt="Preview">
                                </div>
                                <div class="col-md-6">
                                    <h6><i class="bi bi-info-circle"></i> Informações</h6>
                                    <table class="table table-sm">
                                        <tr><td>Arquivo:</td><td id="fileName">-</td></tr>
                                        <tr><td>Tamanho:</td><td id="fileSize">-</td></tr>
                                        <tr><td>Tipo:</td><td id="fileType">-</td></tr>
                                    </table>
                                    
                                    <button class="btn btn-success btn-lg w-100 mt-3" onclick="processOcr()">
                                        <i class="bi bi-cpu"></i> Processar com IA
                                    </button>
                                    <button class="btn btn-outline-secondary w-100 mt-2" onclick="resetUpload()">
                                        <i class="bi bi-x-lg"></i> Remover
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2-3: OCR Results & Review -->
    <div id="reviewSection" class="d-none">
        <div class="row">
            <!-- Coluna Esquerda: Imagem -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-image"></i> Receita Original</h6>
                    </div>
                    <div class="card-body p-2">
                        <img id="reviewImage" class="w-100 rounded" src="" alt="Receita">
                    </div>
                </div>

                <!-- Dados do Prescritor -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-person-badge"></i> Prescritor</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small">Nome do Médico</label>
                            <input type="text" class="form-control" id="doctorName" placeholder="Dr(a).">
                        </div>
                        <div class="row">
                            <div class="col-8">
                                <label class="form-label small">CRM</label>
                                <input type="text" class="form-control" id="doctorCrm" placeholder="00000">
                            </div>
                            <div class="col-4">
                                <label class="form-label small">UF</label>
                                <select class="form-select" id="doctorCrmState">
                                    <option value="">-</option>
                                    <option>AC</option><option>AL</option><option>AP</option><option>AM</option>
                                    <option>BA</option><option>CE</option><option>DF</option><option>ES</option>
                                    <option>GO</option><option>MA</option><option>MT</option><option>MS</option>
                                    <option>MG</option><option>PA</option><option>PB</option><option>PR</option>
                                    <option>PE</option><option>PI</option><option>RJ</option><option>RN</option>
                                    <option>RS</option><option>RO</option><option>RR</option><option>SC</option>
                                    <option>SP</option><option>SE</option><option>TO</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cliente -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-person"></i> Cliente</h6>
                    </div>
                    <div class="card-body">
                        <div class="input-group mb-3">
                            <input type="text" class="form-control" id="customerSearch" placeholder="Nome, CPF ou Telefone">
                            <button class="btn btn-outline-primary" onclick="searchCustomer()">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                        
                        <!-- Cliente Encontrado -->
                        <div id="customerResult" class="d-none">
                            <div class="alert alert-success py-2 mb-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong id="customerName">-</strong>
                                        <br><small id="customerPhone">-</small>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" onclick="clearCustomer()">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Novo Cliente -->
                        <div class="text-center mb-2">
                            <button class="btn btn-sm btn-link" onclick="toggleNewCustomer()">
                                <i class="bi bi-plus-circle"></i> Novo Cliente
                            </button>
                        </div>
                        <div id="newCustomerForm" class="d-none">
                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" id="newCustomerName" placeholder="Nome completo *">
                            </div>
                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" id="newCustomerPhone" placeholder="Telefone/WhatsApp *">
                            </div>
                            <div class="mb-2">
                                <input type="email" class="form-control form-control-sm" id="newCustomerEmail" placeholder="E-mail (opcional)">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Coluna Direita: Ingredientes e Fórmula -->
            <div class="col-lg-8">
                <!-- Ingredientes -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-capsule"></i> Ingredientes Identificados</h6>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary" id="ingredientCount">0</span>
                            <button class="btn btn-sm btn-success" onclick="toggleAddIngredient()">
                                <i class="bi bi-plus-lg"></i> Adicionar
                            </button>
                        </div>
                    </div>
                    
                    <!-- Formulário Adicionar Ingrediente -->
                    <div id="addIngredientForm" class="card-body border-bottom bg-light d-none">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label small">Matéria-Prima</label>
                                <div class="position-relative">
                                    <input type="text" class="form-control" id="searchRawMaterial" 
                                           placeholder="Buscar por nome ou código..." 
                                           autocomplete="off"
                                           onkeyup="searchRawMaterials(this.value)">
                                    <div id="rawMaterialResults" class="position-absolute w-100 bg-white border rounded-bottom shadow-sm d-none" 
                                         style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                                    </div>
                                </div>
                                <input type="hidden" id="selectedRawMaterialId">
                                <input type="hidden" id="selectedRawMaterialName">
                                <input type="hidden" id="selectedRawMaterialUnitCost">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Quantidade</label>
                                <input type="number" class="form-control" id="addQuantity" placeholder="Ex: 500" step="0.01" min="0.01">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Unidade</label>
                                <select class="form-select" id="addUnit">
                                    <option value="mg">mg</option>
                                    <option value="mcg">mcg</option>
                                    <option value="g">g</option>
                                    <option value="ml">mL</option>
                                    <option value="UI">UI</option>
                                    <option value="%">%</option>
                                    <option value="qsp">qsp</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-primary w-100" onclick="addIngredientManual()">
                                    <i class="bi bi-plus-circle"></i> Adicionar
                                </button>
                            </div>
                        </div>
                        <div id="selectedRawMaterialInfo" class="mt-2 d-none">
                            <small class="text-success">
                                <i class="bi bi-check-circle"></i> 
                                <span id="selectedRawMaterialDisplay"></span>
                            </small>
                        </div>
                    </div>
                    
                    <div class="card-body ocr-result-card" id="ingredientsList">
                        <!-- Ingredientes serão inseridos aqui -->
                        <div id="noIngredientsMessage" class="text-center text-muted py-4">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mb-0 mt-2">Nenhum ingrediente identificado</p>
                            <small>Clique em "Adicionar" para incluir manualmente</small>
                        </div>
                    </div>
                </div>

                <!-- Informações da Fórmula -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-prescription2"></i> Informações da Fórmula</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label small">Forma Farmacêutica</label>
                                <select class="form-select" id="pharmaceuticalForm">
                                    <option value="CAPSULAS">Cápsulas</option>
                                    <option value="COMPRIMIDOS">Comprimidos</option>
                                    <option value="CREME">Creme</option>
                                    <option value="GEL">Gel</option>
                                    <option value="LOCAO">Loção</option>
                                    <option value="POMADA">Pomada</option>
                                    <option value="SOLUCAO">Solução</option>
                                    <option value="XAROPE">Xarope</option>
                                    <option value="PO">Pó</option>
                                    <option value="SACHE">Sachê</option>
                                    <option value="SUPOSITORIO">Supositório</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small">Quantidade Total</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" id="totalQuantity" value="30" min="1">
                                    <select class="form-select" id="quantityUnit" style="max-width: 80px;">
                                        <option value="un">un</option>
                                        <option value="ml">ml</option>
                                        <option value="g">g</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small">Uso</label>
                                <select class="form-select" id="usageType">
                                    <option value="ORAL">Interno/Oral</option>
                                    <option value="TOPICO">Tópico/Externo</option>
                                    <option value="OFTALMICO">Oftálmico</option>
                                    <option value="NASAL">Nasal</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <label class="form-label small">Posologia / Instruções</label>
                                <textarea class="form-control" id="instructions" rows="2" placeholder="Ex: Tomar 1 cápsula ao dia"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botões de Ação -->
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary" onclick="backToUpload()">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </button>
                    <button class="btn btn-success btn-lg flex-grow-1" onclick="generateQuote()">
                        <i class="bi bi-calculator"></i> Gerar Orçamento
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 4: Quote Result -->
    <div id="quoteSection" class="d-none">
        <div class="row justify-content-center">
            <div class="col-lg-12">
                <!-- Resumo do Orçamento -->
                <div class="quote-summary mb-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h4 class="mb-1"><i class="bi bi-check-circle"></i> Orçamento Gerado!</h4>
                            <p class="mb-0 opacity-75">Código: <strong id="quoteCode">-</strong></p>
                        </div>
                        <div class="col-md-4 text-end">
                            <h2 class="mb-0" id="quoteTotalValue">R$ 0,00</h2>
                            <small class="opacity-75">Valor Total</small>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Coluna Esquerda: Cliente, Médico e Ações -->
                    <div class="col-lg-4">
                        <!-- Card do Cliente -->
                        <div class="card shadow-sm mb-3">
                            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-person-circle text-primary"></i> Cliente</h6>
                                <button class="btn btn-sm btn-outline-primary" onclick="toggleQuoteCustomerEdit()">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                            <div class="card-body">
                                <!-- Visualização do Cliente -->
                                <div id="quoteCustomerView">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" 
                                             style="width: 45px; height: 45px; font-size: 1.2rem;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0" id="quoteCustomerName">Não informado</h6>
                                            <small class="text-muted" id="quoteCustomerPhone">-</small>
                                            <div id="quoteCustomerEmailDisplay" class="text-muted small"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Edição do Cliente -->
                                <div id="quoteCustomerEdit" class="d-none">
                                    <div class="input-group input-group-sm mb-2">
                                        <input type="text" class="form-control" id="quoteCustomerSearch" placeholder="Buscar cliente...">
                                        <button class="btn btn-outline-primary" onclick="searchQuoteCustomer()">
                                            <i class="bi bi-search"></i>
                                        </button>
                                    </div>
                                    <div id="quoteCustomerSearchResults" class="list-group list-group-flush mb-2 d-none" style="max-height: 150px; overflow-y: auto;"></div>
                                    
                                    <div class="border-top pt-2 mt-2">
                                        <small class="text-muted d-block mb-2">Ou cadastre novo:</small>
                                        <input type="text" class="form-control form-control-sm mb-1" id="quoteNewCustomerName" placeholder="Nome completo *">
                                        <input type="text" class="form-control form-control-sm mb-1" id="quoteNewCustomerPhone" placeholder="Telefone/WhatsApp *">
                                        <input type="email" class="form-control form-control-sm mb-2" id="quoteNewCustomerEmail" placeholder="E-mail (opcional)">
                                        <button class="btn btn-sm btn-success w-100" onclick="saveQuoteNewCustomer()">
                                            <i class="bi bi-check"></i> Salvar Cliente
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card do Médico/Prescritor -->
                        <div class="card shadow-sm mb-3">
                            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                <h6 class="mb-0"><i class="bi bi-hospital text-info"></i> Prescritor</h6>
                                <button class="btn btn-sm btn-outline-info" onclick="toggleQuoteDoctorEdit()">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                            <div class="card-body">
                                <!-- Visualização do Médico -->
                                <div id="quoteDoctorView">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-info text-white d-flex align-items-center justify-content-center" 
                                             style="width: 45px; height: 45px; font-size: 1.2rem;">
                                            <i class="bi bi-person-badge"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="mb-0" id="quoteDoctorName">Não informado</h6>
                                            <small class="text-muted" id="quoteDoctorCrm">-</small>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Edição do Médico -->
                                <div id="quoteDoctorEdit" class="d-none">
                                    <div class="input-group input-group-sm mb-2">
                                        <input type="text" class="form-control" id="quoteDoctorSearch" placeholder="Buscar por nome ou CRM...">
                                        <button class="btn btn-outline-info" onclick="searchQuoteDoctor()">
                                            <i class="bi bi-search"></i>
                                        </button>
                                    </div>
                                    <div id="quoteDoctorSearchResults" class="list-group list-group-flush mb-2 d-none" style="max-height: 150px; overflow-y: auto;"></div>
                                    
                                    <div class="border-top pt-2 mt-2">
                                        <small class="text-muted d-block mb-2">Ou informe manualmente:</small>
                                        <input type="text" class="form-control form-control-sm mb-1" id="quoteNewDoctorName" placeholder="Nome do médico *">
                                        <div class="row g-1 mb-2">
                                            <div class="col-8">
                                                <input type="text" class="form-control form-control-sm" id="quoteNewDoctorCrm" placeholder="CRM *">
                                            </div>
                                            <div class="col-4">
                                                <select class="form-select form-select-sm" id="quoteNewDoctorCrmState">
                                                    <option value="SE">SE</option>
                                                    <option value="BA">BA</option>
                                                    <option value="AL">AL</option>
                                                    <option value="SP">SP</option>
                                                    <option value="RJ">RJ</option>
                                                    <option value="MG">MG</option>
                                                </select>
                                            </div>
                                        </div>
                                        <input type="text" class="form-control form-control-sm mb-2" id="quoteNewDoctorSpecialty" placeholder="Especialidade (opcional)">
                                        <button class="btn btn-sm btn-info w-100 text-white" onclick="saveQuoteDoctor()">
                                            <i class="bi bi-check"></i> Confirmar Prescritor
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Prazo e Validade -->
                        <div class="card shadow-sm mb-3">
                            <div class="card-body py-2">
                                <div class="row text-center">
                                    <div class="col-6 border-end">
                                        <div class="text-muted small">Prazo</div>
                                        <strong id="quoteEstimatedDays">3 dias</strong>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-muted small">Válido até</div>
                                        <strong id="quoteValidUntil">-</strong>
                                    </div>
