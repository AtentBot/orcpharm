let quoteItemSearchTimeout = null;

async function searchQuoteRawMaterial(query) {
    const resultsDiv = document.getElementById('quoteItemSearchResults');
    
    if (!query || query.length < 2) {
        resultsDiv.classList.add('d-none');
        return;
    }
    
