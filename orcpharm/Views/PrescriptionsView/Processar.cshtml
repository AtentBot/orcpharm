                                            <td>Desconto (%)</td>
                                            <td class="text-end">
                                                <input type="number" class="form-control form-control-sm text-end" 
                                                       id="quoteDiscountInput" value="0" min="0" max="100" step="0.01"
                                                       style="width: 80px;" onchange="recalculateQuote()">
