@{
    ViewData["Title"] = "Estoque Baixo";
}

@section Styles {
<style>
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .ds-stat {
        background: var(--surface); border: 1px solid var(--rule); border-radius: var(--r-md);
        padding: 16px 20px; display: flex; flex-direction: column; gap: 4px; position: relative; overflow: hidden;
    }
    .ds-stat::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--ink-5); }
    .ds-stat.is-danger::before { background: var(--danger); }
    .ds-stat.is-warn::before { background: var(--amber-500); }
    .ds-stat.is-info::before { background: var(--info); }
    .ds-stat-label { font-size: 12px; color: var(--ink-3); font-weight: 500; }
    .ds-stat-value { font-size: 26px; font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; color: var(--ink); }
    .ds-stat-delta { font-size: 12px; color: var(--ink-3); display: inline-flex; align-items: center; gap: 4px; }
    .ds-stat-delta.danger { color: var(--danger); }
    .ds-stat-delta.warn { color: var(--warn); }
    .ds-stat-delta.info { color: var(--info); }

    .ds-card { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--r-md); overflow: hidden; }
    .ds-card-head { padding: 16px 20px; border-bottom: 1px solid var(--rule); display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
    .ds-card-eyebrow { font-family: var(--font-mono); font-size: 11px; color: var(--petrol-500); margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; }
    .ds-card-title { font-size: 17px; font-weight: 600; letter-spacing: -0.015em; margin: 0; }

    .empty-state { text-align: center; padding: 56px 24px; color: var(--ink-3); }
    .empty-state i { font-size: 44px; color: var(--ok); }
    .empty-state p { margin: 12px 0 0; font-size: 14px; }

    .loading-row { text-align: center; color: var(--ink-3); padding: 40px; }
    .spin { display: inline-block; width: 16px; height: 16px; border: 2px solid var(--ink-5); border-top-color: var(--petrol-500); border-radius: 50%; animation: dsSpin .6s linear infinite; vertical-align: -3px; margin-right: 6px; }
    @@keyframes dsSpin { to { transform: rotate(360deg); } }

    /* Tabela vira lista de cards no mobile */
    @@media (max-width: 820px) {
        .stat-grid { grid-template-columns: repeat(2, 1fr); }
        table.responsive-stack thead { display: none; }
        table.responsive-stack tbody tr {
            display: block; border-bottom: 1px solid var(--rule); padding: 12px 16px;
        }
        table.responsive-stack tbody tr:hover td { background: transparent; }
        table.responsive-stack tbody td {
            display: flex; justify-content: space-between; align-items: center;
            padding: 5px 0; border: none; text-align: right;
        }
        table.responsive-stack tbody td::before {
            content: attr(data-label); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em;
            color: var(--ink-3); font-weight: 500; text-align: left; margin-right: 12px;
        }
        table.responsive-stack tbody td[data-label=""]::before { content: ""; }
        table.responsive-stack tbody td.stack-action { justify-content: flex-end; padding-top: 10px; }
    }
    @@media (max-width: 480px) {
        .stat-grid { grid-template-columns: 1fr; }
    }
</style>
}

<div>
    <div class="page-head">
        <div>
            <div class="eyebrow" style="margin-bottom:6px;">ESTOQUE · ALERTAS</div>
            <h1 style="font-size: var(--t-h2); font-weight: 600; letter-spacing: -0.025em; margin: 0 0 4px;">Estoque Baixo</h1>
            <p style="color: var(--ink-3); font-size: 14px; margin: 0;" id="headSummary">Carregando alertas de reposição…</p>
        </div>
        <div class="row">
            <a class="btn btn-secondary" href="/Stock"><i class="bi bi-arrow-left"></i>Voltar</a>
            <button class="btn btn-primary" onclick="loadLowStock(this)"><i class="bi bi-arrow-clockwise"></i>Atualizar</button>
        </div>
    </div>

    <div class="stat-grid">
        <div class="ds-stat is-danger">
            <div class="ds-stat-label">Itens em falta</div>
            <div class="ds-stat-value" id="kpiOutOfStock">—</div>
            <div class="ds-stat-delta danger"><i class="bi bi-x-circle"></i>estoque zerado</div>
        </div>
        <div class="ds-stat is-warn">
            <div class="ds-stat-label">Estoque baixo</div>
            <div class="ds-stat-value" id="kpiLowStock">—</div>
            <div class="ds-stat-delta warn"><i class="bi bi-exclamation-triangle"></i>abaixo do mínimo</div>
        </div>
        <div class="ds-stat is-info">
            <div class="ds-stat-label">Valor parado</div>
            <div class="ds-stat-value" id="kpiTotalValue">—</div>
            <div class="ds-stat-delta info"><i class="bi bi-cash-stack"></i>capital imobilizado</div>
        </div>
        <div class="ds-stat">
            <div class="ds-stat-label">Total de alertas</div>
            <div class="ds-stat-value" id="kpiTotal">—</div>
            <div class="ds-stat-delta"><i class="bi bi-bell"></i>itens para reposição</div>
        </div>
    </div>

    <div class="ds-card">
        <div class="ds-card-head">
            <div>
                <div class="ds-card-eyebrow">Reposição</div>
                <h3 class="ds-card-title">Matérias-primas com estoque baixo</h3>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table responsive-stack mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Código</th>
                        <th>Nome</th>
                        <th class="text-end">Estoque atual</th>
                        <th class="text-end">Mínimo</th>
                        <th class="text-end">Faltante</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody id="lowStockBody">
                    <tr><td colspan="7" class="loading-row"><span class="spin"></span>Carregando…</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        loadLowStock();
    });

    function fmtQty(n) {
        return (n ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function fmtMoney(n) {
        return (n ?? 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }

    async function loadLowStock(btn) {
        if (btn) { btn.disabled = true; }
        const tbody = document.getElementById('lowStockBody');
        try {
            const response = await fetch('/api/PDV/low-stock-alerts', { credentials: 'include' });
            const result = await response.json();

            const data = (result.success && Array.isArray(result.data)) ? result.data : [];
            tbody.innerHTML = '';

            if (!data.length) {
                tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state">'
                    + '<i class="bi bi-check-circle"></i>'
                    + '<p>Nenhum item com estoque baixo. Tudo em dia. 🎉</p>'
                    + '</div></td></tr>';
                setKpis(0, 0, 0, 0);
                document.getElementById('headSummary').textContent = 'Estoque dentro do nível mínimo — nenhuma reposição pendente.';
                return;
            }

            let outOfStock = 0, lowStock = 0, totalValue = 0;

            data.sort((a, b) => a.currentQuantity - b.currentQuantity).forEach(item => {
                const out = item.currentQuantity <= 0;
                const missing = Math.max(0, (item.minimumStock ?? 0) - (item.currentQuantity ?? 0));
                const unit = item.unit || '';
                if (out) { outOfStock++; } else { lowStock++; }
                totalValue += (item.currentQuantity ?? 0) * (item.unitCost ?? item.averageCost ?? 0);

                const status = out
                    ? '<span class="badge badge-danger badge-no-dot">Sem estoque</span>'
                    : '<span class="badge badge-warn badge-no-dot">Baixo</span>';

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td data-label="Status">${status}</td>
                    <td data-label="Código" class="mono">${item.code ?? '—'}</td>
                    <td data-label="Nome" style="color:var(--ink);font-weight:500;">${item.name ?? '—'}</td>
                    <td data-label="Estoque atual" class="text-end mono" style="color:${out ? 'var(--danger)' : 'var(--warn)'};font-weight:600;">${fmtQty(item.currentQuantity)} ${unit}</td>
                    <td data-label="Mínimo" class="text-end mono">${fmtQty(item.minimumStock)} ${unit}</td>
                    <td data-label="Faltante" class="text-end mono" style="color:var(--danger);font-weight:600;">${fmtQty(missing)} ${unit}</td>
                    <td data-label="" class="text-end stack-action">
                        <button class="btn btn-primary btn-sm" onclick="requestPurchase('${item.rawMaterialId}', ${missing})">
                            <i class="bi bi-cart-plus"></i>Solicitar compra
                        </button>
                    </td>`;
                tbody.appendChild(row);
            });

            setKpis(outOfStock, lowStock, totalValue, data.length);

            const summary = document.getElementById('headSummary');
            summary.innerHTML = '<strong style="color:var(--danger)">' + outOfStock + '</strong> em falta · '
                + '<strong style="color:var(--warn)">' + lowStock + '</strong> abaixo do mínimo · '
                + data.length + ' item(ns) para reposição.';
        } catch (error) {
            console.error('Erro ao carregar alertas:', error);
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--danger);padding:32px;">Erro ao carregar dados.</td></tr>';
            document.getElementById('headSummary').textContent = 'Não foi possível carregar os alertas de estoque.';
        } finally {
            if (btn) { btn.disabled = false; }
        }
    }

    function setKpis(out, low, value, total) {
        document.getElementById('kpiOutOfStock').textContent = out;
        document.getElementById('kpiLowStock').textContent = low;
        document.getElementById('kpiTotalValue').textContent = fmtMoney(value);
        document.getElementById('kpiTotal').textContent = total;
    }

    function requestPurchase(rawMaterialId, quantity) {
        if (confirm(`Deseja criar uma solicitação de compra para esta matéria-prima?\n\nQuantidade sugerida: ${fmtQty(quantity)}`)) {
            window.location.href = `/PurchaseOrders/Create?rawMaterialId=${rawMaterialId}&quantity=${quantity}`;
        }
    }
</script>
}
