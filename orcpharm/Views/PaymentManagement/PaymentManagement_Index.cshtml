@{
    ViewData["Title"] = "Gestão de Pagamentos";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="mb-0">
                    <i class="bi bi-credit-card-2-front me-2"></i>
                    Gestão de Pagamentos
                </h2>
                <div>
                    <button class="btn btn-outline-primary" onclick="window.location.href='@Url.Action("Configuration")'">
                        <i class="bi bi-gear"></i> Configurações
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- KPIs do Dia -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total Recebido Hoje</p>
                            <h3 class="mb-0" id="totalReceivedToday">R$ 0,00</h3>
                            <small class="text-success" id="todayChange">+0%</small>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cash-stack text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Vendas Finalizadas</p>
                            <h3 class="mb-0" id="completedSales">0</h3>
                            <small class="text-info" id="avgTicket">Ticket médio: R$ 0,00</small>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-check-circle text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Pagamentos Pendentes</p>
                            <h3 class="mb-0" id="pendingPayments">0</h3>
                            <small class="text-warning" id="pendingAmount">R$ 0,00 pendente</small>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-hourglass-split text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Método Mais Usado</p>
                            <h3 class="mb-0" id="topMethod">-</h3>
                            <small class="text-primary" id="topMethodPercentage">0%</small>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-graph-up text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Abas de Navegação -->
    <ul class="nav nav-tabs mb-4" id="paymentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
                <i class="bi bi-graph-up-arrow me-2"></i>Visão Geral
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="methods-tab" data-bs-toggle="tab" data-bs-target="#methods" type="button" role="tab">
                <i class="bi bi-wallet2 me-2"></i>Formas de Pagamento
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="transactions-tab" data-bs-toggle="tab" data-bs-target="#transactions" type="button" role="tab">
                <i class="bi bi-list-ul me-2"></i>Transações
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="reports-tab" data-bs-toggle="tab" data-bs-target="#reports" type="button" role="tab">
                <i class="bi bi-file-earmark-bar-graph me-2"></i>Relatórios
            </button>
        </li>
    </ul>

    <!-- Conteúdo das Abas -->
    <div class="tab-content" id="paymentTabsContent">
        
        <!-- Visão Geral -->
        <div class="tab-pane fade show active" id="overview" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Recebimentos dos Últimos 7 Dias</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="paymentsChart" height="80"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Distribuição por Método</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="methodsChart" height="200"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Últimas Transações</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover" id="recentTransactionsTable">
                                    <thead>
                                        <tr>
                                            <th>Data/Hora</th>
                                            <th>Venda</th>
                                            <th>Cliente</th>
                                            <th>Método</th>
                                            <th>Valor</th>
                                            <th>Status</th>
                                            <th>Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody id="recentTransactionsBody">
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">
                                                <i class="bi bi-hourglass-split fs-3 d-block mb-2"></i>
                                                Carregando transações...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Formas de Pagamento -->
        <div class="tab-pane fade" id="methods" role="tabpanel">
            <div class="row g-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Configurar Formas de Pagamento</h5>
                                <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addMethodModal">
                                    <i class="bi bi-plus-lg"></i> Nova Forma
                                </button>
                            </div>
                        </div>
                        <div class="card-body" id="paymentMethodsConfig">
                            <!-- Será preenchido dinamicamente -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Transações -->
        <div class="tab-pane fade" id="transactions" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="mb-0">Todas as Transações</h5>
                        </div>
                        <div class="col-md-6">
                            <div class="row g-2">
                                <div class="col">
                                    <input type="date" class="form-control" id="filterDateStart">
                                </div>
                                <div class="col">
                                    <input type="date" class="form-control" id="filterDateEnd">
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-primary" onclick="filterTransactions()">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="allTransactionsTable">
                            <thead>
                                <tr>
                                    <th>Data/Hora</th>
                                    <th>Venda</th>
                                    <th>Cliente</th>
                                    <th>Método</th>
                                    <th>Detalhes</th>
                                    <th>Valor</th>
                                    <th>Status</th>
                                    <th>Operador</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="allTransactionsBody">
                                <!-- Será preenchido dinamicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Relatórios -->
        <div class="tab-pane fade" id="reports" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Relatório por Período</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Período</label>
                                <select class="form-select" id="reportPeriod" onchange="generateReport()">
                                    <option value="today">Hoje</option>
                                    <option value="week">Última Semana</option>
                                    <option value="month">Último Mês</option>
                                    <option value="custom">Personalizado</option>
                                </select>
                            </div>
                            <div id="customPeriod" class="d-none">
                                <div class="row g-2 mb-3">
                                    <div class="col">
                                        <label class="form-label">Data Inicial</label>
                                        <input type="date" class="form-control" id="reportStartDate">
                                    </div>
                                    <div class="col">
                                        <label class="form-label">Data Final</label>
                                        <input type="date" class="form-control" id="reportEndDate">
                                    </div>
                                </div>
                            </div>
                            <button class="btn btn-primary w-100" onclick="generateReport()">
                                <i class="bi bi-file-earmark-pdf"></i> Gerar Relatório PDF
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Exportar Dados</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-success" onclick="exportToExcel()">
                                    <i class="bi bi-file-earmark-excel"></i> Exportar para Excel
                                </button>
                                <button class="btn btn-outline-info" onclick="exportToCSV()">
                                    <i class="bi bi-filetype-csv"></i> Exportar para CSV
                                </button>
                                <button class="btn btn-outline-secondary" onclick="printReport()">
                                    <i class="bi bi-printer"></i> Imprimir
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 py-3">
                            <h5 class="mb-0">Resumo Financeiro</h5>
                        </div>
                        <div class="card-body">
                            <div id="financialSummary">
                                <!-- Será preenchido dinamicamente -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Adicionar Forma de Pagamento -->
<div class="modal fade" id="addMethodModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nova Forma de Pagamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addMethodForm">
                    <div class="mb-3">
                        <label class="form-label">Nome da Forma</label>
                        <input type="text" class="form-control" id="methodName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" id="methodType" required>
                            <option value="">Selecione...</option>
                            <option value="DINHEIRO">Dinheiro</option>
                            <option value="CARTAO_DEBITO">Cartão de Débito</option>
                            <option value="CARTAO_CREDITO">Cartão de Crédito</option>
                            <option value="PIX">PIX</option>
                            <option value="BOLETO">Boleto</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="methodActive" checked>
                            <label class="form-check-label" for="methodActive">Ativo</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="savePaymentMethod()">Salvar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/payment-management.js"></script>
}
