@{
    ViewData["Title"] = "Configurações de Pagamento";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Gestão de Pagamentos</a></li>
                    <li class="breadcrumb-item active">Configurações</li>
                </ol>
            </nav>
            <h2><i class="bi bi-gear me-2"></i>Configurações de Pagamento</h2>
        </div>
    </div>

    <div class="row g-4">
        <!-- Formas de Pagamento Ativas -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Formas de Pagamento Ativas</h5>
                </div>
                <div class="card-body">
                    <form id="paymentMethodsForm">
                        <div class="list-group">
                            <!-- Dinheiro -->
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-cash-coin text-success fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0">Dinheiro</h6>
                                                <small class="text-muted">Pagamento em espécie</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="enableCash" checked>
                                    </div>
                                </div>
                                <div class="mt-3" id="cashSettings">
                                    <div class="mb-2">
                                        <label class="form-label small">Limite por transação</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">R$</span>
                                            <input type="number" class="form-control" value="10000.00" step="0.01">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Cartão de Débito -->
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-credit-card text-primary fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0">Cartão de Débito</h6>
                                                <small class="text-muted">À vista na conta</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="enableDebit" checked>
                                    </div>
                                </div>
                                <div class="mt-3" id="debitSettings">
                                    <div class="mb-2">
                                        <label class="form-label small">Valor mínimo</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">R$</span>
                                            <input type="number" class="form-control" value="5.00" step="0.01">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Cartão de Crédito -->
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-credit-card-2-front text-info fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0">Cartão de Crédito</h6>
                                                <small class="text-muted">Parcelado ou à vista</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="enableCredit" checked>
                                    </div>
                                </div>
                                <div class="mt-3" id="creditSettings">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="form-label small">Parcelas máximas</label>
                                            <select class="form-select form-select-sm" id="maxInstallments">
                                                <option value="1">1x</option>
                                                <option value="2">2x</option>
                                                <option value="3">3x</option>
                                                <option value="4">4x</option>
                                                <option value="5">5x</option>
                                                <option value="6" selected>6x</option>
                                                <option value="12">12x</option>
                                            </select>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small">Valor mínimo parcela</label>
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">R$</span>
                                                <input type="number" class="form-control" value="30.00" step="0.01">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- PIX -->
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-qr-code text-warning fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0">PIX</h6>
                                                <small class="text-muted">Pagamento instantâneo</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="enablePix" checked>
                                    </div>
                                </div>
                                <div class="mt-3" id="pixSettings">
                                    <div class="mb-2">
                                        <label class="form-label small">Chave PIX da Empresa</label>
                                        <input type="text" class="form-control form-control-sm" 
                                               placeholder="CPF/CNPJ, Email ou Chave Aleatória">
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="autoGenerateQR">
                                        <label class="form-check-label small" for="autoGenerateQR">
                                            Gerar QR Code automaticamente
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Boleto -->
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-upc-scan text-secondary fs-4 me-3"></i>
                                            <div>
                                                <h6 class="mb-0">Boleto Bancário</h6>
                                                <small class="text-muted">Pagamento por boleto</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="enableBoleto">
                                    </div>
                                </div>
                                <div class="mt-3 d-none" id="boletoSettings">
                                    <div class="mb-2">
                                        <label class="form-label small">Dias de vencimento</label>
                                        <input type="number" class="form-control form-control-sm" value="3" min="1">
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small">Valor mínimo</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">R$</span>
                                            <input type="number" class="form-control" value="50.00" step="0.01">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Salvar Configurações
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Preferências e Regras -->
        <div class="col-lg-6">
            <!-- Preferências Gerais -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-sliders me-2"></i>Preferências Gerais</h5>
                </div>
                <div class="card-body">
                    <form id="preferencesForm">
                        <div class="mb-3">
                            <label class="form-label">Forma de pagamento padrão</label>
                            <select class="form-select">
                                <option value="DINHEIRO" selected>Dinheiro</option>
                                <option value="CARTAO_DEBITO">Cartão de Débito</option>
                                <option value="CARTAO_CREDITO">Cartão de Crédito</option>
                                <option value="PIX">PIX</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Desconto máximo permitido</label>
                            <div class="input-group">
                                <input type="number" class="form-control" value="15" min="0" max="100">
                                <span class="input-group-text">%</span>
                            </div>
                            <small class="text-muted">Desconto máximo que operadores podem aplicar</small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="requireCustomer">
                                <label class="form-check-label" for="requireCustomer">
                                    Exigir identificação do cliente
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="allowSplitPayment" checked>
                                <label class="form-check-label" for="allowSplitPayment">
                                    Permitir múltiplas formas de pagamento
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="autoPrintReceipt" checked>
                                <label class="form-check-label" for="autoPrintReceipt">
                                    Imprimir cupom automaticamente
                                </label>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Aplicar Preferências
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Taxas e Encargos -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-percent me-2"></i>Taxas e Encargos</h5>
                </div>
                <div class="card-body">
                    <form id="feesForm">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Configure as taxas cobradas por cada forma de pagamento
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Taxa Cartão de Débito</label>
                            <div class="input-group">
                                <input type="number" class="form-control" value="1.5" step="0.01">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Taxa Cartão de Crédito (à vista)</label>
                            <div class="input-group">
                                <input type="number" class="form-control" value="2.5" step="0.01">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Taxa Cartão de Crédito (parcelado)</label>
                            <div class="input-group">
                                <input type="number" class="form-control" value="3.5" step="0.01">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Taxa PIX</label>
                            <div class="input-group">
                                <input type="number" class="form-control" value="0.99" step="0.01">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Taxa Boleto</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" class="form-control" value="2.50" step="0.01">
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Salvar Taxas
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Backup e Restauração -->
    <div class="row g-4 mt-2">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-cloud-download me-2"></i>Backup e Restauração</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Exportar Configurações</h6>
                            <p class="text-muted small">Faça backup de todas as configurações de pagamento</p>
                            <button class="btn btn-outline-primary" onclick="exportConfig()">
                                <i class="bi bi-download"></i> Exportar JSON
                            </button>
                        </div>
                        <div class="col-md-6">
                            <h6>Importar Configurações</h6>
                            <p class="text-muted small">Restaurar configurações de um backup anterior</p>
                            <input type="file" class="form-control" id="configFile" accept=".json">
                            <button class="btn btn-outline-success mt-2" onclick="importConfig()">
                                <i class="bi bi-upload"></i> Importar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('paymentMethodsForm').addEventListener('submit', function(e) {
            e.preventDefault();
            // Implementar salvamento
            alert('Configurações salvas com sucesso!');
        });

        document.getElementById('preferencesForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Preferências aplicadas com sucesso!');
        });

        document.getElementById('feesForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Taxas salvas com sucesso!');
        });

        // Toggle de configurações por método
        document.getElementById('enableBoleto').addEventListener('change', function() {
            document.getElementById('boletoSettings').classList.toggle('d-none', !this.checked);
        });

        function exportConfig() {
            const config = {
                paymentMethods: {
                    cash: document.getElementById('enableCash').checked,
                    debit: document.getElementById('enableDebit').checked,
                    credit: document.getElementById('enableCredit').checked,
                    pix: document.getElementById('enablePix').checked,
                    boleto: document.getElementById('enableBoleto').checked
                },
                maxInstallments: document.getElementById('maxInstallments').value,
                exportDate: new Date().toISOString()
            };

            const blob = new Blob([JSON.stringify(config, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'payment-config-' + new Date().toISOString().split('T')[0] + '.json';
            a.click();
        }

        function importConfig() {
            const file = document.getElementById('configFile').files[0];
            if (!file) {
                alert('Selecione um arquivo primeiro');
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const config = JSON.parse(e.target.result);
                    // Aplicar configurações
                    alert('Configurações importadas com sucesso!');
                } catch (error) {
                    alert('Erro ao importar configurações: ' + error.message);
                }
            };
            reader.readAsText(file);
        }
    </script>
}
