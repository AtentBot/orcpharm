@{
    ViewData["Title"] = "Relatório Diário";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">Gestão de Pagamentos</a></li>
                    <li class="breadcrumb-item active">Relatório Diário</li>
                </ol>
            </nav>
            <div class="d-flex justify-content-between align-items-center">
                <h2><i class="bi bi-file-earmark-bar-graph me-2"></i>Relatório Diário de Pagamentos</h2>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary" onclick="printReport()">
                        <i class="bi bi-printer"></i> Imprimir
                    </button>
                    <button class="btn btn-outline-success" onclick="exportExcel()">
                        <i class="bi bi-file-earmark-excel"></i> Excel
                    </button>
                    <button class="btn btn-primary" onclick="generatePDF()">
                        <i class="bi bi-file-earmark-pdf"></i> PDF
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtro de Data -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Data do Relatório</label>
                    <input type="date" class="form-control" id="reportDate" 
                           value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Comparar com</label>
                    <select class="form-select" id="compareWith">
                        <option value="">Sem comparação</option>
                        <option value="yesterday">Dia anterior</option>
                        <option value="lastWeek">Mesma data semana passada</option>
                        <option value="lastMonth">Mesma data mês passado</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filtrar por Operador</label>
                    <select class="form-select" id="filterOperator">
                        <option value="">Todos</option>
                        <!-- Será preenchido dinamicamente -->
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" onclick="loadReport()">
                        <i class="bi bi-search"></i> Gerar Relatório
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumo Executivo -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Faturamento Total</p>
                            <h3 class="mb-0" id="totalRevenue">R$ 0,00</h3>
                            <small id="revenueChange" class="text-success">+0%</small>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-currency-dollar text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total de Vendas</p>
                            <h3 class="mb-0" id="totalSales">0</h3>
                            <small id="salesChange" class="text-info">+0%</small>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cart-check text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Ticket Médio</p>
                            <h3 class="mb-0" id="avgTicket">R$ 0,00</h3>
                            <small id="ticketChange" class="text-primary">+0%</small>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-receipt text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Transações</p>
                            <h3 class="mb-0" id="totalTransactions">0</h3>
                            <small id="transactionsChange" class="text-warning">+0%</small>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-arrow-left-right text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribuição por Forma de Pagamento -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Detalhamento por Forma de Pagamento</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="paymentMethodsTable">
                            <thead>
                                <tr>
                                    <th>Forma de Pagamento</th>
                                    <th class="text-center">Quantidade</th>
                                    <th class="text-end">Valor Total</th>
                                    <th class="text-end">% do Total</th>
                                    <th class="text-end">Ticket Médio</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        Carregando dados...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Distribuição Visual</h5>
                </div>
                <div class="card-body">
                    <canvas id="paymentDistributionChart" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Análise por Horário -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Vendas por Horário</h5>
                </div>
                <div class="card-body">
                    <canvas id="hourlyChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Análise de Descontos -->
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Análise de Descontos</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <h4 id="totalDiscount">R$ 0,00</h4>
                            <small class="text-muted">Total em Descontos</small>
                        </div>
                        <div class="col-4">
                            <h4 id="avgDiscount">0%</h4>
                            <small class="text-muted">Desconto Médio</small>
                        </div>
                        <div class="col-4">
                            <h4 id="salesWithDiscount">0</h4>
                            <small class="text-muted">Vendas com Desconto</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Top 5 Operadores do Dia</h5>
                </div>
                <div class="card-body">
                    <div id="topOperatorsList">
                        <!-- Será preenchido dinamicamente -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vendas Canceladas -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Vendas Canceladas</h5>
                        <span class="badge bg-danger" id="cancelledCount">0</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead>
                                <tr>
                                    <th>Horário</th>
                                    <th>Código Venda</th>
                                    <th>Cliente</th>
                                    <th>Valor</th>
                                    <th>Motivo</th>
                                    <th>Cancelado por</th>
                                </tr>
                            </thead>
                            <tbody id="cancelledSalesTable">
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Nenhuma venda cancelada</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Observações e Notas -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0">Observações do Dia</h5>
                </div>
                <div class="card-body">
                    <textarea class="form-control" id="dailyNotes" rows="4" 
                              placeholder="Adicione observações sobre o dia (eventos especiais, problemas, etc)"></textarea>
                    <button class="btn btn-primary mt-2" onclick="saveDailyNotes()">
                        <i class="bi bi-save"></i> Salvar Observações
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let distributionChart = null;
        let hourlyChart = null;

        document.addEventListener('DOMContentLoaded', function() {
            initializeCharts();
            loadReport();
        });

        function initializeCharts() {
            // Gráfico de distribuição
            const distributionCtx = document.getElementById('paymentDistributionChart').getContext('2d');
            distributionChart = new Chart(distributionCtx, {
                type: 'doughnut',
                data: {
                    labels: [],
                    datasets: [{
                        data: [],
                        backgroundColor: [
                            'rgba(40, 167, 69, 0.8)',
                            'rgba(0, 123, 255, 0.8)',
                            'rgba(23, 162, 184, 0.8)',
                            'rgba(255, 193, 7, 0.8)',
                            'rgba(108, 117, 125, 0.8)'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Gráfico por horário
            const hourlyCtx = document.getElementById('hourlyChart').getContext('2d');
            hourlyChart = new Chart(hourlyCtx, {
                type: 'bar',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Vendas',
                        data: [],
                        backgroundColor: 'rgba(0, 123, 255, 0.7)',
                        borderColor: 'rgba(0, 123, 255, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    }
                }
            });
        }

        async function loadReport() {
            const date = document.getElementById('reportDate').value;
            
            try {
                const response = await fetch(`/api/Payments/daily-cash-flow?date=${date}`);
                const result = await response.json();

                if (result.success) {
                    updateKPIs(result.data);
                    updatePaymentMethodsTable(result.data);
                    updateCharts(result.data);
                    await loadHourlySales(date);
                    await loadTopOperators(date);
                }
            } catch (error) {
                console.error('Erro ao carregar relatório:', error);
            }
        }

        function updateKPIs(data) {
            document.getElementById('totalRevenue').textContent = formatCurrency(data.grandTotal);
            document.getElementById('totalSales').textContent = data.totalSales;
            document.getElementById('avgTicket').textContent = 
                formatCurrency(data.totalSales > 0 ? data.grandTotal / data.totalSales : 0);
            document.getElementById('totalTransactions').textContent = 
                data.paymentMethodBreakdown.reduce((sum, m) => sum + m.count, 0);
        }

        function updatePaymentMethodsTable(data) {
            const tbody = document.getElementById('paymentMethodsTable').querySelector('tbody');
            tbody.innerHTML = '';

            data.paymentMethodBreakdown.forEach(method => {
                const row = tbody.insertRow();
                row.innerHTML = `
                    <td><i class="bi ${getMethodIcon(method.paymentMethod)} me-2"></i>${formatPaymentMethod(method.paymentMethod)}</td>
                    <td class="text-center">${method.count}</td>
                    <td class="text-end"><strong>${formatCurrency(method.totalAmount)}</strong></td>
                    <td class="text-end">${method.percentage.toFixed(1)}%</td>
                    <td class="text-end">${formatCurrency(method.totalAmount / method.count)}</td>
                `;
            });
        }

        function updateCharts(data) {
            const labels = data.paymentMethodBreakdown.map(m => formatPaymentMethod(m.paymentMethod));
            const values = data.paymentMethodBreakdown.map(m => m.totalAmount);

            distributionChart.data.labels = labels;
            distributionChart.data.datasets[0].data = values;
            distributionChart.update();
        }

        async function loadHourlySales(date) {
            // Simular dados por horário
            const hours = Array.from({length: 12}, (_, i) => i + 8); // 8h às 19h
            const salesByHour = hours.map(() => Math.floor(Math.random() * 10));

            hourlyChart.data.labels = hours.map(h => `${h}:00`);
            hourlyChart.data.datasets[0].data = salesByHour;
            hourlyChart.update();
        }

        async function loadTopOperators(date) {
            const container = document.getElementById('topOperatorsList');
            
            // Dados simulados - substituir por chamada real à API
            const operators = [
                { name: 'Maria Silva', sales: 45, amount: 6780.50 },
                { name: 'João Santos', sales: 38, amount: 5420.00 },
                { name: 'Ana Costa', sales: 32, amount: 4890.25 },
                { name: 'Pedro Oliveira', sales: 28, amount: 4120.00 },
                { name: 'Carla Souza', sales: 25, amount: 3850.75 }
            ];

            container.innerHTML = operators.map((op, index) => `
                <div class="d-flex justify-content-between align-items-center mb-2 p-2 ${index === 0 ? 'bg-warning bg-opacity-10' : 'bg-light'} rounded">
                    <div>
                        <span class="badge bg-secondary me-2">#${index + 1}</span>
                        <strong>${op.name}</strong>
                        <small class="text-muted ms-2">${op.sales} vendas</small>
                    </div>
                    <strong>${formatCurrency(op.amount)}</strong>
                </div>
            `).join('');
        }

        function saveDailyNotes() {
            const notes = document.getElementById('dailyNotes').value;
            // Implementar salvamento
            alert('Observações salvas com sucesso!');
        }

        function printReport() {
            window.print();
        }

        function exportExcel() {
            alert('Exportação para Excel em desenvolvimento');
        }

        function generatePDF() {
            alert('Geração de PDF em desenvolvimento');
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('pt-BR', {
                style: 'currency',
                currency: 'BRL'
            }).format(value);
        }

        function formatPaymentMethod(method) {
            const methods = {
                'DINHEIRO': 'Dinheiro',
                'CARTAO_DEBITO': 'Cartão de Débito',
                'CARTAO_CREDITO': 'Cartão de Crédito',
                'PIX': 'PIX',
                'BOLETO': 'Boleto'
            };
            return methods[method] || method;
        }

        function getMethodIcon(method) {
            const icons = {
                'DINHEIRO': 'bi-cash-coin',
                'CARTAO_DEBITO': 'bi-credit-card',
                'CARTAO_CREDITO': 'bi-credit-card-2-front',
                'PIX': 'bi-qr-code',
                'BOLETO': 'bi-upc-scan'
            };
            return icons[method] || 'bi-wallet2';
        }
    </script>
}
