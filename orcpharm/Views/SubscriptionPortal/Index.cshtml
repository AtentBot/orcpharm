@using Models
@using Models.Billing
@{
    ViewData["Title"] = "Minha Assinatura";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var establishment = ViewBag.Establishment as Establishment;
    var subscription = ViewBag.Subscription as Models.Subscription;
    var invoices = ViewBag.Invoices as List<SubscriptionInvoice> ?? new List<SubscriptionInvoice>();
    var plans = ViewBag.Plans as List<SubscriptionPlan> ?? new List<SubscriptionPlan>();
    
    var statusColors = new Dictionary<string, string>
    {
        { "ACTIVE", "success" },
        { "TRIALING", "info" },
        { "PAST_DUE", "warning" },
        { "CANCELED", "danger" },
        { "TRIAL_EXPIRED", "secondary" }
    };
    
    var statusLabels = new Dictionary<string, string>
    {
        { "ACTIVE", "Ativa" },
        { "TRIALING", "Em período de teste" },
        { "PAST_DUE", "Pagamento pendente" },
        { "CANCELED", "Cancelada" },
        { "TRIAL_EXPIRED", "Trial expirado" }
    };
}

<div class="container py-4">
    <h1 class="mb-4">
        <i class="bi bi-credit-card me-2"></i>Minha Assinatura
    </h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (subscription == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Você ainda não possui uma assinatura ativa.
            <a href="/pricing" class="alert-link">Ver planos disponíveis</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Card Principal da Assinatura -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Detalhes da Assinatura</h5>
                        <span class="badge bg-@(statusColors.GetValueOrDefault(subscription.Status, "secondary"))">
                            @(statusLabels.GetValueOrDefault(subscription.Status, subscription.Status))
                        </span>
                    </div>
                    <div class="card-body">
                        @if (subscription.CancelAtPeriodEnd)
                        {
                            <div class="alert alert-warning mb-3">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                <strong>Cancelamento agendado.</strong> 
                                Sua assinatura será cancelada em @subscription.CurrentPeriodEnd?.ToString("dd/MM/yyyy").
                                <form asp-action="ReactivateSubscription" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-warning ms-2">
                                        Reverter cancelamento
                                    </button>
                                </form>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Plano atual</label>
                                <h4>@(subscription.SubscriptionPlan?.Name ?? "N/A")</h4>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Valor</label>
                                <h4>
                                    R$ @((subscription.BillingCycle == "YEARLY" 
                                        ? subscription.SubscriptionPlan?.PriceYearly 
                                        : subscription.SubscriptionPlan?.PriceMonthly)?.ToString("N2") ?? "0,00")
                                    <small class="text-muted">/@(subscription.BillingCycle == "YEARLY" ? "ano" : "mês")</small>
                                </h4>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            @if (subscription.Status == "TRIALING")
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="text-muted small">Período de teste termina em</label>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-calendar-event text-info me-2 fs-4"></i>
                                        <div>
                                            <strong>@subscription.TrialEnd?.ToString("dd/MM/yyyy")</strong>
                                            @{
                                                var daysLeft = subscription.TrialEnd.HasValue 
                                                    ? (subscription.TrialEnd.Value - DateTime.UtcNow).Days 
                                                    : 0;
                                            }
                                            <br><small class="text-muted">@daysLeft dias restantes</small>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6 mb-3">
                                    <label class="text-muted small">Próxima cobrança</label>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-calendar-check text-success me-2 fs-4"></i>
                                        <strong>@subscription.CurrentPeriodEnd?.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                </div>
                            }
                            <div class="col-md-6 mb-3">
                                <label class="text-muted small">Assinante desde</label>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-clock-history text-primary me-2 fs-4"></i>
                                    <strong>@subscription.CreatedAt.ToString("dd/MM/yyyy")</strong>
                                </div>
                            </div>
                        </div>

                        <hr>

                        <!-- Limites do Plano -->
                        <h6 class="text-muted mb-3">Limites do seu plano</h6>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <div class="d-flex justify-content-between">
                                    <span><i class="bi bi-people me-2"></i>Funcionários</span>
                                    <strong>@(establishment?.MaxEmployeesLimit?.ToString() ?? "∞")</strong>
                                </div>
                            </div>
                            <div class="col-md-6 mb-2">
                                <div class="d-flex justify-content-between">
                                    <span><i class="bi bi-box me-2"></i>Ordens/mês</span>
                                    <strong>@(establishment?.MaxOrdersLimit?.ToString() ?? "∞")</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex gap-2 flex-wrap">
                            <form asp-action="RedirectToStripePortal" method="post">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-credit-card me-2"></i>Gerenciar Pagamento
                                </button>
                            </form>
                            
                            @if (!subscription.CancelAtPeriodEnd && subscription.Status != "CANCELED")
                            {
                                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelModal">
                                    <i class="bi bi-x-circle me-2"></i>Cancelar Assinatura
                                </button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Histórico de Faturas -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-transparent">
                        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Histórico de Faturas</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (invoices.Count == 0)
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-inbox display-4"></i>
                                <p class="mt-2">Nenhuma fatura encontrada</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Data</th>
                                            <th>Valor</th>
                                            <th>Status</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var invoice in invoices)
                                        {
                                            <tr>
                                                <td>@invoice.CreatedAt.ToString("dd/MM/yyyy")</td>
                                                <td>R$ @invoice.Amount.ToString("N2")</td>
                                                <td>
                                                    @if (invoice.Status == "PAID")
                                                    {
                                                        <span class="badge bg-success">Paga</span>
                                                    }
                                                    else if (invoice.Status == "PENDING")
                                                    {
                                                        <span class="badge bg-warning">Pendente</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">@invoice.Status</span>
                                                    }
                                                </td>
                                                <td class="text-end">
                                                    @if (!string.IsNullOrEmpty(invoice.InvoiceUrl))
                                                    {
                                                        <a href="@invoice.InvoiceUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-eye"></i>
                                                        </a>
                                                    }
                                                    @if (!string.IsNullOrEmpty(invoice.InvoicePdfUrl))
                                                    {
                                                        <a href="@invoice.InvoicePdfUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-download"></i>
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar - Trocar Plano -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent">
                        <h5 class="mb-0"><i class="bi bi-arrow-up-circle me-2"></i>Trocar de Plano</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var plan in plans)
                        {
                            var isCurrentPlan = subscription.SubscriptionPlanId == plan.Id;
                            <div class="border rounded p-3 mb-3 @(isCurrentPlan ? "border-primary bg-primary bg-opacity-10" : "")">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">
                                            @plan.Name
                                            @if (isCurrentPlan)
                                            {
                                                <span class="badge bg-primary ms-2">Atual</span>
                                            }
                                        </h6>
                                        <small class="text-muted">@plan.Description</small>
                                    </div>
                                    <div class="text-end">
                                        <strong>R$ @plan.PriceMonthly.ToString("N0")</strong>
                                        <small class="text-muted">/mês</small>
                                    </div>
                                </div>
                                
                                @if (!isCurrentPlan)
                                {
                                    <form asp-action="ChangePlan" method="post" class="mt-2">
                                        <input type="hidden" name="planId" value="@plan.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary w-100"
                                                onclick="return confirm('Confirma a troca para o plano @plan.Name?')">
                                            @if (plan.PriceMonthly > subscription.SubscriptionPlan?.PriceMonthly)
                                            {
                                                <i class="bi bi-arrow-up me-1"></i>@:Fazer upgrade
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-down me-1"></i>@:Fazer downgrade
                                            }
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Card de Suporte -->
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body text-center">
                        <i class="bi bi-headset display-4 text-primary"></i>
                        <h6 class="mt-3">Precisa de ajuda?</h6>
                        <p class="text-muted small mb-3">
                            Nossa equipe está pronta para ajudar
                        </p>
                        <a href="mailto:suporte@orcpharm.com.br" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-envelope me-2"></i>Falar com Suporte
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal de Cancelamento -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Cancelar Assinatura</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RequestCancellation" method="post">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Atenção!</strong> Ao cancelar, você perderá acesso às funcionalidades premium ao final do período atual.
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Por que você está cancelando? (opcional)</label>
                        <select class="form-select" name="reason">
                            <option value="">Selecione um motivo</option>
                            <option value="price">Preço muito alto</option>
                            <option value="not_using">Não estou usando</option>
                            <option value="missing_features">Falta de funcionalidades</option>
                            <option value="competitor">Vou usar outro sistema</option>
                            <option value="closing">Estou fechando a farmácia</option>
                            <option value="other">Outro motivo</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Voltar</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-x-circle me-2"></i>Confirmar Cancelamento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
