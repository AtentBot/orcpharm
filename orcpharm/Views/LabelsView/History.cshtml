@{
    ViewData["Title"] = "Histórico de Rótulos";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-0">
                <i class="bi bi-clock-history me-2"></i>Histórico de Rótulos
            </h2>
            <p class="text-muted">Buscar e visualizar rótulos gerados</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="bi bi-funnel me-2"></i>Filtros
            </h5>
        </div>
        <div class="card-body">
            <form id="searchForm">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Nome do Paciente</label>
                        <input type="text" id="patientName" class="form-control" 
                               placeholder="Digite o nome...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Número do Lote</label>
                        <input type="text" id="batchNumber" class="form-control" 
                               placeholder="Ex: L2024001">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Status</label>
                        <select id="status" class="form-select">
                            <option value="">Todos</option>
                            <option value="PENDENTE">Pendente</option>
                            <option value="IMPRESSO">Impresso</option>
                            <option value="REIMPRESSO">Reimpresso</option>
                            <option value="CANCELADO">Cancelado</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Data Inicial</label>
                        <input type="date" id="dateFrom" class="form-control">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Data Final</label>
                        <input type="date" id="dateTo" class="form-control">
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-md-2">
                        <div class="form-check mt-4">
                            <input type="checkbox" id="isControlled" class="form-check-input">
                            <label class="form-check-label">Apenas Controlados</label>
                        </div>
                    </div>
                    <div class="col-md-10 text-end mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-2"></i>Buscar
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="clearFilters()">
                            <i class="bi bi-x-circle me-2"></i>Limpar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div id="loadingIndicator" class="text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Carregando rótulos...</p>
            </div>

            <div id="resultsContainer" style="display: none;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div id="resultsSummary" class="text-muted"></div>
                    <div>
                        <button class="btn btn-sm btn-outline-primary" onclick="exportResults()">
                            <i class="bi bi-download me-1"></i>Exportar
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Paciente</th>
                                <th>Fórmula</th>
                                <th>Lote</th>
                                <th>Manipulação</th>
                                <th>Validade</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Impressões</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="resultsTable">
                        </tbody>
                    </table>
                </div>

                <nav id="pagination" class="mt-3"></nav>
            </div>

            <div id="noResults" style="display: none;" class="text-center py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <p class="mt-3 text-muted">Nenhum rótulo encontrado com os filtros selecionados</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 20;
        
        async function searchLabels(page = 1) {
            currentPage = page;
            
            const params = new URLSearchParams({
                page: page,
                pageSize: pageSize
            });
            
            const patientName = document.getElementById('patientName').value;
            if (patientName) params.append('patientName', patientName);
            
            const batchNumber = document.getElementById('batchNumber').value;
            if (batchNumber) params.append('batchNumber', batchNumber);
            
            const status = document.getElementById('status').value;
            if (status) params.append('status', status);
            
            const dateFrom = document.getElementById('dateFrom').value;
            if (dateFrom) params.append('dateFrom', dateFrom);
            
            const dateTo = document.getElementById('dateTo').value;
            if (dateTo) params.append('dateTo', dateTo);
            
            const isControlled = document.getElementById('isControlled').checked;
            if (isControlled) params.append('isControlled', 'true');
            
            document.getElementById('loadingIndicator').style.display = 'block';
            document.getElementById('resultsContainer').style.display = 'none';
            document.getElementById('noResults').style.display = 'none';
            
            try {
                const response = await fetch(`/api/Labels/search?${params}`);
                const data = await response.json();
                
                document.getElementById('loadingIndicator').style.display = 'none';
                
                if (data.labels && data.labels.length > 0) {
                    displayResults(data);
                } else {
                    document.getElementById('noResults').style.display = 'block';
                }
            } catch (error) {
                console.error('Erro na busca:', error);
                document.getElementById('loadingIndicator').style.display = 'none';
                alert('Erro ao buscar rótulos: ' + error.message);
            }
        }
        
        function displayResults(data) {
            document.getElementById('resultsContainer').style.display = 'block';
            
            const summary = `Exibindo ${data.labels.length} de ${data.pagination.totalCount} rótulo${data.pagination.totalCount !== 1 ? 's' : ''}`;
            document.getElementById('resultsSummary').textContent = summary;
            
            let html = '';
            data.labels.forEach(label => {
                let statusBadge = '';
                switch(label.status) {
                    case 'PENDENTE': statusBadge = '<span class="badge bg-warning">Pendente</span>'; break;
                    case 'IMPRESSO': statusBadge = '<span class="badge bg-success">Impresso</span>'; break;
                    case 'REIMPRESSO': statusBadge = '<span class="badge bg-info">Reimpresso</span>'; break;
                    case 'CANCELADO': statusBadge = '<span class="badge bg-danger">Cancelado</span>'; break;
                }
                
                html += `
                    <tr>
                        <td>
                            <strong>${label.labelCode}</strong>
                            ${label.isControlled ? '<span class="badge bg-danger ms-2">Controlado</span>' : ''}
                        </td>
                        <td>${label.patientName || '-'}</td>
                        <td>${label.formulaName}</td>
                        <td><small class="text-muted">${label.batchNumber || '-'}</small></td>
                        <td><small>${new Date(label.manipulationDate).toLocaleDateString('pt-BR')}</small></td>
                        <td><small>${new Date(label.expirationDate).toLocaleDateString('pt-BR')}</small></td>
                        <td class="text-center">${statusBadge}</td>
                        <td class="text-center">
                            ${label.printCount > 0 ? 
                                `<span class="badge bg-secondary">${label.printCount}x</span>` : 
                                '<span class="text-muted">-</span>'}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="/Labels/View/${label.id}" class="btn btn-outline-info" title="Visualizar">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button class="btn btn-outline-primary" onclick="printQuick('${label.id}')" title="Imprimir">
                                    <i class="bi bi-printer"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
            
            document.getElementById('resultsTable').innerHTML = html;
            
            displayPagination(data.pagination.totalCount, data.pagination.currentPage, data.pagination.totalPages);
        }
        
        function displayPagination(totalCount, currentPage, totalPages) {
            if (totalPages <= 1) {
                document.getElementById('pagination').innerHTML = '';
                return;
            }
            
            let html = '<ul class="pagination justify-content-center mb-0">';
            
            if (currentPage > 1) {
                html += `<li class="page-item"><a class="page-link" href="#" onclick="searchLabels(${currentPage - 1}); return false;">Anterior</a></li>`;
            }
            
            for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="searchLabels(${i}); return false;">${i}</a>
                </li>`;
            }
            
            if (currentPage < totalPages) {
                html += `<li class="page-item"><a class="page-link" href="#" onclick="searchLabels(${currentPage + 1}); return false;">Próxima</a></li>`;
            }
            
            html += '</ul>';
            document.getElementById('pagination').innerHTML = html;
        }
        
        async function printQuick(labelId) {
            try {
                const response = await fetch(`/api/Labels/${labelId}/print`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        copies: 1,
                        format: 'HTML',
                        printReason: 'IMPRESSAO'
                    })
                });
                
                if (response.ok) {
                    window.open(`/Labels/View/${labelId}`, '_blank');
                    searchLabels(currentPage);
                } else {
                    alert('Erro ao imprimir rótulo');
                }
            } catch (error) {
                alert('Erro: ' + error.message);
            }
        }
        
        function clearFilters() {
            document.getElementById('searchForm').reset();
            searchLabels(1);
        }
        
        function exportResults() {
            alert('Funcionalidade de exportação em desenvolvimento');
        }
        
        document.getElementById('searchForm').addEventListener('submit', function(e) {
            e.preventDefault();
            searchLabels(1);
        });
        
        // Carregar resultados iniciais
        searchLabels(1);
    </script>
}
