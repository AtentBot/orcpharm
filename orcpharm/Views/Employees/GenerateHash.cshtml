@{
    ViewData["Title"] = "Gerador de Hash de Senha";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrcPharm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --card-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 40px 20px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .generator-container {
            max-width: 900px;
            margin: 0 auto;
        }

        .card {
            border: none;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .card-header {
            background: white;
            border-bottom: 2px solid #f3f4f6;
            padding: 30px;
        }

        .logo-section {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background: var(--primary-gradient);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 20px;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

        .logo-icon i {
            font-size: 1.8rem;
            color: white;
        }

        .page-title {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            color: #1f2937;
        }

        .page-subtitle {
            margin: 5px 0 0 0;
            color: #6b7280;
            font-size: 1rem;
        }

        .card-body {
            padding: 30px;
        }

        .form-label {
            font-weight: 600;
            color: #374151;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
        }

        .form-label i {
            margin-right: 8px;
            color: #9ca3af;
        }

        .form-control {
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        }

        .password-input-wrapper {
            position: relative;
        }

        .toggle-password, .generate-random {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #9ca3af;
            transition: color 0.2s;
            z-index: 10;
        }

        .generate-random {
            right: 50px;
        }

        .toggle-password:hover, .generate-random:hover {
            color: #667eea;
        }

        .password-strength {
            height: 4px;
            background: #e5e7eb;
            border-radius: 2px;
            margin-top: 8px;
            overflow: hidden;
        }

        .password-strength-bar {
            height: 100%;
            width: 0;
            transition: all 0.3s ease;
        }

        .password-strength-bar.strength-weak {
            width: 33%;
            background: #ef4444;
        }

        .password-strength-bar.strength-medium {
            width: 66%;
            background: #f59e0b;
        }

        .password-strength-bar.strength-strong {
            width: 100%;
            background: #10b981;
        }

        .strength-label {
            font-size: 0.85rem;
            margin-top: 5px;
            font-weight: 600;
        }

        .btn-generate {
            background: var(--primary-gradient);
            border: none;
            border-radius: 12px;
            padding: 14px 30px;
            font-weight: 600;
            font-size: 1.05rem;
            color: white;
            width: 100%;
            margin-top: 20px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-generate:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
        }

        .btn-generate:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .result-section {
            background: #f9fafb;
            border-radius: 12px;
            padding: 25px;
            margin-top: 30px;
            border: 2px dashed #d1d5db;
            display: none;
        }

        .result-section.show {
            display: block;
            animation: slideIn 0.3s ease-out;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .result-label {
            font-weight: 600;
            color: #4b5563;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
        }

        .result-label i {
            margin-right: 8px;
        }

        .result-value {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 12px 15px;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            word-break: break-all;
            color: #1f2937;
            margin-bottom: 15px;
            position: relative;
        }

        .copy-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: #667eea;
            border: none;
            color: white;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .copy-btn:hover {
            background: #5568d3;
        }

        .copy-btn.copied {
            background: #10b981;
        }

        .sql-block {
            background: #1f2937;
            color: #f3f4f6;
            border-radius: 8px;
            padding: 20px;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            overflow-x: auto;
            position: relative;
        }

        .sql-block pre {
            margin: 0;
            color: #f3f4f6;
        }

        .info-box {
            background: #dbeafe;
            border-left: 4px solid #3b82f6;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
        }

        .info-box i {
            color: #3b82f6;
            margin-right: 8px;
        }

        .footer-links {
            text-align: center;
            margin-top: 30px;
        }

        .footer-links a {
            display: inline-block;
            margin: 0 15px;
            color: white;
            text-decoration: none;
            font-weight: 500;
            transition: opacity 0.2s;
        }

        .footer-links a:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        .spinner-border-sm {
            width: 1rem;
            height: 1rem;
            border-width: 0.2em;
        }
    </style>
</head>
<body>
    <div class="generator-container">
        <div class="card">
            <div class="card-header">
                <div class="logo-section">
                    <div class="logo-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <div>
                        <h1 class="page-title">Gerador de Hash de Senha</h1>
                        <p class="page-subtitle">Crie hashes seguros Argon2id para senhas</p>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <form id="hashForm">
                    <div class="mb-3">
                        <label for="password" class="form-label">
                            <i class="bi bi-key-fill"></i>
                            Digite a Senha
                        </label>
                        <div class="password-input-wrapper">
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="Digite a senha" required minlength="8"
                                   style="padding-right: 100px;">
                            <i class="bi bi-shuffle generate-random" id="generateRandom" 
                               title="Gerar senha aleatória"></i>
                            <i class="bi bi-eye toggle-password" id="togglePassword"></i>
                        </div>
                        <div class="password-strength">
                            <div class="password-strength-bar" id="strengthBar"></div>
                        </div>
                        <div class="strength-label" id="strengthLabel"></div>
                    </div>

                    <div class="info-box">
                        <i class="bi bi-info-circle"></i>
                        <strong>Requisitos de Senha:</strong> Mínimo 8 caracteres. 
                        Recomendado: letras maiúsculas, minúsculas, números e símbolos.
                    </div>

                    <button type="submit" class="btn btn-generate" id="btnGenerate">
                        <i class="bi bi-shield-lock me-2"></i>
                        Gerar Hash Argon2
                    </button>
                </form>

                <div class="result-section" id="resultSection">
                    <h5 class="mb-4">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        Hash Gerado com Sucesso
                    </h5>

                    <div class="mb-4">
                        <div class="result-label">
                            <i class="bi bi-key-fill"></i>
                            Senha Original
                        </div>
                        <div class="result-value" style="position: relative;">
                            <span id="originalPassword"></span>
                            <button type="button" class="copy-btn" onclick="copyToClipboard('originalPassword', this)">
                                <i class="bi bi-clipboard"></i> Copiar
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="result-label">
                            <i class="bi bi-shield-shaded"></i>
                            Hash Argon2id
                        </div>
                        <div class="result-value" style="position: relative;">
                            <span id="generatedHash"></span>
                            <button type="button" class="copy-btn" onclick="copyToClipboard('generatedHash', this)">
                                <i class="bi bi-clipboard"></i> Copiar
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="result-label">
                            <i class="bi bi-code-square"></i>
                            Script SQL para Atualização
                        </div>
                        <div class="sql-block">
                            <pre id="sqlScript"></pre>
                            <button type="button" class="copy-btn" style="top: 15px;" 
                                    onclick="copyToClipboard('sqlScript', this)">
                                <i class="bi bi-clipboard"></i> Copiar SQL
                            </button>
                        </div>
                    </div>

                    <div class="alert alert-warning mt-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Atenção:</strong> Substitua <code>CPF_AQUI</code> pelo CPF do funcionário no script SQL.
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-links">
            <a href="/Employees/List">
                <i class="bi bi-arrow-left me-1"></i>
                Voltar para Funcionários
            </a>
            <a href="/Dashboard">
                <i class="bi bi-house me-1"></i>
                Dashboard
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const passwordInput = document.getElementById('password');
        const togglePassword = document.getElementById('togglePassword');
        const generateRandom = document.getElementById('generateRandom');
        const strengthBar = document.getElementById('strengthBar');
        const strengthLabel = document.getElementById('strengthLabel');

        // Toggle password visibility
        togglePassword.addEventListener('click', function() {
            const type = passwordInput.type === 'password' ? 'text' : 'password';
            passwordInput.type = type;
            
            this.classList.toggle('bi-eye');
            this.classList.toggle('bi-eye-slash');
        });

        // Generate random password
        generateRandom.addEventListener('click', function() {
            const length = 12;
            const charset = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@@#$%^&*';
            let password = '';
            
            for (let i = 0; i < length; i++) {
                password += charset.charAt(Math.floor(Math.random() * charset.length));
            }
            
            passwordInput.value = password;
            checkPasswordStrength(password);
            
            // Show password temporarily
            passwordInput.type = 'text';
            togglePassword.classList.remove('bi-eye');
            togglePassword.classList.add('bi-eye-slash');
            
            // Animate icon
            this.style.color = '#10b981';
            setTimeout(() => {
                this.style.color = '';
            }, 500);
        });

        // Check password strength
        passwordInput.addEventListener('input', function() {
            checkPasswordStrength(this.value);
        });

        function checkPasswordStrength(password) {
            let strength = 0;
            
            if (password.length >= 8) strength++;
            if (password.length >= 12) strength++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
            if (/\d/.test(password)) strength++;
            if (/[^a-zA-Z\d]/.test(password)) strength++;
            
            strengthBar.className = 'password-strength-bar';
            
            if (strength <= 2) {
                strengthBar.classList.add('strength-weak');
                strengthLabel.textContent = 'Fraca';
                strengthLabel.style.color = '#ef4444';
            } else if (strength <= 4) {
                strengthBar.classList.add('strength-medium');
                strengthLabel.textContent = 'Média';
                strengthLabel.style.color = '#f59e0b';
            } else {
                strengthBar.classList.add('strength-strong');
                strengthLabel.textContent = 'Forte';
                strengthLabel.style.color = '#10b981';
            }
        }

        // Submit form
        document.getElementById('hashForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const password = passwordInput.value;
            const btnGenerate = document.getElementById('btnGenerate');
            
            // Disable button
            btnGenerate.disabled = true;
            btnGenerate.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Gerando hash...';
            
            try {
                const response = await fetch('/api/Employees/generate-hash', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ password: password })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    // Show results
                    document.getElementById('originalPassword').textContent = data.password;
                    document.getElementById('generatedHash').textContent = data.hash;
                    document.getElementById('sqlScript').textContent = data.sqlUpdate;
                    
                    document.getElementById('resultSection').classList.add('show');
                    
                    // Scroll to results
                    document.getElementById('resultSection').scrollIntoView({ 
                        behavior: 'smooth', 
                        block: 'nearest' 
                    });
                } else {
                    alert('Erro: ' + (data.error || 'Erro ao gerar hash'));
                }
            } catch (error) {
                console.error('Erro:', error);
                alert('Erro ao gerar hash. Verifique a conexão.');
            } finally {
                // Re-enable button
                btnGenerate.disabled = false;
                btnGenerate.innerHTML = '<i class="bi bi-shield-lock me-2"></i>Gerar Hash Argon2';
            }
        });

        function copyToClipboard(elementId, button) {
            const text = document.getElementById(elementId).textContent;
            
            navigator.clipboard.writeText(text).then(() => {
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="bi bi-check"></i> Copiado!';
                button.classList.add('copied');
                
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('copied');
                }, 2000);
            }).catch(err => {
                console.error('Erro ao copiar:', err);
                alert('Erro ao copiar para a área de transferência');
            });
        }
    </script>
</body>
</html>
