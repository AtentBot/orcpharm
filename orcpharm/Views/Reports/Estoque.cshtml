@using Models.Pharmacy
@{
    ViewData["Title"] = "Relatório de Estoque";
    Layout = "_Layout";
    var estoqueBaixo = ViewBag.EstoqueBaixo as List<RawMaterial>;
    var lotesVencendo = ViewBag.LotesVencendo as List<Batch>;
    var lotesVencidos = ViewBag.LotesVencidos as List<Batch>;
    var valorPorCategoria = ViewBag.ValorPorCategoria as List<ValorPorCategoriaDto>;
    var resumo = ViewBag.Resumo as EstoqueResumoDto;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/Reports" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao Dashboard
            </a>
            <h4 class="mb-0">
                <i class="bi bi-boxes text-primary me-2"></i>
                Relatório de Estoque
            </h4>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-danger btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Imprimir
            </button>
        </div>
    </div>

    <!-- Resumo -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-2">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Total Materiais</p>
                    <h4 class="text-primary mb-0">@(resumo?.TotalMateriais ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Valor Total</p>
                    <h4 class="text-success mb-0">R$ @(resumo?.ValorTotalEstoque.ToString("N2") ?? "0,00")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-2">
            <div class="card border-0 shadow-sm text-center py-3 @(resumo?.ItensEstoqueBaixo > 0 ? "border-start border-warning border-3" : "")">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Estoque Baixo</p>
                    <h4 class="text-warning mb-0">@(resumo?.ItensEstoqueBaixo ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-2">
            <div class="card border-0 shadow-sm text-center py-3 @(resumo?.LotesVencendo30Dias > 0 ? "border-start border-info border-3" : "")">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Vencendo 30d</p>
                    <h4 class="text-info mb-0">@(resumo?.LotesVencendo30Dias ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3 @(resumo?.LotesVencidos > 0 ? "border-start border-danger border-3" : "")">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Lotes Vencidos</p>
                    <h4 class="text-danger mb-0">@(resumo?.LotesVencidos ?? 0)</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Valor por Categoria -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">
                        <i class="bi bi-pie-chart me-2"></i>
                        Valor por Categoria
                    </h6>
                </div>
                <div class="card-body">
                    @if (valorPorCategoria != null && valorPorCategoria.Any())
                    {
                        var total = valorPorCategoria.Sum(v => v.ValorEstimado);
                        foreach (var cat in valorPorCategoria.Take(8))
                        {
                            var percent = total > 0 ? (cat.ValorEstimado / total) * 100 : 0;
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@cat.Categoria</span>
                                    <span>R$ @cat.ValorEstimado.ToString("N2")</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-primary" style="width: @percent%"></div>
                                </div>
                                <small class="text-muted">@cat.QuantidadeItens itens</small>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">Sem dados</p>
                    }
                </div>
            </div>
        </div>

        <!-- Estoque Baixo -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                        Itens com Estoque Baixo
                    </h6>
                    <a href="/Stock/LowStock" class="btn btn-sm btn-outline-warning">Ver todos</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Material</th>
                                    <th class="text-end">Atual</th>
                                    <th class="text-end">Mínimo</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (estoqueBaixo != null && estoqueBaixo.Any())
                                {
                                    foreach (var item in estoqueBaixo)
                                    {
                                        var percent = item.MinimumStock > 0 ? (item.CurrentStock / item.MinimumStock) * 100 : 0;
                                        var badgeClass = percent < 25 ? "bg-danger" : percent < 50 ? "bg-warning text-dark" : "bg-info";
                                        <tr>
                                            <td>@item.Name</td>
                                            <td class="text-end">@item.CurrentStock.ToString("N2") @item.Unit</td>
                                            <td class="text-end">@item.MinimumStock.ToString("N2") @item.Unit</td>
                                            <td>
                                                <span class="badge @badgeClass">@percent.ToString("N0")%</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-3 text-muted">
                                            <i class="bi bi-check-circle text-success me-1"></i>
                                            Nenhum item com estoque baixo
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <!-- Lotes Vencendo -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">
                        <i class="bi bi-calendar-event text-info me-2"></i>
                        Lotes Vencendo em 30 dias
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Material</th>
                                    <th>Lote</th>
                                    <th>Validade</th>
                                    <th class="text-end">Qtd</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (lotesVencendo != null && lotesVencendo.Any())
                                {
                                    foreach (var lote in lotesVencendo)
                                    {
                                        var diasRestantes = (lote.ExpiryDate - DateTime.UtcNow).Days;
                                        <tr>
                                            <td>@lote.RawMaterial?.Name</td>
                                            <td><small>@lote.BatchNumber</small></td>
                                            <td>
                                                <span class="badge @(diasRestantes <= 7 ? "bg-danger" : "bg-warning text-dark")">
                                                    @lote.ExpiryDate.ToString("dd/MM/yyyy")
                                                </span>
                                                <small class="text-muted">(@diasRestantes dias)</small>
                                            </td>
                                            <td class="text-end">@lote.CurrentQuantity.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-3 text-muted">
                                            <i class="bi bi-check-circle text-success me-1"></i>
                                            Nenhum lote vencendo
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lotes Vencidos -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm @(lotesVencidos?.Any() == true ? "border-start border-danger border-3" : "")">
                <div class="card-header bg-white">
                    <h6 class="mb-0">
                        <i class="bi bi-calendar-x text-danger me-2"></i>
                        Lotes Vencidos
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Material</th>
                                    <th>Lote</th>
                                    <th>Venceu em</th>
                                    <th class="text-end">Qtd</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (lotesVencidos != null && lotesVencidos.Any())
                                {
                                    foreach (var lote in lotesVencidos)
                                    {
                                        <tr class="table-danger">
                                            <td>@lote.RawMaterial?.Name</td>
                                            <td><small>@lote.BatchNumber</small></td>
                                            <td>@lote.ExpiryDate.ToString("dd/MM/yyyy")</td>
                                            <td class="text-end">@lote.CurrentQuantity.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-3 text-muted">
                                            <i class="bi bi-check-circle text-success me-1"></i>
                                            Nenhum lote vencido
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, .sidebar, .top-nav { display: none !important; }
        .main-content { margin-left: 0 !important; }
    }
</style>
