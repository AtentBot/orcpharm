@using Models.Pharmacy
@{
    ViewData["Title"] = "Relatório de Produção";
    Layout = "_Layout";
    var ordens = ViewBag.Ordens as List<ManipulationOrder>;
    var resumo = ViewBag.Resumo as ProducaoResumoDto;
    var porStatus = ViewBag.PorStatus as List<ProducaoPorStatusDto>;
    var startDate = (DateTime)ViewBag.StartDate;
    var endDate = (DateTime)ViewBag.EndDate;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/Reports" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao Dashboard
            </a>
            <h4 class="mb-0">
                <i class="bi bi-gear text-primary me-2"></i>
                Relatório de Produção
            </h4>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-success btn-sm" onclick="exportarExcel()">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </button>
            <button class="btn btn-outline-danger btn-sm" onclick="window.print()">
                <i class="bi bi-file-earmark-pdf me-1"></i>Imprimir
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Data Início</label>
                    <input type="date" name="startDate" class="form-control" 
                           value="@startDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Data Fim</label>
                    <input type="date" name="endDate" class="form-control" 
                           value="@endDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                    <a href="/Reports/Producao" class="btn btn-outline-secondary">Limpar</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumo -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Total Ordens</p>
                    <h4 class="text-primary mb-0">@(resumo?.TotalOrdens ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Finalizadas</p>
                    <h4 class="text-success mb-0">@(resumo?.OrdensFinalizadas ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Canceladas</p>
                    <h4 class="text-danger mb-0">@(resumo?.OrdensCanceladas ?? 0)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="card-body py-2">
                    <p class="text-muted small mb-1">Tempo Médio (h)</p>
                    <h4 class="text-info mb-0">@(resumo?.TempoMedioProducaoHoras.ToString("N1") ?? "0")h</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Por Status -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Por Status</h6>
                </div>
                <div class="card-body">
                    @if (porStatus != null && porStatus.Any())
                    {
                        var total = porStatus.Sum(p => p.Quantidade);
                        foreach (var status in porStatus)
                        {
                            var percent = total > 0 ? ((decimal)status.Quantidade / total) * 100 : 0;
                            var barColor = status.Status switch
                            {
                                "FINALIZADO" or "ENTREGUE" => "bg-success",
                                "EM_PRODUCAO" => "bg-warning",
                                "CANCELADO" => "bg-danger",
                                "PENDENTE" => "bg-secondary",
                                _ => "bg-info"
                            };
                            <div class="mb-3">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>@status.Status</span>
                                    <span>@status.Quantidade (@percent.ToString("N0")%)</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar @barColor" style="width: @percent%"></div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">Sem dados</p>
                    }
                </div>
            </div>
        </div>

        <!-- Lista de Ordens -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Detalhamento das Ordens</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 500px;">
                        <table class="table table-hover mb-0" id="producaoTable">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Ordem</th>
                                    <th>Data</th>
                                    <th>Fórmula</th>
                                    <th>Cliente</th>
                                    <th>Qtd</th>
                                    <th>Status</th>
                                    <th>Prioridade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ordens != null && ordens.Any())
                                {
                                    foreach (var ordem in ordens)
                                    {
                                        var statusClass = ordem.Status switch
                                        {
                                            "FINALIZADO" or "ENTREGUE" => "bg-success",
                                            "EM_PRODUCAO" => "bg-warning text-dark",
                                            "CANCELADO" => "bg-danger",
                                            "PENDENTE" => "bg-secondary",
                                            _ => "bg-info"
                                        };
                                        var prioridadeClass = ordem.Priority switch
                                        {
                                            "URGENTE" => "bg-danger",
                                            "ALTA" => "bg-warning text-dark",
                                            "NORMAL" => "bg-secondary",
                                            "BAIXA" => "bg-light text-dark",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <a href="/Manipulacoes/Detalhes/@ordem.Id" class="text-primary">
                                                    @ordem.OrderNumber
                                                </a>
                                            </td>
                                            <td>@ordem.CreatedAt.ToString("dd/MM/yyyy")</td>
                                            <td>@(ordem.Formula?.Name ?? "Livre")</td>
                                            <td>@ordem.CustomerName</td>
                                            <td>@ordem.QuantityToProduce @ordem.Unit</td>
                                            <td><span class="badge @statusClass">@ordem.Status</span></td>
                                            <td><span class="badge @prioridadeClass">@(ordem.Priority ?? "NORMAL")</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            Nenhuma ordem encontrada no período
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, form, .sidebar, .top-nav { display: none !important; }
        .main-content { margin-left: 0 !important; }
    }
</style>

@section Scripts {
<script>
    function exportarExcel() {
        var table = document.getElementById('producaoTable');
        var html = table.outerHTML;
        var url = 'data:application/vnd.ms-excel,' + encodeURIComponent(html);
        var link = document.createElement('a');
        link.href = url;
        link.download = 'relatorio_producao_@(DateTime.Now.ToString("yyyyMMdd")).xlsx';
        link.click();
    }
</script>
}
