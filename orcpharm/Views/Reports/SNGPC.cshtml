@using Models.Pharmacy
@{
    ViewData["Title"] = "Relatório SNGPC";
    Layout = "_Layout";
    var movimentacoes = ViewBag.Movimentacoes as List<StockMovement>;
    var estoqueControlados = ViewBag.EstoqueControlados as List<RawMaterial>;
    var porTipoControle = ViewBag.PorTipoControle as List<ControlePorTipoDto>;
    var month = (int)ViewBag.Month;
    var year = (int)ViewBag.Year;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/Reports" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao Dashboard
            </a>
            <h4 class="mb-0">
                <i class="bi bi-shield-exclamation text-danger me-2"></i>
                Relatório SNGPC - Substâncias Controladas
            </h4>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-success btn-sm" onclick="exportarXML()">
                <i class="bi bi-file-earmark-code me-1"></i>XML SNGPC
            </button>
            <button class="btn btn-outline-danger btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Imprimir
            </button>
        </div>
    </div>

    <!-- Filtro de Período -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small">Mês</label>
                    <select name="month" class="form-select">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var mesNome = new DateTime(2024, m, 1).ToString("MMMM");
                            <option value="@m" selected="@(m == month)">@mesNome</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Ano</label>
                    <select name="year" class="form-select">
                        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                        {
                            <option value="@y" selected="@(y == year)">@y</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                </div>
                <div class="col-md-5 text-end">
                    <span class="badge bg-danger fs-6">
                        <i class="bi bi-shield me-1"></i>
                        Período: @(new DateTime(year, month, 1).ToString("MMMM/yyyy"))
                    </span>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumo por Tipo de Controle -->
    <div class="row g-3 mb-4">
        @if (porTipoControle != null && porTipoControle.Any())
        {
            foreach (var tipo in porTipoControle)
            {
                var cardColor = tipo.TipoControle switch
                {
                    "A1" or "A2" or "A3" => "danger",
                    "B1" or "B2" => "warning",
                    "C1" or "C2" or "C3" or "C4" or "C5" => "info",
                    _ => "secondary"
                };
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow-sm border-start border-@cardColor border-3">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1">Lista @tipo.TipoControle</p>
                                    <h5 class="mb-0">@tipo.QuantidadeSubstancias substâncias</h5>
                                </div>
                                <span class="badge bg-@cardColor fs-5">@tipo.TipoControle</span>
                            </div>
                            <hr class="my-2">
                            <div class="row text-center small">
                                <div class="col-6">
                                    <span class="text-success">
                                        <i class="bi bi-arrow-down-circle me-1"></i>
                                        @tipo.TotalEntradas.ToString("N2")
                                    </span>
                                    <br><small class="text-muted">Entradas</small>
                                </div>
                                <div class="col-6">
                                    <span class="text-danger">
                                        <i class="bi bi-arrow-up-circle me-1"></i>
                                        @tipo.TotalSaidas.ToString("N2")
                                    </span>
                                    <br><small class="text-muted">Saídas</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Nenhuma substância controlada cadastrada ou movimentada no período.
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- Estoque Atual de Controlados -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">
                        <i class="bi bi-clipboard-data me-2 text-primary"></i>
                        Estoque Atual - Substâncias Controladas
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 400px;">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Substância</th>
                                    <th class="text-center">Lista</th>
                                    <th class="text-end">Estoque</th>
                                    <th>Unidade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (estoqueControlados != null && estoqueControlados.Any())
                                {
                                    foreach (var item in estoqueControlados)
                                    {
                                        var badgeClass = item.ControlType switch
                                        {
                                            "A1" or "A2" or "A3" => "bg-danger",
                                            "B1" or "B2" => "bg-warning text-dark",
                                            "C1" or "C2" or "C3" or "C4" or "C5" => "bg-info",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <strong>@item.Name</strong>
                                                @if (!string.IsNullOrEmpty(item.DcbCode))
                                                {
                                                    <br><small class="text-muted">DCB: @item.DcbCode</small>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge @badgeClass">@item.ControlType</span>
                                            </td>
                                            <td class="text-end fw-bold">@item.CurrentStock.ToString("N4")</td>
                                            <td>@item.Unit</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            Nenhuma substância controlada cadastrada
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Movimentações do Período -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0">
                        <i class="bi bi-arrow-left-right me-2 text-warning"></i>
                        Movimentações do Período
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 400px;">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Data</th>
                                    <th>Substância</th>
                                    <th>Tipo</th>
                                    <th class="text-end">Qtd</th>
                                    <th>Lote</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (movimentacoes != null && movimentacoes.Any())
                                {
                                    foreach (var mov in movimentacoes)
                                    {
                                        var tipoClass = mov.MovementType == "ENTRADA" ? "text-success" : "text-danger";
                                        var tipoIcon = mov.MovementType == "ENTRADA" ? "bi-arrow-down-circle" : "bi-arrow-up-circle";
                                        <tr>
                                            <td>@mov.MovementDate.ToString("dd/MM")</td>
                                            <td>
                                                @mov.RawMaterial?.Name
                                                <br>
                                                <span class="badge bg-secondary">@mov.RawMaterial?.ControlType</span>
                                            </td>
                                            <td>
                                                <span class="@tipoClass">
                                                    <i class="bi @tipoIcon me-1"></i>
                                                    @mov.MovementType
                                                </span>
                                            </td>
                                            <td class="text-end fw-bold @tipoClass">
                                                @(mov.MovementType == "ENTRADA" ? "+" : "-")@mov.Quantity.ToString("N4")
                                            </td>
                                            <td><small>@mov.Batch?.BatchNumber</small></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">
                                            Nenhuma movimentação no período
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Informações SNGPC -->
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-body">
            <h6 class="text-danger mb-3">
                <i class="bi bi-info-circle me-2"></i>
                Informações para Transmissão SNGPC
            </h6>
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-unstyled small">
                        <li><i class="bi bi-check text-success me-2"></i>Lista A1, A2, A3: Entorpecentes</li>
                        <li><i class="bi bi-check text-success me-2"></i>Lista B1, B2: Psicotrópicos</li>
                        <li><i class="bi bi-check text-success me-2"></i>Lista C1 a C5: Outras substâncias</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <div class="alert alert-warning py-2 mb-0">
                        <small>
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            A transmissão ao SNGPC deve ser feita até o dia 15 do mês seguinte.
                            <br>
                            Período de referência: <strong>@(new DateTime(year, month, 1).ToString("MMMM/yyyy"))</strong>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .btn, form, .sidebar, .top-nav { display: none !important; }
        .main-content { margin-left: 0 !important; }
        .card { break-inside: avoid; }
    }
</style>

@section Scripts {
<script>
    function exportarXML() {
        alert('Funcionalidade de exportação XML SNGPC em desenvolvimento.\n\nPor enquanto, utilize o sistema da ANVISA para transmissão manual.');
    }
</script>
}
