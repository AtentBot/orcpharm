@{
    ViewData["Title"] = "Central de Alertas";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1"><i class="bi bi-bell me-2"></i>Central de Alertas</h4>
            <p class="text-muted mb-0">Monitoramento de itens que requerem atenção</p>
        </div>
        <div>
            <a href="/Executivo" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Voltar
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tipo de Alerta</label>
                    <select class="form-select" id="filtroTipo" onchange="carregarAlertas()">
                        <option value="">Todos</option>
                        <option value="estoque">Estoque Crítico</option>
                        <option value="validade">Validade</option>
                        <option value="producao">Produção</option>
                        <option value="documentos">Documentos</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Prioridade</label>
                    <select class="form-select" id="filtroPrioridade" onchange="filtrarPorPrioridade()">
                        <option value="">Todas</option>
                        <option value="ALTA">Alta</option>
                        <option value="MEDIA">Média</option>
                        <option value="BAIXA">Baixa</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-primary" onclick="carregarAlertas()">
                        <i class="bi bi-arrow-clockwise me-1"></i>Atualizar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resumo -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0" id="totalAlta">-</h3>
                    <small>Prioridade Alta</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0" id="totalMedia">-</h3>
                    <small>Prioridade Média</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-secondary text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0" id="totalBaixa">-</h3>
                    <small>Prioridade Baixa</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-3">
                    <h3 class="mb-0" id="totalGeral">-</h3>
                    <small>Total de Alertas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Alertas -->
    <div class="card">
        <div class="card-body p-0" id="listaAlertas">
            <div class="text-center py-5 text-muted">
                <div class="spinner-border mb-3"></div>
                <p>Carregando alertas...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let todosAlertas = [];

    document.addEventListener('DOMContentLoaded', function() {
        carregarAlertas();
    });

    async function carregarAlertas() {
        const tipo = document.getElementById('filtroTipo').value;
        let url = '/api/alertas';
        if (tipo) url += `?tipo=${tipo}`;

        try {
            const response = await fetch(url);
            const data = await response.json();

            todosAlertas = data.alertas || [];
            
            // Atualizar contadores
            const alta = todosAlertas.filter(a => a.prioridade === 'ALTA').length;
            const media = todosAlertas.filter(a => a.prioridade === 'MEDIA').length;
            const baixa = todosAlertas.filter(a => a.prioridade === 'BAIXA').length;

            document.getElementById('totalAlta').textContent = alta;
            document.getElementById('totalMedia').textContent = media;
            document.getElementById('totalBaixa').textContent = baixa;
            document.getElementById('totalGeral').textContent = data.total || 0;

            renderizarAlertas(todosAlertas);
        } catch (error) {
            console.error('Erro ao carregar alertas:', error);
            document.getElementById('listaAlertas').innerHTML = `
                <div class="text-center py-5 text-danger">
                    <i class="bi bi-exclamation-circle fs-1"></i>
                    <p class="mt-2">Erro ao carregar alertas</p>
                </div>`;
        }
    }

    function filtrarPorPrioridade() {
        const prioridade = document.getElementById('filtroPrioridade').value;
        const filtrados = prioridade 
            ? todosAlertas.filter(a => a.prioridade === prioridade)
            : todosAlertas;
        renderizarAlertas(filtrados);
    }

    function renderizarAlertas(alertas) {
        const container = document.getElementById('listaAlertas');

        if (!alertas || alertas.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check-circle fs-1 text-success"></i>
                    <p class="mt-3 mb-0">Nenhum alerta encontrado</p>
                    <small>Tudo está em ordem!</small>
                </div>`;
            return;
        }

        container.innerHTML = alertas.map(alerta => `
            <div class="d-flex align-items-center p-3 border-bottom ${alerta.prioridade === 'ALTA' ? 'bg-danger bg-opacity-10' : ''}">
                <div class="rounded-circle bg-${alerta.cor} bg-opacity-10 p-3 me-3">
                    <i class="bi bi-${alerta.icone} text-${alerta.cor} fs-5"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center mb-1">
                        <span class="fw-bold me-2">${alerta.titulo}</span>
                        <span class="badge bg-${getPrioridadeCor(alerta.prioridade)} text-${alerta.prioridade === 'MEDIA' ? 'dark' : 'white'}">
                            ${alerta.prioridade}
                        </span>
                    </div>
                    <p class="mb-1 text-muted">${alerta.mensagem}</p>
                    <small class="text-muted">
                        <i class="bi bi-tag me-1"></i>${alerta.tipo.replace(/_/g, ' ')}
                        ${alerta.dataLimite ? `<span class="ms-2"><i class="bi bi-calendar me-1"></i>${formatarData(alerta.dataLimite)}</span>` : ''}
                    </small>
                </div>
                ${alerta.link ? `
                    <a href="${alerta.link}" class="btn btn-outline-${alerta.cor} btn-sm ms-3">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                ` : ''}
            </div>
        `).join('');
    }

    function getPrioridadeCor(prioridade) {
        return {
            'ALTA': 'danger',
            'MEDIA': 'warning',
            'BAIXA': 'secondary'
        }[prioridade] || 'secondary';
    }

    function formatarData(dateString) {
        return new Date(dateString).toLocaleDateString('pt-BR');
    }
</script>
}
