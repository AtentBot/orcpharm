@{
    ViewData["Title"] = "Formula Clear - Sistema de Gestão para Farmácias de Manipulação";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="~/images/logoFormulaClear.png" alt="Formula Clear" style="height: 36px;" class="me-2">
                <span class="fw-bold ms-2">Formula Clear</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#features">Funcionalidades</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#pricing">Planos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dashboard">Entrar</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary ms-2" href="/Signup">Começar Grátis</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="hero-content">
                        <h1 class="hero-title">
                            Gestão Completa para sua <span class="text-primary">Farmácia de Manipulação</span>
                        </h1>
                        <p class="hero-subtitle">
                            Sistema completo para controlar produção, estoque, vendas e precificação.
                            Aumente a eficiência e profissionalize sua farmácia.
                        </p>
                        <div class="hero-cta">
                            <a href="/Signup" class="btn btn-primary btn-lg me-3">
                                <i class="bi bi-rocket-takeoff me-2"></i>Começar Grátis - 14 dias
                            </a>
                            <a href="#pricing" class="btn btn-outline-secondary btn-lg">
                                Ver Planos
                            </a>
                        </div>
                        <div class="hero-benefits mt-4">
                            <span class="benefit-item">
                                <i class="bi bi-check-circle-fill text-success"></i> Sem cartão de crédito
                            </span>
                            <span class="benefit-item">
                                <i class="bi bi-check-circle-fill text-success"></i> Cancelamento a qualquer momento
                            </span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="hero-image">
                        <img src="~/images/logoFormulaClear.png" alt="Formula Clear Dashboard" class="img-fluid">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section">
        <div class="container">
            <div class="section-header text-center">
                <h2 class="section-title">Por que escolher o Formula Clear?</h2>
                <p class="section-subtitle">Tudo que você precisa para gerenciar sua farmácia em um único lugar</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-clipboard2-pulse"></i>
                        </div>
                        <h3 class="feature-title">Gestão de Produção</h3>
                        <p class="feature-description">
                            Controle completo do processo de manipulação com workflow digital, rastreabilidade e impressão de rótulos profissionais.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-boxes"></i>
                        </div>
                        <h3 class="feature-title">Controle de Estoque</h3>
                        <p class="feature-description">
                            Gestão inteligente de matérias-primas com alertas de estoque mínimo, rastreamento de lotes e validades.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-calculator"></i>
                        </div>
                        <h3 class="feature-title">Precificação Inteligente</h3>
                        <p class="feature-description">
                            Sistema automático de precificação considerando custos, margem e fatores de correção para máxima rentabilidade.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-file-earmark-medical"></i>
                        </div>
                        <h3 class="feature-title">Prescrições Digitais</h3>
                        <p class="feature-description">
                            Gestão completa de receitas médicas com upload de imagens, OCR e validação farmacêutica integrada.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-cart-check"></i>
                        </div>
                        <h3 class="feature-title">Vendas & Orçamentos</h3>
                        <p class="feature-description">
                            Crie orçamentos profissionais, gerencie pedidos e aceite pagamentos online com integração Stripe.
                        </p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                        <h3 class="feature-title">Relatórios & Analytics</h3>
                        <p class="feature-description">
                            Dashboard completo com métricas de produção, vendas, estoque e análise financeira em tempo real.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="pricing-section">
        <div class="container">
            <div class="section-header text-center">
                <h2 class="section-title">Planos e Preços</h2>
                <p class="section-subtitle">Escolha o plano ideal para o tamanho da sua farmácia</p>
            </div>

            <!-- Billing Cycle Toggle -->
            <div class="billing-toggle text-center mb-5">
                <span class="billing-label">Mensal</span>
                <div class="form-check form-switch d-inline-block mx-3">
                    <input class="form-check-input" type="checkbox" id="billingCycleToggle">
                    <label class="form-check-label visually-hidden" for="billingCycleToggle">Alternar ciclo de cobrança</label>
                </div>
                <span class="billing-label">Anual</span>
                <span class="badge bg-success ms-2">Economize até 20%</span>
            </div>

            <div id="pricingCards" class="row g-4 justify-content-center">
                <!-- Pricing cards will be loaded here by JavaScript -->
            </div>

            <div class="text-center mt-5">
                <p class="text-muted">
                    <i class="bi bi-shield-check me-2"></i>
                    Todos os planos incluem 14 dias de teste grátis. Cancele a qualquer momento.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h2 class="cta-title">Pronto para modernizar sua farmácia?</h2>
                    <p class="cta-subtitle">
                        Junte-se a centenas de farmácias que já transformaram sua gestão com o Formula Clear
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="/Signup" class="btn btn-light btn-lg">
                        <i class="bi bi-rocket-takeoff me-2"></i>Começar Agora
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">
                        <img src="~/images/logoFormulaClear.png" alt="Formula Clear" style="height: 28px;" class="me-1">
                        Formula Clear
                    </h5>
                    <p class="text-muted">
                        Sistema completo de gestão para farmácias de manipulação.
                    </p>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold mb-3">Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#features" class="text-muted">Funcionalidades</a></li>
                        <li><a href="#pricing" class="text-muted">Planos</a></li>
                        <li><a href="/Dashboard" class="text-muted">Entrar</a></li>
                        <li><a href="/swagger" class="text-muted">API Docs</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold mb-3">Legal</h6>
                    <ul class="list-unstyled">
                        <li><a href="/terms" class="text-muted">Termos de Uso</a></li>
                        <li><a href="/privacy" class="text-muted">Política de Privacidade</a></li>
                    </ul>
                </div>
            </div>
            <hr>
            <div class="text-center text-muted">
                <p>&copy; 2025 Formula Clear. Todos os direitos reservados. | D&W Consultoria em Ltda</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/landing.js"></script>
</body>
</html>
