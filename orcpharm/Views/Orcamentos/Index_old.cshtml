                    <tr><td>Materiais:</td><td class="text-end">R$ ${formatMoney(quote.materialsCost)}</td></tr>
                    <tr><td>Markup (${quote.markupPercentage || 150}%):</td><td class="text-end">R$ ${formatMoney(quote.markupValue)}</td></tr>
                    <tr><td>Mão de obra:</td><td class="text-end">R$ ${formatMoney(quote.laborCost)}</td></tr>
                    <tr><td>Embalagem:</td><td class="text-end">R$ ${formatMoney(quote.packagingCost)}</td></tr>
                    ${quote.discountValue > 0 ? `<tr class="text-danger"><td>Desconto:</td><td class="text-end">- R$ ${formatMoney(quote.discountValue)}</td></tr>` : ''}
                    <tr class="table-success"><th>Total:</th><th class="text-end">R$ ${formatMoney(quote.finalPrice)}</th></tr>
