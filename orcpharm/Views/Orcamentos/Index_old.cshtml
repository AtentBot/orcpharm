// Exportar
function exportToExcel() {
    showToast('Funcionalidade em desenvolvimento', 'info');
}

// Helpers
function showLoading(show) {
    document.getElementById('loadingOverlay').style.display = show ? 'flex' : 'none';
}

function showError(message) {
    document.getElementById('quotesTable').innerHTML = `
        <tr>
            <td colspan="7" class="text-center py-5 text-danger">
                <i class="bi bi-exclamation-triangle fs-1"></i>
                <p class="mt-2">${message}</p>
                <button class="btn btn-primary" onclick="loadQuotes()">Tentar novamente</button>
            </td>
        </tr>`;
}

function showToast(message, type = 'info') {
    const alertClass = type === 'error' ? 'danger' : type === 'success' ? 'success' : type === 'warning' ? 'warning' : 'info';
    const iconClass = type === 'error' ? 'x-circle' : type === 'success' ? 'check-circle' : type === 'warning' ? 'exclamation-circle' : 'info-circle';
    
    const toast = document.createElement('div');
    toast.className = `alert alert-${alertClass} position-fixed shadow-lg`;
    toast.style.cssText = 'top: 20px; right: 20px; z-index: 10000; min-width: 300px; max-width: 400px;';
    toast.innerHTML = `
        <div class="d-flex align-items-center">
            <i class="bi bi-${iconClass} me-2 fs-5"></i>
            <span>${escapeHtml(message)}</span>
            <button type="button" class="btn-close ms-auto" onclick="this.parentElement.parentElement.remove()"></button>
        </div>
    `;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
}
</script>
