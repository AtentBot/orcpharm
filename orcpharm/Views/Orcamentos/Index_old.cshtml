                    <span><i class="bi bi-calendar-check"></i> Válido até: ${formatDate(quote.validUntil)}</span>
                    <span><i class="bi bi-truck"></i> Prazo: ${quote.estimatedDays || 3} dias</span>
                    <span><i class="bi bi-eye"></i> Visualizações: ${quote.viewCount || 0}</span>
                </div>
            </div>
        </div>
