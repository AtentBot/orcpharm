@{
    ViewData["Title"] = "Posição de Estoque";
}

<!-- Header -->
<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0"><i class="bi bi-graph-up me-2"></i>Posição de Estoque</h2>
                <p class="text-muted mb-0">Visão consolidada do estoque de matérias-primas</p>
            </div>
            <div>
                <button class="btn btn-outline-success me-2" onclick="exportToExcel()">
                    <i class="bi bi-file-earmark-excel me-1"></i> Exportar
                </button>
                <a href="/Estoque" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Voltar ao Estoque
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Cards de Resumo -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Total de Itens</p>
                        <h3 class="mb-0" id="totalItens">-</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="bi bi-boxes text-primary fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Estoque Normal</p>
                        <h3 class="mb-0 text-success" id="estoqueNormal">-</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <i class="bi bi-check-circle text-success fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Estoque Baixo</p>
                        <h3 class="mb-0 text-warning" id="estoqueBaixo">-</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded">
                        <i class="bi bi-exclamation-triangle text-warning fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1 small">Estoque Zerado</p>
                        <h3 class="mb-0 text-danger" id="estoqueZerado">-</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded">
                        <i class="bi bi-x-circle text-danger fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row align-items-end">
                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Situação do Estoque</label>
                        <select id="filterStatus" class="form-select form-select-sm">
                            <option value="">Todos</option>
                            <option value="BAIXO">Estoque Baixo</option>
                            <option value="NORMAL">Estoque Normal</option>
                            <option value="EXCESSO">Estoque em Excesso</option>
                            <option value="ZERADO">Zerado</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Tipo de Controle</label>
                        <select id="filterControl" class="form-select form-select-sm">
                            <option value="">Todos</option>
                            <option value="NORMAL">Normal</option>
                            <option value="CONTROLADO">Controlado</option>
                            <option value="ANTIMICROBIANO">Antimicrobiano</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Buscar</label>
                        <input type="text" id="filterSearch" class="form-control form-control-sm" placeholder="Nome ou código...">
                    </div>
                    <div class="col-md-3 mb-2">
                        <button onclick="loadMaterials()" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-search me-1"></i> Filtrar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabela de Posição -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-list-ul me-2"></i>
                    Posição Atual
                </h5>
                <span class="badge bg-secondary" id="totalRegistros">0 itens</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="stockTable">
                        <thead class="table-light">
                            <tr>
                                <th style="cursor:pointer" onclick="sortTable('name')">
                                    Matéria-Prima <i class="bi bi-arrow-down-up small"></i>
                                </th>
                                <th>Código DCB</th>
                                <th>Tipo</th>
                                <th class="text-end" style="cursor:pointer" onclick="sortTable('currentStock')">
                                    Estoque Atual <i class="bi bi-arrow-down-up small"></i>
                                </th>
                                <th class="text-end">Mínimo</th>
                                <th class="text-end">Máximo</th>
                                <th>Situação</th>
                                <th class="text-center">Nível</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="materialsTable">
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">
                                    <i class="bi bi-hourglass-split fs-1 d-block mb-2"></i>
                                    Carregando posição de estoque...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Detalhes -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-box-seam me-2"></i>
                    <span id="modalMaterialName">Detalhes da Matéria-Prima</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" id="detailsTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabInfo">
                            <i class="bi bi-info-circle me-1"></i> Informações
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabBatches">
                            <i class="bi bi-box-seam me-1"></i> Lotes
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabMovements">
                            <i class="bi bi-arrow-left-right me-1"></i> Movimentações
                        </button>
                    </li>
                </ul>
                <div class="tab-content pt-3" id="detailsTabContent">
                    <div class="tab-pane fade show active" id="tabInfo">
                        <div id="materialInfo">Carregando...</div>
                    </div>
                    <div class="tab-pane fade" id="tabBatches">
                        <div id="materialBatches">Carregando...</div>
                    </div>
                    <div class="tab-pane fade" id="tabMovements">
                        <div id="materialMovements">Carregando...</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let allMaterials = [];
let currentSort = { field: 'name', asc: true };

document.addEventListener('DOMContentLoaded', function() {
    loadMaterials();
    
    // Busca ao digitar
    document.getElementById('filterSearch').addEventListener('keyup', function(e) {
        if (e.key === 'Enter') loadMaterials();
    });
});

function extractArray(result) {
    if (Array.isArray(result)) return result;
    if (result && Array.isArray(result.items)) return result.items;
    if (result && Array.isArray(result.data)) return result.data;
    return [];
}

async function loadMaterials() {
    try {
        const response = await fetch('/api/RawMaterials', { credentials: 'include' });
        
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        
        const result = await response.json();
        let materials = extractArray(result);
        
        allMaterials = materials;
        
        // Aplicar filtros
        const statusFilter = document.getElementById('filterStatus').value;
        const controlFilter = document.getElementById('filterControl').value;
        const searchFilter = document.getElementById('filterSearch').value.toLowerCase();
        
        if (statusFilter) {
            if (statusFilter === 'ZERADO') {
                materials = materials.filter(m => m.currentStock === 0);
            } else {
                materials = materials.filter(m => m.stockStatus === statusFilter);
            }
        }
        
        if (controlFilter) {
            materials = materials.filter(m => m.controlType === controlFilter);
        }
        
        if (searchFilter) {
            materials = materials.filter(m => 
                (m.name || '').toLowerCase().includes(searchFilter) ||
                (m.dcbCode || '').toLowerCase().includes(searchFilter) ||
                (m.casNumber || '').toLowerCase().includes(searchFilter)
            );
        }
        
        // Ordenar
        materials.sort((a, b) => {
            let valA = a[currentSort.field] || '';
            let valB = b[currentSort.field] || '';
            if (typeof valA === 'string') valA = valA.toLowerCase();
            if (typeof valB === 'string') valB = valB.toLowerCase();
            if (valA < valB) return currentSort.asc ? -1 : 1;
            if (valA > valB) return currentSort.asc ? 1 : -1;
            return 0;
        });
        
        updateStats(allMaterials);
        renderMaterials(materials);
        document.getElementById('totalRegistros').textContent = `${materials.length} itens`;
        
    } catch (error) {
        console.error('Erro ao carregar materiais:', error);
        document.getElementById('materialsTable').innerHTML = `
            <tr>
                <td colspan="9" class="text-center py-4 text-danger">
                    <i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i>
                    Erro ao carregar: ${error.message}
                </td>
            </tr>`;
    }
}

function updateStats(materials) {
    const total = materials.length;
    const normal = materials.filter(m => m.stockStatus === 'NORMAL').length;
    const baixo = materials.filter(m => m.stockStatus === 'BAIXO').length;
    const zerado = materials.filter(m => m.currentStock === 0).length;
    
    document.getElementById('totalItens').textContent = total;
    document.getElementById('estoqueNormal').textContent = normal;
    document.getElementById('estoqueBaixo').textContent = baixo;
    document.getElementById('estoqueZerado').textContent = zerado;
}

function renderMaterials(materials) {
    const tbody = document.getElementById('materialsTable');
    
    if (!materials || materials.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="9" class="text-center py-4 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Nenhuma matéria-prima encontrada
                </td>
            </tr>`;
        return;
    }
    
    tbody.innerHTML = materials.map(m => {
        const stockPercent = m.stockPercentage || 0;
        const progressColor = getProgressColor(m.stockStatus);
        
        return `
            <tr>
                <td>
                    <span class="fw-bold">${m.name || '-'}</span>
                    ${m.requiresSpecialAuthorization ? '<br><span class="badge bg-danger">Controlado</span>' : ''}
                </td>
                <td><small class="text-muted">${m.dcbCode || '-'}</small></td>
                <td>${getControlBadge(m.controlType)}</td>
                <td class="text-end fw-bold">${formatQuantity(m.currentStock, m.unit)}</td>
                <td class="text-end text-muted">${formatQuantity(m.minimumStock, m.unit)}</td>
                <td class="text-end text-muted">${formatQuantity(m.maximumStock, m.unit)}</td>
                <td>${getStatusBadge(m.stockStatus, m.currentStock)}</td>
                <td style="width: 120px;">
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar ${progressColor}" style="width: ${Math.min(stockPercent, 100)}%"></div>
                    </div>
                    <small class="text-muted">${stockPercent.toFixed(0)}%</small>
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-info" onclick="showDetails('${m.id}')" title="Detalhes">
                            <i class="bi bi-eye"></i>
                        </button>
                        <a href="/MateriasPrimas/Editar/${m.id}" class="btn btn-outline-secondary" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

function getStatusBadge(status, currentStock) {
    if (currentStock === 0) {
        return '<span class="badge bg-danger">Zerado</span>';
    }
    const badges = {
        'BAIXO': '<span class="badge bg-warning text-dark">Baixo</span>',
        'NORMAL': '<span class="badge bg-success">Normal</span>',
        'EXCESSO': '<span class="badge bg-info">Excesso</span>'
    };
    return badges[status] || '<span class="badge bg-secondary">-</span>';
}

function getControlBadge(type) {
    const badges = {
        'NORMAL': '<span class="badge bg-light text-dark">Normal</span>',
        'CONTROLADO': '<span class="badge bg-danger">Controlado</span>',
        'ANTIMICROBIANO': '<span class="badge bg-warning text-dark">Antimicrobiano</span>'
    };
    return badges[type] || '<span class="badge bg-secondary">-</span>';
}

function getProgressColor(status) {
    const colors = {
        'BAIXO': 'bg-warning',
        'NORMAL': 'bg-success',
        'EXCESSO': 'bg-info'
    };
    return colors[status] || 'bg-secondary';
}

function formatQuantity(qty, unit) {
    if (qty === null || qty === undefined) return '-';
    return `${parseFloat(qty).toFixed(2)} ${unit || ''}`;
}

function sortTable(field) {
    if (currentSort.field === field) {
        currentSort.asc = !currentSort.asc;
    } else {
        currentSort.field = field;
        currentSort.asc = true;
    }
    loadMaterials();
}

async function showDetails(materialId) {
    const material = allMaterials.find(m => m.id === materialId);
    if (material) {
        document.getElementById('modalMaterialName').textContent = material.name;
    }
    
    // Tab Informações
    document.getElementById('materialInfo').innerHTML = `
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold text-muted small">Nome</label>
                <p class="mb-0">${material?.name || '-'}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Código DCB</label>
                <p class="mb-0">${material?.dcbCode || '-'}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">CAS Number</label>
                <p class="mb-0">${material?.casNumber || '-'}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Estoque Atual</label>
                <p class="mb-0 fs-4 fw-bold">${formatQuantity(material?.currentStock, material?.unit)}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Estoque Mínimo</label>
                <p class="mb-0">${formatQuantity(material?.minimumStock, material?.unit)}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Estoque Máximo</label>
                <p class="mb-0">${formatQuantity(material?.maximumStock, material?.unit)}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Situação</label>
                <p class="mb-0">${getStatusBadge(material?.stockStatus, material?.currentStock)}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Tipo Controle</label>
                <p class="mb-0">${getControlBadge(material?.controlType)}</p>
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold text-muted small">Fator de Pureza</label>
                <p class="mb-0">${material?.purityFactor ? (material.purityFactor * 100).toFixed(1) + '%' : '-'}</p>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold text-muted small">Condições de Armazenamento</label>
                <p class="mb-0">
                    ${material?.requiresRefrigeration ? '<span class="badge bg-info me-1">Refrigeração</span>' : ''}
                    ${material?.lightSensitive ? '<span class="badge bg-warning text-dark me-1">Sensível à Luz</span>' : ''}
                    ${material?.humiditySensitive ? '<span class="badge bg-secondary me-1">Sensível à Umidade</span>' : ''}
                    ${!material?.requiresRefrigeration && !material?.lightSensitive && !material?.humiditySensitive ? 'Ambiente normal' : ''}
                </p>
            </div>
        </div>
    `;
    
    // Carregar lotes
    loadMaterialBatches(materialId);
    
    // Carregar movimentações
    loadMaterialMovements(materialId);
    
    new bootstrap.Modal(document.getElementById('detailsModal')).show();
}

async function loadMaterialBatches(materialId) {
    try {
        const response = await fetch(`/api/Batches?rawMaterialId=${materialId}`, { credentials: 'include' });
        const result = await response.json();
        const batches = extractArray(result);
        
        if (batches.length === 0) {
            document.getElementById('materialBatches').innerHTML = '<p class="text-muted">Nenhum lote encontrado</p>';
            return;
        }
        
        document.getElementById('materialBatches').innerHTML = `
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Lote</th>
                        <th>Fornecedor</th>
                        <th class="text-end">Quantidade</th>
                        <th>Validade</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    ${batches.map(b => `
                        <tr>
                            <td>${b.batchNumber || '-'}</td>
                            <td>${b.companyName || b.supplierName || '-'}</td>
                            <td class="text-end">${formatQuantity(b.currentQuantity, b.unit)}</td>
                            <td>${formatDate(b.expiryDate)}</td>
                            <td>${getStatusBadgeBatch(b.status)}</td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        `;
    } catch (error) {
        document.getElementById('materialBatches').innerHTML = '<p class="text-danger">Erro ao carregar lotes</p>';
    }
}

async function loadMaterialMovements(materialId) {
    try {
        const response = await fetch(`/api/StockMovements?rawMaterialId=${materialId}&limit=20`, { credentials: 'include' });
        const result = await response.json();
        const movements = extractArray(result);
        
        if (movements.length === 0) {
            document.getElementById('materialMovements').innerHTML = '<p class="text-muted">Nenhuma movimentação encontrada</p>';
            return;
        }
        
        document.getElementById('materialMovements').innerHTML = `
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Tipo</th>
                        <th class="text-end">Quantidade</th>
                        <th>Lote</th>
                        <th>Motivo</th>
                    </tr>
                </thead>
                <tbody>
                    ${movements.map(m => `
                        <tr>
                            <td>${formatDateTime(m.createdAt || m.movementDate)}</td>
                            <td>${getMovementTypeBadge(m.movementType || m.type)}</td>
                            <td class="text-end">${formatQuantity(m.quantity, m.unit)}</td>
                            <td>${m.batchNumber || '-'}</td>
                            <td><small>${m.reason || m.notes || '-'}</small></td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        `;
    } catch (error) {
        document.getElementById('materialMovements').innerHTML = '<p class="text-danger">Erro ao carregar movimentações</p>';
    }
}

function getStatusBadgeBatch(status) {
    const badges = {
        'QUARENTENA': '<span class="badge bg-warning text-dark">Quarentena</span>',
        'APROVADO': '<span class="badge bg-success">Aprovado</span>',
        'REPROVADO': '<span class="badge bg-danger">Reprovado</span>'
    };
    return badges[status] || `<span class="badge bg-secondary">${status || '-'}</span>`;
}

function getMovementTypeBadge(type) {
    const badges = {
        'ENTRADA': '<span class="badge bg-success">Entrada</span>',
        'SAIDA': '<span class="badge bg-danger">Saída</span>',
        'AJUSTE': '<span class="badge bg-warning text-dark">Ajuste</span>',
        'PERDA': '<span class="badge bg-dark">Perda</span>',
        'TRANSFERENCIA': '<span class="badge bg-info">Transferência</span>'
    };
    return badges[type] || `<span class="badge bg-secondary">${type || '-'}</span>`;
}

function formatDate(dateStr) {
    if (!dateStr) return '-';
    try {
        return new Date(dateStr).toLocaleDateString('pt-BR');
    } catch {
        return '-';
    }
}

function formatDateTime(dateStr) {
    if (!dateStr) return '-';
    try {
        return new Date(dateStr).toLocaleString('pt-BR', { 
            day: '2-digit', 
            month: '2-digit', 
            year: '2-digit',
            hour: '2-digit',
            minute: '2-digit'
        });
    } catch {
        return '-';
    }
}

function exportToExcel() {
    // Criar CSV
    let csv = 'Nome;Código DCB;Tipo Controle;Estoque Atual;Unidade;Mínimo;Máximo;Situação\n';
    
    allMaterials.forEach(m => {
        csv += `"${m.name || ''}";"${m.dcbCode || ''}";"${m.controlType || ''}";"${m.currentStock || 0}";"${m.unit || ''}";"${m.minimumStock || 0}";"${m.maximumStock || 0}";"${m.stockStatus || ''}"\n`;
    });
    
    // Download
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `posicao_estoque_${new Date().toISOString().split('T')[0]}.csv`;
    link.click();
}
</script>
}
