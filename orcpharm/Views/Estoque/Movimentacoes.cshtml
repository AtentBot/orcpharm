@{
    ViewData["Title"] = "Movimentações de Estoque";
}

<!-- Header -->
<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0"><i class="bi bi-arrow-left-right me-2"></i>Movimentações de Estoque</h2>
                <p class="text-muted mb-0">Histórico completo de entradas e saídas</p>
            </div>
            <div>
                <a href="/Estoque" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Tipo de Movimentação</label>
                        <select id="filterType" class="form-select form-select-sm">
                            <option value="">Todos</option>
                            <option value="ENTRADA">Entrada</option>
                            <option value="SAIDA">Saída</option>
                            <option value="AJUSTE">Ajuste</option>
                            <option value="PERDA">Perda</option>
                            <option value="TRANSFERENCIA">Transferência</option>
                        </select>
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Data Início</label>
                        <input type="date" id="filterStartDate" class="form-control form-control-sm">
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Data Fim</label>
                        <input type="date" id="filterEndDate" class="form-control form-control-sm">
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="form-label small">Buscar</label>
                        <input type="text" id="filterSearch" class="form-control form-control-sm" placeholder="Matéria-prima, lote...">
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-12">
                        <button onclick="applyFilters()" class="btn btn-primary btn-sm">
                            <i class="bi bi-funnel me-1"></i>Filtrar
                        </button>
                        <button onclick="clearFilters()" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x-circle me-1"></i>Limpar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabela de Movimentações -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 10%">Data/Hora</th>
                                <th style="width: 10%">Tipo</th>
                                <th style="width: 20%">Matéria-Prima</th>
                                <th style="width: 10%">Lote</th>
                                <th style="width: 10%" class="text-end">Quantidade</th>
                                <th style="width: 15%">Motivo</th>
                                <th style="width: 15%">Funcionário</th>
                                <th style="width: 10%">Documento</th>
                            </tr>
                        </thead>
                        <tbody id="movementsTable">
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Carregando...</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Paginação -->
            <div class="card-footer bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small">Total: <strong id="totalCount">0</strong> movimentações</span>
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentPage = 1;
const pageSize = 20;

document.addEventListener('DOMContentLoaded', function() {
    loadMovements();
});

async function loadMovements(page = 1) {
    currentPage = page;
    
    const type = document.getElementById('filterType').value;
    const startDate = document.getElementById('filterStartDate').value;
    const endDate = document.getElementById('filterEndDate').value;
    const searchTerm = document.getElementById('filterSearch').value;
    
    const params = new URLSearchParams({
        page: page,
        pageSize: pageSize
    });
    
    if (type) params.append('movementType', type);
    if (startDate) params.append('startDate', startDate);
    if (endDate) params.append('endDate', endDate);
    if (searchTerm) params.append('searchTerm', searchTerm);
    
    try {
        const response = await fetch(`/api/StockMovements?${params}`, {
            credentials: 'include'
        });
        const data = await response.json();
        
        renderMovements(data.movements);
        renderPagination(data.totalPages, data.page);
        document.getElementById('totalCount').textContent = data.totalCount;
        
    } catch (error) {
        console.error('Erro ao carregar movimentações:', error);
        document.getElementById('movementsTable').innerHTML = 
            '<tr><td colspan="8" class="text-center text-danger py-4">Erro ao carregar movimentações</td></tr>';
    }
}

function renderMovements(movements) {
    const tbody = document.getElementById('movementsTable');
    
    if (!movements || movements.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-muted">Nenhuma movimentação encontrada</td></tr>';
        return;
    }
    
    tbody.innerHTML = movements.map(m => `
        <tr>
            <td>
                <small>${formatDateTime(m.movementDate)}</small>
            </td>
            <td>
                ${getMovementTypeBadge(m.movementType)}
            </td>
            <td>
                <strong>${m.rawMaterialName}</strong>
            </td>
            <td>
                <small class="text-muted">${m.batchNumber || '-'}</small>
            </td>
            <td class="text-end">
                <strong class="${m.quantity > 0 ? 'text-success' : 'text-danger'}">
                    ${m.quantity > 0 ? '+' : ''}${m.quantity.toFixed(2)}
                </strong>
            </td>
            <td>
                <small class="text-muted">${m.reason || '-'}</small>
            </td>
            <td>
                <small>${m.performedByEmployeeName || '-'}</small>
            </td>
            <td>
                <small class="text-muted">${m.documentNumber || '-'}</small>
            </td>
        </tr>
    `).join('');
}

function renderPagination(totalPages, currentPage) {
    const pagination = document.getElementById('pagination');
    
    if (totalPages <= 1) {
        pagination.innerHTML = '';
        return;
    }
    
    let html = '';
    
    // Anterior
    html += `
        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="loadMovements(${currentPage - 1}); return false;">Anterior</a>
        </li>
    `;
    
    // Páginas
    for (let i = 1; i <= Math.min(totalPages, 5); i++) {
        html += `
            <li class="page-item ${i === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" onclick="loadMovements(${i}); return false;">${i}</a>
            </li>
        `;
    }
    
    // Próxima
    html += `
        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="loadMovements(${currentPage + 1}); return false;">Próxima</a>
        </li>
    `;
    
    pagination.innerHTML = html;
}

function getMovementTypeBadge(type) {
    const badges = {
        'ENTRADA': '<span class="badge bg-success">Entrada</span>',
        'SAIDA': '<span class="badge bg-danger">Saída</span>',
        'AJUSTE': '<span class="badge bg-warning">Ajuste</span>',
        'PERDA': '<span class="badge bg-secondary">Perda</span>',
        'TRANSFERENCIA': '<span class="badge bg-info">Transfer.</span>'
    };
    return badges[type] || `<span class="badge bg-secondary">${type}</span>`;
}

function formatDateTime(dateStr) {
    const date = new Date(dateStr);
    return date.toLocaleDateString('pt-BR') + ' ' + date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
}

function applyFilters() {
    loadMovements(1);
}

function clearFilters() {
    document.getElementById('filterType').value = '';
    document.getElementById('filterStartDate').value = '';
    document.getElementById('filterEndDate').value = '';
    document.getElementById('filterSearch').value = '';
    loadMovements(1);
}
</script>
}
