@{
    ViewData["Title"] = "Redefinir Senha";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrcPharm — Redefinir Senha</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>@@import url('https://api.fontshare.com/v2/css?f[]=general-sans@@400,500,600&display=swap');</style>
    <link rel="stylesheet" href="~/css/design-system/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system/components.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">

    <style>
        body { background: var(--bg); }
        .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 32px; }
        .login-card { width: 100%; max-width: 420px; }
        .login-card .brand-block { text-align: center; margin-bottom: 32px; }
        .login-card h1 { font-size: 26px; font-weight: 600; letter-spacing: -0.025em; margin: 0 0 8px; text-align: center; }
        .login-card .sub { color: var(--ink-3); font-size: 14px; margin: 0 0 32px; text-align: center; }
        .login-form { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--r-md); padding: 32px; box-shadow: var(--shadow-1); display: flex; flex-direction: column; gap: 16px; }
        .login-footer { text-align: center; margin-top: 24px; font-size: 13px; color: var(--ink-3); }
        .login-footer a { color: var(--petrol-500); text-decoration: none; font-weight: 500; }
        .compliance { text-align: center; margin-top: 32px; color: var(--ink-4); font-size: 11px; font-family: var(--font-mono); letter-spacing: 0.06em; text-transform: uppercase; display: flex; gap: 16px; justify-content: center; }
        .brand-lg { font-size: 22px; }
        .pw-field { position: relative; }
        .pw-field .input { padding-right: 40px; }
        .pw-toggle { position: absolute; right: 4px; top: 4px; bottom: 4px; width: 32px; border: none; background: transparent; color: var(--ink-3); cursor: pointer; display: flex; align-items: center; justify-content: center; border-radius: var(--r-xs); }
        .pw-toggle:hover { background: var(--bg-subtle); }
        .password-strength { height: 4px; border-radius: 2px; margin-top: 6px; background: var(--rule); transition: all .2s; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="brand-block">
                <a href="/" class="brand brand-lg">
                    <span class="brand-glyph" style="width:32px;height:32px;"><svg width="32" height="32" viewBox="0 0 88 88" fill="none" aria-hidden="true"><path d="M18 18 H36 a16 16 0 0 1 16 16 V52 H36 a16 16 0 0 1 -16 -16 V18 Z" fill="var(--petrol-500)"/><rect x="52" y="18" width="22" height="11" rx="5.5" fill="var(--petrol-500)"/><rect x="52" y="35" width="16" height="10" rx="5" fill="var(--petrol-500)"/></svg></span>
                    <span class="brand-name">farmify<span class="accent">.</span></span>
                </a>
            </div>
            <h1>Redefinir senha</h1>
            <p class="sub">Digite o código recebido e sua nova senha.</p>

            <div id="alertContainer"></div>

            <form id="resetForm" class="login-form" autocomplete="off">
                <input type="hidden" id="identifier" />

                <div id="cpfGroup">
                    <label class="input-label" for="cpfInput">CPF</label>
                    <input class="input mono" type="text" id="cpfInput" placeholder="000.000.000-00" maxlength="14" required />
                    <div class="input-hint">Digite o CPF que solicitou a recuperação</div>
                </div>

                <div>
                    <label class="input-label" for="code">Código de verificação</label>
                    <input class="input mono" type="text" id="code" placeholder="000000" required maxlength="6" />
                    <div class="input-hint">Digite o código de 6 dígitos recebido no WhatsApp</div>
                </div>

                <div>
                    <label class="input-label" for="newPassword">Nova senha</label>
                    <div class="pw-field">
                        <input class="input" type="password" id="newPassword" placeholder="••••••••••" required minlength="8" />
                        <button class="pw-toggle" type="button" id="togglePassword" aria-label="Mostrar senha">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="password-strength" id="strengthBar"></div>
                    <div class="input-hint">Mínimo 8 caracteres, incluindo letras e números</div>
                </div>

                <div>
                    <label class="input-label" for="confirmPassword">Confirmar senha</label>
                    <input class="input" type="password" id="confirmPassword" placeholder="••••••••••" required minlength="8" />
                </div>

                <button type="submit" class="btn btn-primary btn-lg" id="btnReset" style="justify-content:center;">
                    <span id="btnText">Redefinir senha</span>
                    <span id="btnLoader" style="display:none;">
                        <span class="spinner-border spinner-border-sm me-2"></span>Enviando...
                    </span>
                    <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="login-footer">
                <a href="/Account/Login"><i class="bi bi-arrow-left" style="font-size:12px;"></i> Voltar para login</a>
            </div>
            <div class="compliance">
                <span>LGPD</span><span>Anvisa</span><span>SNGPC</span>
            </div>
        </div>
    </div>

    <script>
        // Pegar identifier da URL ou ViewBag
        const urlParams = new URLSearchParams(window.location.search);
        const identifierFromUrl = urlParams.get('identifier');
        const identifierFromViewBag = '@ViewBag.Identifier';

        let identifierValue = identifierFromUrl || (identifierFromViewBag !== '' && identifierFromViewBag !== '@ViewBag.Identifier' ? identifierFromViewBag : '');

        if (identifierValue && identifierValue.trim() !== '') {
            document.getElementById('identifier').value = identifierValue;
            const cpfGroup = document.getElementById('cpfGroup');
            cpfGroup.style.display = 'none';
            document.getElementById('cpfInput').removeAttribute('required');
            const cpfFormatted = identifierValue.replace(/\D/g, '').replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
            document.getElementById('cpfInput').value = cpfFormatted;
        }

        // Toggle visualização de senha
        document.getElementById('togglePassword').addEventListener('click', function() {
            const passwordInput = document.getElementById('newPassword');
            const icon = this.querySelector('i');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                passwordInput.type = 'password';
                icon.className = 'bi bi-eye';
            }
        });

        // Verificar força da senha
        document.getElementById('newPassword').addEventListener('input', function(e) {
            const password = e.target.value;
            const strengthBar = document.getElementById('strengthBar');

            let strength = 0;
            if (password.length >= 8) strength++;
            if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
            if (password.match(/[0-9]/)) strength++;
            if (password.match(/[^a-zA-Z0-9]/)) strength++;

            const colors = ['var(--danger)', 'var(--amber-500)', 'var(--ok)', 'var(--ok)'];
            const widths = ['25%', '50%', '75%', '100%'];

            if (password.length > 0) {
                strengthBar.style.width = widths[strength - 1] || '25%';
                strengthBar.style.backgroundColor = colors[strength - 1] || 'var(--danger)';
            } else {
                strengthBar.style.width = '0%';
            }
        });

        // Máscara para código (apenas números)
        document.getElementById('code').addEventListener('input', function(e) {
            e.target.value = e.target.value.replace(/\D/g, '');
        });

        // Máscara de CPF
        document.getElementById('cpfInput').addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length <= 11) {
                value = value.replace(/(\d{3})(\d)/, '$1.$2');
                value = value.replace(/(\d{3})(\d)/, '$1.$2');
                value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
                e.target.value = value;
            }
        });

        // Enviar formulário
        document.getElementById('resetForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const btn = document.getElementById('btnReset');
            const txt = document.getElementById('btnText');
            const ldr = document.getElementById('btnLoader');

            let identifier = document.getElementById('identifier').value;
            if (!identifier || identifier.trim() === '' || identifier === '@ViewBag.Identifier') {
                const cpfInput = document.getElementById('cpfInput').value;
                identifier = cpfInput.replace(/\D/g, '');
            } else {
                identifier = identifier.replace(/\D/g, '');
            }

            const code = document.getElementById('code').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (!identifier || identifier.trim() === '' || identifier.length !== 11) {
                showAlert('Digite um CPF válido (11 dígitos) para continuar.');
                document.getElementById('cpfInput').focus();
                return;
            }

            if (code.length !== 6) {
                showAlert('O código deve ter 6 dígitos.');
                return;
            }

            if (newPassword.length < 8) {
                showAlert('A senha deve ter no mínimo 8 caracteres.');
                return;
            }

            if (newPassword !== confirmPassword) {
                showAlert('As senhas não coincidem.');
                return;
            }

            btn.disabled = true; txt.style.display = 'none'; ldr.style.display = 'inline-flex';

            try {
                const response = await fetch('/api/auth/password/reset', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-API-KEY': 'orcpharm-2024'
                    },
                    body: JSON.stringify({
                        identifier: identifier,
                        code: code,
                        newPassword: newPassword,
                        confirmPassword: confirmPassword
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    showSuccess('Senha redefinida com sucesso! Redirecionando...');
                    setTimeout(() => {
                        window.location.href = '/Account/Login';
                    }, 2000);
                } else {
                    showAlert(data.message || 'Erro ao redefinir senha. Verifique o código.');
                    btn.disabled = false; txt.style.display = ''; ldr.style.display = 'none';
                }
            } catch (error) {
                showAlert('Erro de conexão. Tente novamente.');
                btn.disabled = false; txt.style.display = ''; ldr.style.display = 'none';
            }
        });

        function showAlert(message) {
            document.getElementById('alertContainer').innerHTML =
                `<div style="background:var(--danger-soft);color:var(--danger);border:1px solid var(--danger-border);padding:10px 14px;border-radius:var(--r-sm);font-size:13px;display:flex;align-items:center;gap:8px;margin-bottom:4px;"><i class="bi bi-exclamation-triangle-fill"></i>${message}</div>`;
        }

        function showSuccess(message) {
            document.getElementById('alertContainer').innerHTML =
                `<div style="background:var(--ok-soft);color:var(--ok);border:1px solid var(--ok-border);padding:10px 14px;border-radius:var(--r-sm);font-size:13px;display:flex;align-items:center;gap:8px;margin-bottom:4px;"><i class="bi bi-check-circle-fill"></i>${message}</div>`;
        }
    </script>
</body>
</html>
