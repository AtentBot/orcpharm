@{
    ViewData["Title"] = "Entrar";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrcPharm — Entrar</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>@@import url('https://api.fontshare.com/v2/css?f[]=general-sans@@400,500,600&display=swap');</style>
    <link rel="stylesheet" href="~/css/design-system/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system/components.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.2/font/bootstrap-icons.min.css">

    <style>
        body { background: var(--bg); }
        .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 32px; }
        .login-card { width: 100%; max-width: 420px; }
        .login-card .brand-block { text-align: center; margin-bottom: 32px; }
        .login-card h1 { font-size: 26px; font-weight: 600; letter-spacing: -0.025em; margin: 0 0 8px; text-align: center; }
        .login-card .sub { color: var(--ink-3); font-size: 14px; margin: 0 0 32px; text-align: center; }
        .login-form { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--r-md); padding: 32px; box-shadow: var(--shadow-1); display: flex; flex-direction: column; gap: 16px; }
        .form-actions-row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
        .form-actions-row label { display: flex; gap: 8px; align-items: center; color: var(--ink-2); cursor: pointer; }
        .form-actions-row a { color: var(--petrol-500); text-decoration: none; }
        .form-actions-row a:hover { text-decoration: underline; }
        .login-footer { text-align: center; margin-top: 24px; font-size: 13px; color: var(--ink-3); }
        .login-footer a { color: var(--petrol-500); text-decoration: none; font-weight: 500; }
        .compliance { text-align: center; margin-top: 32px; color: var(--ink-4); font-size: 11px; font-family: var(--font-mono); letter-spacing: 0.06em; text-transform: uppercase; display: flex; gap: 16px; justify-content: center; }
        .brand-lg { font-size: 22px; }
        .brand-lg .brand-glyph { width: 40px; height: 40px; font-size: 20px; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="brand-block">
                <a href="/" class="brand brand-lg">
                    <span class="brand-glyph">o</span>
                    <span class="brand-name">orcpharm</span>
                </a>
            </div>
            <h1>Bem-vindo de volta.</h1>
            <p class="sub">Entre na sua farmácia.</p>

            <div id="alertContainer"></div>

            <form id="loginForm" class="login-form" autocomplete="on">
                <div>
                    <label class="input-label" for="cpf">CPF</label>
                    <input class="input mono" type="text" id="cpf" name="cpf" placeholder="000.000.000-00" maxlength="14" required autocomplete="username" />
                </div>
                <div>
                    <label class="input-label" for="password">Senha</label>
                    <input class="input" type="password" id="password" name="password" placeholder="••••••••••" required autocomplete="current-password" />
                </div>
                <div class="form-actions-row">
                    <label><input type="checkbox" checked />Manter conectado</label>
                    <a href="/Account/ForgotPassword">Esqueci minha senha</a>
                </div>
                <button type="submit" class="btn btn-primary btn-lg" id="btnLogin" style="justify-content:center;">
                    <span id="btnText">Entrar</span>
                    <span id="btnLoader" style="display:none;">
                        <span class="spinner-border spinner-border-sm me-2"></span>Entrando...
                    </span>
                    <i class="bi bi-arrow-right"></i>
                </button>
                <div style="text-align:center;font-size:12px;color:var(--ink-3);">
                    <a href="/Account/ResetPassword" style="color:var(--ink-3);">Já tenho um código de redefinição</a>
                </div>
            </form>

            <div class="login-footer">
                Não tem conta ainda? <a href="/Signup">Criar conta grátis</a>
            </div>
            <div class="compliance">
                <span>LGPD</span><span>Anvisa</span><span>SNGPC</span>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('cpf').addEventListener('input', function(e) {
            let v = e.target.value.replace(/\D/g, '');
            if (v.length <= 11) {
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
                e.target.value = v;
            }
        });

        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btnLogin');
            const txt = document.getElementById('btnText');
            const ldr = document.getElementById('btnLoader');
            const alertBox = document.getElementById('alertContainer');
            alertBox.innerHTML = '';
            btn.disabled = true; txt.style.display = 'none'; ldr.style.display = 'inline-flex';
            try {
                const cpf = document.getElementById('cpf').value.replace(/\D/g, '');
                const password = document.getElementById('password').value;
                const r = await fetch('/api/Employees/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ cpf, password })
                });
                const d = await r.json();
                if (r.ok) {
                    if (d.requires2FA) {
                        sessionStorage.setItem('pendingEmployeeId', d.employeeId);
                        window.location.href = '/Account/ValidateCode';
                    } else {
                        window.location.href = '/Dashboard';
                    }
                } else {
                    showAlert(d.error || d.message || 'Erro ao fazer login', 'danger');
                }
            } catch (err) {
                console.error('Login error:', err);
                showAlert('Erro de conexão. Tente novamente.', 'danger');
            } finally {
                btn.disabled = false; txt.style.display = ''; ldr.style.display = 'none';
            }
        });

        function showAlert(message, type) {
            const box = document.getElementById('alertContainer');
            const cls = type === 'danger' ? 'badge-danger' : 'badge-info';
            box.innerHTML = `<div style="background:var(--danger-soft);color:var(--danger);border:1px solid var(--danger-border);padding:10px 14px;border-radius:var(--r-sm);font-size:13px;display:flex;align-items:center;gap:8px;"><i class="bi bi-exclamation-triangle-fill"></i>${message}</div>`;
        }
    </script>
</body>
</html>
