@{
    ViewData["Title"] = "Recuperar Senha";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrcPharm — Recuperar Senha</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>@@import url('https://api.fontshare.com/v2/css?f[]=general-sans@@400,500,600&display=swap');</style>
    <link rel="stylesheet" href="~/css/design-system/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system/components.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.2/font/bootstrap-icons.min.css">

    <style>
        body { background: var(--bg); }
        .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 32px; }
        .login-card { width: 100%; max-width: 420px; }
        .login-card .brand-block { text-align: center; margin-bottom: 32px; }
        .login-card h1 { font-size: 26px; font-weight: 600; letter-spacing: -0.025em; margin: 0 0 8px; text-align: center; }
        .login-card .sub { color: var(--ink-3); font-size: 14px; margin: 0 0 32px; text-align: center; }
        .login-form { background: var(--surface); border: 1px solid var(--rule); border-radius: var(--r-md); padding: 32px; box-shadow: var(--shadow-1); display: flex; flex-direction: column; gap: 16px; }
        .login-footer { text-align: center; margin-top: 24px; font-size: 13px; color: var(--ink-3); }
        .login-footer a { color: var(--petrol-500); text-decoration: none; font-weight: 500; }
        .compliance { text-align: center; margin-top: 32px; color: var(--ink-4); font-size: 11px; font-family: var(--font-mono); letter-spacing: 0.06em; text-transform: uppercase; display: flex; gap: 16px; justify-content: center; }
        .brand-lg { font-size: 22px; }
        .success-state { text-align: center; padding: 8px 0; }
        .success-state .success-icon { font-size: 40px; color: var(--petrol-500); margin-bottom: 12px; }
        .success-state p { color: var(--ink-2); font-size: 14px; line-height: 1.6; }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="brand-block">
                <a href="/" class="brand brand-lg">
                    <span class="brand-glyph" style="width:32px;height:32px;"><svg width="32" height="32" viewBox="0 0 88 88" fill="none" aria-hidden="true"><path d="M18 18 H36 a16 16 0 0 1 16 16 V52 H36 a16 16 0 0 1 -16 -16 V18 Z" fill="var(--petrol-500)"/><rect x="52" y="18" width="22" height="11" rx="5.5" fill="var(--petrol-500)"/><rect x="52" y="35" width="16" height="10" rx="5" fill="var(--petrol-500)"/></svg></span>
                    <span class="brand-name">farmify<span class="accent">.</span></span>
                </a>
            </div>
            <h1>Recuperar senha</h1>
            <p class="sub">Digite seu CPF para receber o código via WhatsApp.</p>

            <div id="alertContainer"></div>

            <form id="forgotForm" class="login-form" autocomplete="off">
                <div id="formFields">
                    <div style="display:flex;flex-direction:column;gap:16px;">
                        <div>
                            <label class="input-label" for="cpf">CPF</label>
                            <input class="input mono" type="text" id="cpf" placeholder="000.000.000-00" maxlength="14" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg" id="btnEnviar" style="justify-content:center;">
                            <span id="btnText">Enviar código</span>
                            <span id="btnLoader" style="display:none;">
                                <span class="spinner-border spinner-border-sm me-2"></span>Enviando...
                            </span>
                            <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                </div>

                <div id="successState" class="success-state" style="display:none;">
                    <div class="success-icon"><i class="bi bi-whatsapp"></i></div>
                    <p>Código enviado pelo WhatsApp!<br>Verifique seu celular e siga as instruções.</p>
                    <a href="/Account/ResetPassword" id="linkReset" class="btn btn-primary btn-lg" style="justify-content:center;margin-top:8px;text-decoration:none;">
                        Inserir código <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </form>

            <div class="login-footer">
                <a href="/Account/Login"><i class="bi bi-arrow-left" style="font-size:12px;"></i> Voltar para login</a>
            </div>
            <div class="compliance">
                <span>LGPD</span><span>Anvisa</span><span>SNGPC</span>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('cpf').addEventListener('input', function(e) {
            let v = e.target.value.replace(/\D/g, '');
            if (v.length <= 11) {
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d)/, '$1.$2');
                v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
                e.target.value = v;
            }
        });

        document.getElementById('forgotForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btnEnviar');
            const txt = document.getElementById('btnText');
            const ldr = document.getElementById('btnLoader');
            const alertBox = document.getElementById('alertContainer');
            alertBox.innerHTML = '';
            btn.disabled = true; txt.style.display = 'none'; ldr.style.display = 'inline-flex';

            try {
                const cpf = document.getElementById('cpf').value.replace(/\D/g, '');
                const r = await fetch('/api/auth/password/request-reset', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-API-KEY': 'orcpharm-2024'
                    },
                    body: JSON.stringify({ identifier: cpf, method: 'WHATSAPP' })
                });
                const d = await r.json();

                if (r.ok) {
                    document.getElementById('formFields').style.display = 'none';
                    document.getElementById('successState').style.display = 'block';
                    document.getElementById('linkReset').href = '/Account/ResetPassword?identifier=' + encodeURIComponent(cpf);
                } else {
                    showAlert(d.error || d.message || 'Erro ao enviar código');
                    btn.disabled = false; txt.style.display = ''; ldr.style.display = 'none';
                }
            } catch (err) {
                showAlert('Erro de conexão. Tente novamente.');
                btn.disabled = false; txt.style.display = ''; ldr.style.display = 'none';
            }
        });

        function showAlert(message) {
            document.getElementById('alertContainer').innerHTML =
                `<div style="background:var(--danger-soft);color:var(--danger);border:1px solid var(--danger-border);padding:10px 14px;border-radius:var(--r-sm);font-size:13px;display:flex;align-items:center;gap:8px;margin-bottom:4px;"><i class="bi bi-exclamation-triangle-fill"></i>${message}</div>`;
        }
    </script>
</body>
</html>
