@using Models.Pharmacy

@{
    ViewData["Title"] = "Relatório do Cupom";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var coupon = ViewBag.Coupon as Coupon;
    var usages = ViewBag.Usages as List<CouponUsage> ?? new List<CouponUsage>();
}

<div class="container py-4" style="max-width: 900px;">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Cupons">Cupons</a></li>
            <li class="breadcrumb-item active">Relatório</li>
        </ol>
    </nav>

    <!-- Coupon Header -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi bi-ticket-perforated text-primary fs-3"></i>
                        </div>
                        <div>
                            <h2 class="h4 mb-1">@coupon?.Code</h2>
                            <p class="text-muted mb-0">@(coupon?.Description ?? "Cupom de desconto")</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <span class="badge bg-@(coupon?.IsActive == true ? "success" : "secondary") fs-6 px-3 py-2">
                        @(coupon?.IsActive == true ? "Ativo" : "Inativo")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-primary">@coupon?.DiscountDisplay</div>
                    <small class="text-muted">Desconto</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-success">@(coupon?.UsedCount ?? 0)</div>
                    <small class="text-muted">Usos</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-warning">@(coupon?.MaxUses?.ToString() ?? "∞")</div>
                    <small class="text-muted">Limite</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-6 fw-bold text-info">
                        R$ @(usages.Sum(u => u.DiscountApplied).ToString("N2"))
                    </div>
                    <small class="text-muted">Total Descontos</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Details -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Detalhes</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td class="text-muted">Tipo:</td>
                            <td class="fw-semibold">@(coupon?.DiscountType == "PERCENTAGE" ? "Porcentagem" : "Valor Fixo")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Valor Mínimo:</td>
                            <td class="fw-semibold">@(coupon?.MinOrderValue.HasValue == true ? $"R$ {coupon.MinOrderValue:N2}" : "Sem mínimo")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Válido de:</td>
                            <td class="fw-semibold">@coupon?.ValidFrom.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Válido até:</td>
                            <td class="fw-semibold">@coupon?.ValidUntil.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Primeira compra:</td>
                            <td class="fw-semibold">@(coupon?.FirstPurchaseOnly == true ? "Sim" : "Não")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Performance</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Taxa de uso</span>
                            <span class="fw-semibold">
                                @{
                                    var usageRate = coupon?.MaxUses.HasValue == true && coupon.MaxUses > 0
                                        ? (coupon.UsedCount * 100 / coupon.MaxUses.Value)
                                        : 0;
                                }
                                @usageRate%
                            </span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-primary" style="width: @usageRate%"></div>
                        </div>
                    </div>
                    <div class="text-center py-3">
                        <canvas id="usageChart" height="150"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Usage History -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Histórico de Uso</h5>
        </div>
        <div class="card-body p-0">
            @if(usages.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Cliente</th>
                                <th>Data/Hora</th>
                                <th>Desconto Aplicado</th>
                                <th>Pedido</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var usage in usages)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-secondary bg-opacity-10 rounded-circle p-2 me-2">
                                                <i class="bi bi-person text-secondary"></i>
                                            </div>
                                            @(usage.Customer?.FullName ?? "Cliente")
                                        </div>
                                    </td>
                                    <td>@usage.UsedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-success fw-semibold">- R$ @usage.DiscountApplied.ToString("N2")</td>
                                    <td>
                                        @if(usage.OrderId.HasValue)
                                        {
                                            <a href="/Pedidos/Detalhes/@usage.OrderId" class="btn btn-sm btn-outline-primary">
                                                Ver Pedido
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                    <p class="text-muted mb-0">Nenhum uso registrado ainda</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Simple chart showing usage over time
const ctx = document.getElementById('usageChart');
if (ctx) {
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Sem 1', 'Sem 2', 'Sem 3', 'Sem 4'],
            datasets: [{
                label: 'Usos',
                data: [@(usages.Count > 0 ? usages.Count / 4 : 0), @(usages.Count > 0 ? usages.Count / 3 : 0), @(usages.Count > 0 ? usages.Count / 2 : 0), @usages.Count],
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99, 102, 241, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });
}
</script>
}
