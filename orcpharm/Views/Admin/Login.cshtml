@{ViewData["Title"] = "Login Admin"; Layout = null;}
<!DOCTYPE html>
<html><head><meta charset="utf-8"/><title>Admin Login - OrcPharm</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/admin.css"/></head><body>
<div class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
<div class="card" style="width: 400px;"><div class="card-body p-4">
<h3 class="text-center mb-4">Admin Login</h3>
<form method="post" action="/api/admin/auth/login">
<div class="mb-3"><input type="email" class="form-control" name="email" placeholder="E-mail" required/></div>
<div class="mb-3"><input type="password" class="form-control" name="password" placeholder="Senha" required/></div>
<button type="submit" class="btn btn-primary w-100">Entrar</button>
</form></div></div></div></body></html>