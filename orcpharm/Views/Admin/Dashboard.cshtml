@{ViewData["Title"] = "Dashboard"; Layout = "_LayoutAdmin";}
<div class="dashboard-grid">
<div class="metric-card border-primary"><div class="metric-label">Total Estabelecimentos</div><div class="metric-value" id="totalEstablishments">0</div></div>
<div class="metric-card border-success"><div class="metric-label">Ativos</div><div class="metric-value" id="activeEstablishments">0</div></div>
<div class="metric-card border-info"><div class="metric-label">MRR</div><div class="metric-value" id="mrr">R$ 0</div></div>
<div class="metric-card border-warning"><div class="metric-label">Churn Rate</div><div class="metric-value" id="churnRate">0%</div></div>
</div>
<div class="chart-container"><canvas id="revenueChart"></canvas></div>
@section Scripts {
<script src="~/js/admin-dashboard.js"></script>
<script src="~/js/admin-charts.js"></script>
}