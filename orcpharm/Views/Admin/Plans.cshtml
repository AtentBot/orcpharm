@{
    ViewData["Title"] = "Planos";
    ViewData["Subtitle"] = "Gerenciar planos de assinatura";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#planModal" onclick="openNewPlanModal()">
        <i class="bi bi-plus-lg me-2"></i>Novo Plano
    </button>
</div>

<div class="row g-4" id="plansContainer">
    <div class="col-12 text-center py-5">
        <div class="spinner-border"></div>
        <p class="mt-2 text-muted">Carregando planos...</p>
    </div>
</div>

<!-- Plan Modal -->
<div class="modal fade" id="planModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="planModalTitle">Novo Plano</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="planForm">
                    <input type="hidden" id="planId">
                    
                    <!-- Nav Tabs -->
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabBasic" type="button">
                                <i class="bi bi-info-circle me-1"></i>Básico
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabGateways" type="button">
                                <i class="bi bi-credit-card me-1"></i>Gateways
                                <span class="badge bg-secondary ms-1" id="gatewaysBadge">0/3</span>
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <!-- Tab Básico -->
                        <div class="tab-pane fade show active" id="tabBasic">
                            <div class="mb-3">
                                <label class="form-label">Nome do Plano *</label>
                                <input type="text" class="form-control" id="planName" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <textarea class="form-control" id="planDescription" rows="2"></textarea>
                            </div>
                            
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label class="form-label">Preço Mensal (R$) *</label>
                                    <input type="number" class="form-control" id="priceMonthly" step="0.01" required>
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="form-label">Preço Anual (R$) *</label>
                                    <input type="number" class="form-control" id="priceYearly" step="0.01" required>
                                    <small class="text-muted">Sugestão (10% desc): <span id="suggestedYearly">-</span></small>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label class="form-label">Limite de Funcionários</label>
                                    <input type="number" class="form-control" id="maxEmployees" value="5">
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="form-label">Limite de Pedidos/Mês</label>
                                    <input type="number" class="form-control" id="maxOrders" value="100">
                                </div>
                            </div>
                            
                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" id="isActive" checked>
                                <label class="form-check-label" for="isActive">Plano Ativo</label>
                            </div>
                        </div>

                        <!-- Tab Gateways -->
                        <div class="tab-pane fade" id="tabGateways">
                            <div class="alert alert-info small mb-3">
                                <i class="bi bi-info-circle me-2"></i>
                                Configure os IDs de preço de cada gateway. Obtenha os IDs no dashboard de cada serviço.
                            </div>

                            <!-- Stripe -->
                            <div class="card mb-3">
                                <div class="card-header bg-primary bg-opacity-10 py-2">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-stripe fs-5 text-primary me-2"></i>
                                            <strong>Stripe</strong>
                                        </div>
                                        <span class="badge" id="stripeBadge">Não configurado</span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <label class="form-label small">Price ID Mensal</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="stripePriceMonthly" placeholder="price_1Qab..." 
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small">Price ID Anual</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="stripePriceYearly" placeholder="price_1Qab..."
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                    </div>
                                    <a href="https://dashboard.stripe.com/products" target="_blank" class="small text-muted">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>Abrir Stripe Dashboard
                                    </a>
                                </div>
                            </div>

                            <!-- MercadoPago -->
                            <div class="card mb-3">
                                <div class="card-header bg-info bg-opacity-10 py-2">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-wallet2 fs-5 text-info me-2"></i>
                                            <strong>Mercado Pago</strong>
                                            <span class="badge bg-secondary ms-2">Em breve</span>
                                        </div>
                                        <span class="badge" id="mpBadge">Não configurado</span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <label class="form-label small">Plan ID Mensal</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="mpPlanMonthly" placeholder="2c938084..." disabled
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small">Plan ID Anual</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="mpPlanYearly" placeholder="2c938084..." disabled
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Abacatepay -->
                            <div class="card">
                                <div class="card-header bg-success bg-opacity-10 py-2">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-cash-coin fs-5 text-success me-2"></i>
                                            <strong>Abacatepay</strong>
                                            <span class="badge bg-secondary ms-2">Em breve</span>
                                        </div>
                                        <span class="badge" id="abacateBadge">Não configurado</span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <label class="form-label small">Plan ID Mensal</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="abacatePlanMonthly" placeholder="plan_..." disabled
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small">Plan ID Anual</label>
                                            <input type="text" class="form-control form-control-sm font-monospace" 
                                                   id="abacatePlanYearly" placeholder="plan_..." disabled
                                                   onchange="updateGatewayBadges()">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="savePlan()">
                    <i class="bi bi-check-lg me-1"></i>Salvar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        loadPlans();
        
        // Calcular preço anual sugerido
        document.getElementById('priceMonthly').addEventListener('input', function(e) {
            const monthly = parseFloat(e.target.value) || 0;
            const yearly = (monthly * 12 * 0.9).toFixed(2);
            document.getElementById('suggestedYearly').textContent = `R$ ${yearly}`;
        });
    });

    async function loadPlans() {
        try {
            const response = await fetch('/api/admin/plans');
            if (response.ok) {
                const plans = await response.json();
                renderPlans(plans);
            } else {
                document.getElementById('plansContainer').innerHTML = `
                    <div class="col-12 text-center py-5 text-danger">
                        <i class="bi bi-exclamation-triangle display-4"></i>
                        <p class="mt-3">Erro ao carregar planos</p>
                    </div>
                `;
            }
        } catch (error) {
            console.error('Erro:', error);
            document.getElementById('plansContainer').innerHTML = `
                <div class="col-12 text-center py-5 text-danger">
                    <i class="bi bi-exclamation-triangle display-4"></i>
                    <p class="mt-3">Erro ao carregar planos</p>
                </div>
            `;
        }
    }

    function renderPlans(plans) {
        const container = document.getElementById('plansContainer');

        if (!plans || plans.length === 0) {
            container.innerHTML = `
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-collection display-4"></i>
                    <p class="mt-3">Nenhum plano cadastrado</p>
                </div>
            `;
            return;
        }

        container.innerHTML = plans.map(p => {
            const hasStripe = p.stripePriceIdMonthly || p.stripePriceIdYearly;
            const hasMp = p.mercadoPagoPlanIdMonthly || p.mercadoPagoPlanIdYearly;
            const hasAbacate = p.abacatepayPlanIdMonthly || p.abacatepayPlanIdYearly;
            
            return `
            <div class="col-md-6 col-lg-4">
                <div class="admin-card h-100 ${!p.isActive ? 'opacity-50' : ''}">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="mb-1">${p.name}</h5>
                                <span class="status-badge ${p.isActive ? 'active' : 'inactive'}">
                                    ${p.isActive ? 'Ativo' : 'Inativo'}
                                </span>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="editPlan('${p.id}')">
                                        <i class="bi bi-pencil me-2"></i>Editar
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="togglePlan('${p.id}')">
                                        <i class="bi bi-toggle-on me-2"></i>${p.isActive ? 'Desativar' : 'Ativar'}
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="#" onclick="deletePlan('${p.id}')">
                                        <i class="bi bi-trash me-2"></i>Excluir
                                    </a></li>
                                </ul>
                            </div>
                        </div>
                        
                        <p class="text-muted small mb-3">${p.description || 'Sem descrição'}</p>
                        
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Mensal</span>
                                <strong class="text-primary">${formatCurrency(p.priceMonthly)}</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Anual</span>
                                <strong class="text-success">${formatCurrency(p.priceYearly)}</strong>
                            </div>
                        </div>
                        
                        <hr>
                        
                        <div class="small text-muted mb-3">
                            <div class="mb-1">
                                <i class="bi bi-people me-2"></i>
                                Até ${p.maxEmployees || '∞'} funcionários
                            </div>
                            <div>
                                <i class="bi bi-box me-2"></i>
                                Até ${p.maxMonthlyOrders || '∞'} pedidos/mês
                            </div>
                        </div>
                        
                        <!-- Gateway Status -->
                        <div class="d-flex gap-1 flex-wrap">
                            <span class="badge ${hasStripe ? 'bg-success' : 'bg-danger'}" 
                                  title="${p.stripePriceIdMonthly || 'Não configurado'}">
                                <i class="bi bi-stripe me-1"></i>Stripe
                            </span>
                            <span class="badge ${hasMp ? 'bg-success' : 'bg-secondary'}"
                                  title="${p.mercadoPagoPlanIdMonthly || 'Não configurado'}">
                                MP
                            </span>
                            <span class="badge ${hasAbacate ? 'bg-success' : 'bg-secondary'}"
                                  title="${p.abacatepayPlanIdMonthly || 'Não configurado'}">
                                Abacate
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        `}).join('');
    }

    function openNewPlanModal() {
        document.getElementById('planModalTitle').textContent = 'Novo Plano';
        document.getElementById('planForm').reset();
        document.getElementById('planId').value = '';
        document.getElementById('isActive').checked = true;
        
        // Limpar campos de gateway
        document.getElementById('stripePriceMonthly').value = '';
        document.getElementById('stripePriceYearly').value = '';
        document.getElementById('mpPlanMonthly').value = '';
        document.getElementById('mpPlanYearly').value = '';
        document.getElementById('abacatePlanMonthly').value = '';
        document.getElementById('abacatePlanYearly').value = '';
        
        // Voltar para aba básica
        const tabBasic = document.querySelector('[data-bs-target="#tabBasic"]');
        bootstrap.Tab.getOrCreateInstance(tabBasic).show();
        
        updateGatewayBadges();
    }

    async function editPlan(id) {
        try {
            const response = await fetch(`/api/admin/plans/${id}`);
            if (response.ok) {
                const plan = await response.json();
                
                document.getElementById('planModalTitle').textContent = 'Editar Plano';
                document.getElementById('planId').value = plan.id;
                document.getElementById('planName').value = plan.name;
                document.getElementById('planDescription').value = plan.description || '';
                document.getElementById('priceMonthly').value = plan.priceMonthly;
                document.getElementById('priceYearly').value = plan.priceYearly;
                document.getElementById('maxEmployees').value = plan.maxEmployees || '';
                document.getElementById('maxOrders').value = plan.maxMonthlyOrders || '';
                document.getElementById('isActive').checked = plan.isActive;
                
                // Gateway IDs
                document.getElementById('stripePriceMonthly').value = plan.stripePriceIdMonthly || '';
                document.getElementById('stripePriceYearly').value = plan.stripePriceIdYearly || '';
                document.getElementById('mpPlanMonthly').value = plan.mercadoPagoPlanIdMonthly || '';
                document.getElementById('mpPlanYearly').value = plan.mercadoPagoPlanIdYearly || '';
                document.getElementById('abacatePlanMonthly').value = plan.abacatepayPlanIdMonthly || '';
                document.getElementById('abacatePlanYearly').value = plan.abacatepayPlanIdYearly || '';
                
                updateGatewayBadges();
                
                new bootstrap.Modal(document.getElementById('planModal')).show();
            }
        } catch (error) {
            console.error('Erro:', error);
            showToast('Erro ao carregar plano', 'danger');
        }
    }

    function updateGatewayBadges() {
        const stripeM = document.getElementById('stripePriceMonthly').value;
        const stripeY = document.getElementById('stripePriceYearly').value;
        const mpM = document.getElementById('mpPlanMonthly').value;
        const mpY = document.getElementById('mpPlanYearly').value;
        const abacateM = document.getElementById('abacatePlanMonthly').value;
        const abacateY = document.getElementById('abacatePlanYearly').value;
        
        // Update individual badges
        const stripeBadge = document.getElementById('stripeBadge');
        const mpBadge = document.getElementById('mpBadge');
        const abacateBadge = document.getElementById('abacateBadge');
        
        if (stripeM || stripeY) {
            stripeBadge.className = 'badge bg-success';
            stripeBadge.textContent = 'Configurado';
        } else {
            stripeBadge.className = 'badge bg-danger';
            stripeBadge.textContent = 'Não configurado';
        }
        
        if (mpM || mpY) {
            mpBadge.className = 'badge bg-success';
            mpBadge.textContent = 'Configurado';
        } else {
            mpBadge.className = 'badge bg-secondary';
            mpBadge.textContent = 'Não configurado';
        }
        
        if (abacateM || abacateY) {
            abacateBadge.className = 'badge bg-success';
            abacateBadge.textContent = 'Configurado';
        } else {
            abacateBadge.className = 'badge bg-secondary';
            abacateBadge.textContent = 'Não configurado';
        }
        
        // Update tab badge
        let count = 0;
        if (stripeM || stripeY) count++;
        if (mpM || mpY) count++;
        if (abacateM || abacateY) count++;
        
        const gatewaysBadge = document.getElementById('gatewaysBadge');
        gatewaysBadge.textContent = `${count}/3`;
        gatewaysBadge.className = count > 0 ? 'badge bg-success ms-1' : 'badge bg-secondary ms-1';
    }

    async function savePlan() {
        const id = document.getElementById('planId').value;
        const data = {
            name: document.getElementById('planName').value,
            description: document.getElementById('planDescription').value,
            priceMonthly: parseFloat(document.getElementById('priceMonthly').value),
            priceYearly: parseFloat(document.getElementById('priceYearly').value),
            maxEmployees: parseInt(document.getElementById('maxEmployees').value) || null,
            maxMonthlyOrders: parseInt(document.getElementById('maxOrders').value) || null,
            isActive: document.getElementById('isActive').checked,
            // Gateway IDs
            stripePriceIdMonthly: document.getElementById('stripePriceMonthly').value || null,
            stripePriceIdYearly: document.getElementById('stripePriceYearly').value || null,
            mercadoPagoPlanIdMonthly: document.getElementById('mpPlanMonthly').value || null,
            mercadoPagoPlanIdYearly: document.getElementById('mpPlanYearly').value || null,
            abacatepayPlanIdMonthly: document.getElementById('abacatePlanMonthly').value || null,
            abacatepayPlanIdYearly: document.getElementById('abacatePlanYearly').value || null
        };

        if (!data.name) {
            showToast('Nome é obrigatório', 'warning');
            return;
        }

        try {
            const url = id ? `/api/admin/plans/${id}` : '/api/admin/plans';
            const method = id ? 'PUT' : 'POST';

            const response = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('planModal')).hide();
                showToast('Plano salvo com sucesso!', 'success');
                loadPlans();
            } else {
                const error = await response.json();
                showToast('Erro: ' + (error.message || 'Erro ao salvar'), 'danger');
            }
        } catch (error) {
            console.error('Erro:', error);
            showToast('Erro ao salvar plano', 'danger');
        }
    }

    async function togglePlan(id) {
        try {
            const response = await fetch(`/api/admin/plans/${id}/toggle`, { method: 'POST' });
            if (response.ok) {
                const result = await response.json();
                showToast(result.message, 'success');
                loadPlans();
            } else {
                showToast('Erro ao alterar status', 'danger');
            }
        } catch (error) {
            showToast('Erro ao alterar status', 'danger');
        }
    }

    async function deletePlan(id) {
        if (!confirm('Excluir este plano? Esta ação não pode ser desfeita.')) return;

        try {
            const response = await fetch(`/api/admin/plans/${id}`, { method: 'DELETE' });
            if (response.ok) {
                showToast('Plano excluído!', 'success');
                loadPlans();
            } else {
                const error = await response.json();
                showToast('Erro: ' + (error.message || 'Erro ao excluir'), 'danger');
            }
        } catch (error) {
            console.error('Erro:', error);
            showToast('Erro ao excluir plano', 'danger');
        }
    }

    function formatCurrency(value) {
        return new Intl.NumberFormat('pt-BR', { 
            style: 'currency', 
            currency: 'BRL' 
        }).format(value || 0);
    }

    function showToast(message, type = 'info') {
        let container = document.getElementById('toastContainer');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toastContainer';
            container.className = 'toast-container position-fixed top-0 end-0 p-3';
            container.style.zIndex = '1100';
            document.body.appendChild(container);
        }

        const toastId = 'toast-' + Date.now();
        const iconMap = {
            success: 'bi-check-circle-fill text-success',
            danger: 'bi-x-circle-fill text-danger',
            warning: 'bi-exclamation-triangle-fill text-warning',
            info: 'bi-info-circle-fill text-primary'
        };

        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi ${iconMap[type] || iconMap.info} me-2"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `;

        container.insertAdjacentHTML('beforeend', toastHtml);
        const toastEl = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
        toast.show();

        toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
    }
</script>
}
