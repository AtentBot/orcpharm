@{
    ViewData["Title"] = "Recuperar Senha";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrcPharm Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
            width: 100%;
            max-width: 420px;
        }
        .card-header-section {
            text-align: center;
            margin-bottom: 30px;
        }
        .card-header-section h1 {
            color: #1a1a2e;
            font-weight: 700;
            font-size: 1.6rem;
        }
        .card-header-section p {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 10px;
        }
        .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        .icon-circle i {
            font-size: 2.5rem;
            color: white;
        }
        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 2px solid #e9ecef;
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
        }
        .btn-submit {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
        }
        .alert {
            border-radius: 10px;
        }
        .success-container {
            text-align: center;
            padding: 20px 0;
        }
        .success-container .icon-circle {
            background: linear-gradient(135deg, #198754 0%, #146c43 100%);
        }
        .success-container h2 {
            color: #198754;
            font-size: 1.4rem;
            margin-bottom: 15px;
        }
        .success-container p {
            color: #6c757d;
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .info-box {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            margin-top: 20px;
        }
        .info-box ul {
            margin: 0;
            padding-left: 20px;
        }
        .info-box li {
            color: #6c757d;
            font-size: 0.85rem;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>
    <div class="card-container">
        <div id="requestForm">
            <div class="card-header-section">
                <div class="icon-circle">
                    <i class="bi bi-envelope-paper"></i>
                </div>
                <h1>Recuperar Senha</h1>
                <p>Digite seu e-mail de administrador para receber as instruções de recuperação.</p>
            </div>

            <div id="alertContainer"></div>

            <form id="forgotPasswordForm">
                <div class="mb-4">
                    <label for="email" class="form-label">E-mail</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input type="email" 
                               class="form-control" 
                               id="email" 
                               name="email"
                               placeholder="admin&#64;orcpharm.com.br" 
                               required 
                               autofocus />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-submit" id="btnSubmit">
                    <span id="btnText">Enviar Instruções</span>
                    <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status"></span>
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/admin/login" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i>
                    Voltar ao login
                </a>
            </div>
        </div>

        <div id="successContainer" class="d-none">
            <div class="success-container">
                <div class="icon-circle">
                    <i class="bi bi-check-lg"></i>
                </div>
                <h2>E-mail Enviado!</h2>
                <p>
                    Se o e-mail informado estiver cadastrado, você receberá em breve as instruções 
                    para redefinir sua senha.
                </p>
                
                <div class="info-box">
                    <strong class="d-block mb-2 text-dark">
                        <i class="bi bi-info-circle me-1"></i>Não recebeu o e-mail?
                    </strong>
                    <ul>
                        <li>Verifique sua pasta de spam/lixo eletrônico</li>
                        <li>Aguarde alguns minutos e tente novamente</li>
                        <li>Certifique-se de que digitou o e-mail correto</li>
                    </ul>
                </div>
            </div>

            <div class="d-grid gap-2 mt-4">
                <button type="button" class="btn btn-outline-primary" onclick="tryAgain()">
                    <i class="bi bi-arrow-repeat me-1"></i>
                    Tentar novamente
                </button>
                <a href="/admin/login" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Ir para login
                </a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('forgotPasswordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            var email = document.getElementById('email').value.trim();
            var btnText = document.getElementById('btnText');
            var btnSpinner = document.getElementById('btnSpinner');
            var btnSubmit = document.getElementById('btnSubmit');
            var alertContainer = document.getElementById('alertContainer');
            
            alertContainer.innerHTML = '';
            
            if (!email) {
                showAlert('Informe seu e-mail', 'warning');
                return;
            }

            var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                showAlert('Informe um e-mail válido', 'warning');
                return;
            }
            
            btnSubmit.disabled = true;
            btnText.textContent = 'Enviando...';
            btnSpinner.classList.remove('d-none');
            
            try {
                var response = await fetch('/api/admin/auth/forgot-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email: email })
                });
                
                var data = await response.json();
                
                if (response.ok) {
                    document.getElementById('requestForm').classList.add('d-none');
                    document.getElementById('successContainer').classList.remove('d-none');

                    if (data.debug) {
                        console.log('Token de Debug:', data.debug);
                        console.log('URL de Reset:', data.debug.resetUrl);
                    }
                } else {
                    showAlert(data.message || 'Erro ao processar solicitação', 'danger');
                }
            } catch (error) {
                console.error('Erro:', error);
                showAlert('Erro ao conectar com o servidor. Tente novamente.', 'danger');
            } finally {
                btnSubmit.disabled = false;
                btnText.textContent = 'Enviar Instruções';
                btnSpinner.classList.add('d-none');
            }
        });
        
        function showAlert(message, type) {
            var alertContainer = document.getElementById('alertContainer');
            var icon = type === 'success' ? 'check-circle' : 
                       type === 'danger' ? 'exclamation-circle' : 'info-circle';
            
            alertContainer.innerHTML = 
                '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    '<i class="bi bi-' + icon + ' me-2"></i>' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>';
        }

        function tryAgain() {
            document.getElementById('successContainer').classList.add('d-none');
            document.getElementById('requestForm').classList.remove('d-none');
            document.getElementById('email').value = '';
            document.getElementById('email').focus();
        }
        
        document.getElementById('email').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                document.getElementById('forgotPasswordForm').dispatchEvent(new Event('submit'));
            }
        });
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
