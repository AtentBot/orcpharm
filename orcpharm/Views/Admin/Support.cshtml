@{
    ViewData["Title"] = "Suporte";
    ViewData["Subtitle"] = "Chamados e monitoramento de plataforma";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- WhatsApp Status Banner -->
<div id="waStatusBanner" class="alert d-none mb-4" role="alert" style="border-radius:12px;border:none;"></div>

<!-- Stats -->
<div class="row g-4 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon primary"><i class="bi bi-ticket-detailed"></i></div>
            <div class="stat-value" id="statTotal">-</div>
            <div class="stat-label">Total</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon warning"><i class="bi bi-circle-fill"></i></div>
            <div class="stat-value" id="statOpen">-</div>
            <div class="stat-label">Abertos</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon success"><i class="bi bi-check2-circle"></i></div>
            <div class="stat-value" id="statResolved">-</div>
            <div class="stat-label">Resolvidos</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon danger"><i class="bi bi-exclamation-octagon-fill"></i></div>
            <div class="stat-value" id="statCritical">-</div>
            <div class="stat-label">Críticos abertos</div>
        </div>
    </div>
</div>

<!-- Filters & Table -->
<div class="admin-card">
    <div class="card-header">
        <div class="row g-2 align-items-center">
            <div class="col-md-3">
                <select class="form-select form-select-sm" id="filterStatus" onchange="loadTickets()">
                    <option value="">Todos os status</option>
                    <option value="OPEN">Abertos</option>
                    <option value="IN_PROGRESS">Em andamento</option>
                    <option value="RESOLVED">Resolvidos</option>
                    <option value="CLOSED">Fechados</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" id="filterOrigin" onchange="loadTickets()">
                    <option value="">Toda origem</option>
                    <option value="MANUAL">Manual</option>
                    <option value="SYSTEM">Sistema</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" id="filterPriority" onchange="loadTickets()">
                    <option value="">Toda prioridade</option>
                    <option value="CRITICAL">Crítica</option>
                    <option value="HIGH">Alta</option>
                    <option value="MEDIUM">Média</option>
                    <option value="LOW">Baixa</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" id="filterCategory" onchange="loadTickets()">
                    <option value="">Toda categoria</option>
                    <option value="WHATSAPP">WhatsApp</option>
                    <option value="PAYMENT">Pagamento</option>
                    <option value="SIGNUP">Cadastro</option>
                    <option value="TECHNICAL">Técnico</option>
                    <option value="JOB">Processo interno</option>
                    <option value="GENERAL">Geral</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-sm btn-outline-secondary" onclick="loadAll()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Atualizar
                </button>
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Prioridade</th>
                        <th>Título</th>
                        <th>Origem</th>
                        <th>Categoria</th>
                        <th>Farmácia</th>
                        <th>Status</th>
                        <th>Data</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="ticketsTable">
                    <tr><td colspan="8" class="text-center py-4">
                        <div class="spinner-border spinner-border-sm me-2"></div>Carregando...
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Chamado -->
<div class="modal fade" id="ticketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="modalTitle">Chamado</h5>
                    <small class="text-muted" id="modalMeta"></small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalLoading" class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </div>
                <div id="modalContent" class="d-none">
                    <div class="mb-3 p-3 bg-light rounded" id="modalDescription"></div>
                    <hr>
                    <h6 class="mb-3">Conversa</h6>
                    <div id="modalMessages" style="max-height:300px;overflow-y:auto;"></div>
                    <div class="mt-3">
                        <textarea id="replyBody" class="form-control" rows="3" placeholder="Digite sua resposta..."></textarea>
                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-primary btn-sm" onclick="sendReply()">
                                <i class="bi bi-send me-1"></i>Responder
                            </button>
                            <select id="newStatus" class="form-select form-select-sm" style="width:auto;">
                                <option value="">Mudar status...</option>
                                <option value="IN_PROGRESS">Em andamento</option>
                                <option value="RESOLVED">Resolvido</option>
                                <option value="CLOSED">Fechado</option>
                                <option value="OPEN">Reabrir</option>
                            </select>
                            <button class="btn btn-outline-secondary btn-sm" onclick="changeStatus()">Salvar status</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentTicketId = null;

const PRIORITY_BADGE = {
    CRITICAL: '<span class="badge bg-danger">Crítica</span>',
    HIGH:     '<span class="badge bg-warning text-dark">Alta</span>',
    MEDIUM:   '<span class="badge bg-secondary">Média</span>',
    LOW:      '<span class="badge bg-light text-dark border">Baixa</span>'
};

const STATUS_BADGE = {
    OPEN:        '<span class="badge" style="background:#e8f4fd;color:#1a73e8">Aberto</span>',
    IN_PROGRESS: '<span class="badge" style="background:#fff3e0;color:#e65100">Em andamento</span>',
    RESOLVED:    '<span class="badge" style="background:#e8f5e9;color:#2e7d32">Resolvido</span>',
    CLOSED:      '<span class="badge bg-secondary">Fechado</span>'
};

const ORIGIN_BADGE = {
    MANUAL: '<span class="badge bg-info text-dark">Manual</span>',
    SYSTEM: '<span class="badge bg-dark">Sistema</span>'
};

async function loadAll() {
    await Promise.all([loadStats(), loadWaStatus(), loadTickets()]);
}

async function loadStats() {
    const r = await fetch('/api/admin/support/tickets/stats');
    if (!r.ok) return;
    const d = await r.json();
    document.getElementById('statTotal').textContent = d.total;
    document.getElementById('statOpen').textContent = d.open + d.inProgress;
    document.getElementById('statResolved').textContent = d.resolved;
    document.getElementById('statCritical').textContent = d.critical;
}

async function loadWaStatus() {
    const r = await fetch('/api/admin/support/whatsapp-status');
    if (!r.ok) return;
    const list = await r.json();
    const banner = document.getElementById('waStatusBanner');

    if (!list.length) { banner.classList.add('d-none'); return; }

    const disconnected = list.filter(s => !s.isHealthy);
    if (disconnected.length === 0) {
        banner.className = 'alert alert-success mb-4';
        banner.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i><strong>WhatsApp OK</strong> — todas as instâncias conectadas.';
        setTimeout(() => banner.classList.add('d-none'), 5000);
    } else {
        const inst = disconnected[0];
        const since = inst.disconnectedSince
            ? ' desde ' + new Date(inst.disconnectedSince).toLocaleString('pt-BR')
            : '';
        banner.className = 'alert mb-4';
        banner.style.cssText = 'background:#fff5f5;border-left:4px solid #dc3545;border-radius:12px;';
        banner.innerHTML = `
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-octagon-fill text-danger fs-4"></i>
                <div>
                    <strong class="text-danger">WhatsApp desconectado</strong> — instância <code>${inst.instanceName}</code>${since}<br>
                    <small class="text-muted">Clientes não estão recebendo códigos de verificação.</small>
                </div>
                <a href="https://api.atentbot.com/manager/" target="_blank" class="btn btn-danger btn-sm ms-auto">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Reconectar
                </a>
            </div>`;
        banner.classList.remove('d-none');
    }
}

async function loadTickets() {
    const status   = document.getElementById('filterStatus').value;
    const origin   = document.getElementById('filterOrigin').value;
    const priority = document.getElementById('filterPriority').value;
    const category = document.getElementById('filterCategory').value;

    const params = new URLSearchParams({ pageSize: 50 });
    if (status)   params.set('status', status);
    if (origin)   params.set('origin', origin);
    if (priority) params.set('priority', priority);
    if (category) params.set('category', category);

    const r = await fetch('/api/admin/support/tickets?' + params);
    if (!r.ok) return;
    const { items } = await r.json();

    const tbody = document.getElementById('ticketsTable');
    if (!items.length) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-muted">Nenhum chamado encontrado</td></tr>';
        return;
    }

    tbody.innerHTML = items.map(t => `
        <tr>
            <td>${PRIORITY_BADGE[t.priority] || t.priority}</td>
            <td>
                <span class="fw-medium">${escHtml(t.title)}</span>
                ${t.messageCount > 0 ? `<br><small class="text-muted">${t.messageCount} mensagem(s)</small>` : ''}
            </td>
            <td>${ORIGIN_BADGE[t.origin] || t.origin}</td>
            <td><small>${escHtml(t.categoryDisplay)}</small></td>
            <td><small>${escHtml(t.pharmacyName || '—')}</small></td>
            <td>${STATUS_BADGE[t.status] || t.status}</td>
            <td><small class="text-muted">${fmtDate(t.createdAt)}</small></td>
            <td>
                <button class="btn btn-sm btn-outline-primary" onclick="openTicket('${t.id}')">
                    <i class="bi bi-chat-text"></i>
                </button>
            </td>
        </tr>
    `).join('');
}

async function openTicket(id) {
    currentTicketId = id;
    document.getElementById('modalLoading').classList.remove('d-none');
    document.getElementById('modalContent').classList.add('d-none');
    document.getElementById('replyBody').value = '';
    document.getElementById('newStatus').value = '';
    new bootstrap.Modal(document.getElementById('ticketModal')).show();

    const r = await fetch(`/api/admin/support/tickets/${id}`);
    if (!r.ok) return;
    const t = await r.json();

    document.getElementById('modalTitle').textContent = t.title;
    document.getElementById('modalMeta').innerHTML =
        `${PRIORITY_BADGE[t.priority]} ${STATUS_BADGE[t.status]} &nbsp;` +
        `<span class="text-muted">${ORIGIN_BADGE[t.origin]} · ${t.categoryDisplay}</span>` +
        (t.pharmacyName ? ` · <strong>${escHtml(t.pharmacyName)}</strong>` : '');

    document.getElementById('modalDescription').innerHTML =
        `<p class="mb-1 text-muted small">Descrição inicial</p>${escHtml(t.description).replace(/\n/g,'<br>')}`;

    const msgs = document.getElementById('modalMessages');
    msgs.innerHTML = t.messages.length === 0
        ? '<p class="text-muted small">Sem mensagens ainda</p>'
        : t.messages.map(m => {
            const isAdmin = m.authorType === 'ADMIN';
            const isSys   = m.authorType === 'SYSTEM';
            return `
                <div class="mb-2 ${isAdmin ? 'text-end' : ''}">
                    <div class="d-inline-block p-2 rounded ${
                        isSys   ? 'bg-light text-muted' :
                        isAdmin ? 'bg-primary text-white' : 'bg-light'
                    }" style="max-width:80%;text-align:left;">
                        <div class="small fw-bold mb-1">${escHtml(m.authorName)} ${isSys ? '<i class="bi bi-robot"></i>' : ''}</div>
                        ${escHtml(m.body).replace(/\n/g,'<br>')}
                        <div class="small opacity-75 mt-1">${fmtDate(m.createdAt)}</div>
                    </div>
                </div>`;
        }).join('');
    msgs.scrollTop = msgs.scrollHeight;

    document.getElementById('modalLoading').classList.add('d-none');
    document.getElementById('modalContent').classList.remove('d-none');
}

async function sendReply() {
    const body = document.getElementById('replyBody').value.trim();
    if (!body || !currentTicketId) return;
    const r = await fetch(`/api/admin/support/tickets/${currentTicketId}/reply`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body })
    });
    if (r.ok) {
        document.getElementById('replyBody').value = '';
        await openTicket(currentTicketId);
        loadAll();
    }
}

async function changeStatus() {
    const status = document.getElementById('newStatus').value;
    if (!status || !currentTicketId) return;
    const r = await fetch(`/api/admin/support/tickets/${currentTicketId}/status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
    });
    if (r.ok) {
        await openTicket(currentTicketId);
        loadAll();
    }
}

function fmtDate(d) {
    return d ? new Date(d).toLocaleString('pt-BR', { dateStyle:'short', timeStyle:'short' }) : '—';
}

function escHtml(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Auto-refresh a cada 60s
loadAll();
setInterval(loadAll, 60_000);
</script>
}
