@{
    ViewData["Title"] = "Redefinir Senha";
    Layout = null;
    var token = ViewBag.Token as string ?? "";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Formula Clear Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: var(--ink);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
            width: 100%;
            max-width: 450px;
        }
        .card-header-section {
            text-align: center;
            margin-bottom: 30px;
        }
        .card-header-section h1 {
            color: var(--ink);
            font-weight: 700;
            font-size: 1.6rem;
        }
        .card-header-section p {
            color: var(--ink-3);
            font-size: 0.9rem;
            margin-top: 10px;
        }
        .icon-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: var(--petrol-500);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }
        .icon-circle i {
            font-size: 2.5rem;
            color: white;
        }
        .icon-circle.success {
            background: linear-gradient(135deg, var(--ok) 0%, var(--ok) 100%);
        }
        .icon-circle.error {
            background: linear-gradient(135deg, var(--danger) 0%, #b02a37 100%);
        }
        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 2px solid var(--bg-subtle);
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: var(--info);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
        }
        .form-control.is-valid {
            border-color: var(--ok);
        }
        .form-control.is-invalid {
            border-color: var(--danger);
        }
        .btn-submit {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
        }
        .alert {
            border-radius: 10px;
        }
        .password-strength {
            height: 4px;
            background: var(--bg-subtle);
            border-radius: 2px;
            margin-top: 8px;
            overflow: hidden;
        }
        .password-strength-bar {
            height: 100%;
            width: 0%;
            transition: all 0.3s;
            border-radius: 2px;
        }
        .strength-weak { background: var(--danger); width: 25%; }
        .strength-fair { background: var(--amber-500); width: 50%; }
        .strength-good { background: var(--ok); width: 75%; }
        .strength-strong { background: var(--ok); width: 100%; }
        .password-requirements {
            font-size: 0.8rem;
            color: var(--ink-3);
            margin-top: 10px;
        }
        .password-requirements li {
            margin-bottom: 3px;
            transition: color 0.2s;
        }
        .password-requirements li.valid {
            color: var(--ok);
        }
        .loading-container {
            text-align: center;
            padding: 40px 20px;
        }
        .success-container, .error-container {
            text-align: center;
            padding: 20px 0;
        }
    </style>
</head>
<body>
    <div class="card-container">
        <div id="loadingContainer" class="loading-container">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="text-muted">Validando token...</p>
        </div>

        <div id="resetForm" class="d-none">
            <div class="card-header-section">
                <div class="icon-circle">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h1>Redefinir Senha</h1>
                <p>Crie uma nova senha segura para sua conta.</p>
                <small class="text-muted" id="emailDisplay"></small>
            </div>

            <div id="alertContainer"></div>

            <form id="resetPasswordForm">
                <input type="hidden" id="token" value="@token" />

                <div class="mb-3">
                    <label for="newPassword" class="form-label">Nova Senha</label>
                    <div class="input-group">
                        <input type="password" 
                               class="form-control" 
                               id="newPassword" 
                               name="newPassword"
                               placeholder="••••••••" 
                               required 
                               minlength="8" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('newPassword', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="password-strength">
                        <div class="password-strength-bar" id="strengthBar"></div>
                    </div>
                    <ul class="password-requirements list-unstyled mt-2">
                        <li id="req-length">&#9675; Mínimo 8 caracteres</li>
                        <li id="req-upper">&#9675; Uma letra maiúscula</li>
                        <li id="req-lower">&#9675; Uma letra minúscula</li>
                        <li id="req-number">&#9675; Um número</li>
                        <li id="req-special">&#9675; Um caractere especial (!#$%...)</li>
                    </ul>
                </div>

                <div class="mb-4">
                    <label for="confirmPassword" class="form-label">Confirmar Senha</label>
                    <div class="input-group">
                        <input type="password" 
                               class="form-control" 
                               id="confirmPassword" 
                               name="confirmPassword"
                               placeholder="••••••••" 
                               required />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <small class="text-danger d-none" id="passwordMatchError">
                        <i class="bi bi-x-circle me-1"></i>As senhas não conferem
                    </small>
                </div>

                <button type="submit" class="btn btn-primary btn-submit" id="btnSubmit" disabled>
                    <span id="btnText">Redefinir Senha</span>
                    <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status"></span>
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/admin/login" class="text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i>
                    Voltar ao login
                </a>
            </div>
        </div>

        <div id="errorContainer" class="d-none">
            <div class="error-container">
                <div class="icon-circle error">
                    <i class="bi bi-x-lg"></i>
                </div>
                <h2 class="text-danger mb-3">Link Inválido</h2>
                <p class="text-muted">
                    Este link de recuperação é inválido ou já expirou. 
                    Os links de recuperação são válidos por apenas 1 hora.
                </p>
            </div>

            <div class="d-grid gap-2 mt-4">
                <a href="/admin/forgot-password" class="btn btn-primary">
                    <i class="bi bi-envelope me-1"></i>
                    Solicitar novo link
                </a>
                <a href="/admin/login" class="btn btn-outline-secondary">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Ir para login
                </a>
            </div>
        </div>

        <div id="successContainer" class="d-none">
            <div class="success-container">
                <div class="icon-circle success">
                    <i class="bi bi-check-lg"></i>
                </div>
                <h2 class="text-success mb-3">Senha Redefinida!</h2>
                <p class="text-muted">
                    Sua senha foi alterada com sucesso. 
                    Você pode fazer login com sua nova senha.
                </p>
            </div>

            <div class="d-grid mt-4">
                <a href="/admin/login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right me-1"></i>
                    Fazer Login
                </a>
            </div>
        </div>
    </div>

    <script>
        var resetToken = document.getElementById('token').value;

        document.addEventListener('DOMContentLoaded', async function() {
            if (!resetToken) {
                showError();
                return;
            }

            try {
                var response = await fetch('/api/admin/auth/validate-reset-token?token=' + encodeURIComponent(resetToken));
                var data = await response.json();

                if (data.valid) {
                    showResetForm();
                    if (data.email) {
                        document.getElementById('emailDisplay').textContent = 'Para: ' + data.email;
                    }
                } else {
                    showError();
                }
            } catch (error) {
                console.error('Erro ao validar token:', error);
                showError();
            }
        });

        function showResetForm() {
            document.getElementById('loadingContainer').classList.add('d-none');
            document.getElementById('resetForm').classList.remove('d-none');
            document.getElementById('newPassword').focus();
        }

        function showError() {
            document.getElementById('loadingContainer').classList.add('d-none');
            document.getElementById('errorContainer').classList.remove('d-none');
        }

        function showSuccess() {
            document.getElementById('resetForm').classList.add('d-none');
            document.getElementById('successContainer').classList.remove('d-none');
        }

        var newPasswordInput = document.getElementById('newPassword');
        var confirmPasswordInput = document.getElementById('confirmPassword');
        var strengthBar = document.getElementById('strengthBar');
        var btnSubmit = document.getElementById('btnSubmit');

        newPasswordInput.addEventListener('input', function() {
            var password = this.value;
            validatePasswordRequirements(password);
            checkPasswordMatch();
        });

        confirmPasswordInput.addEventListener('input', checkPasswordMatch);

        function validatePasswordRequirements(password) {
            var requirements = {
                length: password.length >= 8,
                upper: /[A-Z]/.test(password),
                lower: /[a-z]/.test(password),
                number: /[0-9]/.test(password),
                special: /[^A-Za-z0-9]/.test(password)
            };

            var keys = ['length', 'upper', 'lower', 'number', 'special'];
            for (var i = 0; i < keys.length; i++) {
                var key = keys[i];
                var elem = document.getElementById('req-' + key);
                if (requirements[key]) {
                    elem.classList.add('valid');
                    elem.innerHTML = '&#10003; ' + elem.textContent.substring(2);
                } else {
                    elem.classList.remove('valid');
                    elem.innerHTML = '&#9675; ' + elem.textContent.substring(2);
                }
            }

            var strength = 0;
            for (var j = 0; j < keys.length; j++) {
                if (requirements[keys[j]]) strength++;
            }

            strengthBar.className = 'password-strength-bar';
            
            if (strength === 0) {
                strengthBar.style.width = '0%';
            } else if (strength <= 2) {
                strengthBar.classList.add('strength-weak');
            } else if (strength === 3) {
                strengthBar.classList.add('strength-fair');
            } else if (strength === 4) {
                strengthBar.classList.add('strength-good');
            } else {
                strengthBar.classList.add('strength-strong');
            }

            return requirements.length && requirements.upper && requirements.lower && 
                   requirements.number && requirements.special;
        }

        function checkPasswordMatch() {
            var newPassword = newPasswordInput.value;
            var confirmPassword = confirmPasswordInput.value;
            var errorElem = document.getElementById('passwordMatchError');
            
            var passwordsMatch = newPassword === confirmPassword && confirmPassword.length > 0;
            var passwordIsValid = validatePasswordRequirements(newPassword);

            if (confirmPassword.length > 0 && !passwordsMatch) {
                errorElem.classList.remove('d-none');
                confirmPasswordInput.classList.add('is-invalid');
                confirmPasswordInput.classList.remove('is-valid');
            } else if (passwordsMatch) {
                errorElem.classList.add('d-none');
                confirmPasswordInput.classList.remove('is-invalid');
                confirmPasswordInput.classList.add('is-valid');
            } else {
                errorElem.classList.add('d-none');
                confirmPasswordInput.classList.remove('is-invalid', 'is-valid');
            }

            btnSubmit.disabled = !(passwordsMatch && passwordIsValid);
        }

        function togglePassword(inputId, button) {
            var input = document.getElementById(inputId);
            var icon = button.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        document.getElementById('resetPasswordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            var newPassword = newPasswordInput.value;
            var confirmPassword = confirmPasswordInput.value;
            var btnText = document.getElementById('btnText');
            var btnSpinner = document.getElementById('btnSpinner');
            var alertContainer = document.getElementById('alertContainer');
            
            alertContainer.innerHTML = '';

            if (!validatePasswordRequirements(newPassword)) {
                showAlert('A senha não atende aos requisitos mínimos', 'warning');
                return;
            }

            if (newPassword !== confirmPassword) {
                showAlert('As senhas não conferem', 'warning');
                return;
            }
            
            btnSubmit.disabled = true;
            btnText.textContent = 'Redefinindo...';
            btnSpinner.classList.remove('d-none');
            
            try {
                var response = await fetch('/api/admin/auth/reset-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        token: resetToken,
                        newPassword: newPassword,
                        confirmPassword: confirmPassword
                    })
                });
                
                var data = await response.json();
                
                if (response.ok) {
                    showSuccess();
                } else {
                    showAlert(data.message || 'Erro ao redefinir senha', 'danger');
                    btnSubmit.disabled = false;
                }
            } catch (error) {
                console.error('Erro:', error);
                showAlert('Erro ao conectar com o servidor. Tente novamente.', 'danger');
                btnSubmit.disabled = false;
            } finally {
                btnText.textContent = 'Redefinir Senha';
                btnSpinner.classList.add('d-none');
            }
        });
        
        function showAlert(message, type) {
            var alertContainer = document.getElementById('alertContainer');
            var icon = type === 'success' ? 'check-circle' : 
                       type === 'danger' ? 'exclamation-circle' : 'info-circle';
            
            alertContainer.innerHTML = 
                '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    '<i class="bi bi-' + icon + ' me-2"></i>' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>';
        }
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
