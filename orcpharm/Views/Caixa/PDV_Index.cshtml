@{
    ViewData["Title"] = "PDV - Ponto de Venda";
    Layout = "_Layout";
}

<div class="container-fluid vh-100 d-flex flex-column p-0">
    <!-- Cabeçalho -->
    <div class="bg-primary text-white p-3 shadow-sm">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">
                    <i class="bi bi-shop me-2"></i>
                    Ponto de Venda
                </h4>
                <small id="cashRegisterInfo">Caixa: Carregando...</small>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <!-- Badge de pedidos online -->
                <button class="btn btn-warning position-relative" onclick="showOnlineOrdersModal()" id="onlineOrdersBtn">
                    <i class="bi bi-bag-check"></i> Pedidos Online
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="onlineOrdersBadge" style="display:none;">
                        0
                    </span>
                </button>
                <span class="badge bg-light text-dark fs-6" id="currentTime"></span>
                <button class="btn btn-light btn-sm" onclick="openCashRegister()">
                    <i class="bi bi-cash-stack"></i> Abrir Caixa
                </button>
                <button class="btn btn-danger btn-sm" onclick="closePDV()">
                    <i class="bi bi-x-circle"></i> Fechar PDV
                </button>
            </div>
        </div>
    </div>

    <div class="row g-0 flex-grow-1">
        <!-- Coluna Esquerda: Carrinho e Produtos -->
        <div class="col-lg-8 d-flex flex-column p-3">
            
            <!-- Busca de Produtos -->
            <div class="mb-3">
                <div class="input-group input-group-lg">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="productSearch" 
                           placeholder="Buscar produto, código de barras ou pedido de manipulação..."
                           autofocus>
                    <button class="btn btn-outline-secondary" onclick="showProductsModal()">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </button>
                </div>
            </div>

            <!-- Alerta de Pedido Online Carregado -->
            <div id="onlineOrderAlert" class="alert alert-warning d-none mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-bag-check me-2"></i>
                        <strong>Pedido Online:</strong> <span id="loadedOrderNumber"></span>
                        <span class="ms-2 badge bg-primary" id="loadedOrderStatus"></span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" onclick="clearOnlineOrder()">
                        <i class="bi bi-x"></i> Limpar
                    </button>
                </div>
            </div>

            <!-- Carrinho -->
            <div class="card flex-grow-1 shadow-sm">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Itens do Carrinho</h5>
                        <button class="btn btn-sm btn-outline-danger" onclick="clearCart()">
                            <i class="bi bi-trash"></i> Limpar
                        </button>
                    </div>
                </div>
                <div class="card-body overflow-auto">
                    <div id="cartItems">
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
                            <p>Carrinho vazio</p>
                            <p class="small">Busque produtos ou escaneie código de barras</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Coluna Direita: Totais e Pagamento -->
        <div class="col-lg-4 bg-light p-3 d-flex flex-column">
            
            <!-- Cliente -->
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <label class="form-label fw-bold">Cliente</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="customerSearch" 
                               placeholder="CPF, Nome ou Telefone" readonly>
                        <button class="btn btn-outline-primary" onclick="searchCustomer()">
                            <i class="bi bi-search"></i>
                        </button>
                        <button class="btn btn-outline-secondary" onclick="clearCustomer()">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    <input type="hidden" id="selectedCustomerId">
                    <input type="hidden" id="selectedOnlineOrderId">
                </div>
            </div>

            <!-- Totais -->
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <strong id="subtotal">R$ 0,00</strong>
                    </div>
                    <div class="input-group mb-2">
                        <span class="input-group-text">Desconto</span>
                        <input type="number" class="form-control" id="discountInput" 
                               value="0" min="0" step="0.01" onchange="calculateTotal()">
                        <span class="input-group-text">%</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Desconto:</span>
                        <strong class="text-danger" id="discountAmount">- R$ 0,00</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <h4 class="mb-0">TOTAL:</h4>
                        <h4 class="mb-0 text-success" id="totalAmount">R$ 0,00</h4>
                    </div>
                </div>
            </div>

            <!-- Formas de Pagamento -->
            <div class="card mb-3 shadow-sm flex-grow-1">
                <div class="card-header bg-white">
                    <h6 class="mb-0">Formas de Pagamento</h6>
                </div>
                <div class="card-body">
                    <div id="paymentsContainer">
                        <p class="text-muted small">Nenhum pagamento adicionado</p>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-2 mt-3">
                        <span>Total Pago:</span>
                        <strong class="text-info" id="totalPaid">R$ 0,00</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Restante:</span>
                        <strong class="text-warning" id="remaining">R$ 0,00</strong>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-success btn-lg" onclick="showPaymentModal('DINHEIRO')">
                            <i class="bi bi-cash-coin me-2"></i>Dinheiro
                        </button>
                        <button class="btn btn-primary btn-lg" onclick="showPaymentModal('CARTAO_DEBITO')">
                            <i class="bi bi-credit-card me-2"></i>Débito
                        </button>
                        <button class="btn btn-info btn-lg" onclick="showPaymentModal('CARTAO_CREDITO')">
                            <i class="bi bi-credit-card-2-front me-2"></i>Crédito
                        </button>
                        <button class="btn btn-warning btn-lg" onclick="showPaymentModal('PIX')">
                            <i class="bi bi-qr-code me-2"></i>PIX
                        </button>
                    </div>
                </div>
            </div>

            <!-- Finalizar Venda -->
            <button class="btn btn-lg btn-success w-100 py-3" id="finishSaleBtn" 
                    onclick="finishSale()" disabled>
                <i class="bi bi-check-circle me-2"></i>
                <strong>FINALIZAR VENDA</strong>
            </button>
        </div>
    </div>
</div>

<!-- Modal: Pedidos Online -->
<div class="modal fade" id="onlineOrdersModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">
                    <i class="bi bi-bag-check me-2"></i>Pedidos Online Aguardando Pagamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="onlineOrdersList">
                    <div class="text-center py-4">
                        <div class="spinner-border text-warning" role="status"></div>
                        <p class="mt-2">Carregando pedidos...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-warning" onclick="loadOnlineOrders()">
                    <i class="bi bi-arrow-clockwise"></i> Atualizar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Adicionar Pagamento -->
<div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentModalTitle">Adicionar Pagamento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="paymentMethod">
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Valor</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text">R$</span>
                        <input type="number" class="form-control" id="paymentAmount" 
                               step="0.01" min="0.01" required autofocus>
                    </div>
                    <button class="btn btn-sm btn-outline-primary mt-2" onclick="setRemainingAmount()">
                        Usar valor restante
                    </button>
                </div>

                <!-- Campos específicos por método -->
                <div id="cashFields" class="d-none">
                    <div class="mb-3">
                        <label class="form-label">Valor Recebido</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" class="form-control" id="cashReceived" 
                                   step="0.01" min="0" onkeyup="calculateChange()">
                        </div>
                    </div>
                    <div class="alert alert-info" id="changeDisplay" style="display:none;">
                        <strong>Troco:</strong> <span id="changeAmount">R$ 0,00</span>
                    </div>
                </div>

                <div id="cardFields" class="d-none">
                    <div class="mb-3">
                        <label class="form-label">Bandeira</label>
                        <select class="form-select" id="cardBrand">
                            <option value="">Selecione...</option>
                            <option value="VISA">Visa</option>
                            <option value="MASTERCARD">Mastercard</option>
                            <option value="ELO">Elo</option>
                            <option value="AMEX">American Express</option>
                            <option value="HIPERCARD">Hipercard</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Últimos 4 Dígitos</label>
                        <input type="text" class="form-control" id="cardLastDigits" 
                               maxlength="4" placeholder="1234">
                    </div>
                    <div class="mb-3" id="installmentsField">
                        <label class="form-label">Parcelas</label>
                        <select class="form-select" id="installments">
                            <option value="1">1x à vista</option>
                            <option value="2">2x sem juros</option>
                            <option value="3">3x sem juros</option>
                            <option value="4">4x sem juros</option>
                            <option value="5">5x sem juros</option>
                            <option value="6">6x sem juros</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">NSU/DOC</label>
                        <input type="text" class="form-control" id="nsu" 
                               placeholder="Número do comprovante">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Código de Autorização</label>
                        <input type="text" class="form-control" id="authCode" 
                               placeholder="Código de autorização">
                    </div>
                </div>

                <div id="pixFields" class="d-none">
                    <div class="mb-3">
                        <label class="form-label">Chave PIX</label>
                        <input type="text" class="form-control" id="pixKey" 
                               placeholder="CPF, Email, Telefone ou Chave Aleatória">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ID da Transação</label>
                        <input type="text" class="form-control" id="pixTransactionId" 
                               placeholder="E12345678202411251030...">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Observações</label>
                    <textarea class="form-control" id="paymentObs" rows="2" 
                              placeholder="Observações opcionais"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="addPayment()">
                    <i class="bi bi-plus-circle"></i> Adicionar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Buscar Cliente -->
<div class="modal fade" id="customerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Buscar Cliente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control mb-3" id="customerModalSearch" 
                       placeholder="Buscar por CPF, Nome ou Telefone...">
                <div id="customersList" style="max-height: 400px; overflow-y: auto;">
                    <!-- Lista de clientes -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Recibo -->
<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Comprovante de Venda</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptContent">
                <!-- Conteúdo do recibo -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-primary" onclick="printReceipt()">
                    <i class="bi bi-printer"></i> Imprimir
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Variáveis globais
        let cart = [];
        let payments = [];
        let selectedCustomer = null;
        let selectedOnlineOrder = null;
        let onlineOrders = [];

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            updateClock();
            setInterval(updateClock, 1000);
            loadOnlineOrdersCount();
            checkCashRegister();
            
            // Verificar se veio da tela de pedidos online
            const urlParams = new URLSearchParams(window.location.search);
            const orderId = urlParams.get('orderId');
            if (orderId) {
                loadOnlineOrderById(orderId);
            }
            
            // Auto-refresh pedidos online a cada 30 segundos
            setInterval(loadOnlineOrdersCount, 30000);
        });

        function updateClock() {
            document.getElementById('currentTime').textContent = 
                new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        }

        async function checkCashRegister() {
            try {
                const response = await fetch('/api/PDV/cash-register/status');
                const data = await response.json();
                if (data.success && data.data && data.data.isOpen) {
                    document.getElementById('cashRegisterInfo').textContent = 
                        `Caixa: ${data.data.code || 'Aberto'} - ${data.data.operatorName || ''}`;
                } else {
                    document.getElementById('cashRegisterInfo').innerHTML = 
                        '<span class="text-warning">⚠️ Caixa fechado - Abra o caixa para realizar vendas</span>';
                }
            } catch (error) {
                console.error('Erro ao verificar caixa:', error);
                document.getElementById('cashRegisterInfo').innerHTML = 
                    '<span class="text-warning">⚠️ Caixa fechado</span>';
            }
        }

        // ================================================================
        // PEDIDOS ONLINE
        // ================================================================

        async function loadOnlineOrdersCount() {
            try {
                const response = await fetch('/api/PDV/online-orders-ready');
                const data = await response.json();
                
                if (data.success) {
                    const count = data.data.length;
                    const badge = document.getElementById('onlineOrdersBadge');
                    
                    if (count > 0) {
                        badge.textContent = count;
                        badge.style.display = 'inline';
                        document.getElementById('onlineOrdersBtn').classList.add('btn-warning');
                        document.getElementById('onlineOrdersBtn').classList.remove('btn-outline-warning');
                    } else {
                        badge.style.display = 'none';
                        document.getElementById('onlineOrdersBtn').classList.remove('btn-warning');
                        document.getElementById('onlineOrdersBtn').classList.add('btn-outline-warning');
                    }
                    
                    onlineOrders = data.data;
                }
            } catch (error) {
                console.error('Erro ao carregar pedidos online:', error);
            }
        }

        function showOnlineOrdersModal() {
            loadOnlineOrders();
            new bootstrap.Modal(document.getElementById('onlineOrdersModal')).show();
        }

        async function loadOnlineOrders() {
            const container = document.getElementById('onlineOrdersList');
            container.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-warning"></div></div>';
            
            try {
                const response = await fetch('/api/PDV/online-orders-ready');
                const data = await response.json();
                
                if (data.success && data.data.length > 0) {
                    onlineOrders = data.data;
                    container.innerHTML = data.data.map(order => `
                        <div class="card mb-3 border-warning">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="mb-1">
                                            <i class="bi bi-bag-check text-warning me-2"></i>
                                            Pedido #${order.orderNumber}
                                        </h5>
                                        <p class="mb-1">
                                            <i class="bi bi-person me-1"></i>${order.customerName}
                                            ${order.customerPhone ? `<a href="https://wa.me/55${order.customerPhone}" target="_blank" class="ms-2 text-success"><i class="bi bi-whatsapp"></i></a>` : ''}
                                        </p>
                                        <p class="mb-1 text-muted small">
                                            <i class="bi bi-clock me-1"></i>${new Date(order.createdAt).toLocaleString('pt-BR')}
                                            <span class="badge bg-${order.status === 'READY' ? 'success' : 'info'} ms-2">${order.statusDisplay}</span>
                                        </p>
                                        <p class="mb-0 small">${order.itemsCount} item(ns)</p>
                                    </div>
                                    <div class="text-end">
                                        <h4 class="text-success mb-2">R$ ${order.total.toFixed(2).replace('.', ',')}</h4>
                                        <button class="btn btn-warning" onclick="selectOnlineOrder('${order.id}')">
                                            <i class="bi bi-cash-coin me-1"></i>Cobrar
                                        </button>
                                    </div>
                                </div>
                                <hr class="my-2">
                                <div class="small">
                                    ${order.items.map(item => `
                                        <div class="d-flex justify-content-between">
                                            <span>${item.quantity}x ${item.productName}</span>
                                            <span>R$ ${item.totalPrice.toFixed(2).replace('.', ',')}</span>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = `
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            <p>Nenhum pedido online aguardando pagamento</p>
                        </div>
                    `;
                }
            } catch (error) {
                container.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Erro ao carregar pedidos: ${error.message}
                    </div>
                `;
            }
        }

        async function selectOnlineOrder(orderId) {
            const order = onlineOrders.find(o => o.id === orderId);
            if (!order) return;
            
            // Fechar modal
            bootstrap.Modal.getInstance(document.getElementById('onlineOrdersModal'))?.hide();
            
            // Carregar pedido no PDV
            selectedOnlineOrder = order;
            selectedCustomer = { id: order.customerId, fullName: order.customerName };
            
            // Atualizar interface
            document.getElementById('selectedCustomerId').value = order.customerId;
            document.getElementById('selectedOnlineOrderId').value = order.id;
            document.getElementById('customerSearch').value = order.customerName;
            
            // Mostrar alerta de pedido online
            document.getElementById('onlineOrderAlert').classList.remove('d-none');
            document.getElementById('loadedOrderNumber').textContent = '#' + order.orderNumber;
            document.getElementById('loadedOrderStatus').textContent = order.statusDisplay;
            
            // Carregar itens no carrinho
            cart = order.items.map(item => ({
                id: crypto.randomUUID(),
                description: item.productName,
                quantity: item.quantity,
                unitPrice: item.unitPrice,
                totalPrice: item.totalPrice,
                isOnlineOrderItem: true
            }));
            
            // Desabilitar edição do carrinho (é pedido online)
            document.getElementById('discountInput').value = order.discount > 0 ? 
                ((order.discount / order.subtotal) * 100).toFixed(2) : 0;
            document.getElementById('discountInput').disabled = true;
            
            renderCart();
            calculateTotal();
        }

        async function loadOnlineOrderById(orderId) {
            try {
                const response = await fetch(`/api/PDV/online-order/${orderId}`);
                const data = await response.json();
                
                if (data.success) {
                    selectOnlineOrder(orderId);
                }
            } catch (error) {
                console.error('Erro ao carregar pedido:', error);
            }
        }

        function clearOnlineOrder() {
            selectedOnlineOrder = null;
            document.getElementById('selectedOnlineOrderId').value = '';
            document.getElementById('onlineOrderAlert').classList.add('d-none');
            document.getElementById('discountInput').disabled = false;
            clearCart();
            clearCustomer();
        }

        // ================================================================
        // CARRINHO
        // ================================================================

        function renderCart() {
            const container = document.getElementById('cartItems');
            
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
                        <p>Carrinho vazio</p>
                        <p class="small">Busque produtos ou escaneie código de barras</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = cart.map((item, index) => `
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <div class="flex-grow-1">
                        <strong>${item.description}</strong>
                        <div class="small text-muted">
                            ${item.quantity} x R$ ${item.unitPrice.toFixed(2).replace('.', ',')}
                        </div>
                    </div>
                    <div class="text-end">
                        <strong class="text-success">R$ ${item.totalPrice.toFixed(2).replace('.', ',')}</strong>
                        ${!item.isOnlineOrderItem ? `
                            <button class="btn btn-sm btn-outline-danger ms-2" onclick="removeFromCart(${index})">
                                <i class="bi bi-trash"></i>
                            </button>
                        ` : ''}
                    </div>
                </div>
            `).join('');
        }

        function clearCart() {
            if (selectedOnlineOrder) {
                clearOnlineOrder();
                return;
            }
            cart = [];
            payments = [];
            renderCart();
            renderPayments();
            calculateTotal();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
            calculateTotal();
        }

        function calculateTotal() {
            const subtotal = cart.reduce((sum, item) => sum + item.totalPrice, 0);
            const discountPercent = parseFloat(document.getElementById('discountInput').value) || 0;
            const discountAmount = subtotal * (discountPercent / 100);
            const total = subtotal - discountAmount;
            
            document.getElementById('subtotal').textContent = `R$ ${subtotal.toFixed(2).replace('.', ',')}`;
            document.getElementById('discountAmount').textContent = `- R$ ${discountAmount.toFixed(2).replace('.', ',')}`;
            document.getElementById('totalAmount').textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
            
            updatePaymentSummary();
        }

        // ================================================================
        // PAGAMENTOS
        // ================================================================

        function showPaymentModal(method) {
            document.getElementById('paymentMethod').value = method;
            
            // Títulos
            const titles = {
                'DINHEIRO': 'Pagamento em Dinheiro',
                'CARTAO_DEBITO': 'Pagamento em Débito',
                'CARTAO_CREDITO': 'Pagamento em Crédito',
                'PIX': 'Pagamento via PIX'
            };
            document.getElementById('paymentModalTitle').textContent = titles[method] || 'Adicionar Pagamento';
            
            // Esconder todos os campos específicos
            document.getElementById('cashFields').classList.add('d-none');
            document.getElementById('cardFields').classList.add('d-none');
            document.getElementById('pixFields').classList.add('d-none');
            document.getElementById('installmentsField').style.display = 'none';
            
            // Mostrar campos específicos
            if (method === 'DINHEIRO') {
                document.getElementById('cashFields').classList.remove('d-none');
            } else if (method.includes('CARTAO')) {
                document.getElementById('cardFields').classList.remove('d-none');
                if (method === 'CARTAO_CREDITO') {
                    document.getElementById('installmentsField').style.display = 'block';
                }
            } else if (method === 'PIX') {
                document.getElementById('pixFields').classList.remove('d-none');
            }
            
            // Calcular valor restante
            setRemainingAmount();
            
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }

        function setRemainingAmount() {
            const total = parseFloat(document.getElementById('totalAmount').textContent.replace('R$ ', '').replace('.', '').replace(',', '.')) || 0;
            const paid = payments.reduce((sum, p) => sum + p.amount, 0);
            const remaining = Math.max(0, total - paid);
            document.getElementById('paymentAmount').value = remaining.toFixed(2);
        }

        function calculateChange() {
            const amount = parseFloat(document.getElementById('paymentAmount').value) || 0;
            const received = parseFloat(document.getElementById('cashReceived').value) || 0;
            const change = received - amount;
            
            if (change >= 0 && received > 0) {
                document.getElementById('changeDisplay').style.display = 'block';
                document.getElementById('changeAmount').textContent = `R$ ${change.toFixed(2).replace('.', ',')}`;
            } else {
                document.getElementById('changeDisplay').style.display = 'none';
            }
        }

        function addPayment() {
            const method = document.getElementById('paymentMethod').value;
            const amount = parseFloat(document.getElementById('paymentAmount').value) || 0;
            
            if (amount <= 0) {
                Swal.fire('Erro', 'Informe um valor válido', 'error');
                return;
            }
            
            const payment = {
                id: crypto.randomUUID(),
                method: method,
                amount: amount,
                methodDisplay: {
                    'DINHEIRO': 'Dinheiro',
                    'CARTAO_DEBITO': 'Débito',
                    'CARTAO_CREDITO': 'Crédito',
                    'PIX': 'PIX'
                }[method] || method
            };
            
            // Campos específicos
            if (method === 'DINHEIRO') {
                payment.cashReceived = parseFloat(document.getElementById('cashReceived').value) || amount;
                payment.changeAmount = Math.max(0, payment.cashReceived - amount);
            } else if (method.includes('CARTAO')) {
                payment.cardBrand = document.getElementById('cardBrand').value;
                payment.cardLastDigits = document.getElementById('cardLastDigits').value;
                payment.installments = parseInt(document.getElementById('installments').value) || 1;
                payment.nsu = document.getElementById('nsu').value;
                payment.authCode = document.getElementById('authCode').value;
            } else if (method === 'PIX') {
                payment.pixKey = document.getElementById('pixKey').value;
                payment.pixTransactionId = document.getElementById('pixTransactionId').value;
            }
            
            payments.push(payment);
            renderPayments();
            updatePaymentSummary();
            
            // Fechar modal e limpar campos
            bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
            clearPaymentForm();
        }

        function clearPaymentForm() {
            document.getElementById('paymentAmount').value = '';
            document.getElementById('cashReceived').value = '';
            document.getElementById('cardBrand').value = '';
            document.getElementById('cardLastDigits').value = '';
            document.getElementById('installments').value = '1';
            document.getElementById('nsu').value = '';
            document.getElementById('authCode').value = '';
            document.getElementById('pixKey').value = '';
            document.getElementById('pixTransactionId').value = '';
            document.getElementById('paymentObs').value = '';
            document.getElementById('changeDisplay').style.display = 'none';
        }

        function renderPayments() {
            const container = document.getElementById('paymentsContainer');
            
            if (payments.length === 0) {
                container.innerHTML = '<p class="text-muted small">Nenhum pagamento adicionado</p>';
                return;
            }
            
            container.innerHTML = payments.map((p, index) => `
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <div>
                        <span class="badge bg-${p.method === 'DINHEIRO' ? 'success' : p.method === 'PIX' ? 'warning' : 'primary'}">${p.methodDisplay}</span>
                        ${p.changeAmount > 0 ? `<small class="ms-2 text-muted">Troco: R$ ${p.changeAmount.toFixed(2).replace('.', ',')}</small>` : ''}
                    </div>
                    <div>
                        <strong>R$ ${p.amount.toFixed(2).replace('.', ',')}</strong>
                        <button class="btn btn-sm btn-outline-danger ms-2" onclick="removePayment(${index})">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function removePayment(index) {
            payments.splice(index, 1);
            renderPayments();
            updatePaymentSummary();
        }

        function updatePaymentSummary() {
            const total = parseFloat(document.getElementById('totalAmount').textContent.replace('R$ ', '').replace('.', '').replace(',', '.')) || 0;
            const paid = payments.reduce((sum, p) => sum + p.amount, 0);
            const remaining = Math.max(0, total - paid);
            
            document.getElementById('totalPaid').textContent = `R$ ${paid.toFixed(2).replace('.', ',')}`;
            document.getElementById('remaining').textContent = `R$ ${remaining.toFixed(2).replace('.', ',')}`;
            
            // Habilitar botão de finalizar
            const canFinish = cart.length > 0 && paid >= total;
            document.getElementById('finishSaleBtn').disabled = !canFinish;
        }

        // ================================================================
        // FINALIZAR VENDA
        // ================================================================

        async function finishSale() {
            if (cart.length === 0) {
                Swal.fire('Erro', 'Carrinho vazio', 'error');
                return;
            }
            
            const total = parseFloat(document.getElementById('totalAmount').textContent.replace('R$ ', '').replace('.', '').replace(',', '.')) || 0;
            const paid = payments.reduce((sum, p) => sum + p.amount, 0);
            
            if (paid < total) {
                Swal.fire('Erro', 'Valor pago insuficiente', 'error');
                return;
            }
            
            // Se é um pedido online, usar endpoint específico
            if (selectedOnlineOrder) {
                await processOnlineOrderPayment();
                return;
            }
            
            // Venda normal
            await processRegularSale();
        }

        async function processOnlineOrderPayment() {
            const payment = payments[0]; // Pegar primeiro pagamento
            
            const dto = {
                paymentMethod: payment.method,
                paidAmount: payment.amount,
                cashReceived: payment.cashReceived,
                changeAmount: payment.changeAmount,
                cardBrand: payment.cardBrand,
                cardLastDigits: payment.cardLastDigits,
                installments: payment.installments,
                nsu: payment.nsu,
                authorizationCode: payment.authCode,
                pixTransactionId: payment.pixTransactionId
            };
            
            try {
                Swal.fire({
                    title: 'Processando...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });
                
                const response = await fetch(`/api/PDV/process-online-order/${selectedOnlineOrder.id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });
                
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Pagamento Processado!',
                        html: `
                            <p>Pedido: <strong>#${data.data.orderNumber}</strong></p>
                            <p>Venda: <strong>${data.data.saleCode}</strong></p>
                            <p>Total: <strong>R$ ${data.data.total.toFixed(2).replace('.', ',')}</strong></p>
                            ${data.data.changeAmount > 0 ? `<p class="text-warning">Troco: R$ ${data.data.changeAmount.toFixed(2).replace('.', ',')}</p>` : ''}
                        `,
                        confirmButtonText: 'OK'
                    }).then(() => {
                        clearOnlineOrder();
                        loadOnlineOrdersCount();
                    });
                } else {
                    Swal.fire('Erro', data.message, 'error');
                }
            } catch (error) {
                Swal.fire('Erro', 'Erro ao processar pagamento: ' + error.message, 'error');
            }
        }

        async function processRegularSale() {
            // Implementação da venda regular existente
            // ... (mantém o código existente)
            Swal.fire('Info', 'Venda regular - implementar', 'info');
        }

        // ================================================================
        // CLIENTE
        // ================================================================

        function searchCustomer() {
            new bootstrap.Modal(document.getElementById('customerModal')).show();
        }

        function clearCustomer() {
            selectedCustomer = null;
            document.getElementById('selectedCustomerId').value = '';
            document.getElementById('customerSearch').value = '';
        }

        // ================================================================
        // OUTRAS FUNÇÕES
        // ================================================================

        function openCashRegister() {
            window.location.href = '/Caixa/Abrir';
        }

        function closePDV() {
            window.location.href = '/Caixa';
        }

        function showProductsModal() {
            // Implementar modal de produtos
        }

        function printReceipt() {
            window.print();
        }
    </script>
