@model Models.CashRegister
@{
    ViewData["Title"] = "Fechar Caixa";
    Layout = "_Layout";
    var movements = ViewBag.Movements as List<Models.CashMovement> ?? new List<Models.CashMovement>();
    
    // Calcular saldo esperado
    var saldoEsperado = Model.OpeningBalance + Model.TotalCash - Model.TotalWithdrawals + Model.TotalSupplies;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="d-flex align-items-center mb-4">
                <a href="/Caixa" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h4 class="mb-0">Fechar Caixa</h4>
                    <small class="text-muted">@Model.Code - Aberto em @Model.OpeningDate.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
            </div>

            <!-- Resumo do Caixa -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Resumo do Caixa</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3 col-6 mb-3">
                            <small class="text-muted d-block">Saldo Inicial</small>
                            <strong>R$ @Model.OpeningBalance.ToString("N2")</strong>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <small class="text-muted d-block">Vendas Dinheiro</small>
                            <strong class="text-success">R$ @Model.TotalCash.ToString("N2")</strong>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <small class="text-muted d-block">Sangrias</small>
                            <strong class="text-danger">- R$ @Model.TotalWithdrawals.ToString("N2")</strong>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <small class="text-muted d-block">Suprimentos</small>
                            <strong class="text-info">+ R$ @Model.TotalSupplies.ToString("N2")</strong>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div class="row text-center">
                        <div class="col-md-4 col-6 mb-3">
                            <small class="text-muted d-block">Total Cartão</small>
                            <strong class="text-primary">R$ @Model.TotalCard.ToString("N2")</strong>
                        </div>
                        <div class="col-md-4 col-6 mb-3">
                            <small class="text-muted d-block">Total PIX</small>
                            <strong class="text-warning">R$ @Model.TotalPix.ToString("N2")</strong>
                        </div>
                        <div class="col-md-4 mb-3">
                            <small class="text-muted d-block">Vendas Realizadas</small>
                            <strong>@Model.SalesCount</strong>
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-primary mb-0">
                                <strong>Total em Vendas:</strong>
                                <span class="float-end fs-5">R$ @Model.TotalSales.ToString("N2")</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-success mb-0">
                                <strong>Saldo Esperado em Caixa:</strong>
                                <span class="float-end fs-5">R$ @saldoEsperado.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Formulário de Fechamento -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-lock me-2"></i>Conferência e Fechamento</h5>
                </div>
                <div class="card-body">
                    <form method="post" action="/Caixa/Fechar" id="formFecharCaixa">
                        <input type="hidden" name="cashRegisterId" value="@Model.Id">

                        <div class="mb-4">
                            <label class="form-label fw-bold">Saldo Final Contado (Dinheiro em Caixa) *</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text">R$</span>
                                <input type="number" 
                                       class="form-control" 
                                       name="saldoFinal" 
                                       id="saldoFinal"
                                       step="0.01" 
                                       min="0" 
                                       value="@saldoEsperado.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                       required>
                            </div>
                            <div class="form-text">
                                Conte o dinheiro físico no caixa e informe o valor total.
                            </div>
                        </div>

                        <div id="diferencaAlert" class="alert d-none mb-4">
                            <strong>Diferença:</strong> <span id="diferencaValor"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Observações do Fechamento</label>
                            <textarea class="form-control" 
                                      name="observacoes" 
                                      rows="3" 
                                      placeholder="Observações sobre o fechamento..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-lock me-2"></i>Confirmar Fechamento
                            </button>
                            <a href="/Caixa" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Movimentações -->
            @if (movements.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Movimentações do Caixa</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Hora</th>
                                        <th>Tipo</th>
                                        <th>Descrição</th>
                                        <th class="text-end">Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var mov in movements.OrderByDescending(m => m.CreatedAt))
                                    {
                                        var tipoClass = mov.MovementType switch
                                        {
                                            "ENTRADA" => "success",
                                            "SANGRIA" => "danger",
                                            "SUPRIMENTO" => "info",
                                            _ => "secondary"
                                        };
                                        <tr>
                                            <td>@mov.CreatedAt.ToString("HH:mm")</td>
                                            <td><span class="badge bg-@tipoClass">@mov.MovementType</span></td>
                                            <td>@mov.Description</td>
                                            <td class="text-end">
                                                <span class="text-@tipoClass">
                                                    @(mov.MovementType == "SANGRIA" ? "-" : "+") R$ @mov.Amount.ToString("N2")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const saldoEsperado = @saldoEsperado.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    
    document.getElementById('saldoFinal').addEventListener('input', function() {
        const saldoFinal = parseFloat(this.value) || 0;
        const diferenca = saldoFinal - saldoEsperado;
        const alertDiv = document.getElementById('diferencaAlert');
        const valorSpan = document.getElementById('diferencaValor');
        
        if (Math.abs(diferenca) > 0.01) {
            alertDiv.classList.remove('d-none');
            if (diferenca > 0) {
                alertDiv.className = 'alert alert-success mb-4';
                valorSpan.textContent = `Sobra de R$ ${diferenca.toFixed(2)}`;
            } else {
                alertDiv.className = 'alert alert-danger mb-4';
                valorSpan.textContent = `Falta de R$ ${Math.abs(diferenca).toFixed(2)}`;
            }
        } else {
            alertDiv.classList.add('d-none');
        }
    });

    document.getElementById('formFecharCaixa').addEventListener('submit', function(e) {
        const saldoFinal = parseFloat(document.getElementById('saldoFinal').value) || 0;
        const diferenca = saldoFinal - saldoEsperado;
        
        let msg = 'Confirma o fechamento do caixa?';
        if (Math.abs(diferenca) > 0.01) {
            msg = diferenca > 0 
                ? `Há uma SOBRA de R$ ${diferenca.toFixed(2)}. Confirma o fechamento?`
                : `Há uma FALTA de R$ ${Math.abs(diferenca).toFixed(2)}. Confirma o fechamento?`;
        }
        
        if (!confirm(msg)) {
            e.preventDefault();
        }
    });
</script>
}
