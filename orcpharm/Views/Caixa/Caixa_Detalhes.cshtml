@model Models.CashRegister
@{
    ViewData["Title"] = $"Caixa {Model.Code}";
    Layout = "_Layout";
    var movements = ViewBag.Movements as List<Models.CashMovement> ?? new List<Models.CashMovement>();
    var isOpen = Model.Status == "ABERTO";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="/Caixa" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h4 class="mb-0">Caixa @Model.Code</h4>
            <span class="badge bg-@(isOpen ? "success" : "secondary")">@Model.Status</span>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Informações</h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <td class="text-muted">Abertura:</td>
                            <td>@Model.OpeningDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        @if (Model.ClosingDate.HasValue)
                        {
                            <tr>
                                <td class="text-muted">Fechamento:</td>
                                <td>@Model.ClosingDate.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-muted">Saldo Inicial:</td>
                            <td>R$ @Model.OpeningBalance.ToString("N2")</td>
                        </tr>
                        @if (Model.ClosingBalance.HasValue)
                        {
                            <tr>
                                <td class="text-muted">Saldo Final:</td>
                                <td>R$ @Model.ClosingBalance.Value.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Diferença:</td>
                                <td class="@(Model.Difference > 0 ? "text-success" : Model.Difference < 0 ? "text-danger" : "")">
                                    @(Model.Difference > 0 ? "+" : "") R$ @Model.Difference?.ToString("N2")
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Resumo</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Vendas:</span>
                        <strong>@Model.SalesCount</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Dinheiro:</span>
                        <strong class="text-success">R$ @Model.TotalCash.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Cartão:</span>
                        <strong class="text-primary">R$ @Model.TotalCard.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>PIX:</span>
                        <strong class="text-warning">R$ @Model.TotalPix.ToString("N2")</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Sangrias:</span>
                        <strong class="text-danger">- R$ @Model.TotalWithdrawals.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Suprimentos:</span>
                        <strong class="text-info">+ R$ @Model.TotalSupplies.ToString("N2")</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong>Total Vendas:</strong>
                        <strong class="text-success fs-5">R$ @Model.TotalSales.ToString("N2")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>Movimentações</h6>
                </div>
                <div class="card-body p-0">
                    @if (movements.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Data/Hora</th>
                                        <th>Tipo</th>
                                        <th>Forma Pgto</th>
                                        <th>Descrição</th>
                                        <th class="text-end">Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var mov in movements.OrderByDescending(m => m.CreatedAt))
                                    {
                                        var tipoClass = mov.MovementType switch
                                        {
                                            "ENTRADA" => "success",
                                            "SANGRIA" => "danger",
                                            "SUPRIMENTO" => "info",
                                            _ => "secondary"
                                        };
                                        <tr>
                                            <td>@mov.CreatedAt.ToString("dd/MM HH:mm")</td>
                                            <td><span class="badge bg-@tipoClass">@mov.MovementType</span></td>
                                            <td>@mov.PaymentMethod</td>
                                            <td>@mov.Description</td>
                                            <td class="text-end">
                                                <span class="text-@tipoClass fw-bold">
                                                    @(mov.MovementType == "SANGRIA" ? "-" : "+") R$ @mov.Amount.ToString("N2")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            <p>Nenhuma movimentação registrada.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
